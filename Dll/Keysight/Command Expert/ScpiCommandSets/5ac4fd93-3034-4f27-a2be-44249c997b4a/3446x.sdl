										<String />
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="STAT" mnemonic="STATe">
				<Node aliases="REC" mnemonic="RECall">
					<Node mnemonic="AUTO">
						<SubsystemCommand>
							<Synopsis>The command disables or enables the automatic recall of a specific stored instrument state at power-on.</Synopsis>
							<HelpLinks>
								<HelpLink name=":MMEMory:STATe:RECall:AUTO" endAnchor="STAT-REC-SELect" url="__I_SCPI\MMEMory_STATe_PREF.htm#STAT-REC-AUTO" />
							</HelpLinks>
							<CommandSyntaxes>
								<CommandSyntax>
									<Parameters>
										<Parameter name="state" semanticType="Boolean" description="Disables or enables the automatic recall of a specific stored instrument state at power-on.">
											<ParameterType>
												<DecimalNumeric>
													<EnumRef name="enum_3446x_boolean" />
												</DecimalNumeric>
												<Character>
													<EnumRef name="enum_3446x_boolean" />
												</Character>
											</ParameterType>
										</Parameter>
									</Parameters>
								</CommandSyntax>
							</CommandSyntaxes>
							<QuerySyntaxes>
								<QuerySyntax>
									<Responses>
										<Response name="state" semanticType="Boolean" description="Returns the state of the automatic recall of a specific stored instrument state at power-on.">
											<ResponseType>
												<NR1Numeric>
													<EnumRef name="enum_3446x_boolean" />
												</NR1Numeric>
											</ResponseType>
										</Response>
									</Responses>
								</QuerySyntax>
							</QuerySyntaxes>
						</SubsystemCommand>
					</Node>
					<Node aliases="SEL" mnemonic="SELect">
						<SubsystemCommand>
							<Synopsis>The command selects which instrument state will be used at power-on if the automatic recall mode is enabled .</Synopsis>
							<HelpLinks>
								<HelpLink name=":MMEMory:STATe:RECall:SELect" endAnchor="STAT-VALid" url="__I_SCPI\MMEMory_STATe_PREF.htm#STAT-REC-SELect" />
							</HelpLinks>
							<CommandSyntaxes>
								<CommandSyntax>
									<Parameters>
										<Parameter name="file" semanticType="String" description="Any valid file name.">
											<ParameterType>
												<String />
											</ParameterType>
										</Parameter>
									</Parameters>
								</CommandSyntax>
							</CommandSyntaxes>
							<QuerySyntaxes>
								<QuerySyntax>
									<Responses>
										<Response name="file" semanticType="String" description="Returns the file name with the current instrument state.">
											<ResponseType>
												<String />
											</ResponseType>
										</Response>
									</Responses>
								</QuerySyntax>
							</QuerySyntaxes>
						</SubsystemCommand>
					</Node>
				</Node>
				<Node aliases="VAL" mnemonic="VALid">
					<SubsystemCommand>
						<Synopsis>The query returns 1 if the specified state file exists and contains a valid state file.Returns 0 otherwise.</Synopsis>
						<HelpLinks>
							<HelpLink name=":MMEMory:STATe:VALid" url="__I_SCPI\MMEMory_STATe_PREF.htm#STAT-VALid" />
						</HelpLinks>
						<QuerySyntaxes>
							<QuerySyntax>
								<Parameters>
									<Parameter name="file" semanticType="String" description="Any valid file name.">
