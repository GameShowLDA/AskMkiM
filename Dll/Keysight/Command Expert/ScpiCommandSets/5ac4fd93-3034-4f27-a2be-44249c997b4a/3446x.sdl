												</Character>
											</ParameterType>
										</Parameter>
									</Parameters>
									<Responses>
										<Response name="value" semanticType="Real" description="Returns the current upper limit value.">
											<ResponseType>
												<NR3Numeric />
											</ResponseType>
										</Response>
									</Responses>
								</QuerySyntax>
							</QuerySyntaxes>
						</SubsystemCommand>
					</Node>
				</Node>
			</Node>
			<Node aliases="SCAL" mnemonic="SCALe">
