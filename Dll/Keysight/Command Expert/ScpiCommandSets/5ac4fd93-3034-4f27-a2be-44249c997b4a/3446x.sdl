							<Responses>
								<Response name="slope" semanticType="String" description="Returns the Slope of the trigger signal on the rear-panel Ext Trig BNC connector when external triggering is selected; or the rising or falling edge of the input signal when level triggering is selected.&#xD;&#xA;">
									<ResponseType>
										<Character>
											<EnumRef name="trig_seq_slope_query_response_1" />
										</Character>
									</ResponseType>
								</Response>
