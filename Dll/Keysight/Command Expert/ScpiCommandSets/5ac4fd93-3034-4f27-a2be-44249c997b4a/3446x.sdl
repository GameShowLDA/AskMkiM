		<RootNode aliases="MMEM" mnemonic="MMEMory">
			<Node aliases="CAT" mnemonic="CATalog">
				<Node default="true" mnemonic="ALL">
					<SubsystemCommand>
						<Synopsis>The query returns a list of files in the specified folder.</Synopsis>
						<HelpLinks>
							<HelpLink name=":MMEMory:CATalog[:ALL]" endAnchor="RDIRectory" url="__I_SCPI\MMEMory_Subsystem.htm#CATalog" />
						</HelpLinks>
						<QuerySyntaxes>
							<QuerySyntax>
								<Parameters>
									<Parameter name="folder" semanticType="String" description="Any valid folder name; defaults to folder selected by MMEMory:CDIRectory" optional="true">
										<ParameterType>
											<String />
										</ParameterType>
									</Parameter>
								</Parameters>
								<Responses>
									<Response name="all" semanticType="String" description="Returns a list of files in the specified folder.">
										<ResponseType>
											<String />
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
			</Node>
			<Node aliases="CDIR" mnemonic="CDIRectory">
				<SubsystemCommand>
					<Synopsis>The command selects the default folder for MMEMory subsystem commands.
The query returns the current default folder.</Synopsis>
					<HelpLinks>
						<HelpLink name=":MMEMory:CDIRectory" endAnchor="COPY" url="__I_SCPI\MMEMory_Subsystem.htm#CDIRectory" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax>
							<Parameters>
								<Parameter name="folder" semanticType="String" description="The default folder for MMEMory subsystem commands.">
									<ParameterType>
										<String />
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="folder" semanticType="String" description="Returns the current default folder for MMEMory subsystem commands.">
									<ResponseType>
										<String />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node mnemonic="COPY">
				<SubsystemCommand>
					<Synopsis>The command copies &lt;file1&gt; to &lt;file2&gt;. Each file name must include the file extension.</Synopsis>
					<HelpLinks>
						<HelpLink name=":MMEMory:COPY" endAnchor="DELete" url="__I_SCPI\MMEMory_Subsystem.htm#COPY" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax>
							<Parameters>
								<Parameter name="file1" semanticType="String" description="The source file.">
									<ParameterType>
										<String />
									</ParameterType>
								</Parameter>
								<Parameter name="file2" semanticType="String" description="The destination file.">
									<ParameterType>
										<String />
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="DEL" mnemonic="DELete">
				<SubsystemCommand>
					<Synopsis>The command deletes a file. </Synopsis>
					<HelpLinks>
						<HelpLink name=":MMEMory:DELete" endAnchor="MOVE" url="__I_SCPI\MMEMory_Subsystem.htm#DELete" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax>
							<Parameters>
								<Parameter name="file" semanticType="String" description="Any valid file name, including file extension, or a &lt;filespec&gt;.">
									<ParameterType>
										<String />
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="DOWN" mnemonic="DOWNload">
				<Node mnemonic="DATA">
					<SubsystemCommand>
						<Synopsis>The command downloads data from the host computer to a file whose name has been specified by MMEMory:DOWNload:FNAMe.</Synopsis>
						<HelpLinks>
							<HelpLink name=":MMEMory:DOWNload:DATA" endAnchor="kanchor311" url="__I_SCPI\MMEMory_Data_Transfer.htm#DOWNload_DATA" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax name="BytesArray">
								<Parameters>
									<Parameter name="binaryBlock" semanticType="1-D Array" description="Any IEEE-488.2 definite-length block.">
										<ParameterType>
											<ArbitraryBlock>
												<Element format="BinaryLittleEndian" type="Byte" />
											</ArbitraryBlock>
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
					</SubsystemCommand>
				</Node>
				<Node aliases="FNAM" mnemonic="FNAMe">
					<SubsystemCommand>
						<Synopsis>The command creates or opens the specified filename prior to writing data to that file with MMEMory:DOWNload:DATA.

</Synopsis>
						<HelpLinks>
							<HelpLink name=":MMEMory:DOWNload:FNAMe" endAnchor="CSEParator" url="__I_SCPI\MMEMory_Data_Transfer.htm#DOWNload_FNAMe" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax>
								<Parameters>
									<Parameter name="filename" semanticType="String" description="Any valid file name.">
										<ParameterType>
											<String />
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
						<QuerySyntaxes>
							<QuerySyntax>
								<Responses>
									<Response name="filename" semanticType="String" description="Returns the currently selected file name.">
										<ResponseType>
											<String />
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
			</Node>
			<Node aliases="FORM" mnemonic="FORMat">
				<Node aliases="READ" mnemonic="READing">
					<Node aliases="CSEP" mnemonic="CSEParator">
						<SubsystemCommand>
							<Synopsis>The command specifies the character used to separate the columns in stored data.</Synopsis>
							<HelpLinks>
								<HelpLink name=":MMEMory:FORMat:READing:CSEParator" endAnchor="kanchor313" url="__I_SCPI\MMEMory_Data_Transfer.htm#CSEParator" />
							</HelpLinks>
							<CommandSyntaxes>
								<CommandSyntax>
									<Parameters>
										<Parameter name="cseparator" semanticType="String" description="Specifies the character used to separate the columns in stored data.">
											<ParameterType>
												<Character>
													<EnumRef name="mmem_form_read_cseparator_command_parameter_1" />
												</Character>
											</ParameterType>
										</Parameter>
									</Parameters>
								</CommandSyntax>
							</CommandSyntaxes>
							<QuerySyntaxes>
								<QuerySyntax>
									<Responses>
										<Response name="cseparator" semanticType="String" description="Returns the Specified character used to separate the columns in stored data.">
											<ResponseType>
												<Character>
													<EnumRef name="mmem_form_read_cseparator_query_response_1" />
												</Character>
											</ResponseType>
										</Response>
									</Responses>
								</QuerySyntax>
							</QuerySyntaxes>
						</SubsystemCommand>
					</Node>
					<Node aliases="INF" mnemonic="INFormation">
						<SubsystemCommand>
							<Synopsis>The command disables/enables header information and reading numbers in stored data.</Synopsis>
							<HelpLinks>
								<HelpLink name=":MMEMory:FORMat:READing:INFormation" endAnchor="kanchor314" url="__I_SCPI\MMEMory_Data_Transfer.htm#INFormation" />
							</HelpLinks>
							<CommandSyntaxes>
								<CommandSyntax>
									<Parameters>
										<Parameter name="state" semanticType="Boolean" description="Disables/enables header information and reading numbers in stored data.">
											<ParameterType>
												<DecimalNumeric>
													<EnumRef name="enum_3446x_boolean" />
												</DecimalNumeric>
												<Character>
													<EnumRef name="enum_3446x_boolean" />
												</Character>
											</ParameterType>
										</Parameter>
									</Parameters>
								</CommandSyntax>
							</CommandSyntaxes>
							<QuerySyntaxes>
								<QuerySyntax>
									<Responses>
										<Response name="state" semanticType="Boolean" description="Returns the state of header information and reading numbers in stored data.">
											<ResponseType>
												<NR1Numeric>
													<EnumRef name="enum_3446x_boolean" />
												</NR1Numeric>
											</ResponseType>
										</Response>
									</Responses>
								</QuerySyntax>
							</QuerySyntaxes>
						</SubsystemCommand>
					</Node>
					<Node aliases="RLIM" mnemonic="RLIMit">
						<SubsystemCommand>
							<Synopsis>The command when enabled, limits the maximum number rows per stored .csv data file to one million, including any header row, if enabled.</Synopsis>
							<HelpLinks>
								<HelpLink name=":MMEMory:FORMat:READing:RLIMit" endAnchor="kanchor315" url="__I_SCPI\MMEMory_Data_Transfer.htm#RLIMit" />
							</HelpLinks>
							<CommandSyntaxes>
								<CommandSyntax>
									<Parameters>
										<Parameter name="state" semanticType="Boolean" description="Disables/enables the row limits for the .csv file.">
											<ParameterType>
												<DecimalNumeric>
													<EnumRef name="enum_3446x_boolean" />
												</DecimalNumeric>
												<Character>
													<EnumRef name="enum_3446x_boolean" />
												</Character>
											</ParameterType>
										</Parameter>
									</Parameters>
								</CommandSyntax>
							</CommandSyntaxes>
							<QuerySyntaxes>
								<QuerySyntax>
									<Responses>
										<Response name="state" semanticType="Boolean" description="Returns the row limits state for the .csv file.">
											<ResponseType>
												<NR1Numeric>
													<EnumRef name="enum_3446x_boolean" />
												</NR1Numeric>
											</ResponseType>
										</Response>
									</Responses>
								</QuerySyntax>
							</QuerySyntaxes>
						</SubsystemCommand>
					</Node>
				</Node>
			</Node>
			<Node mnemonic="LOAD">
				<Node aliases="PREF" mnemonic="PREFerences">
