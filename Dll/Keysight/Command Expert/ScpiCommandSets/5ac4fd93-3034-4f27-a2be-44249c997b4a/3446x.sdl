							<QuerySyntax>
								<Responses>
									<Response name="year" semanticType="Integer" description="Returns the date of the last autocalibration(year).">
										<ResponseType>
											<NR1Numeric />
										</ResponseType>
									</Response>
									<Response name="month" semanticType="Integer" description="Returns the date of the last autocalibration(month).">
										<ResponseType>
											<NR1Numeric />
										</ResponseType>
									</Response>
									<Response name="day" semanticType="Integer" description="Returns the date of the last autocalibration(day).">
										<ResponseType>
											<NR1Numeric />
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
				<Node aliases="TEMP" mnemonic="TEMPerature">
					<SubsystemCommand>
						<Synopsis>The query returns the temperature of the last autocalibration in °C.</Synopsis>
						<HelpLinks>
							<HelpLink name=":SYSTem:ACALibration:TEMPerature" endAnchor="kanchor502" url="__I_SCPI\SYSTem_General Commands.htm#AUTOCAL_TEMP" />
