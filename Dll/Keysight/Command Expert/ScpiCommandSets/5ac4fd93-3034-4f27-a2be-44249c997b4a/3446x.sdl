										<String />
									</ParameterType>
								</Parameter>
								<Parameter name="file2" semanticType="String" description="Any valid file name.">
									<ParameterType>
										<String />
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="RDIR" mnemonic="RDIRectory">
				<SubsystemCommand>
