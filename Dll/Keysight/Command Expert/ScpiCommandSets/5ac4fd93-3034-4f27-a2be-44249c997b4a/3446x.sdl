			<Node aliases="LAB" mnemonic="LABel">
				<SubsystemCommand>
					<Synopsis>The command places a message in a large font on the bottom half of the instrument's front-panel display.</Synopsis>
					<HelpLinks>
						<HelpLink name=":SYSTem:LABel" endAnchor="PRES" url="__I_SCPI\SYSTem_General Commands.htm#LAB" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax>
							<Parameters>
								<Parameter name="string" semanticType="String" description="A quoted string of up to 40 characters. You can use letters (A-Z), numbers (0-9) and special characters such as @, %, *, and so forth.">
									<ParameterType>
										<String />
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="label" semanticType="String" description="Returns the message placed on the bottom half of the instrument's front-panel display.">
									<ResponseType>
										<String />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="LIC" mnemonic="LICense">
				<Node aliases="CAT" mnemonic="CATalog">
					<SubsystemCommand>
						<Synopsis>The query returns a comma separated list of installed, licensed options.</Synopsis>
						<HelpLinks>
							<HelpLink name=":SYSTem:LICense:CATalog" endAnchor="kanchor557" url="__I_SCPI\SYSTem_LICense_Subsystem.htm#CAT" />
						</HelpLinks>
						<QuerySyntaxes>
							<QuerySyntax>
								<Responses>
									<Response name="catalog" semanticType="String" description="Returns a comma separated list of installed, licensed options.">
										<ResponseType>
											<ArbitraryAscii />
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
				<Node aliases="DEL" mnemonic="DELete">
					<SubsystemCommand>
						<Synopsis>The command deletes a license and disables the associated functionality.</Synopsis>
						<HelpLinks>
							<HelpLink name=":SYSTem:LICense:DELete" endAnchor="DEL-ALL" url="__I_SCPI\SYSTem_LICense_Subsystem.htm#DEL" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax>
								<Parameters>
									<Parameter name="optionName" semanticType="String" description="&quot;LAN&quot; or &quot;SEC&quot; (34460A)&#xD;&#xA;&quot;SEC&quot; (34461A)&#xD;&#xA;&#xD;&#xA;&quot;DIG&quot;, &quot;MEM&quot;, or &quot;SEC&quot; (34465A/70A)&#xD;&#xA;">
										<ParameterType>
											<String />
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
					</SubsystemCommand>
					<Node mnemonic="ALL">
						<SubsystemCommand>
							<Synopsis>The command deletes all licenses and disables the associated functionality.</Synopsis>
							<HelpLinks>
								<HelpLink name=":SYSTem:LICense:DELete:ALL" endAnchor="DESC" url="__I_SCPI\SYSTem_LICense_Subsystem.htm#DEL-ALL" />
							</HelpLinks>
							<CommandSyntaxes>
								<CommandSyntax />
							</CommandSyntaxes>
						</SubsystemCommand>
					</Node>
				</Node>
				<Node aliases="DESC" mnemonic="DESCription">
					<SubsystemCommand>
						<Synopsis>The query returns a description of the specified option, regardless of whether it is currently licensed.</Synopsis>
						<HelpLinks>
							<HelpLink name=":SYSTem:LICense:DESCription" endAnchor="ERR" url="__I_SCPI\SYSTem_LICense_Subsystem.htm#DESC" />
						</HelpLinks>
						<QuerySyntaxes>
							<QuerySyntax>
								<Parameters>
									<Parameter name="optionName" semanticType="String" description="&quot;LAN&quot; or &quot;SEC&quot; (34460A)&#xD;&#xA;&quot;SEC&quot; (34461A)&#xD;&#xA;&#xD;&#xA;&quot;DIG&quot;, &quot;MEM&quot;, or &quot;SEC&quot; (34465A/70A)&#xD;&#xA;">
										<ParameterType>
											<String />
										</ParameterType>
									</Parameter>
								</Parameters>
								<Responses>
									<Response name="description" semanticType="String" description="Returns a description of the specified option, regardless of whether it is currently licensed.">
										<ResponseType>
											<String />
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
				<Node aliases="ERR" mnemonic="ERRor">
					<SubsystemCommand>
						<Synopsis>The query return the license installation error string.</Synopsis>
						<HelpLinks>
							<HelpLink name=":SYSTem:LICense:ERRor" endAnchor="ERR-COUN" url="__I_SCPI\SYSTem_LICense_Subsystem.htm#ERR" />
						</HelpLinks>
						<QuerySyntaxes>
							<QuerySyntax>
								<Responses>
									<Response name="error" semanticType="1-D Array" description="Return the license installation error string.">
										<ResponseType>
											<DefiniteLengthArbitraryBlock>
												<Element format="Ascii" type="String" separator="newline" />
											</DefiniteLengthArbitraryBlock>
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
					<Node aliases="COUN" mnemonic="COUNt">
						<SubsystemCommand>
							<Synopsis>The query returns the number of license errors generated by SYSTem:LICense:INSTall.

</Synopsis>
							<HelpLinks>
								<HelpLink name=":SYSTem:LICense:ERRor:COUNt" endAnchor="INST" url="__I_SCPI\SYSTem_LICense_Subsystem.htm#ERR-COUN" />
							</HelpLinks>
							<QuerySyntaxes>
								<QuerySyntax>
									<Responses>
										<Response name="count" semanticType="Integer" description="Returns the number of license errors.">
											<ResponseType>
												<NR1Numeric />
											</ResponseType>
										</Response>
									</Responses>
								</QuerySyntax>
							</QuerySyntaxes>
						</SubsystemCommand>
					</Node>
				</Node>
				<Node aliases="INST" mnemonic="INSTall">
					<SubsystemCommand>
						<Synopsis>The command installs all licenses from a specified file or from all license files in the specified folder.</Synopsis>
						<HelpLinks>
							<HelpLink name=":SYSTem:LICense:INSTall" url="__I_SCPI\SYSTem_LICense_Subsystem.htm#INST" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax>
								<Parameters>
									<Parameter name="folderFile" semanticType="String" description="The specified folder or file name." optional="true">
