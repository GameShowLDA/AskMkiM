	<CommonCommands>
		<CommonCommand mnemonic="CAL">
			<Synopsis>Peforms autocalibration (autocal) and returns the result.</Synopsis>
			<HelpLinks>
				<HelpLink name="*CAL" endAnchor="kanchor244" url="__I_SCPI\IEEE-488_Common_Commands.htm#CAL" />
			</HelpLinks>
			<QuerySyntaxes>
				<QuerySyntax timeout="60000">
					<Responses>
						<Response name="result" semanticType="Integer" description="Peforms autocalibration (autocal) and returns the result.">
							<ResponseType>
								<NR1Numeric />
							</ResponseType>
						</Response>
					</Responses>
				</QuerySyntax>
			</QuerySyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="CLS">
			<Synopsis>Clears the event registers in all register groups. </Synopsis>
			<HelpLinks>
				<HelpLink name="*CLS" endAnchor="ESR" url="__I_SCPI\IEEE-488_Common_Commands.htm#CLS" />
			</HelpLinks>
			<CommandSyntaxes>
				<CommandSyntax />
			</CommandSyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="ESE">
			<Synopsis>Enables bits in the enable register for the Standard Event Register group.</Synopsis>
			<HelpLinks>
				<HelpLink name="*ESE" endAnchor="ESR" url="__I_SCPI\IEEE-488_Common_Commands.htm#ESE" />
			</HelpLinks>
			<CommandSyntaxes>
				<CommandSyntax>
					<Parameters>
						<Parameter name="enableValue" semanticType="Integer" description="Decimal sum of the bits in the register.">
							<ParameterType>
								<DecimalNumeric />
								<NonDecimalNumeric />
							</ParameterType>
						</Parameter>
					</Parameters>
				</CommandSyntax>
			</CommandSyntaxes>
			<QuerySyntaxes>
				<QuerySyntax>
					<Responses>
						<Response name="register" semanticType="Integer" description="Returns the Decimal sum of the bits in the register.">
							<ResponseType>
								<NR1Numeric />
							</ResponseType>
						</Response>
					</Responses>
				</QuerySyntax>
			</QuerySyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="ESR">
			<Synopsis>Queries the event register for the Standard Event Register group. </Synopsis>
			<HelpLinks>
				<HelpLink name="*ESR" endAnchor="kanchor247" url="__I_SCPI\IEEE-488_Common_Commands.htm#ESR" />
			</HelpLinks>
			<QuerySyntaxes>
				<QuerySyntax>
					<Responses>
						<Response name="register" semanticType="Integer" description="Read the event register">
							<ResponseType>
								<NR1Numeric />
							</ResponseType>
						</Response>
					</Responses>
				</QuerySyntax>
			</QuerySyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="IDN">
			<Synopsis>Returns the instrument’s identification string.</Synopsis>
			<HelpLinks>
				<HelpLink name="*IDN" endAnchor="LRN" url="__I_SCPI\IEEE-488_Common_Commands.htm#IDN" />
			</HelpLinks>
			<QuerySyntaxes>
				<QuerySyntax>
					<Responses>
						<Response name="idn" semanticType="String" description="Returns the instrument’s identification string.">
							<ResponseType>
								<ArbitraryAscii />
							</ResponseType>
						</Response>
					</Responses>
				</QuerySyntax>
			</QuerySyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="LRN">
			<Synopsis>Returns an ASCII string of all of the commands required to put the instrument into its current state.</Synopsis>
			<HelpLinks>
				<HelpLink name="*LRN" endAnchor="kanchor249" url="__I_SCPI\IEEE-488_Common_Commands.htm#LRN" />
			</HelpLinks>
			<QuerySyntaxes>
				<QuerySyntax>
					<Responses>
						<Response name="learnString" semanticType="String" description="Returns an ASCII string of all of the commands required to put the instrument into its current state.">
							<ResponseType>
								<ArbitraryAscii />
							</ResponseType>
						</Response>
					</Responses>
				</QuerySyntax>
			</QuerySyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="OPC">
			<Synopsis>Sets "Operation Complete" (bit 0) in the Standard Event register at the completion of the current operation.
Returns 1 to the output buffer after all pending commands complete. 

</Synopsis>
			<HelpLinks>
				<HelpLink name="*OPC" endAnchor="OPCQuest" url="__I_SCPI\IEEE-488_Common_Commands.htm#OPC" />
				<HelpLink name="*OPC?" endAnchor="OPT" url="__I_SCPI\IEEE-488_Common_Commands.htm#OPCQuest" />
			</HelpLinks>
			<CommandSyntaxes>
				<CommandSyntax />
			</CommandSyntaxes>
			<QuerySyntaxes>
				<QuerySyntax>
					<Responses>
						<Response name="opc" semanticType="Integer" description="Returns 1 to the output buffer after all pending commands complete.">
							<ResponseType>
								<NR1Numeric />
							</ResponseType>
						</Response>
					</Responses>
				</QuerySyntax>
			</QuerySyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="OPT">
			<Synopsis>Returns a string identifying any installed options.</Synopsis>
			<HelpLinks>
				<HelpLink name="*OPT" endAnchor="kanchor254" url="__I_SCPI\IEEE-488_Common_Commands.htm#OPT" />
			</HelpLinks>
			<QuerySyntaxes>
				<QuerySyntax>
					<Responses>
						<Response name="opt" semanticType="String" description="Returns a string identifying any installed options.">
							<ResponseType>
								<ArbitraryAscii />
							</ResponseType>
						</Response>
					</Responses>
				</QuerySyntax>
			</QuerySyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="PSC">
			<Synopsis>Enables (1) or disables (0) the clearing of certain enable registers at power on.</Synopsis>
			<HelpLinks>
				<HelpLink name="*PSC" endAnchor="SAV" url="__I_SCPI\IEEE-488_Common_Commands.htm#PSC" />
			</HelpLinks>
			<CommandSyntaxes>
				<CommandSyntax>
					<Parameters>
						<Parameter name="psc" semanticType="Integer" description="Enables (1) or disables (0) the clearing of certain enable registers at power on.">
							<ParameterType>
								<DecimalNumeric />
							</ParameterType>
						</Parameter>
					</Parameters>
				</CommandSyntax>
			</CommandSyntaxes>
			<QuerySyntaxes>
				<QuerySyntax>
					<Responses>
						<Response name="psc" semanticType="Integer" description="Returns whether certain enable registers are cleared at power on.">
							<ResponseType>
								<NR1Numeric />
							</ResponseType>
						</Response>
					</Responses>
				</QuerySyntax>
			</QuerySyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="RCL">
			<Synopsis>This command recalls the instrument state from, the state file STATE_&lt;n&gt;.sta in the root folder of the internal flash file system.</Synopsis>
			<HelpLinks>
				<HelpLink name="*RCL" endAnchor="RST" url="__I_SCPI\IEEE-488_Common_Commands.htm#RCL" />
			</HelpLinks>
			<CommandSyntaxes>
				<CommandSyntax>
					<Parameters>
						<Parameter name="location" semanticType="Integer" description="{0|1|2|3|4}">
							<ParameterType>
								<DecimalNumeric />
								<NonDecimalNumeric />
							</ParameterType>
						</Parameter>
					</Parameters>
				</CommandSyntax>
			</CommandSyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="RST">
			<Synopsis>Resets instrument to factory default state.</Synopsis>
			<HelpLinks>
				<HelpLink name="*RST" endAnchor="SRE" url="__I_SCPI\IEEE-488_Common_Commands.htm#RST" />
			</HelpLinks>
			<CommandSyntaxes>
				<CommandSyntax />
			</CommandSyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="SAV">
			<Synopsis>Stores the current instrument state to the state file STATE_&lt;n&gt;.sta in the root folder of the internal flash file system, where &lt;n&gt; is the number specified.</Synopsis>
			<HelpLinks>
				<HelpLink name="*SAV" endAnchor="kanchor259" url="__I_SCPI\IEEE-488_Common_Commands.htm#SAV" />
			</HelpLinks>
			<CommandSyntaxes>
				<CommandSyntax>
					<Parameters>
						<Parameter name="location" semanticType="Integer" description="{0|1|2|3|4}">
							<ParameterType>
								<DecimalNumeric />
								<NonDecimalNumeric />
							</ParameterType>
						</Parameter>
					</Parameters>
				</CommandSyntax>
			</CommandSyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="SRE">
			<Synopsis>Enables bits in the enable register for the Status Byte Register group.</Synopsis>
			<HelpLinks>
				<HelpLink name="*SRE" endAnchor="kanchor261" url="__I_SCPI\IEEE-488_Common_Commands.htm#SRE" />
			</HelpLinks>
			<CommandSyntaxes>
				<CommandSyntax>
					<Parameters>
						<Parameter name="enableValue" semanticType="Integer" description="A decimal value which corresponds to the binary-weighted sum of the bits in the register.">
							<ParameterType>
								<DecimalNumeric />
								<NonDecimalNumeric />
							</ParameterType>
						</Parameter>
					</Parameters>
				</CommandSyntax>
			</CommandSyntaxes>
			<QuerySyntaxes>
				<QuerySyntax>
					<Responses>
						<Response name="register" semanticType="Integer" description="Returns the current value of the binary-weighted sum of the bits in the register.">
							<ResponseType>
								<NR1Numeric />
							</ResponseType>
						</Response>
					</Responses>
				</QuerySyntax>
			</QuerySyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="STB">
			<Synopsis>Queries the condition register for the Status Byte Register group and returns a decimal value equal to the binary-weighted sum of all bits set in the register.
</Synopsis>
			<HelpLinks>
				<HelpLink name="*STB" endAnchor="TRG" url="__I_SCPI\IEEE-488_Common_Commands.htm#STB" />
			</HelpLinks>
			<QuerySyntaxes>
				<QuerySyntax>
					<Responses>
						<Response name="condRegister" semanticType="Integer" description="Returns a decimal value equal to the binary-weighted sum of all bits set in the register.">
							<ResponseType>
								<NR1Numeric />
							</ResponseType>
						</Response>
					</Responses>
				</QuerySyntax>
			</QuerySyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="TRG">
			<Synopsis>Triggers the instrument if TRIGger:SOURce BUS is selected.</Synopsis>
			<HelpLinks>
				<HelpLink name="*TRG" endAnchor="kanchor265" url="__I_SCPI\IEEE-488_Common_Commands.htm#TRG" />
			</HelpLinks>
			<CommandSyntaxes>
				<CommandSyntax />
			</CommandSyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="TST">
			<Synopsis>Performs a basic self-test of the instrument and returns a pass/fail indication.</Synopsis>
			<HelpLinks>
				<HelpLink name="*TST" endAnchor="kanchor266" url="__I_SCPI\IEEE-488_Common_Commands.htm#TST" />
			</HelpLinks>
			<QuerySyntaxes>
				<QuerySyntax timeout="5000">
					<Responses>
						<Response name="tst" semanticType="Integer" description="Returns the result of the basic self-test of the instrument.">
							<ResponseType>
								<NR1Numeric />
							</ResponseType>
						</Response>
					</Responses>
				</QuerySyntax>
			</QuerySyntaxes>
		</CommonCommand>
		<CommonCommand mnemonic="WAI">
			<Synopsis>Configures the instrument's output buffer to wait for all pending operations to complete before executing any additional commands over the interface.</Synopsis>
			<HelpLinks>
				<HelpLink name="*WAI" url="__I_SCPI\IEEE-488_Common_Commands.htm#WAI" />
			</HelpLinks>
			<CommandSyntaxes>
				<CommandSyntax />
			</CommandSyntaxes>
		</CommonCommand>
	</CommonCommands>
	<SubsystemCommands>
		<RootNode aliases="ABOR" mnemonic="ABORt">
			<SubsystemCommand>
				<Synopsis>Aborts a measurement in progress.</Synopsis>
				<HelpLinks>
					<HelpLink name=":ABORt" url="__I_SCPI\ABORt.htm" />
				</HelpLinks>
				<CommandSyntaxes>
					<CommandSyntax />
				</CommandSyntaxes>
			</SubsystemCommand>
		</RootNode>
		<RootNode aliases="CALC" mnemonic="CALCulate">
			<Node aliases="AVER" mnemonic="AVERage">
				<Node mnemonic="ALL">
					<SubsystemCommand>
						<Synopsis>The query returns the arithmetic mean (average), standard deviation, minimum value and maximum value of all measurements taken since the last time statistics were cleared. </Synopsis>
						<HelpLinks>
							<HelpLink name=":CALCulate:AVERage:ALL" endAnchor="CLE" url="__I_SCPI\CALCulate_AVERage_Subsystem.htm#ALL" />
						</HelpLinks>
						<QuerySyntaxes>
							<QuerySyntax>
								<Responses>
									<Response name="average" semanticType="Real" description="The arithmatic mean average.">
										<ResponseType>
											<NR3Numeric />
										</ResponseType>
									</Response>
									<Response name="standardDeviation" semanticType="Real" description="The standard deviation.">
										<ResponseType>
											<NR3Numeric />
										</ResponseType>
									</Response>
									<Response name="minValue" semanticType="Real" description="The minimum value.">
										<ResponseType>
											<NR3Numeric />
										</ResponseType>
									</Response>
									<Response name="maxValue" semanticType="Real" description="The maximum value.">
										<ResponseType>
											<NR3Numeric />
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
				<Node aliases="AVER" mnemonic="AVERage">
					<SubsystemCommand>
						<Synopsis>The query returns the arithmetic mean (average) of all measurements taken since the last time statistics were cleared.</Synopsis>
						<HelpLinks>
							<HelpLink name=":CALCulate:AVERage:AVERage" endAnchor="CLE" url="__I_SCPI\CALCulate_AVERage_Subsystem.htm#AVER" />
						</HelpLinks>
						<QuerySyntaxes>
							<QuerySyntax>
								<Responses>
									<Response name="average" semanticType="Real" description="Returns the arithmetic mean (average) of all measurements taken since the last time statistics were cleared.">
										<ResponseType>
											<NR3Numeric />
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
				<Node aliases="CLE" mnemonic="CLEar">
					<Node aliases="IMM" default="true" mnemonic="IMMediate">
						<SubsystemCommand>
							<Synopsis>The command clears all computed statistics: minimum, maximum, average, peak-to-peak, count and standard deviation. </Synopsis>
							<HelpLinks>
								<HelpLink name=":CALCulate:AVERage:CLEar[:IMMediate]" endAnchor="STAT" url="__I_SCPI\CALCulate_AVERage_Subsystem.htm#CLE" />
							</HelpLinks>
							<CommandSyntaxes>
								<CommandSyntax />
							</CommandSyntaxes>
						</SubsystemCommand>
					</Node>
				</Node>
				<Node aliases="COUN" mnemonic="COUNt">
					<SubsystemCommand>
						<Synopsis>The query returns the count of all measurements taken since the last time statistics were cleared.</Synopsis>
						<HelpLinks>
							<HelpLink name=":CALCulate:AVERage:COUNt" endAnchor="kanchor186" url="__I_SCPI\CALCulate_AVERage_Subsystem.htm#COUN" />
						</HelpLinks>
						<QuerySyntaxes>
							<QuerySyntax>
								<Responses>
									<Response name="count" semanticType="Real" description="Returns the count of all measurements taken since the last time statistics were cleared.">
										<ResponseType>
											<NR3Numeric />
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
				<Node aliases="MAX" mnemonic="MAXimum">
					<SubsystemCommand>
						<Synopsis>The query returns the maximum value of all measurements taken since the last time statistics were cleared.</Synopsis>
						<HelpLinks>
