					<SubsystemCommand>
						<Synopsis>The query returns the sum of the bits in the condition register for the Standard Operation Register group.</Synopsis>
						<HelpLinks>
							<HelpLink name=":STATus:OPERation:CONDition" endAnchor="kanchor490" url="__I_SCPI\STATus_Subsystem.htm#OPER-COND" />
