											<ResponseType>
												<String />
											</ResponseType>
										</Response>
									</Responses>
								</QuerySyntax>
							</QuerySyntaxes>
						</SubsystemCommand>
					</Node>
					<Node aliases="SMAS" mnemonic="SMASk">
