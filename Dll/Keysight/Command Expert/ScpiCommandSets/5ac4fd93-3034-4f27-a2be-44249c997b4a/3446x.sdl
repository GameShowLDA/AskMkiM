							<CommandSyntax>
								<Parameters>
									<Parameter name="state" semanticType="Boolean" description="Disables/enables the beeper state.">
										<ParameterType>
											<DecimalNumeric>
												<EnumRef name="enum_3446x_boolean" />
											</DecimalNumeric>
											<Character>
