											<Parameter name="minMaxDef" semanticType="String" description="MIN|MAX|DEF." optional="true">
												<ParameterType>
													<Character>
														<EnumRef name="enum_3446x_enumMinMaxDef" />
													</Character>
												</ParameterType>
											</Parameter>
										</Parameters>
										<Responses>
											<Response name="upperValue" semanticType="Real" description="Returns the upper range value for the histogram.">
												<ResponseType>
													<NR3Numeric />
												</ResponseType>
											</Response>
										</Responses>
									</QuerySyntax>
								</QuerySyntaxes>
							</SubsystemCommand>
						</Node>
					</Node>
					<Node aliases="STAT" default="true" mnemonic="STATe">
						<SubsystemCommand>
							<Synopsis>The command enables or disables histogram computation.
The query returns the histogram computation state.</Synopsis>
							<HelpLinks>
								<HelpLink name=":CALCulate:TRANsform:HISTogram[:STATe]" url="__I_SCPI\CALCulate_TRANsform_HISTogram_Subsystem.htm#STATe" />
							</HelpLinks>
							<CommandSyntaxes>
								<CommandSyntax>
									<Parameters>
										<Parameter name="state" semanticType="Boolean" description="Enable/disable histogram computation.">
											<ParameterType>
												<DecimalNumeric>
													<EnumRef name="enum_3446x_boolean" />
												</DecimalNumeric>
												<Character>
													<EnumRef name="enum_3446x_boolean" />
												</Character>
											</ParameterType>
										</Parameter>
									</Parameters>
								</CommandSyntax>
							</CommandSyntaxes>
							<QuerySyntaxes>
								<QuerySyntax>
									<Responses>
										<Response name="state" semanticType="Boolean" description="Returns the current value of histogram computation.">
											<ResponseType>
												<NR1Numeric>
													<EnumRef name="enum_3446x_boolean" />
												</NR1Numeric>
											</ResponseType>
										</Response>
									</Responses>
								</QuerySyntax>
							</QuerySyntaxes>
						</SubsystemCommand>
					</Node>
				</Node>
			</Node>
		</RootNode>
		<RootNode aliases="CAL" mnemonic="CALibration">
			<Node mnemonic="ADC">
				<SubsystemCommand>
					<Synopsis>The query performs a low-level calibration of the ADC (analog-to-digital converter) circuitry.</Synopsis>
					<HelpLinks>
						<HelpLink name=":CALIBRATION:ADC" endAnchor="CALibration_ALL" url="__I_SCPI\CALibration_Subsystem.htm#CALibration_ADC" />
					</HelpLinks>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="adc" semanticType="Integer" description="Returns the result of the low-level calibration of the ADC (analog-to-digital converter) circuitry.">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node default="true" mnemonic="ALL">
				<SubsystemCommand>
					<Synopsis>The query performs a calibration using the calibration value based on the function and range.</Synopsis>
					<HelpLinks>
						<HelpLink name=":CALIBRATION[:ALL]" endAnchor="kanchor197" url="__I_SCPI\CALibration_Subsystem.htm#CALibration_ALL" />
					</HelpLinks>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="result" semanticType="Integer" description="Return a pass/fail indication.">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="COUN" mnemonic="COUNt">
				<SubsystemCommand>
					<Synopsis>The query returns the calibration count.</Synopsis>
					<HelpLinks>
						<HelpLink name=":CALIBRATION:COUNt" endAnchor="CALibration_DATE" url="__I_SCPI\CALibration_Subsystem.htm#CALibration_COUNt" />
					</HelpLinks>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="count" semanticType="Integer" description="Returns the calibration count.">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node mnemonic="DATE">
				<SubsystemCommand>
					<Synopsis>The query returns the date of the last calibration in the format yyyy,mm,dd. </Synopsis>
					<HelpLinks>
						<HelpLink name=":CALibration:DATE" endAnchor="kanchor199" url="__I_SCPI\CALibration_Subsystem.htm#CALibration_DATE" />
					</HelpLinks>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="year" semanticType="Integer" description="Returns the calibration date (year).">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
								<Response name="month" semanticType="Integer" description="Returns the calibration date (month).">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
								<Response name="day" semanticType="Integer" description="Returns the calibration date (day).">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="SEC" mnemonic="SECure">
				<Node mnemonic="CODE">
					<SubsystemCommand>
						<Synopsis>The command sets the security code to prevent unauthorized calibrations.</Synopsis>
						<HelpLinks>
							<HelpLink name=":CALIBRATION:SECure:CODE" endAnchor="CALibration_SECure_STATe" url="__I_SCPI\CALibration_Subsystem.htm#CALibration_SECure_CODE" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax>
								<Parameters>
									<Parameter name="newCode" semanticType="String" description="Unquoted string up to 12 characters&#xD;&#xA;Must start with letter (A-Z)&#xD;&#xA;May contain letters, numbers (0-9) and underscores.">
										<ParameterType>
											<Character />
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
					</SubsystemCommand>
				</Node>
				<Node aliases="STAT" mnemonic="STATe">
					<SubsystemCommand>
						<Synopsis>The command unsecures or secures the instrument for calibration.
The query returns the secure state.</Synopsis>
						<HelpLinks>
							<HelpLink name=":CALIBRATION:SECure:STATe" endAnchor="CALibration_STORe" url="__I_SCPI\CALibration_Subsystem.htm#CALibration_SECure_STATe" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax>
								<Parameters>
									<Parameter name="state" semanticType="Boolean" description="The state of the security of the instrument for calibration.">
										<ParameterType>
											<DecimalNumeric>
												<EnumRef name="enum_3446x_boolean" />
											</DecimalNumeric>
											<Character>
												<EnumRef name="enum_3446x_boolean" />
											</Character>
										</ParameterType>
									</Parameter>
									<Parameter name="code" semanticType="String" description="Security code." optional="true">
										<ParameterType>
											<Character />
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
						<QuerySyntaxes>
							<QuerySyntax>
								<Responses>
									<Response name="state" semanticType="Boolean" description="Returns the current state of the security of the instrument for calibration.">
										<ResponseType>
											<NR1Numeric>
												<EnumRef name="enum_3446x_boolean" />
											</NR1Numeric>
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
			</Node>
			<Node aliases="STOR" mnemonic="STORe">
				<SubsystemCommand>
					<Synopsis>The command takes calibration constants in volatile memory (CALibration:ALL?), and places them in nonvolatile memory, where they are not changed by cycling power, *RST, or SYSTem:PRESet.</Synopsis>
					<HelpLinks>
						<HelpLink name=":CALIBRATION:STORe" endAnchor="CALibration_STRing" url="__I_SCPI\CALibration_Subsystem.htm#CALibration_STORe" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax />
					</CommandSyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="STR" mnemonic="STRing">
				<SubsystemCommand>
					<Synopsis>The command stores a message in calibration memory.</Synopsis>
					<HelpLinks>
						<HelpLink name=":CALIBRATION:STRing" endAnchor="CALibration_TEMP" url="__I_SCPI\CALibration_Subsystem.htm#CALibration_STRing" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax>
							<Parameters>
								<Parameter name="string" semanticType="String" description="Quoted string up to 40 characters&#xD;&#xA;May contain letters, numbers, spaces, and other common characters.">
									<ParameterType>
										<String />
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="string" semanticType="String" description="Returns the message stored in calibration memory.">
									<ResponseType>
										<String />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="TEMP" mnemonic="TEMPerature">
				<SubsystemCommand>
					<Synopsis>The query returns the temperature of the last calibration in °C. </Synopsis>
					<HelpLinks>
						<HelpLink name=":CALibration:TEMPerature" endAnchor="kanchor204" url="__I_SCPI\CALibration_Subsystem.htm#CALibration_TEMP" />
					</HelpLinks>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="temperature" semanticType="Real" description="Return the calibration temperature.">
									<ResponseType>
										<NR3Numeric />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node mnemonic="TIME">
				<SubsystemCommand>
					<Synopsis>The query returns the amount of time since the last calibration in the format  hh,mm,ss.sss. </Synopsis>
					<HelpLinks>
						<HelpLink name=":CALibration:TIME" endAnchor="kanchor205" url="__I_SCPI\CALibration_Subsystem.htm#CALibration_TIME" />
					</HelpLinks>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="hour" semanticType="Integer" description="Return the calibration time(hour).">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
								<Response name="minute" semanticType="Integer" description="Return the calibration time(minute).">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
								<Response name="second" semanticType="Real" description="Return the calibration time(second).">
									<ResponseType>
										<NR3Numeric />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="VAL" mnemonic="VALue">
				<SubsystemCommand>
					<Synopsis>The command specifies the value of the known calibration signal.
The query returns the value of the known calibration signal.</Synopsis>
					<HelpLinks>
						<HelpLink name=":CALIBRATION:VALue" url="__I_SCPI\CALibration_Subsystem.htm#CALibration_VALue" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax>
							<Parameters>
								<Parameter name="value" semanticType="Real" description="The calibration value.">
									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="value" semanticType="Real" description="Returns the current calibration value.">
									<ResponseType>
										<NR3Numeric />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
		</RootNode>
