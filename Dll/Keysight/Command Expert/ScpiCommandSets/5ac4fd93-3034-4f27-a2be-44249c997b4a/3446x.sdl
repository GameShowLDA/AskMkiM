						<CommandSyntax>
							<Parameters>
								<Parameter name="level" semanticType="Real" description="Sets the level on which a trigger occurs when level triggering is enabled.">
									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
										<Character>
											<EnumRef name="enum_3446x_enumMinMaxDef" />
										</Character>
									</ParameterType>
								</Parameter>
							</Parameters>
