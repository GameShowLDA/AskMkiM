					<Node mnemonic="WINS">
						<SubsystemCommand>
							<Synopsis>The command assigns the static IP addresses of the Windows Internet Name System (WINS) servers.</Synopsis>
							<HelpLinks>
								<HelpLink name=":SYSTem:COMMunicate:LAN:WINS" url="__I_SCPI\SYSTem_IO_Configuration.htm#WINS" />
							</HelpLinks>
