					<Node aliases="UPD" mnemonic="UPDate">
						<SubsystemCommand>
							<Synopsis>The command stores any changes made to the LAN settings into non-volatile memory and restarts the LAN driver with the updated settings.</Synopsis>
							<HelpLinks>
								<HelpLink name=":SYSTem:COMMunicate:LAN:UPDate" endAnchor="WINS" url="__I_SCPI\SYSTem_IO_Configuration.htm#UPDate" />
							</HelpLinks>
