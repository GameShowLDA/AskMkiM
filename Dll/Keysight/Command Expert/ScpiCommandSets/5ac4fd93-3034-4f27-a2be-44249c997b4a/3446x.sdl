								<CommandSyntax>
									<Parameters>
										<Parameter name="address" semanticType="String" description="The static IP address of the Windows Internet Name System (WINS) servers.">
											<ParameterType>
												<String />
											</ParameterType>
										</Parameter>
									</Parameters>
								</CommandSyntax>
							</CommandSyntaxes>
							<QuerySyntaxes>
								<QuerySyntax>
									<Parameters>
										<Parameter name="currentStatic" semanticType="String" description="CURRent|STATic, default CURRent." optional="true">
											<ParameterType>
												<Character>
													<EnumRef name="enum_3446x_enumStaticCurrent" />
												</Character>
											</ParameterType>
										</Parameter>
									</Parameters>
									<Responses>
										<Response name="winsAddress" semanticType="String" description="Returns the static IP address of the Windows Internet Name System (WINS) Server. ">
											<ResponseType>
												<String />
											</ResponseType>
										</Response>
									</Responses>
								</QuerySyntax>
							</QuerySyntaxes>
						</SubsystemCommand>
						<NodeSuffixes name="num" description="The Windows Internet Name System (WINS) server identifier.">
							<NodeSuffixRange min="1" max="2" />
						</NodeSuffixes>
					</Node>
				</Node>
			</Node>
			<Node mnemonic="DATE">
				<SubsystemCommand>
					<Synopsis>The command sets the date for the instrument's real-time clock.</Synopsis>
					<HelpLinks>
						<HelpLink name=":SYSTem:DATE" endAnchor="ERR" url="__I_SCPI\SYSTem_General Commands.htm#DATE" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax>
							<Parameters>
								<Parameter name="year" semanticType="Integer" description="2000 to 2099.">
									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
									</ParameterType>
								</Parameter>
								<Parameter name="month" semanticType="Integer" description="1 to 12.">
									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
									</ParameterType>
								</Parameter>
								<Parameter name="day" semanticType="Integer" description="1 to 31.">
									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="year" semanticType="Integer" description="Returns the current year.">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
								<Response name="month" semanticType="Integer" description="Returns the current month.">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
								<Response name="day" semanticType="Integer" description="Returns the current day.">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="ERR" mnemonic="ERRor">
				<Node default="true" mnemonic="NEXT">
					<SubsystemCommand>
						<Synopsis>The query reads and clears one error from the error queue. </Synopsis>
						<HelpLinks>
							<HelpLink name=":SYSTem:ERRor[:NEXT]" endAnchor="HELP" url="__I_SCPI\SYSTem_General Commands.htm#ERR" />
						</HelpLinks>
