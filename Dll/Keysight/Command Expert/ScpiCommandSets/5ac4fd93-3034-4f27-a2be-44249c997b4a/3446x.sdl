			<Node aliases="LIM" mnemonic="LIMit">
				<Node aliases="CLE" mnemonic="CLEar">
					<Node aliases="IMM" default="true" mnemonic="IMMediate">
						<SubsystemCommand>
							<Synopsis>The command clears front panel indications of limits being exceeded and clears bit 11 ("Lower Limit Failed") and bit 12 ("Upper Limit Failed") in the Condition Register of the Questionable Data Register event register group.</Synopsis>
							<HelpLinks>
								<HelpLink name=":CALCulate:LIMit:CLEar[:IMMediate]" endAnchor="LIMit-LOWer-UPPer" url="__I_SCPI\CALCulate_LIMit_Subsystem.htm#CALCulate_LIMit_CLEar" />
							</HelpLinks>
							<CommandSyntaxes>
								<CommandSyntax />
							</CommandSyntaxes>
						</SubsystemCommand>
					</Node>
				</Node>
				<Node aliases="LOW" mnemonic="LOWer">
					<Node default="true" mnemonic="DATA">
						<SubsystemCommand>
							<Synopsis>The command sets the lower limit.
The query returns the lower limit.


</Synopsis>
							<HelpLinks>
								<HelpLink name=":CALCulate:LIMit:LOWer[:DATA]" endAnchor="LIMit-STATe" url="__I_SCPI\CALCulate_LIMit_Subsystem.htm#LIMit-LOWer-UPPer" />
							</HelpLinks>
							<CommandSyntaxes>
								<CommandSyntax>
									<Parameters>
										<Parameter name="value" semanticType="Real" description="-1.0E+15 to -1.0E-15,&#xD;&#xA;or &#xD;&#xA;0.0 (default)&#xD;&#xA;or&#xD;&#xA;+1.0E-15 to 1.0E+15">
											<ParameterType>
												<DecimalNumeric />
												<NonDecimalNumeric />
												<Character>
													<EnumRef name="enum_3446x_enumMinMaxDef" />
												</Character>
											</ParameterType>
										</Parameter>
									</Parameters>
								</CommandSyntax>
							</CommandSyntaxes>
							<QuerySyntaxes>
								<QuerySyntax>
									<Parameters>
										<Parameter name="minMaxDef" semanticType="String" description="MIN|MAX|DEF." optional="true">
											<ParameterType>
												<Character>
													<EnumRef name="enum_3446x_enumMinMaxDef" />
												</Character>
											</ParameterType>
										</Parameter>
									</Parameters>
									<Responses>
										<Response name="value" semanticType="Real" description="Returns the current lower limit value.">
											<ResponseType>
												<NR3Numeric />
											</ResponseType>
										</Response>
									</Responses>
								</QuerySyntax>
							</QuerySyntaxes>
						</SubsystemCommand>
					</Node>
				</Node>
				<Node aliases="STAT" default="true" mnemonic="STATe">
					<SubsystemCommand>
						<Synopsis>The command enables or disables limit testing.
The query returns the limit testing state.
</Synopsis>
						<HelpLinks>
							<HelpLink name=":CALCulate:LIMit[:STATe]" url="__I_SCPI\CALCulate_LIMit_Subsystem.htm#LIMit-STATe" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax>
								<Parameters>
									<Parameter name="state" semanticType="Boolean" description="Enable/disable the limit testing.">
										<ParameterType>
											<DecimalNumeric>
												<EnumRef name="enum_3446x_boolean" />
											</DecimalNumeric>
											<Character>
												<EnumRef name="enum_3446x_boolean" />
											</Character>
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
						<QuerySyntaxes>
							<QuerySyntax>
								<Responses>
									<Response name="state" semanticType="Boolean" description="Returns the current value of the limit testing.">
										<ResponseType>
											<NR1Numeric>
												<EnumRef name="enum_3446x_boolean" />
											</NR1Numeric>
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
				<Node aliases="UPP" mnemonic="UPPer">
					<Node default="true" mnemonic="DATA">
						<SubsystemCommand>
							<Synopsis>The command sets an upper limit.
The query returns an upper limit.


</Synopsis>
							<HelpLinks>
								<HelpLink name=":CALCulate:LIMit:UPPer[:DATA]" endAnchor="LIMit-STATe" url="__I_SCPI\CALCulate_LIMit_Subsystem.htm#LIMit-LOWer-UPPer" />
							</HelpLinks>
							<CommandSyntaxes>
								<CommandSyntax>
									<Parameters>
										<Parameter name="value" semanticType="Real" description="-1.0E+15 to -1.0E-15,&#xD;&#xA;or &#xD;&#xA;0.0 (default)&#xD;&#xA;or&#xD;&#xA;+1.0E-15 to 1.0E+15.">
											<ParameterType>
												<DecimalNumeric />
												<NonDecimalNumeric />
												<Character>
													<EnumRef name="enum_3446x_enumMinMaxDef" />
