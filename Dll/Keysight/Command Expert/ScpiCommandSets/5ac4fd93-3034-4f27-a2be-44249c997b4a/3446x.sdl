										</ResponseType>
									</Response>
									<Response name="errString" semanticType="String" description="The error string enclosed in double quotes.">
										<ResponseType>
											<String />
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
			</Node>
