											<Parameter name="string" semanticType="String" description="String of up to 15 characters. Default: 34460A&gt;, 34461A&gt;, 34465A&gt;, or  34470A&gt;&#xD;&#xA;">
												<ParameterType>
													<String />
												</ParameterType>
											</Parameter>
										</Parameters>
									</CommandSyntax>
								</CommandSyntaxes>
								<QuerySyntaxes>
									<QuerySyntax>
										<Responses>
