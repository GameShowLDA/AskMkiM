					<SubsystemCommand>
						<Synopsis>The command disables or enables the GPIB, USB, or LAN remote interface.</Synopsis>
						<HelpLinks>
							<HelpLink name=":SYSTem:COMMunicate:ENABle" endAnchor="SYSTem_COMMunicate_GPIB_ADDRess" url="__I_SCPI\SYSTem_IO_Configuration.htm#SYSTem_COMMunicate_ENABle" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax>
								<Parameters>
									<Parameter name="state" semanticType="Boolean" description="Disables or enables the GPIB, USB, or LAN remote interface.">
										<ParameterType>
											<DecimalNumeric>
												<EnumRef name="enum_3446x_boolean" />
											</DecimalNumeric>
											<Character>
												<EnumRef name="enum_3446x_boolean" />
											</Character>
										</ParameterType>
									</Parameter>
									<Parameter name="interface" semanticType="String" description="{GPIB|HISLip|USB|LAN|SOCKets|TELNet|VXI11|WEB|USBMtp|USBHost}.">
										<ParameterType>
											<Character>
												<EnumRef name="syst_comm_enable_command_parameter_2" />
											</Character>
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
						<QuerySyntaxes>
							<QuerySyntax>
								<Parameters>
									<Parameter name="interface" semanticType="String" description="{GPIB|HISLip|USB|LAN|SOCKets|TELNet|VXI11|WEB|USBMtp|USBHost}.">
										<ParameterType>
											<Character>
												<EnumRef name="syst_comm_enable_command_parameter_2" />
											</Character>
										</ParameterType>
									</Parameter>
								</Parameters>
								<Responses>
									<Response name="state" semanticType="Boolean" description="Returns the current state of the GPIB, USB, or LAN remote interface. Also of the available remote services such as Sockets, HiSLIP, Telnet, VXI11, and the built-in Web Interface.">
