						<QuerySyntaxes>
							<QuerySyntax>
								<Responses>
									<Response name="standardDeviation" semanticType="Real" description="Returns the standard deviation of all measurements taken since the last time statistics were cleared.">
										<ResponseType>
											<NR3Numeric />
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
				<Node aliases="STAT" default="true" mnemonic="STATe">
					<SubsystemCommand>
						<Synopsis>The command enables or disables statistics computation.
</Synopsis>
						<HelpLinks>
							<HelpLink name=":CALCulate:AVERage[:STATe]" url="__I_SCPI\CALCulate_AVERage_Subsystem.htm#STAT" />
						</HelpLinks>
