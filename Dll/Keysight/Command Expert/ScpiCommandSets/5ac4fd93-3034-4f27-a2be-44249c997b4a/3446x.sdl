		</RootNode>
		<RootNode mnemonic="LXI">
			<Node aliases="IDEN" mnemonic="IDENtify">
				<Node aliases="STAT" default="true" mnemonic="STATe">
					<SubsystemCommand>
						<Synopsis>The command shows or removes the LXI Web Identify indicator on the display.</Synopsis>
						<HelpLinks>
							<HelpLink name=":LXI:IDENtify[:STATe]" endAnchor="LXI_MDNS_ENABle" url="__I_SCPI\LXI_Subsystem.htm#LXI_IDENtify" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax>
								<Parameters>
									<Parameter name="state" semanticType="Boolean" description="Sets the LXI Web Identify indicator state on the display.">
										<ParameterType>
											<DecimalNumeric>
												<EnumRef name="enum_3446x_boolean" />
											</DecimalNumeric>
											<Character>
												<EnumRef name="enum_3446x_boolean" />
											</Character>
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
						<QuerySyntaxes>
							<QuerySyntax>
								<Responses>
									<Response name="state" semanticType="Boolean" description="Returns the state of the LXI Web Identify indicator on the display.">
										<ResponseType>
											<NR1Numeric>
												<EnumRef name="enum_3446x_boolean" />
											</NR1Numeric>
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
			</Node>
			<Node mnemonic="MDNS">
				<Node aliases="ENAB" mnemonic="ENABle">
					<SubsystemCommand>
						<Synopsis>The command disables or enables the multicast Domain Name System (mDNS), which provides the capabilities of a DNS server for service discovery in a small network without a DNS server.</Synopsis>
						<HelpLinks>
							<HelpLink name=":LXI:MDNS:ENABle" endAnchor="LXI_MDNS_HNAMe" url="__I_SCPI\LXI_Subsystem.htm#LXI_MDNS_ENABle" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax>
								<Parameters>
									<Parameter name="state" semanticType="Boolean" description="Disables or enables the multicast Domain Name System (mDNS).">
										<ParameterType>
											<DecimalNumeric>
												<EnumRef name="enum_3446x_boolean" />
											</DecimalNumeric>
											<Character>
												<EnumRef name="enum_3446x_boolean" />
											</Character>
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
						<QuerySyntaxes>
							<QuerySyntax>
								<Responses>
									<Response name="state" semanticType="Boolean" description="Returns the current state of multicast Domain Name System (mDNS).">
