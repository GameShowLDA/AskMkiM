							<SubsystemCommand>
								<Synopsis>The command sets the command prompt seen when communicating with the instrument via Telnet.
</Synopsis>
								<HelpLinks>
									<HelpLink name=":SYSTem:COMMunicate:LAN:TELNet:PROMpt" endAnchor="TELN-WMESsage" url="__I_SCPI\SYSTem_IO_Configuration.htm#TELN-PROMpt" />
								</HelpLinks>
