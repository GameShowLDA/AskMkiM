			</Node>
			<Node aliases="MDIR" mnemonic="MDIRectory">
				<SubsystemCommand>
					<Synopsis>The command makes a new directory (folder) on the mass storage medium.</Synopsis>
					<HelpLinks>
						<HelpLink name=":MMEMory:MDIRectory" endAnchor="COPY" url="__I_SCPI\MMEMory_Subsystem.htm#MDIRectory" />
					</HelpLinks>
