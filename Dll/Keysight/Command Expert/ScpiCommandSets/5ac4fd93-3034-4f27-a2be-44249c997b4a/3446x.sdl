												<EnumRef name="enum_3446x_boolean" />
											</DecimalNumeric>
											<Character>
												<EnumRef name="enum_3446x_boolean" />
											</Character>
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
						<QuerySyntaxes>
							<QuerySyntax>
								<Responses>
									<Response name="state" semanticType="Boolean" description="Returns the current value of statistics computation.">
										<ResponseType>
											<NR1Numeric>
												<EnumRef name="enum_3446x_boolean" />
											</NR1Numeric>
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
			</Node>
			<Node aliases="CLE" mnemonic="CLEar">
				<Node aliases="IMM" default="true" mnemonic="IMMediate">
					<SubsystemCommand>
						<Synopsis>This command clears all limits, histogram data, statistics, and measurements.</Synopsis>
