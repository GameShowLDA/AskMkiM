									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
				<Node mnemonic="TIME">
					<SubsystemCommand>
						<Synopsis>The query returns the time of the last autocalibration in the format hh,mm,ss.sss. </Synopsis>
