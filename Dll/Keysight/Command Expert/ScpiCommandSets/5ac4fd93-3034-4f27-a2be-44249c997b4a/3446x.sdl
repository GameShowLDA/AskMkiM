									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node mnemonic="TIME">
				<SubsystemCommand>
					<Synopsis>The command sets the time for the instrument's real-time clock.</Synopsis>
					<HelpLinks>
						<HelpLink name=":SYSTem:TIME" endAnchor="UPTime" url="__I_SCPI\SYSTem_General Commands.htm#TIME" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax>
							<Parameters>
								<Parameter name="hour" semanticType="Integer" description="0 to 23.">
									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
									</ParameterType>
								</Parameter>
								<Parameter name="minute" semanticType="Integer" description="0 to 59.">
									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
									</ParameterType>
								</Parameter>
								<Parameter name="second" semanticType="Real" description="0 to 60.">
									<ParameterType>
										<DecimalNumeric />
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="hour" semanticType="Integer" description="Returns the current time(hour) for the instrument's real-time clock.">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
								<Response name="minute" semanticType="Integer" description="Returns the current time(minute) for the instrument's real-time clock.">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
								<Response name="second" semanticType="Real" description="Returns the current time(second) for the instrument's real-time clock.">
									<ResponseType>
										<NR3Numeric />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="UPT" mnemonic="UPTime">
				<SubsystemCommand>
					<Synopsis>The query returns the amount of time that the instrument has been running since the last power-on.</Synopsis>
					<HelpLinks>
						<HelpLink name=":SYSTem:UPTime" endAnchor="kanchor529" url="__I_SCPI\SYSTem_General Commands.htm#UPTime" />
					</HelpLinks>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="days" semanticType="Integer" description="Returns the amount of time(days) that the instrument has been running since the last power-on.">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
								<Response name="hours" semanticType="Integer" description="Returns the amount of time(hours) that the instrument has been running since the last power-on.">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
								<Response name="minutes" semanticType="Integer" description="Returns the amount of time(minutes) that the instrument has been running since the last power-on.">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
								<Response name="seconds" semanticType="Integer" description="Returns the amount of time(seconds) that the instrument has been running since the last power-on.">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node mnemonic="USB">
