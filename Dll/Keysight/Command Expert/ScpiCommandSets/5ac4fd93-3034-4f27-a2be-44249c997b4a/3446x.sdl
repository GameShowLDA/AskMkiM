											<String />
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
						<QuerySyntaxes>
							<QuerySyntax>
								<Parameters>
									<Parameter name="optionName" semanticType="String" description="The option.">
										<ParameterType>
											<String />
										</ParameterType>
									</Parameter>
								</Parameters>
								<Responses>
									<Response name="licenseStatus" semanticType="Boolean" description="Returns the status of the license.">
										<ResponseType>
											<NR1Numeric>
												<EnumRef name="enum_3446x_boolean" />
											</NR1Numeric>
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
			</Node>
			<Node aliases="LOC" mnemonic="LOCal">
				<SubsystemCommand>
					<Synopsis>Sets the instrument state to local, clears the Remote display annunciator, and enables front-panel operation</Synopsis>
					<HelpLinks>
						<HelpLink name=":SYSTem:LOCal" endAnchor="kanchor416" url="_documentation\__I_SCPI\SYSTem_General Commands.htm#LOC" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax />
					</CommandSyntaxes>
				</SubsystemCommand>
			</Node>
			<Node mnemonic="LOCK">
