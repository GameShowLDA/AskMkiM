		<RootNode aliases="TRIG" mnemonic="TRIGger">
			<Node aliases="COUN" mnemonic="COUNt">
				<SubsystemCommand>
					<Synopsis>The command selects the number of triggers that will be accepted by the instrument before returning to the "idle" trigger state.</Synopsis>
					<HelpLinks>
						<HelpLink name=":TRIGger[:SEQuence]:COUNt" endAnchor="DELay" url="__I_SCPI\TRIGger_Subsystem.htm#COUNt" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax>
							<Parameters>
								<Parameter name="count" semanticType="Real" description="&#xD;&#xA;1 to 1,000,000 (1x106) or continuous (INFinity). Default: 1. (34460A/61A)&#xD;&#xA;1 to 1,000,000,000 (1x109) or continuous (INFinity). Default: 1. (34465A/70A)&#xD;&#xA; &#xD;&#xA; ">
									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
										<Character>
											<EnumRef name="enum_3446x_enumMinMaxDefInf" />
										</Character>
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
					<QuerySyntaxes>
						<QuerySyntax>
							<Parameters>
								<Parameter name="minMaxDef" semanticType="String" description="MIN|MAX|DEF." optional="true">
									<ParameterType>
										<Character>
											<EnumRef name="enum_3446x_enumMinMaxDef" />
										</Character>
									</ParameterType>
								</Parameter>
							</Parameters>
							<Responses>
								<Response name="count" semanticType="Real" description="Returns the number of triggers that will be accepted by the instrument before returning to the &quot;idle&quot; trigger state.">
									<ResponseType>
										<NR3Numeric />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="DEL" mnemonic="DELay">
				<SubsystemCommand>
					<Synopsis>The command sets the delay between the trigger signal and the first measurement. </Synopsis>
					<HelpLinks>
						<HelpLink name=":TRIGger[:SEQuence]:DELay" endAnchor="DELay-AUTO" url="__I_SCPI\TRIGger_Subsystem.htm#DELay" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax>
							<Parameters>
								<Parameter name="seconds" semanticType="Real" description="0 to ~3600 seconds (~1 µs steps), default 1 s.">
									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
										<Character>
											<EnumRef name="enum_3446x_enumMinMaxDef" />
										</Character>
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
					<QuerySyntaxes>
						<QuerySyntax>
							<Parameters>
								<Parameter name="minMaxDef" semanticType="String" description="MIN|MAX|DEF." optional="true">
									<ParameterType>
										<Character>
											<EnumRef name="enum_3446x_enumMinMaxDef" />
										</Character>
									</ParameterType>
								</Parameter>
							</Parameters>
							<Responses>
								<Response name="delay" semanticType="Real" description="Returns the delay between the trigger signal and the first measurement.">
									<ResponseType>
										<NR3Numeric />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
				<Node mnemonic="AUTO">
					<SubsystemCommand>
						<Synopsis>The command disables or enables automatic trigger delay. </Synopsis>
						<HelpLinks>
							<HelpLink name=":TRIGger[:SEQuence]:DELay:AUTO" endAnchor="Level" url="__I_SCPI\TRIGger_Subsystem.htm#DELay-AUTO" />
						</HelpLinks>
