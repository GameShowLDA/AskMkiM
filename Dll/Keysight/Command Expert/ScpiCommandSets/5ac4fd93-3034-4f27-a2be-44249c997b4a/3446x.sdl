			<Node aliases="ACAL" mnemonic="ACALibration">
				<Node mnemonic="DATE">
					<SubsystemCommand>
						<Synopsis>The query returns the date of the last autocalibration in the format yyyy,mm,dd. </Synopsis>
						<HelpLinks>
