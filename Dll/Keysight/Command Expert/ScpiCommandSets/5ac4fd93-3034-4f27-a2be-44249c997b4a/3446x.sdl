										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
				<Node aliases="ENAB" mnemonic="ENABle">
					<SubsystemCommand>
						<Synopsis>The command enables bits in the enable register for the Standard Operation Register group.</Synopsis>
