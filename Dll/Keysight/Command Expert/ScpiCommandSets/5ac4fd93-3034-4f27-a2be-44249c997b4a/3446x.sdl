											<String />
										</ParameterType>
									</Parameter>
								</Parameters>
								<Responses>
									<Response name="status" semanticType="Boolean" description="Returns the status of the specified state file.">
										<ResponseType>
											<NR1Numeric>
												<EnumRef name="enum_3446x_boolean" />
											</NR1Numeric>
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
			</Node>
			<Node aliases="STOR" mnemonic="STORe">
				<Node mnemonic="DATA">
					<SubsystemCommand>
						<Synopsis>The command stores all measurements in reading memory to the specified data file. </Synopsis>
						<HelpLinks>
							<HelpLink name=":MMEMory:STORe:DATA" endAnchor="UPLoad" url="__I_SCPI\MMEMory_Data_Transfer.htm#STOR-DATA" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax>
								<Parameters>
									<Parameter name="rdgStore" semanticType="String" description="The only allowed value is RDG_STORE">
										<ParameterType>
											<Character>
												<EnumRef name="mmem_store_data_command_parameter_1" />
											</Character>
										</ParameterType>
									</Parameter>
									<Parameter name="file" semanticType="String" description="The file where to store the measurements.">
										<ParameterType>
											<String />
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
					</SubsystemCommand>
				</Node>
				<Node aliases="PREF" mnemonic="PREFerences">
					<SubsystemCommand>
						<Synopsis>The command stores nonvolatile I/O settings and user preferences to a file. </Synopsis>
						<HelpLinks>
							<HelpLink name=":MMEMory:STORe:PREFerences" endAnchor="STOR-STAT" url="__I_SCPI\MMEMory_STATe_PREF.htm#STOR-PREF" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax>
								<Parameters>
									<Parameter name="file" semanticType="String" description="Any valid file name.&#xD;&#xA;">
										<ParameterType>
											<String />
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
					</SubsystemCommand>
				</Node>
				<Node aliases="STAT" mnemonic="STATe">
					<SubsystemCommand>
						<Synopsis>The command saves the current instrument state to a state file.</Synopsis>
						<HelpLinks>
							<HelpLink name=":MMEMory:STORe:STATe" endAnchor="STAT-REC-AUTO" url="__I_SCPI\MMEMory_STATe_PREF.htm#STOR-STAT" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax>
								<Parameters>
									<Parameter name="filename" semanticType="String" description="Any valid file name.">
										<ParameterType>
											<String />
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
					</SubsystemCommand>
				</Node>
			</Node>
			<Node aliases="UPL" mnemonic="UPLoad">
				<SubsystemCommand>
					<Synopsis>The query uploads the contents of a file from the instrument to the host computer.</Synopsis>
					<HelpLinks>
						<HelpLink name=":MMEMory:UPLoad" url="__I_SCPI\MMEMory_Data_Transfer.htm#UPLoad" />
					</HelpLinks>
					<QuerySyntaxes>
						<QuerySyntax>
							<Parameters>
								<Parameter name="filename" semanticType="String" description="Any valid file name.">
									<ParameterType>
										<String />
									</ParameterType>
								</Parameter>
							</Parameters>
							<Responses>
								<Response name="upload" semanticType="1-D Array" description="Returns the contents of a file from the instrument to the host computer.">
									<ResponseType>
										<DefiniteLengthArbitraryBlock>
											<Element format="BinaryLittleEndian" type="Byte" />
										</DefiniteLengthArbitraryBlock>
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
		</RootNode>
		<RootNode aliases="OUTP" mnemonic="OUTPut">
			<Node aliases="TRIG" mnemonic="TRIGger">
				<Node aliases="SLOP" mnemonic="SLOPe">
					<SubsystemCommand>
						<Synopsis>The command selects the slope of the voltmeter complete output signal on the rear-panel VM Comp BNC connector.</Synopsis>
						<HelpLinks>
							<HelpLink name=":OUTPut:TRIGger:SLOPe" url="__I_SCPI\OUTPut_TRIGger_SLOPe.htm" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax>
								<Parameters>
									<Parameter name="slope" semanticType="String" description="Selects the slope of the voltmeter complete output signal on the rear-panel VM Comp BNC connector.">
										<ParameterType>
											<Character>
												<EnumRef name="outp_trig_slope_command_parameter_1" />
											</Character>
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
						<QuerySyntaxes>
							<QuerySyntax>
								<Responses>
									<Response name="slope" semanticType="String" description="Returns the current value of slope of the voltmeter complete output signal on the rear-panel VM Comp BNC connector.">
										<ResponseType>
											<Character>
												<EnumRef name="outp_trig_slope_query_response_1" />
											</Character>
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
			</Node>
		</RootNode>
		<RootNode mnemonic="R">
			<SubsystemCommand>
				<Synopsis>The query reads and erases all available measurements from the reading memory up to the specified &lt;max_readings&gt;. </Synopsis>
				<HelpLinks>
					<HelpLink name=":R" url="__I_SCPI\R_.htm" />
				</HelpLinks>
				<QuerySyntaxes>
					<QuerySyntax name="Query">
						<Parameters>
							<Parameter name="maxReadings" semanticType="Integer" description="1 to 2,000,000 (readings) &#xD;&#xA;&#xD;&#xA;Default is all readings in memory.&#xD;&#xA;" optional="true">
								<ParameterType>
									<DecimalNumeric />
									<NonDecimalNumeric />
								</ParameterType>
							</Parameter>
						</Parameters>
						<Responses>
							<Response name="readings" semanticType="1-D Array" description="Reads and removes the specified number of readings.">
								<ResponseType>
									<DefiniteLengthArbitraryBlock>
										<Element format="Ascii" type="Double" separator="," />
									</DefiniteLengthArbitraryBlock>
								</ResponseType>
							</Response>
						</Responses>
					</QuerySyntax>
				</QuerySyntaxes>
			</SubsystemCommand>
		</RootNode>
		<RootNode mnemonic="READ">
			<SubsystemCommand>
				<Synopsis>The query starts a new sets of measurements, waits for all measurements to complete, and transfers all available measurements. </Synopsis>
				<HelpLinks>
					<HelpLink name=":READ" url="__I_SCPI\READ_.htm" />
				</HelpLinks>
				<QuerySyntaxes>
					<QuerySyntax name="AsciiReal">
						<FormatCommandsRef name="AsciiReal" />
						<Responses>
							<Response name="read" semanticType="Real" description="Transfer measurements from reading memory." repeat="*">
								<ResponseType>
									<NR3Numeric />
								</ResponseType>
							</Response>
						</Responses>
					</QuerySyntax>
					<QuerySyntax name="BlockReal64">
						<FormatCommandsRef name="BlockReal64yyy" />
						<Responses>
							<Response name="read" semanticType="1-D Array" description="Transfer measurements from reading memory.">
								<ResponseType>
									<IndefiniteLengthArbitraryBlock>
										<Element format="BinaryLittleEndian" type="Double" />
									</IndefiniteLengthArbitraryBlock>
								</ResponseType>
							</Response>
						</Responses>
					</QuerySyntax>
				</QuerySyntaxes>
			</SubsystemCommand>
		</RootNode>
		<RootNode aliases="ROUT" mnemonic="ROUTe">
			<Node aliases="TERM" mnemonic="TERMinals">
				<SubsystemCommand>
					<Synopsis>The query indicates which input terminals are selected on the 34461A front panel Front/Rear switch.</Synopsis>
					<HelpLinks>
						<HelpLink name=":ROUTe:TERMinals" url="__I_SCPI\ROUTe_TERMinals_.htm" />
					</HelpLinks>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="terminals" semanticType="String" description="Return the state of the Front/Rear switch.">
									<ResponseType>
										<String />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
		</RootNode>
		<RootNode aliases="SAMP" mnemonic="SAMPle">
			<Node aliases="COUN" mnemonic="COUNt">
				<SubsystemCommand>
					<Synopsis>The command specifies the number of measurements (samples) the instrument takes per trigger.</Synopsis>
					<HelpLinks>
						<HelpLink name=":SAMPle:COUNt" endAnchor="kanchor321" url="__I_SCPI\SAMPle_Subsystem.htm#COUNt" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax>
							<Parameters>
								<Parameter name="count" semanticType="Integer" description="1 to 1,000,000 (1x106). Default: 1. (34460A/61A)&#xD;&#xA;1 to 1,000,000,000 (1x109). Default: 1. (34465A/70A)">
									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
										<Character>
											<EnumRef name="enum_3446x_enumMinMaxDef" />
										</Character>
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
					<QuerySyntaxes>
						<QuerySyntax>
							<Parameters>
								<Parameter name="minMaxDef" semanticType="String" description="MIN|MAX|DEF." optional="true">
									<ParameterType>
										<Character>
											<EnumRef name="enum_3446x_enumMinMaxDef" />
										</Character>
									</ParameterType>
								</Parameter>
							</Parameters>
							<Responses>
								<Response name="sampleCount" semanticType="Integer" description="Returns number of measurements (samples) the instrument takes per trigger.">
									<ResponseType>
										<NR1Numeric />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
				<Node aliases="PRET" mnemonic="PRETrigger">
					<SubsystemCommand>
						<Synopsis>The command allows collection of the data being digitized before  the trigger. Reserves memory for pretrigger  samples up to the specified number of pretrigger samples.</Synopsis>
						<HelpLinks>
							<HelpLink name=":SAMPle:COUNt:PRETrigger" endAnchor="kanchor326" url="__I_SCPI\SAMPle_Subsystem.htm#PRETrigger" />
						</HelpLinks>
						<CommandSyntaxes>
							<CommandSyntax>
								<Parameters>
									<Parameter name="count" semanticType="Integer" description="0 to 1,999,999. Default: 0.">
										<ParameterType>
											<DecimalNumeric />
											<NonDecimalNumeric />
											<Character>
												<EnumRef name="enum_3446x_enumMinMaxDef" />
											</Character>
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
						</CommandSyntaxes>
						<QuerySyntaxes>
							<QuerySyntax>
								<Parameters>
									<Parameter name="minMaxDef" semanticType="String" description="MIN|MAX|DEF." optional="true">
										<ParameterType>
											<Character>
												<EnumRef name="enum_3446x_enumMinMaxDef" />
											</Character>
										</ParameterType>
									</Parameter>
								</Parameters>
								<Responses>
									<Response name="pretrigger" semanticType="Integer" description="Returns the specified number of pretrigger samples.">
										<ResponseType>
											<NR1Numeric />
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
			</Node>
			<Node aliases="SOUR" mnemonic="SOURce">
				<SubsystemCommand>
					<Synopsis>The command determines sample timing.</Synopsis>
					<HelpLinks>
						<HelpLink name=":SAMPle:SOURce" endAnchor="kanchor331" url="__I_SCPI\SAMPle_Subsystem.htm#SOURce" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax>
							<Parameters>
								<Parameter name="source" semanticType="String" description="Set sample source.">
									<ParameterType>
										<Character>
											<EnumRef name="samp_source_command_parameter_1" />
										</Character>
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
					<QuerySyntaxes>
						<QuerySyntax>
							<Responses>
								<Response name="source" semanticType="String" description="Returns sample source.">
									<ResponseType>
										<Character>
											<EnumRef name="samp_source_query_response_1" />
										</Character>
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="TIM" mnemonic="TIMer">
				<SubsystemCommand>
					<Synopsis>The command sets a sample interval for timed sampling (SAMPle:SOURce TIMer) when the sample count is greater than one. </Synopsis>
					<HelpLinks>
						<HelpLink name=":SAMPle:TIMer" url="__I_SCPI\SAMPle_Subsystem.htm#TIMer" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax>
							<Parameters>
								<Parameter name="interval" semanticType="Real" description="Sets a sample interval for timed sampling.">
									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
										<Character>
											<EnumRef name="enum_3446x_enumMinMaxDef" />
										</Character>
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
					<QuerySyntaxes>
						<QuerySyntax>
							<Parameters>
								<Parameter name="minMaxDef" semanticType="String" description="MIN|MAX|DEF." optional="true">
									<ParameterType>
										<Character>
											<EnumRef name="enum_3446x_enumMinMaxDef" />
										</Character>
									</ParameterType>
								</Parameter>
							</Parameters>
							<Responses>
								<Response name="interval" semanticType="Real" description="Returns a sample interval for timed sampling.">
									<ResponseType>
										<NR3Numeric />
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
		</RootNode>
		<RootNode aliases="SENS" default="true" mnemonic="SENSe">
			<Node aliases="CAP" mnemonic="CAPacitance">
				<Node mnemonic="NULL">
					<Node aliases="STAT" default="true" mnemonic="STATe">
						<SubsystemCommand>
							<Synopsis>The command turns the null function on or off for capacitance measurements.
The query returns the null function state for capacitance measurements.</Synopsis>
							<HelpLinks>
								<HelpLink name="[:SENSe]:CAPacitance:NULL[:STATe]" endAnchor="kanchor343" url="__I_SCPI\SENSe_CAPacitance_Subsystem.htm#STATe" />
							</HelpLinks>
							<CommandSyntaxes>
								<CommandSyntax>
									<Parameters>
										<Parameter name="state" semanticType="Boolean" description="Turns the null function on or off for capacitance measurements.">
											<ParameterType>
												<DecimalNumeric>
													<EnumRef name="enum_3446x_boolean" />
												</DecimalNumeric>
												<Character>
													<EnumRef name="enum_3446x_boolean" />
												</Character>
											</ParameterType>
										</Parameter>
									</Parameters>
								</CommandSyntax>
							</CommandSyntaxes>
							<QuerySyntaxes>
								<QuerySyntax>
									<Responses>
										<Response name="state" semanticType="Boolean" description="Returns the null function state for capacitance measurements.">
