			<Node aliases="TEMP" mnemonic="TEMPerature">
				<SubsystemCommand>
					<Synopsis>The command sets all measurement parameters and trigger parameters to their default values for temperature measurements. Also specifies the transducer and the measurement resolution.</Synopsis>
					<HelpLinks>
						<HelpLink name=":CONFigure[:SCALar]:TEMPerature" endAnchor="VOLT-ACDC" url="__I_SCPI\CONFigure_Subsystem.htm#TEMP" />
					</HelpLinks>
					<CommandSyntaxes>
						<CommandSyntax>
							<Parameters>
								<Parameter name="probeType" semanticType="String" description="FRTD|RTD|FTHermistor|THERmistor|TCouple. Default: FRTD." optional="true">
									<ParameterType>
										<Character>
											<EnumRef name="conf_scal_temperature_command_parameter_1" />
										</Character>
									</ParameterType>
								</Parameter>
								<Parameter name="type" semanticType="Integer" description="85 (only possible value for RTD/FRTD), 5000 (only possible value for THERmistor/FTHermistor), or E, J, K, N, R, T (TCouple)." optional="true">
									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
										<Character>
											<EnumRef name="conf_scal_temperature_command_parameter_2" />
										</Character>
									</ParameterType>
								</Parameter>
								<Parameter name="num" semanticType="Integer" description="The implied range parameter." optional="true">
									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
									</ParameterType>
								</Parameter>
								<Parameter name="resolution" semanticType="Real" description="Specifies the resolution." optional="true">
									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
										<Character>
											<EnumRef name="enum_3446x_enumMinMaxDef" />
										</Character>
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="VOLT" default="true" mnemonic="VOLTage">
