									<ParameterType>
										<DecimalNumeric />
										<NonDecimalNumeric />
										<Character>
											<EnumRef name="enum_3446x_enumMinMaxDef" />
										</Character>
									</ParameterType>
								</Parameter>
							</Parameters>
