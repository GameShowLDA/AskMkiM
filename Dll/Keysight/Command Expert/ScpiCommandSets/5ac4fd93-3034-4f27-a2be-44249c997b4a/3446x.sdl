					<Synopsis>The command selects the manufacturer and model number returned by *IDN?. </Synopsis>
					<HelpLinks>
						<HelpLink name=":SYSTem:IDENtify" endAnchor="LAB" url="__I_SCPI\SYSTem_General Commands.htm#IDEN" />
					</HelpLinks>
