													<String />
												</ResponseType>
											</Response>
										</Responses>
									</QuerySyntax>
								</QuerySyntaxes>
							</SubsystemCommand>
						</Node>
						<Node aliases="WMES" mnemonic="WMESsage">
							<SubsystemCommand>
								<Synopsis>The command sets welcome message seen when communicating with instrument via Telnet.</Synopsis>
								<HelpLinks>
									<HelpLink name=":SYSTem:COMMunicate:LAN:TELNet:WMESsage" endAnchor="UPDate" url="__I_SCPI\SYSTem_IO_Configuration.htm#TELN-WMESsage" />
								</HelpLinks>
