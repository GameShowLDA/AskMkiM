										<String />
									</ParameterType>
								</Parameter>
							</Parameters>
						</CommandSyntax>
					</CommandSyntaxes>
				</SubsystemCommand>
			</Node>
			<Node mnemonic="MOVE">
				<SubsystemCommand>
					<Synopsis>The command moves and/or renames &lt;file1&gt; to &lt;file2&gt;. Each file name must include the file extension.</Synopsis>
					<HelpLinks>
						<HelpLink name=":MMEMory:MOVE" url="__I_SCPI\MMEMory_Subsystem.htm#MOVE" />
