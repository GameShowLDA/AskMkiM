											<Element format="Ascii" type="String" separator="newline" />
										</DefiniteLengthArbitraryBlock>
									</ResponseType>
								</Response>
							</Responses>
						</QuerySyntax>
					</QuerySyntaxes>
				</SubsystemCommand>
			</Node>
			<Node aliases="IDEN" mnemonic="IDENtify">
