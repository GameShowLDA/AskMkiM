												<EnumRef name="psu_std_num_enums" />
											</Character>
										</ParameterType>
									</Parameter>
									<Parameter name="chanlist" semanticType="String" description="One or more channels. (@2) - channel 2 , (@1,4) - channels 1 and 4, (@1:3) - channels 1 through 3.">
										<ParameterType>
											<Expression>
												<ChannelList />
											</Expression>
										</ParameterType>
									</Parameter>
								</Parameters>
								<Responses>
									<Response name="listCount" repeat="*" semanticType="Real" description="The list count for each channel specified.">
										<ResponseType>
											<NR3Numeric />
										</ResponseType>
									</Response>
								</Responses>
							</QuerySyntax>
						</QuerySyntaxes>
					</SubsystemCommand>
				</Node>
				<Node aliases="CURR" mnemonic="CURRent">
					<Node aliases="LEV" default="true" mnemonic="LEVel">
						<SubsystemCommand>
							<Synopsis>This command specifies the current setting for each list step in amperes. A comma-delimited list of up to 512 steps may be programmed. </Synopsis>
							<HelpLinks>
								<HelpLink name="[SOURce:]LIST:CURRent[:LEVel]" url="SOURce_Subsystem\_SOURce__LIST_CURRent__LEVel_.htm" />
