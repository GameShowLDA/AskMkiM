											<NonDecimalNumeric />
											<Character>
												<EnumRef name="source_list_count_command_parameter_1" />
											</Character>
										</ParameterType>
									</Parameter>
									<Parameter name="chanlist" semanticType="String" description="One or more channels. (@2) - channel 2 , (@1,4) - channels 1 and 4, (@1:3) - channels 1 through 3.">
										<ParameterType>
											<Expression>
												<ChannelList />
											</Expression>
										</ParameterType>
									</Parameter>
								</Parameters>
							</CommandSyntax>
