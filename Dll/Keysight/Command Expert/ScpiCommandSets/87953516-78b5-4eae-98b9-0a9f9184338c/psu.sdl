				<Node aliases="PROT" mnemonic="PROTection">
					<Node aliases="STAT" mnemonic="STATe">
						<SubsystemCommand>
							<Synopsis>This command enables or disables the over-current protection (OCP) function. The enabled state is On (1); the disabled state is Off (0). If the over-current protection function is enabled and the output goes into constant current operation, the output is disabled and the Questionable Condition status register OCP bit is set.</Synopsis>
							<HelpLinks>
								<HelpLink name="[SOURce:]CURRent:PROTection:STATe" url="SOURce_Subsystem\_SOURce__CURRent_PROTection_STATe.htm" />
							</HelpLinks>
							<CommandSyntaxes>
								<CommandSyntax>
									<Parameters>
										<Parameter name="Bool" semanticType="Boolean" description="OFF | 0 | ON | 1">
											<ParameterType>
												<DecimalNumeric>
													<EnumRef name="psu_boolean" />
												</DecimalNumeric>
												<Character>
													<EnumRef name="psu_boolean" />
												</Character>
											</ParameterType>
										</Parameter>
										<Parameter name="chanlist" semanticType="String" description="One or more channels. (@2) - channel 2 , (@1,4) - channels 1 and 4, (@1:3) - channels 1 through 3.">
											<ParameterType>
												<Expression>
													<ChannelList />
												</Expression>
											</ParameterType>
										</Parameter>
									</Parameters>
								</CommandSyntax>
							</CommandSyntaxes>
							<QuerySyntaxes>
								<QuerySyntax>
									<Parameters>
										<Parameter name="chanlist" semanticType="String" description="One or more channels. (@2) - channel 2 , (@1,4) - channels 1 and 4, (@1:3) - channels 1 through 3.">
											<ParameterType>
												<Expression>
													<ChannelList />
												</Expression>
											</ParameterType>
										</Parameter>
									</Parameters>
									<Responses>
										<Response name="ocpState" repeat="*" semanticType="Boolean" description="The over current protection state for the specified channels.">
											<ResponseType>
												<NR1Numeric>
													<EnumRef name="psu_boolean" />
												</NR1Numeric>
											</ResponseType>
										</Response>
									</Responses>
								</QuerySyntax>
							</QuerySyntaxes>
						</SubsystemCommand>
					</Node>
				</Node>
				<Node aliases="RANG" mnemonic="RANGe">
