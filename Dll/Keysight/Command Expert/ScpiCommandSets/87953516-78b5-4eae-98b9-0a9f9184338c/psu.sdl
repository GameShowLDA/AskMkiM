											<ParameterType>
												<DecimalNumeric>
													<Suffix>
														<CustomSuffix default="true" unit="A" />
													</Suffix>
												</DecimalNumeric>
												<NonDecimalNumeric />
											</ParameterType>
										</Parameter>
										<Parameter name="chanlist" semanticType="String" description="One or more channels. (@2) - channel 2 , (@1,4) - channels 1 and 4, (@1:3) - channels 1 through 3.">
											<ParameterType>
												<Expression>
													<ChannelList />
												</Expression>
											</ParameterType>
										</Parameter>
									</Parameters>
								</CommandSyntax>
							</CommandSyntaxes>
							<QuerySyntaxes>
								<QuerySyntax>
									<Parameters>
										<Parameter name="chanlist" semanticType="String" description="One or more channels. (@2) - channel 2 , (@1,4) - channels 1 and 4, (@1:3) - channels 1 through 3.">
											<ParameterType>
												<Expression>
													<ChannelList />
												</Expression>
											</ParameterType>
										</Parameter>
									</Parameters>
									<Responses>
										<Response name="currLevel" repeat="*" semanticType="Real" description="The programmed current level for the specified channels.">
											<ResponseType>
												<NR3Numeric />
											</ResponseType>
										</Response>
									</Responses>
								</QuerySyntax>
							</QuerySyntaxes>
						</SubsystemCommand>
					</Node>
					<Node aliases="POIN" mnemonic="POINts">
