										</Parameters>
										<Responses>
											<Response name="current" repeat="*" semanticType="Real" description="The programmed current level in the form +1.000000E+01 for each channel specified. Multiple responses are separated by commas.">
												<ResponseType>
													<NR3Numeric />
												</ResponseType>
											</Response>
										</Responses>
									</QuerySyntax>
								</QuerySyntaxes>
							</SubsystemCommand>
						</Node>
					</Node>
					<Node aliases="TRIG" mnemonic="TRIGgered">
						<Node aliases="AMPL" default="true" mnemonic="AMPLitude">
							<SubsystemCommand>
								<Synopsis>This command sets the triggered current level of the specified output channel. Units are in amperes. The triggered level is a stored value that is transferred to the output when an output Step is triggered. 

</Synopsis>
								<HelpLinks>
									<HelpLink name="[SOURce:]CURRent[:LEVel]:TRIGgered[:AMPLitude]" url="SOURce_Subsystem\_SOURce__CURRent__LEVel__TRIGgered.htm" />
								</HelpLinks>
								<CommandSyntaxes>
									<CommandSyntax>
										<Parameters>
											<Parameter name="current" semanticType="Real" description="0 - maximum | MIN | MAX. The maximum value is dependent on the current rating of the power module.">
												<ParameterType>
													<DecimalNumeric>
														<Suffix>
															<CustomSuffix default="true" unit="A" />
														</Suffix>
													</DecimalNumeric>
													<NonDecimalNumeric />
													<Character>
														<EnumRef name="psu_std_num_enums" />
													</Character>
												</ParameterType>
											</Parameter>
											<Parameter name="chanlist" semanticType="String" description="One or more channels. (@2) - channel 2 , (@1,4) - channels 1 and 4, (@1:3) - channels 1 through 3.">
												<ParameterType>
													<Expression>
														<ChannelList />
													</Expression>
												</ParameterType>
											</Parameter>
										</Parameters>
									</CommandSyntax>
								</CommandSyntaxes>
								<QuerySyntaxes>
									<QuerySyntax>
										<Parameters>
											<Parameter name="minMax" optional="true" semanticType="String" description="MIN|MAX">
												<ParameterType>
													<Character>
														<EnumRef name="psu_std_num_enums" />
													</Character>
												</ParameterType>
											</Parameter>
											<Parameter name="chanlist" semanticType="String" description="One or more channels. (@2) - channel 2 , (@1,4) - channels 1 and 4, (@1:3) - channels 1 through 3.">
												<ParameterType>
													<Expression>
														<ChannelList />
													</Expression>
												</ParameterType>
											</Parameter>
										</Parameters>
										<Responses>
											<Response name="trigLevel" repeat="*" semanticType="Real" description="The programmed triggered level in the form +1.000000E+01 for each channel specified.">
												<ResponseType>
													<NR3Numeric />
												</ResponseType>
											</Response>
										</Responses>
									</QuerySyntax>
								</QuerySyntaxes>
							</SubsystemCommand>
						</Node>
					</Node>
				</Node>
				<Node mnemonic="MODE">
					<SubsystemCommand>
						<Synopsis>This command determines what happens to the output current when the transient system is initiated and triggered.</Synopsis>
						<HelpLinks>
							<HelpLink name="[SOURce:]CURRent:MODE" url="SOURce_Subsystem\_SOURce__CURRent_MODE.htm" />
						</HelpLinks>
