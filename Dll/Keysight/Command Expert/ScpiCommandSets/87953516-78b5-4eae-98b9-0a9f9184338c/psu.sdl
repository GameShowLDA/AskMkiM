											<ResponseType>
												<NR1Numeric>
													<EnumRef name="psu_boolean" />
												</NR1Numeric>
											</ResponseType>
										</Response>
									</Responses>
								</QuerySyntax>
							</QuerySyntaxes>
						</SubsystemCommand>
					</Node>
				</Node>
				<Node aliases="TOUT" mnemonic="TOUTput">
					<Node aliases="BOST" mnemonic="BOSTep">
						<Node default="true" mnemonic="DATA">
							<SubsystemCommand>
								<Synopsis>This command specifies which list steps generate a trigger-out signal at the beginning of the list step (BOSTep). A comma-delimited list of up to 512 steps may be programmed. The state is either ON (1) or OFF (0).</Synopsis>
								<HelpLinks>
									<HelpLink name="[SOURce:]LIST:TOUTput:BOSTep[:DATA]" url="SOURce_Subsystem\_SOURce__LIST_TOUTput_BOSTep__DATA_.htm" />
								</HelpLinks>
								<CommandSyntaxes>
									<CommandSyntax>
										<Parameters>
											<Parameter name="Bool" repeat="*" semanticType="Boolean" description="OFF | 0 | ON | 1">
												<ParameterType>
													<DecimalNumeric>
														<EnumRef name="psu_boolean" />
													</DecimalNumeric>
													<Character>
														<EnumRef name="psu_boolean" />
													</Character>
												</ParameterType>
											</Parameter>
											<Parameter name="chanlist" semanticType="String" description="One or more channels. (@2) - channel 2 , (@1,4) - channels 1 and 4, (@1:3) - channels 1 through 3.">
												<ParameterType>
													<Expression>
														<ChannelList />
													</Expression>
												</ParameterType>
											</Parameter>
										</Parameters>
									</CommandSyntax>
								</CommandSyntaxes>
								<QuerySyntaxes>
									<QuerySyntax>
										<Parameters>
											<Parameter name="chanlist" semanticType="String" description="One or more channels. (@2) - channel 2 , (@1,4) - channels 1 and 4, (@1:3) - channels 1 through 3.">
												<ParameterType>
