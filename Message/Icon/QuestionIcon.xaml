<UserControl x:Class="Message.Icon.QuestionIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Message.Icon"
             mc:Ignorable="d" 
             Width="{Binding Size, ElementName=root}"
             Height="{Binding Size, ElementName=root}">
    <Grid>
        <!-- Фон круга -->
        <Ellipse Fill="{Binding CircleColor, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

        <!-- Вопросительный знак -->
        <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Canvas Width="100" Height="100">
                <!-- Верхняя дуга "?" -->
                <Path Stroke="{Binding IconStrokeColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      StrokeThickness="10"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Fill="Transparent"
                      Data="M30,30 
                            C30,15 70,15 70,35 
                            C70,50 50,50 50,65"/>

                <!-- Точка под знаком -->
                <Ellipse Width="12" Height="12" Canvas.Left="44" Canvas.Top="75"
                         Fill="{Binding IconStrokeColor, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </Canvas>
        </Viewbox>
    </Grid>
</UserControl>
