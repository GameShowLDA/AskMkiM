<Window x:Class="MainWindowProgram.Windows.OpkToPkConversionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Конвертация OPK в PK"
        Width="760"
        Height="500"
        MinWidth="760"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrushes}"
        Foreground="{DynamicResource ForegrounfBrushes}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Выберите один или несколько файлов OPK и папку, в которую нужно сохранить результаты конвертации."
                   TextWrapping="Wrap"
                   FontSize="15"
                   Margin="0,0,0,16" />

        <TextBlock Grid.Row="1"
                   Text="Папка для сохранения PK"
                   Margin="0,0,0,8"
                   FontWeight="SemiBold" />

        <Grid Grid.Row="2"
              Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="OutputDirectoryTextBox"
                     Grid.Column="0"
                     MinHeight="34"
                     VerticalContentAlignment="Center"
                     TextChanged="OutputDirectoryTextBox_TextChanged" />

            <Button Grid.Column="1"
                    Margin="12,0,0,0"
                    MinWidth="150"
                    Height="34"
                    Content="Выбрать папку"
                    Click="SelectOutputDirectoryButton_Click" />
        </Grid>

        <GroupBox Grid.Row="3"
                  Header="Файлы OPK">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0"
                           Margin="0,0,0,10">
                    <TextBlock x:Name="SelectedFilesSummaryTextBlock"
                               VerticalAlignment="Center"
                               Text="Файлы не выбраны." />

                    <StackPanel Orientation="Horizontal"
                                DockPanel.Dock="Right">
                        <Button MinWidth="140"
                                Height="34"
                                Margin="12,0,0,0"
                                Content="Выбрать файлы"
                                Click="SelectFilesButton_Click" />
                        <Button MinWidth="140"
                                Height="34"
                                Margin="12,0,0,0"
                                Content="Очистить список"
                                Click="ClearFilesButton_Click" />
                    </StackPanel>
                </DockPanel>

                <ListBox x:Name="SelectedFilesListBox"
                         Grid.Row="1"
                         HorizontalContentAlignment="Stretch" />
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button MinWidth="120"
                    Height="36"
                    Content="Отмена"
                    IsCancel="True" />
            <Button x:Name="ConvertButton"
                    MinWidth="180"
                    Height="36"
                    Margin="12,0,0,0"
                    Content="Конвертировать"
                    IsDefault="True"
                    Click="ConvertButton_Click" />
        </StackPanel>
    </Grid>
</Window>
