<Window x:Class="MainWindowProgram.Windows.RunAskMkiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выполнение АСК-МКИ OLD"
        Width="830"
        Height="530"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Foreground" Value="#E7EDF6"/>
            <Setter Property="Background" Value="#2D4772"/>
            <Setter Property="BorderBrush" Value="#5F84C2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#385989"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#7397D5"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#243C62"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#8F98A6"/>
                                <Setter TargetName="Root" Property="Background" Value="#25303D"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3C4654"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#202A36"/>
            <Setter Property="BorderBrush" Value="#3D4B5E"/>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#245A3B"/>
            <Setter Property="BorderBrush" Value="#4A9365"/>
            <Setter Property="Foreground" Value="#CFE8D5"/>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#E7EDF6"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A344F"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#4A3D5F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PathTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="60"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#DDE6F3"/>
            <Setter Property="Background" Value="#202A36"/>
            <Setter Property="BorderBrush" Value="#3F5065"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}"
                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="#202832"
          BorderBrush="#3A4658"
          BorderThickness="1"
          CornerRadius="14"
          SnapsToDevicePixels="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="82"/>
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0"
              Background="#29263D"
              BorderBrush="#3A4658"
              BorderThickness="0,0,0,1"
              CornerRadius="14,14,0,0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid>
                    <TextBlock Text="Выполнение АСК-МКИ OLD"
                     Foreground="#E7EDF6"
                     FontSize="18"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center"
                     Margin="22,0,0,0"/>

                    <Button Content="×"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Margin="0,0,14,0"
                  Style="{StaticResource CloseButtonStyle}"
                  Click="CancelButton_Click"/>
                </Grid>
            </Border>

            <!-- Контент -->
            <Grid Grid.Row="1"
            Margin="24,24,24,0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>



                <!-- Блок mkiw.exe -->
                <Border Grid.Row="1"
                Background="#26313E"
                BorderBrush="#3F5065"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18" Margin="0,0,0,18" Grid.RowSpan="3">

                    <StackPanel>
                        <TextBlock Text="Исполняемый файл старой программы"
                       Foreground="#E7EDF6"
                       FontSize="16"
                       FontWeight="SemiBold"/>

                        <TextBlock Text="Выберите файл mkiw.exe"
                       Foreground="#AEB8C7"
                       FontSize="14"
                       Margin="0,6,0,14"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="158"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="MkiPathTextBox"
                       Grid.Column="0"
                       Style="{StaticResource PathTextBoxStyle}"/>

                            <Button Grid.Column="2"
                      Content="Выбрать"
                      Style="{StaticResource BaseButtonStyle}"
                      Click="SelectMkiButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Блок программы контроля -->
                <Border Grid.Row="4"
                Background="#26313E"
                BorderBrush="#3F5065"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18">

                    <StackPanel>
                        <TextBlock Text="Программа контроля"
                       Foreground="#E7EDF6"
                       FontSize="16"
                       FontWeight="SemiBold"/>

                        <TextBlock Text="Выберите файл *.acs или *.pk, который нужно выполнить"
                       Foreground="#AEB8C7"
                       FontSize="14"
                       Margin="0,6,0,14"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="158"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="ProgramPathTextBox"
                       Grid.Column="0"
                       Style="{StaticResource PathTextBoxStyle}"/>

                            <Button Grid.Column="2"
                      Content="Выбрать"
                      Style="{StaticResource BaseButtonStyle}"
                      Click="SelectProgramButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Низ -->
            <Border Grid.Row="2"
              Background="#202832"
              BorderBrush="#303B49"
              BorderThickness="0,1,0,0"
              CornerRadius="0,0,14,14" Margin="0,0,0,10">

                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,24,0">

                    <Button Content="Отмена"
                  Style="{StaticResource SecondaryButtonStyle}"
                  MinWidth="132"
                  Margin="0,0,12,0"
                  Click="CancelButton_Click"/>

                    <Button x:Name="RunButton"
                  Content="Запустить"
                  Style="{StaticResource SuccessButtonStyle}"
                  MinWidth="160"
                  IsEnabled="False"
                  Click="RunButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>