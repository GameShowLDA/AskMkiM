<Window x:Class="MainWindowProgram.RoleLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в АСК-МКИ-М"
        ShowActivated="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#16202A">

    <Window.Resources>
        <Style x:Key="PlainButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#223040"/>
            <Setter Property="BorderBrush" Value="#4C6177"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2B3B4D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#182430"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlainComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#18202A"/>
            <Setter Property="BorderBrush" Value="#4C6177"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style x:Key="PlainPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#18202A"/>
            <Setter Property="BorderBrush" Value="#4C6177"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#16202A" Offset="0"/>
                <GradientStop Color="#243241" Offset="0.55"/>
                <GradientStop Color="#101820" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="560"
                Padding="36"
                CornerRadius="22"
                Background="#CC2A3440"
                BorderBrush="#556B82"
                BorderThickness="1">
            <Grid>
                <Grid x:Name="LoginPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Image Grid.Row="0"
                           Source="/Resources/logo.png"
                           Width="88"
                           Height="88"
                           Margin="0,0,0,18"
                           HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="1"
                               Text="Вход в систему"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="2"
                               Margin="0,10,0,26"
                               Text="Выберите роль и введите пароль"
                               FontSize="16"
                               Foreground="#C2CEDA"
                               HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="3"
                               Text="Роль"
                               Margin="0,0,0,8"
                               FontSize="16"
                               Foreground="#DCE6F0"/>

                    <ComboBox x:Name="RolesComboBox"
                              Grid.Row="4"
                              Style="{StaticResource PlainComboBoxStyle}"
                              Height="42"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="RolesComboBox_SelectionChanged"/>

                    <StackPanel Grid.Row="5"
                                Margin="0,20,0,0">
                        <TextBlock Text="Пароль"
                                   Margin="0,0,0,8"
                                   FontSize="16"
                                   Foreground="#DCE6F0"/>

                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource PlainPasswordBoxStyle}"
                                     Height="42"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>
                    </StackPanel>

                    <TextBlock x:Name="StatusTextBlock"
                               Grid.Row="6"
                               Margin="0,18,0,0"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#FF9A9A"/>

                    <Grid Grid.Row="7"
                          Margin="0,26,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="CancelButton"
                                Grid.Column="0"
                                Style="{StaticResource PlainButtonStyle}"
                                Height="42"
                                Content="Выход"
                                IsCancel="True"
                                Click="CancelButton_Click"/>

                        <Button x:Name="LoginButton"
                                Grid.Column="2"
                                Style="{StaticResource PlainButtonStyle}"
                                Height="42"
                                Content="Войти"
                                IsDefault="True"
                                Click="LoginButton_Click"/>
                    </Grid>
                </Grid>

                <Grid x:Name="LoadingPanel"
                      Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="340">
                        <Grid Width="104"
                              Height="104"
                              Margin="0,0,0,24"
                              HorizontalAlignment="Center">
                            <Ellipse Stroke="#365064"
                                     StrokeThickness="8"
                                     Opacity="0.35"/>

                            <Path Stroke="#8AD8FF"
                                  StrokeThickness="8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M 52,8 A 44,44 0 0 1 96,52">
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRotateTransform"
                                                     CenterX="52"
                                                     CenterY="52"/>
                                </Path.RenderTransform>
                                <Path.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="SpinnerRotateTransform"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0"
                                                                 To="360"
                                                                 Duration="0:0:1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Path.Triggers>
                            </Path>
                        </Grid>

                        <TextBlock Text="Подготовка рабочего места"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>

                        <TextBlock x:Name="LoadingStatusTextBlock"
                                   Margin="0,14,0,0"
                                   FontSize="13"
                                   Foreground="#C2CEDA"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="Загрузка модулей приложения..."/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
