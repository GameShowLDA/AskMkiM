<Window x:Class="MainWindowProgram.RoleLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в АСК-МКИ-М"
        ShowActivated="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0E141B">

    <Window.Resources>
        <SolidColorBrush x:Key="LoginForegroundBrush" Color="#F3F5F8"/>
        <SolidColorBrush x:Key="LoginMutedForegroundBrush" Color="#ADB4C0"/>
        <SolidColorBrush x:Key="LoginWeakForegroundBrush" Color="#7A8492"/>
        <SolidColorBrush x:Key="LoginAccentBrush" Color="#3F86FF"/>
        <SolidColorBrush x:Key="LoginInputBackgroundBrush" Color="#180A1322"/>
        <SolidColorBrush x:Key="LoginInputForegroundBrush" Color="#F0F2F7"/>
        <SolidColorBrush x:Key="LoginInputHintBrush" Color="#8D98AA"/>
        <SolidColorBrush x:Key="LoginInputBorderBrush" Color="#8A6FA6FF"/>
        <SolidColorBrush x:Key="LoginButtonBackgroundBrush" Color="#26305278"/>
        <SolidColorBrush x:Key="LoginButtonForegroundBrush" Color="#EEF4FF"/>
        <SolidColorBrush x:Key="LoginButtonHoverBrush" Color="#263A78C8"/>
        <SolidColorBrush x:Key="LoginButtonDisabledBrush" Color="#18213444"/>
        <SolidColorBrush x:Key="LoginStatusErrorBrush" Color="#F28F8F"/>
        <SolidColorBrush x:Key="LoginOverlayBrush" Color="#C00B1016"/>
        <SolidColorBrush x:Key="LoginSpinnerTrackBrush" Color="#4F596B"/>
        <SolidColorBrush x:Key="LoginSpinnerAccentBrush" Color="#D7DEE9"/>

        <Style x:Key="GhostCloseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource LoginMutedForegroundBrush}"/>
            <Setter Property="Background" Value="#10081320"/>
            <Setter Property="BorderBrush" Value="#38586C92"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="23">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#183F86FF"/>
                                <Setter Property="Foreground" Value="{StaticResource LoginForegroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoleListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource LoginForegroundBrush}"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <ItemsPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoleListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemRoot"
                                Background="Transparent"
                                CornerRadius="16"
                                Padding="4,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemRoot" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemRoot" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="{StaticResource LoginInputForegroundBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="PasswordChar" Value="●"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="0"
                                      Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginVisiblePasswordTextBoxStyle" TargetType="TextBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="{StaticResource LoginInputForegroundBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PasswordAuxButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource LoginForegroundBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#143F86FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#243F86FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KeyboardLayoutButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PasswordAuxButtonStyle}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource LoginButtonForegroundBrush}"/>
            <Setter Property="Background" Value="{StaticResource LoginButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="#7A4B86FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="25">
                            <Border.Effect>
                                <DropShadowEffect Color="#3F86FF"
                                                  BlurRadius="14"
                                                  ShadowDepth="0"
                                                  Opacity="0.42"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource LoginButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.92"/>
                                <Setter Property="Background" Value="#304B86FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#647086"/>
                                <Setter Property="Background" Value="{StaticResource LoginButtonDisabledBrush}"/>
                                <Setter Property="BorderBrush" Value="#22344C66"/>
                                <Setter Property="Opacity" Value="0.52"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.62,0.48"
                                 GradientOrigin="0.62,0.48"
                                 RadiusX="0.74"
                                 RadiusY="0.86">
                <GradientStop Color="#16213A" Offset="0"/>
                <GradientStop Color="#0B1224" Offset="0.42"/>
                <GradientStop Color="#050914" Offset="0.78"/>
                <GradientStop Color="#03060D" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <Image Source="pack://application:,,,/Ask.UI;component/Resources/Assets/Image/Authorization/login_background.png"
               Stretch="UniformToFill"
               IsHitTestVisible="False"/>

        <Rectangle Fill="#4A03060D"
                   IsHitTestVisible="False"/>

        <Button x:Name="CancelButton"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,28,28,0"
                Style="{StaticResource GhostCloseButtonStyle}"
                Content="✕"
                IsCancel="True"
                Click="CancelButton_Click"/>

        <Grid Margin="48,40,72,56">
            <Grid Width="320"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Bottom"
                  Margin="0,0,0,28">
                <Border Padding="20,18,20,10"
                        Background="#24081322"
                        BorderBrush="#6A6FA6FF"
                        BorderThickness="1.2"
                        CornerRadius="24">
                    <Border.Effect>
                        <DropShadowEffect Color="#3F86FF"
                                          BlurRadius="22"
                                          ShadowDepth="0"
                                          Opacity="0.28"/>
                    </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Выбор учётной записи"
                               Margin="0,0,0,16"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LoginMutedForegroundBrush}"/>

                    <ListBox x:Name="RolesListBox"
                             Style="{StaticResource RoleListStyle}"
                             ItemContainerStyle="{StaticResource RoleListItemStyle}"
                             SelectionChanged="RolesListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="22"
                                            Height="22"
                                            VerticalAlignment="Center"
                                            Background="Transparent">
                                        <TextBlock x:Name="RoleGlyph"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="16"
                                                   Text="&#xE77B;"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource LoginForegroundBrush}"/>
                                    </Border>

                                    <TextBlock x:Name="RoleText"
                                               Grid.Column="1"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               Text="{Binding DisplayName}"
                                               Foreground="{StaticResource LoginForegroundBrush}"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="RoleGlyph" Property="Foreground" Value="{StaticResource LoginAccentBrush}"/>
                                        <Setter TargetName="RoleText" Property="Foreground" Value="{StaticResource LoginAccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="False">
                                        <Setter TargetName="RoleText" Property="Opacity" Value="0.94"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
                </Border>
            </Grid>

            <Grid>
                <Grid x:Name="LoginPanel"
                      Width="620"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Border Width="580"
                            Padding="30,34,30,32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#30081322"
                            BorderBrush="#A66FA6FF"
                            BorderThickness="1.6"
                            CornerRadius="34">
                        <Border.Effect>
                            <DropShadowEffect Color="#4B86FF"
                                              BlurRadius="32"
                                              ShadowDepth="0"
                                              Opacity="0.42"/>
                        </Border.Effect>

                    <StackPanel>
                        <Border Width="94"
                                Height="94"
                                Margin="0,0,0,18"
                                HorizontalAlignment="Center"
                                Background="#0EFFFFFF"
                                BorderBrush="#586A89"
                                BorderThickness="1"
                                CornerRadius="47">
                            <Border.Effect>
                                <DropShadowEffect Color="#1F335B"
                                                  BlurRadius="18"
                                                  ShadowDepth="0"
                                                  Opacity="0.45"/>
                            </Border.Effect>
                            <Grid>
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           FontSize="46"
                                           Text="&#xE77B;"
                                           Foreground="#EEF4FF"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="SelectedRoleNameTextBlock"
                                   Margin="0,0,0,30"
                                   HorizontalAlignment="Center"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LoginForegroundBrush}"
                                   Text="Выберите роль"/>

                        <Grid Width="520"
                              HorizontalAlignment="Center">

                            <Border Width="380"
                                    Height="52"
                                    HorizontalAlignment="Center"
                                    Background="{StaticResource LoginInputBackgroundBrush}"
                                    BorderBrush="{StaticResource LoginInputBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="26">
                                <Border.Effect>
                                    <DropShadowEffect Color="#163F86FF"
                                                      BlurRadius="12"
                                                      ShadowDepth="0"
                                                      Opacity="0.35"/>
                                </Border.Effect>
                            <Grid Margin="16,0,16,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="42"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="54"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="22"
                                           Text="&#xE72E;"
                                           Foreground="#E4ECFF"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <Border Grid.Column="1"
                                        Width="1"
                                        Height="26"
                                        VerticalAlignment="Center"
                                        Background="#28415466"/>

                                <PasswordBox x:Name="PasswordBox"
                                             Grid.Column="2"
                                             Margin="18,0,0,0"
                                             VerticalContentAlignment="Center"
                                             Style="{StaticResource LoginPasswordBoxStyle}"
                                             GotFocus="PasswordBox_GotFocus"
                                             LostFocus="PasswordBox_LostFocus"
                                             PasswordChanged="PasswordBox_PasswordChanged"/>

                                <TextBox x:Name="VisiblePasswordTextBox"
                                         Grid.Column="2"
                                         Margin="18,0,0,0"
                                         Visibility="Collapsed"
                                         Style="{StaticResource LoginVisiblePasswordTextBoxStyle}"
                                         GotFocus="VisiblePasswordTextBox_GotFocus"
                                         LostFocus="VisiblePasswordTextBox_LostFocus"
                                         TextChanged="VisiblePasswordTextBox_TextChanged"/>

                                <TextBlock x:Name="PasswordPlaceholderTextBlock"
                                           Grid.Column="2"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           Foreground="{StaticResource LoginInputHintBrush}"
                                           Text="Пароль"
                                           IsHitTestVisible="False"/>

                                <Button x:Name="TogglePasswordVisibilityButton"
                                        Grid.Column="3"
                                        Style="{StaticResource PasswordAuxButtonStyle}"
                                        ToolTip="Показать пароль"
                                        Click="TogglePasswordVisibilityButton_Click"
                                        Content="&#xE890;"/>

                                <Border Grid.Column="4"
                                        Width="1"
                                        Height="26"
                                        VerticalAlignment="Center"
                                        Background="#28415466"/>

                                <Button x:Name="KeyboardLayoutButton"
                                        Grid.Column="5"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource KeyboardLayoutButtonStyle}"
                                        Click="KeyboardLayoutButton_Click">
                                    <TextBlock x:Name="KeyboardLayoutTextBlock"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI"
                                               FontSize="16"
                                               FontWeight="Normal"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               Text="RU"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Button x:Name="LoginButton"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Style="{StaticResource LoginButtonStyle}"
                                Content="&#x2192;"
                                IsDefault="True"
                                Click="LoginButton_Click"/>
                        </Grid>

                        <TextBlock x:Name="CapsLockWarningTextBlock"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="12"
                                   Foreground="#F4D568"
                                   Visibility="Collapsed"
                                   Text="Caps Lock включён"/>

                        <TextBlock x:Name="StatusTextBlock"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="13"
                                   Foreground="{StaticResource LoginStatusErrorBrush}"/>
                    </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="LoadingPanel"
                      Visibility="Collapsed">
                    <Border Background="{StaticResource LoginOverlayBrush}"
                            CornerRadius="28"
                            Width="400"
                            Height="260"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Grid Width="92"
                                  Height="92"
                                  Margin="0,12,0,22"
                                  HorizontalAlignment="Center">
                                <Ellipse Stroke="{StaticResource LoginSpinnerTrackBrush}"
                                         StrokeThickness="7"
                                         Opacity="0.35"/>

                                <Path Stroke="{StaticResource LoginSpinnerAccentBrush}"
                                      StrokeThickness="7"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M 46,8 A 38,38 0 0 1 84,46">
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotateTransform"
                                                         CenterX="46"
                                                         CenterY="46"/>
                                    </Path.RenderTransform>
                                    <Path.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotateTransform"
                                                                     Storyboard.TargetProperty="Angle"
                                                                     From="0"
                                                                     To="360"
                                                                     Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Path.Triggers>
                                </Path>
                            </Grid>

                            <TextBlock Text="Подготовка рабочего места"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LoginForegroundBrush}"
                                       HorizontalAlignment="Center"/>

                            <TextBlock x:Name="LoadingStatusTextBlock"
                                       Margin="0,14,0,0"
                                       Width="280"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       FontSize="14"
                                       Foreground="{StaticResource LoginMutedForegroundBrush}"
                                       Text="Загрузка модулей приложения..."/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
