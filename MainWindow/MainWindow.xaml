<Window x:Class="MainWindowProgram.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MainWindowProgram"
        
        xmlns:DefaultGUI="clr-namespace:UI.Components;assembly=UI" 
        xmlns:TextEditorControl ="clr-namespace:UI.Controls.TextEditor;assembly=UI"
        xmlns:Controls ="clr-namespace:UI.Controls;assembly=UI"
        xmlns:Components ="clr-namespace:UI.Components;assembly=UI"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"

        mc:Ignorable="d"
        Title="ASK MKI M" 
        Height="600" Width="800"
        WindowStyle="None"
        Padding="3"
        MinWidth="800"
        MinHeight="600"
        WindowState="Maximized"
        
        Name="MainWinApp"
        >
    <Window.Resources>

        <Style TargetType="DefaultGUI:WindowButtons">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource ActiveForegroundSolidColorBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type MenuItem}">

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid SnapsToDevicePixels="true">
                            <DockPanel x:Name="ItemDockPanel" Background="Transparent">
                                <ContentPresenter x:Name="Icon" ContentSource="Icon" Margin="4,0,6,0" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                                <Path x:Name="GlyphPanel" Fill="{TemplateBinding Foreground}" FlowDirection="LeftToRight" Margin="7,0,0,0" Visibility="Collapsed" VerticalAlignment="Center"/>
                                <TextBlock x:Name="HeaderText" Text="{TemplateBinding Header}" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>

                                <!-- Добавляем TextBlock для отображения горячей клавиши -->
                                <TextBlock x:Name="HotkeyText" Text="{Binding InputGestureText, RelativeSource={RelativeSource TemplatedParent}}" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="10,0,0,0"/>

                            </DockPanel>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" Focusable="false" HorizontalOffset="1" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}" Placement="Bottom" VerticalOffset="-1">
                                <Border Background="{TemplateBinding Background}">
                                    <ScrollViewer x:Name="SubMenuScrollViewer" CanContentScroll="true" Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                        <Grid RenderOptions.ClearTypeHint="Enabled">
                                            <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Cycle" Grid.IsSharedSizeScope="true" Margin="2" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" KeyboardNavigation.TabNavigation="Cycle"/>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ActiveForegroundSolidColorBrush}" TargetName="ItemDockPanel"/>
                                <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}" TargetName="HeaderText"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="Background" Value="{StaticResource ActiveForegroundSolidColorBrush}" TargetName="ItemDockPanel"/>
                                <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}" TargetName="HeaderText"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,10,10,10"/>
            <Setter Property="Background" Value="{StaticResource SecondarySolidColorBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource WinstonLight}"/>
            <Setter Property="Cursor" Value="Hand"/>

        </Style>

        <Style x:Key="SideMenuItemStyle" TargetType="{x:Type MenuItem}" BasedOn="{StaticResource {x:Type MenuItem}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid SnapsToDevicePixels="true">
                            <DockPanel x:Name="ItemDockPanel" Background="Transparent">
                                <ContentPresenter x:Name="Icon" ContentSource="Icon" Margin="4,0,6,0" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                                <Path x:Name="GlyphPanel" Fill="{TemplateBinding Foreground}" FlowDirection="LeftToRight" Margin="7,0,0,0" Visibility="Collapsed" VerticalAlignment="Center"/>
                                <TextBlock x:Name="HeaderText" Text="{TemplateBinding Header}" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                <TextBlock x:Name="HotkeyText" Text="{Binding InputGestureText, RelativeSource={RelativeSource TemplatedParent}}" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="10,0,0,0"/>
                            </DockPanel>
                            <Popup x:Name="PART_Popup"
                           AllowsTransparency="true"
                           Focusable="false"
                           HorizontalOffset="0"
                           VerticalOffset="0"
                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                           Placement="Right"
                           PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}">
                                <Border Background="{TemplateBinding Background}">
                                    <ScrollViewer x:Name="SubMenuScrollViewer"
                                          CanContentScroll="true"
                                          Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                        <Grid RenderOptions.ClearTypeHint="Enabled">
                                            <ItemsPresenter x:Name="ItemsPresenter"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle"
                                                    Grid.IsSharedSizeScope="true"
                                                    Margin="2"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                    KeyboardNavigation.TabNavigation="Cycle"/>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ActiveForegroundSolidColorBrush}" TargetName="ItemDockPanel"/>
                                <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}" TargetName="HeaderText"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="Background" Value="{StaticResource ActiveForegroundSolidColorBrush}" TargetName="ItemDockPanel"/>
                                <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}" TargetName="HeaderText"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="SizeChanged">
            <i:InvokeCommandAction Command="{Binding Window.AdjustCommand}" />
        </i:EventTrigger>

        <i:EventTrigger EventName="Closing">
            <i:InvokeCommandAction 
                Command="{Binding Window.ClosingCommand}" 
                PassEventArgsToCommand="True" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="TopPanel" Background="{StaticResource SecondarySolidColorBrush}" Cursor="SizeAll">

            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseLeftButtonDown">
                    <i:InvokeCommandAction Command="{Binding Window.DragMoveCommand}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="50"/>
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Menu Name="mainMenu" VerticalAlignment="Top" VerticalContentAlignment="Center" FontSize="16" Background="Transparent" 
                Foreground="{StaticResource ForegroundSolidColorBrush}" Grid.Column="0" BorderThickness="0">

                <MenuItem 
                   Header="{Binding Source={StaticResource LS_Menu_File}, Path=Value}"
                    Name="File" Uid="1" BorderBrush="#FF303843" OpacityMask="#FF303843" Tag="menuHeader_1">

                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Archive}, Path=Value}" Tag="OpenArchive" Name="ArchiveMenuItem" Command="{Binding File.OpenArchiveCommand}"/>

                    <Separator Background="{StaticResource ActiveBorderSolidColorBrush}" Visibility="Collapsed" x:Name="fileActionsSeparator"/>
                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Save}, Path=Value}" Tag="SaveFile" x:Name="saveMenuItem" Visibility="Collapsed" Command="{Binding File.SaveFileCommand}"/>
                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_SaveAs}, Path=Value}" Tag="SaveFileAs" x:Name="saveAsMenuItem" Visibility="Collapsed" Command="{Binding File.SaveFileAsCommand}"/>
                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_OpenFolder}, Path=Value}" Tag="OpenFolder" x:Name="openFolderMenuItem" Visibility="Collapsed" Command="{Binding File.OpenFolderCommand}"/>
                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Print}, Path=Value}" Tag="PrintFile" x:Name="printMenuItem" Visibility="Collapsed" Command="{Binding File.PrintFileCommand}" />
                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Search}, Path=Value}" Tag="SearchFile" x:Name="searchMenuItem" Visibility="Collapsed" Command="{Binding File.SearchFileCommand}" />

                    <Separator Background="{StaticResource ActiveBorderSolidColorBrush}"/>
                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Open}, Path=Value}" Tag="OpenFile" Command="{Binding File.OpenFileCommand}" />
                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Create}, Path=Value}" Tag="CreateNewFile" Command="{Binding File.CreateNewFileCommand}" />
                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Compare}, Path=Value}" Tag="CompareFile" x:Name="compareMenuItem" Command="{Binding File.CompareFileCommand}" />

                    <Separator Background="{StaticResource ActiveBorderSolidColorBrush}"/>
                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Exit}, Path=Value}" Tag="ExitApplication" Command="{Binding File.ExitApplicationCommand}"/>

                </MenuItem>

                <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test}, Path=Value}" Tag="menuHeader_2" >

                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Metrology}, Path=Value}" Name="Metrology" Style="{StaticResource SideMenuItemStyle}">

                        <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Metrology_KS}, Path=Value}" Name="ModeKSMenuItem" Command="{Binding Metrology.KCCommand}" />
                        <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Metrology_IE}, Path=Value}" Name="ModeIEMenuItem" Command="{Binding Metrology.IECommand}" />
                        <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Metrology_CI}, Path=Value}" Name="ModeCIMenuItem" Command="{Binding Metrology.CICommand}" />
                        <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Metrology_PR}, Path=Value}" Name="ModePrMenuItem" Command="{Binding Metrology.PRCommand}" />

                        <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Metrology_PRT}, Path=Value}" Name="ModePrMenuItemT" Command="{Binding Metrology.PR_TCommand}" />
                        <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Metrology_PIDCW}, Path=Value}" Name="ModePIDCWMenuItem" Command="{Binding Metrology.PIDCWCommand}" />
                        <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Metrology_PIACW}, Path=Value}"  Name="ModePIACWMenuItem" Command="{Binding Metrology.PIACWCommand}" />
                        <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Metrology_KNDCW}, Path=Value}"  Name="ModeKNDCWMenuItem" Command="{Binding Metrology.KNDCWCommand}" />
                        <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Metrology_KNACW}, Path=Value}"  Name="ModeKNACWMenuItem" Command="{Binding Metrology.KNACWCommand}" />

                    </MenuItem>

                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_SelfControl}, Path=Value}"  Name="SelfControl" Tag="menuHeader_3" Style="{StaticResource SideMenuItemStyle}">

                        <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_SelfControl_Module}, Path=Value}"   Name="SelfControlMenuItem" Command="{Binding SelfTest.SelfTestModuleCommand}"/>

                    </MenuItem>

                    <MenuItem   Header="{Binding Source={StaticResource LS_Menu_Test_Tests}, Path=Value}"  Name="TestControl" Tag="menuHeader_4" Style="{StaticResource SideMenuItemStyle}">

                        <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Tests_CI}, Path=Value}"  Style="{StaticResource SideMenuItemStyle}" >

                            <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Tests_CI_Node}, Path=Value}"  Name="NodeMethodMenuItemCI" Command="{Binding Test.CiNodeMethodCommand}" />
                            <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Tests_CI_Group}, Path=Value}"  Name="MethodExecutorMenuItemCI" Command="{Binding Test.CiMethodExecutorCommand}" />

                        </MenuItem>

                        <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Tests_PIDCW}, Path=Value}" Style="{StaticResource SideMenuItemStyle}">

                            <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Tests_PIDCW_Node}, Path=Value}"  Name="NodeMethodMenuItemPiDCW" Command="{Binding Test.PiDCWNodeMethodCommand}" />
                            <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Tests_PIDCW_Group}, Path=Value}"    Command="{Binding Test.PiDCWMethodExecutorCommand}" />

                        </MenuItem>

                        <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Tests_PIACW}, Path=Value}" Style="{StaticResource SideMenuItemStyle}">

                            <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Tests_PIACW_Node}, Path=Value}" Name="NodeMethodMenuItemPiACW" Command="{Binding Test.PiACWNodeMethodCommand}" />
                            <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Tests_PIACW_Group}, Path=Value}"  Name="MethodExecutorMenuItemPiACW" Command="{Binding Test.PiACWMethodExecutorCommand}" />

                        </MenuItem>

                        <MenuItem Header="{Binding Source={StaticResource LS_Menu_Test_Tests_Cross_MKR}, Path=Value}"  Name="CrossTestMkrMenuItem" Command="{Binding Test.CrossTestMkrExecutorCommand}" />

                    </MenuItem>

                </MenuItem>

                <MenuItem Header="{Binding Source={StaticResource LS_Menu_Execution}, Path=Value}" Tag="menuHeader_3" Name="Translation">

                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Execution_Build}, Path=Value}" Tag="Build" Name="Build" Command="{Binding Translation.BuildCommand}"/>
                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Execution_Run}, Path=Value}" Tag="Run" Name="Run" Command="{Binding Translation.RunCommand}"/>

                </MenuItem>

                <MenuItem Header="{Binding Source={StaticResource LS_Menu_Setting}, Path=Value}" Name="Settings" Tag="menuHeader_4">

                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Setting_Config}, Path=Value}" Name="ConfigMenuItem" Command="{Binding Settings.ConfigCommand}"/>
                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Setting_Execution}, Path=Value}" Name="ExecutionMenuItem" Command="{Binding Settings.ExecutionCommand}"/>
                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Setting_Protocol}, Path=Value}" Name="ProtocolMenuItem" Command="{Binding Settings.ProtocolCommand}"/>

                </MenuItem>

                <MenuItem Header="{Binding Source={StaticResource LS_Menu_Help}, Path=Value}" Name="HelpText" Command="{Binding Settings.HelpCommand}">

                </MenuItem>

                <MenuItem Header="{Binding Source={StaticResource LS_Menu_Admin}, Path=Value}" Name="Admin">

                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Admin_Error}, Path=Value}" Name="ErrorMenuItem" Command="{Binding Admin.ErrorCommand}"/>
                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Admin_USB}, Path=Value}" Name="USBMenuItem" Command="{Binding Admin.UsbCommand}"/>
                    
                    <Separator Background="{StaticResource ActiveBorderSolidColorBrush}"/>

                    <MenuItem Header="Console" Name="SendCommandMenuItem" Command="{Binding Admin.SendCommandCommand}"/>
                    <MenuItem Header="Logger" Name="LoggerMenuItem" Command="{Binding Admin.LoggerCommand}"/>

                    <Separator Background="{StaticResource ActiveBorderSolidColorBrush}"/>

                    <MenuItem Header="{Binding Source={StaticResource LS_Menu_Admin_Management}, Path=Value}" Name="DeviceManagment">
                        <MenuItem Header="GPT" Name="GptManagment" Command="{Binding Admin.GptCommand}"/>
                        <MenuItem Header="МеШ" Name="ModuleMeshMenuItem" Command="{Binding Service.ServicesTestMeshCommand}" />
                        <MenuItem Header="МИНТ" Name="ModuleMintMenuItem" Command="{Binding Service.ServicesTestMintCommand}" />
                        <MenuItem Header="МКР" Name="ModuleMkrMenuItem" Command="{Binding Service.ServicesTestMkrCommand}" />
                        <MenuItem Header="УКШ" Name="ModuleUkshMenuItem" Command="{Binding Service.ServicesTestUkshCommand}" />
                    </MenuItem>

                    <MenuItem Header="Тесты ПО">
                        <MenuItem Header="Протокол" Name="ProtocolTest" Command="{Binding Admin.ProtocolCommand}"/>
                        <MenuItem Header="Выбор устройства" Name="ChoiceTest" Command="{Binding Admin.ChoiceCommand}"/>
                        <MenuItem Header="Самоконтроль" Name="SelfTest" Command="{Binding Admin.SelfCommand}"/>
                        <MenuItem Header="Тест консоли" Name="ConsoleTest" Command="{Binding Admin.ConsoleTest}"/>
                    </MenuItem>

                </MenuItem>

            </Menu>

            <StackPanel  
                Background="Transparent" 
                Grid.Column="2">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="MouseLeftButtonDown">
                        <i:InvokeCommandAction Command="{Binding Window.DragMoveCommand}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </StackPanel>

            <StackPanel Name="ButtonsPanel"
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Grid.Column="2" 
                    Background="Transparent"
                    >

                <DefaultGUI:WindowButtons 
                        Width="{Binding ActualHeight, ElementName=mainMenu}" 
                        Height="{Binding ActualHeight, ElementName=mainMenu}" 
                        x:Name="minimizeButton" ChoiceElement="Minimize" 
                        Command="{Binding Window.MinimizeCommand}"
                        />

                <DefaultGUI:WindowButtons 
                        Width="{Binding ActualHeight, ElementName=mainMenu}" 
                        Height="{Binding ActualHeight, ElementName=mainMenu}"
                        x:Name="maximizeButton" ChoiceElement="Maximize" 
                        Command="{Binding Window.MaximizeCommand}"
                        />

                <DefaultGUI:WindowButtons 
                        Width="{Binding ActualHeight, ElementName=mainMenu}" 
                        Height="{Binding ActualHeight, ElementName=mainMenu}"
                        x:Name="exitButton" ChoiceElement="Exit" 
                        Command="{Binding Window.CloseCommand}"
                        />
            </StackPanel>
        </Grid>

        <Components:MultiWindowControl 
            x:Name="MultiWindow" 
            Grid.Row="1" Background="{StaticResource PrimarySolidColorBrush}"
            />

        <Grid 
            Name="BottomPanel"
            Grid.Row="2" 
            Height="30" 
            Background="{StaticResource SecondarySolidColorBrush}"
            >

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <TextBlock 
                x:Name="InfoBlock" 
                VerticalAlignment="Center" 
                Padding="10,0,0,0" 
                FontSize="14" 
                Foreground="{StaticResource ForegroundSolidColorBrush}" 
				/>


            <Controls:StatusBarControl
                Grid.Column="1" 
                x:Name="StatusBar"
                HorizontalAlignment="Right"
                Visibility="Hidden"
                />


            <Controls:DateTimeControl Opacity="0.7"
                x:Name="TimeBlock" 
                Margin="0,0,10,0" 
                FontSize="13" 
                Foreground="{StaticResource ForegroundSolidColorBrush}" 
                Grid.Column="3" 
                Cursor="Hand"
				/>

            <Components:KeyboardLayoutComponent Opacity="0.7"
                x:Name="LanguageBlock" 
                VerticalAlignment="Center" 
                FontSize="15" 
                Foreground="{StaticResource ForegroundSolidColorBrush}" 
                Grid.Column="2" 
				/>

            <DefaultGUI:PowerButton
                Grid.Column="4" 
                Width="200"
                Name="PowerButton"
                />
        </Grid>
    </Grid>
</Window>
