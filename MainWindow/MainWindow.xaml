<Window x:Class="MainWindowProgram.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MainWindowProgram"
        
        xmlns:DefaultGUI="clr-namespace:UI.Components;assembly=UI" 
        xmlns:TextEditorControl ="clr-namespace:UI.Controls.TextEditor;assembly=UI"
        xmlns:Components ="clr-namespace:UI.Components;assembly=UI"
        
        mc:Ignorable="d"
        Title="ASK MKI M" 
        Height="600" Width="800"
        WindowStyle="None"
        Padding="3"
        MinWidth="800"
        MinHeight="600"
        WindowState="Maximized"
        >
    <Window.Resources>

        <Style TargetType="DefaultGUI:WindowButtons">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource ActiveForegroundSolidColorBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid SnapsToDevicePixels="true">
                            <DockPanel x:Name="ItemDockPanel" Background="Transparent">
                                <ContentPresenter x:Name="Icon" ContentSource="Icon" Margin="4,0,6,0" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                                <Path x:Name="GlyphPanel" Fill="{TemplateBinding Foreground}" FlowDirection="LeftToRight" Margin="7,0,0,0" Visibility="Collapsed" VerticalAlignment="Center"/>
                                <TextBlock x:Name="HeaderText" Text="{TemplateBinding Header}" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </DockPanel>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" Focusable="false" HorizontalOffset="1" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}" Placement="Bottom" VerticalOffset="-1">
                                <Border Background="{TemplateBinding Background}">
                                    <ScrollViewer x:Name="SubMenuScrollViewer" CanContentScroll="true" Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                        <Grid RenderOptions.ClearTypeHint="Enabled">
                                            <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Cycle" Grid.IsSharedSizeScope="true" Margin="2" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" KeyboardNavigation.TabNavigation="Cycle"/>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ActiveForegroundSolidColorBrush}" TargetName="ItemDockPanel"/>
                                <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}" TargetName="HeaderText"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="Background" Value="{StaticResource ActiveForegroundSolidColorBrush}" TargetName="ItemDockPanel"/>
                                <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}" TargetName="HeaderText"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,10,10,10"/>
            <Setter Property="Background" Value="{StaticResource SecondarySolidColorBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}"/>
        </Style>

    </Window.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="TopPanel" Background="{StaticResource SecondarySolidColorBrush}" MouseLeftButtonDown="TopPanel_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="50"/>
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Menu 
                Name="mainMenu" 
                VerticalAlignment="Top" 
                VerticalContentAlignment="Center" 
                Height="40" 
                FontSize="15" 
                Background="{StaticResource SecondarySolidColorBrush}" 
                Foreground="{StaticResource ForegroundSolidColorBrush}" 
                Grid.Column="0" BorderThickness="0"
                Padding="0,0,40,0"
                >

                <MenuItem 
                    Header="Файл" 
                    Name="File"
                    Cursor="Hand" 
                    BorderBrush="#FF303843" 
                    OpacityMask="#FF303843"
                    >

                    <MenuItem 
                        Header="Открыть" 
                        Name="OpenMenuItem"
                        PreviewMouseDown="Open_PreviewMouseDownAsync"
                        />

                    <MenuItem 
                        Header="Создать" 
                        Name="CreateMenuItem"
                        PreviewMouseDown="Create_PreviewMouseDownAsync"
                        />

                    <Separator 
                        Background="{StaticResource ActiveBorderSolidColorBrush}" 
                        />

                    <MenuItem 
                        Header="Выход" 
                        PreviewMouseDown="Exit_Handler" 
                        />

                </MenuItem>

                <MenuItem 
                    Header="Метрология"
                    Name="Metrology"
                    >

                    <MenuItem 
                        Header="Режим КС" 
                         Name="ModeKSMenuItem"
                        PreviewMouseDown="KC_Handler" 
                        />

                    <MenuItem 
                        Header="Режим ИЕ" 
                        Name="ModeIEMenuItem"
                        PreviewMouseDown="IE_Handler" 
                        />

                    <MenuItem 
                        Header="Режим СИ" 
                        Name="ModeCIMenuItem"
                        PreviewMouseDown="CI_Handler" 
                        />


                </MenuItem>

                <MenuItem 
                    Header="Самоконтроль"
                    Name="SelfControl"
                    >

                    <MenuItem 
                        Header="Модуль" 
                        Name="SelfControlMenuItem"
                        PreviewMouseDown="Test_Self" 
                        />

                </MenuItem>

                <MenuItem 
                    Header="Тесты"
                    Name="TestControl"
                    >

                    <MenuItem 
                        Header="Тест СИ" 
                        >

                        <MenuItem Header="Метод узла"
                                  Name="NodeMethodMenuItem"
                                  PreviewMouseDown="NodeMethodControl_PreviewMouseDown"
                                  />

                    </MenuItem>

                </MenuItem>

                <MenuItem 
                    Header="Настройки"
                    Name="Settings"
                    >

                    <MenuItem 
                        Header="Конфигурация" 
                        Name="ConfigMenuItem"
                        PreviewMouseDown="Config_Handler" 
                        />

                    <MenuItem 
                        Header="Выполнение" 
                        Name="ExecutionMenuItem"
                        PreviewMouseDown="Execution_Handler"
                        />

                    <MenuItem 
                        Header="Протокол" 
                        Name="ProtocolMenuItem"
                        PreviewMouseDown="Protocol_Handler"
                        />

                    <MenuItem 
                        Header="Погрешности" 
                        Name="ErrorMenuItem"
                        PreviewMouseDown="Error_Handler"
                        />

                </MenuItem>

                <MenuItem 
                    Header="Справка"
                    Name="Help"
                    >

                    <MenuItem 
                        Header="О программе" 
                        />

                    <MenuItem 
                        Header="Справка" 
                        />

                </MenuItem>

                <MenuItem 
    Header="Администрирование"
    Name="Admin"
    >

                    <MenuItem 
        Header="Console" 
        Name="SendCommandMenuItem"
        PreviewMouseDown="SendCommand_Handler"
        />


                    <MenuItem 
        Header="Logger" 
        Name="LoggerMenuItem"
        PreviewMouseDown="Logger_Handler"
        />

                    <MenuItem 
        Header="USB" 
        Name="USBMenuItem"
        PreviewMouseDown="USB_Handler"
        />

                    <MenuItem 
                    Header="Управление" 
                    Name="DeviceManagment"
                    >
                        <MenuItem 
                            Header="GPT" 
                            Name="GptManagment"
                            PreviewMouseDown="Gpt_Handler"
                            >
                        </MenuItem>
                    </MenuItem>

                </MenuItem>
            </Menu>

            <StackPanel  
                Background="{StaticResource SecondarySolidColorBrush}" 
                Grid.Column="2" 
                MouseLeftButtonDown="mainMenu_MouseLeftButtonDown"
                />

            <StackPanel 
                Orientation="Horizontal" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Grid.Column="2" 
                Name="ButtonsPanel"
                Background="{StaticResource SecondarySolidColorBrush}"
                >

                <DefaultGUI:WindowButtons 
                    Width="{Binding ActualHeight, ElementName=mainMenu}" 
                    Height="{Binding ActualHeight, ElementName=mainMenu}" 
                    x:Name="minimizeButton" 
                    ChoiceElement="Minimize"
                    PreviewMouseDown="minimizeButton_PreviewMouseDown"
                    />

                <DefaultGUI:WindowButtons 
                    x:Name="maximizeButton" 
                    ChoiceElement="Maximize" 
                    Width="{Binding ActualHeight, ElementName=mainMenu}" 
                    Height="{Binding ActualHeight, ElementName=mainMenu}"
                    PreviewMouseDown="maximizeButton_PreviewMouseDown"
                    />

                <DefaultGUI:WindowButtons 
                    x:Name="exitButton"
                    ChoiceElement="Exit"  
                    Width="{Binding ActualHeight, ElementName=mainMenu}" 
                    Height="{Binding ActualHeight, ElementName=mainMenu}"
                    PreviewMouseDown="exitButton_PreviewMouseDown"
                    />
            </StackPanel>
        </Grid>

        <Components:MultiEditorControl
            x:Name="multiEditors" 
            Grid.Row="1"
            />

        <Grid 
            Grid.Row="2" 
            Height="40" 
            Background="{StaticResource SecondarySolidColorBrush}"
            >

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <TextBlock 
                x:Name="InfoBlock" 
                VerticalAlignment="Center" 
                Padding="10,0,0,0" 
                FontSize="14" 
                Foreground="{StaticResource ForegroundSolidColorBrush}"
                >
                Тут будет информационый текст
            </TextBlock>
            <DefaultGUI:PowerButton
                Grid.Column="2" 
                Width="200"
                Name="PowerButton"
                />
        </Grid>
    </Grid>
</Window>
