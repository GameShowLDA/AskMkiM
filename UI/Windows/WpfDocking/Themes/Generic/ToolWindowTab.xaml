<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="clr-namespace:UI.Windows.WpfDocking.Windows"
    xmlns:docking="clr-namespace:UI.Windows.WpfDocking.Windows.Docking"
    xmlns:primitives="clr-namespace:UI.Windows.WpfDocking.Windows.Docking.Primitives">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/UI;component/Style.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="primitives:ToolWindowTab">
        <Style.Resources>

            <Style TargetType="primitives:TabBorder">
                <Setter Property="IsBottom" Value="True" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>

            <ControlTemplate x:Key="ControlTemplate" TargetType="primitives:ToolWindowTab" >
                <primitives:TabBorder 
                        x:Name="border"
                        CornerRadius="10,10,0,0"
                    >
                    <Border x:Name="insideBorder"
                            BorderBrush="{StaticResource SecondarySolidColorBrush}"
                            BorderThickness="0"
                            Background="{StaticResource SecondarySolidColorBrush}"
                            CornerRadius="10,10,0,0"
                            Padding="5,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="tabTextBlock"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="{Binding TabText}"
                                FontFamily="{DynamicResource {x:Static SystemFonts.MenuFontFamilyKey}}"
                                FontSize="14"
                                FontStyle="{DynamicResource {x:Static SystemFonts.MenuFontStyleKey}}"
                                FontWeight="{DynamicResource {x:Static SystemFonts.MenuFontWeightKey}}"
                                Foreground="{StaticResource ForegroundSolidColorBrush}"
                                TextWrapping="NoWrap"  TextTrimming="CharacterEllipsis" />
                            <Button Grid.Column="2"
                                    Width="16"
                                    Height="16"
                                    Margin="5,0,0,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Cursor="Hand"
                                    Command="{x:Static docking:DockCommands.PerformClose}">
                                <Path Data="M 0 0 L 8 8 M 8 0 L 0 8"
                                      Stroke="{StaticResource ForegroundSolidColorBrush}"
                                      StrokeThickness="2"
                                      Stretch="Uniform" />
                            </Button>
                        </Grid>
                    </Border>
                </primitives:TabBorder>
                <ControlTemplate.Triggers>
                    <Trigger Property="UIElement.IsMouseOver" Value="True">
                        <Setter Property="Background" TargetName="insideBorder" Value="{StaticResource IsCheckedColorSolidColorBrush}" />
                    </Trigger>
                    <DataTrigger Binding="{Binding Path=IsSelected}" Value="True">
                        <Setter Property="Background" TargetName="insideBorder" Value="{StaticResource GreenColorSolidColorBrush}" />
                    </DataTrigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Style.Resources>
        <Setter Property="Margin" Value="0,0,0,-5" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="DataContext" Value="{Binding RelativeSource={x:Static RelativeSource.Self}, Path=Content}" />
        <Setter Property="primitives:DockManager.TargetItem" Value="{Binding}" />
        <Setter Property="primitives:DockManager.TargetPosition" Value="Tab" />
        <Setter Property="DoubleClickCommand" Value="{x:Static docking:DockCommands.ToggleFloating}" />
        <Setter Property="Template" Value="{StaticResource ControlTemplate}" />
        <Style.Triggers>
            <Trigger Property="IsContentTrimmed" Value="True">
                <Setter Property="ToolTip" Value="{Binding TabText}" />
            </Trigger>
            <DataTrigger Binding="{Binding Path=IsSelected}" Value="True">
                <Setter Property="Panel.ZIndex" Value="1" />
                <Setter Property="Margin" Value="-1,-1,0,-5" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>