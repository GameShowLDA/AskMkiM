<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:docking="clr-namespace:UI.Windows.WpfDocking.Windows.Docking"
    xmlns:primitives="clr-namespace:UI.Windows.WpfDocking.Windows.Docking.Primitives">

    <Style TargetType="{x:Type docking:DockItem}">
        <Style.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceDictionary Source="DockItem.TabContextMenu.xaml" />
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </Style.Resources>
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type docking:DockItem}">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="TabContextMenu" Value="{DynamicResource {ComponentResourceKey {x:Type docking:DockItem}, TabContextMenu}}" />
    </Style>
    
</ResourceDictionary>