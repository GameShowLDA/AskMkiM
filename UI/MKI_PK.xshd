<?xml version="1.0"?>

<SyntaxDefinition name="MKI" extensions=".pk;.pkw;.opk;.opkw;.acs" xmlns="http://icsharpcode.net/sharpdevelop/syntaxdefinition/2008">
	<Color name="Comment" foreground="#4CAF50" />
	<Color name="Mnemonic" foreground="#90EE90" />
	<Color name="CommandNumber" foreground="#00BFFF" />
	<Color name="Resistance" foreground="#FFD700" />
	<Color name="Voltage" foreground="#FFD700" />
	<Color name="Time" foreground="#FFD700" />
	<Color name="Wire" foreground="#F44336"/>
	<Color name="OkParam" foreground="#FFB300" />

	<RuleSet ignoreCase="false">

		<Rule color="CommandNumber">^\s*\d+\b</Rule>

		<!--Мнемоника-->
		<Rule color="Mnemonic">\bСИ\b</Rule>
		<Rule color="Mnemonic">\bОК\b</Rule>
		<Rule color="Mnemonic">\bСП\b</Rule>
		<Rule color="Mnemonic">\bРМ\b</Rule>
		<Rule color="Mnemonic">\bЦУ\b</Rule>
		<Rule color="Mnemonic">\bПР\b</Rule>
		<Rule color="Mnemonic">\bПИ\b</Rule>
		<Rule color="Mnemonic">\bКЦ\b</Rule>
		<Rule color="Mnemonic">\bУП\b</Rule>
		<Rule color="Mnemonic">\bКС\b</Rule>
		<Rule color="Mnemonic">\bИЕ\b</Rule>
		<Rule color="Mnemonic">\bЭТ\b</Rule>
		<Rule color="Mnemonic">\bНЭ\b</Rule>
		<Rule color="Mnemonic">\bПТ\b</Rule>
		<Rule color="Mnemonic">\bВШ\b</Rule>
		<Rule color="Mnemonic">\bСК\b</Rule>


		<!--Ключи-->
		
		<!--Ключ К-->
		<Rule color="Mnemonic">\sК\s</Rule>
		<Rule color="Mnemonic">,К\s</Rule>
		<Rule color="Mnemonic">\sК,</Rule>
		<Rule color="Mnemonic">,К,</Rule>
		<Rule color="Mnemonic">\sК$</Rule>
		<Rule color="Mnemonic">,К$</Rule>
		
		<!--Ключ ЗР-->
		<Rule color="Mnemonic">\sЗР\s</Rule>
		<Rule color="Mnemonic">,ЗР\s</Rule>
		<Rule color="Mnemonic">\sЗР,</Rule>
		<Rule color="Mnemonic">,ЗР,</Rule>
		<Rule color="Mnemonic">\sЗР$</Rule>
		<Rule color="Mnemonic">,ЗР$</Rule>

		<!--Ключ ЗС -->
		<Rule color="Mnemonic">\sЗС\s</Rule>
		<Rule color="Mnemonic">,ЗС\s</Rule>
		<Rule color="Mnemonic">\sЗС,</Rule>
		<Rule color="Mnemonic">,ЗС,</Rule>
		<Rule color="Mnemonic">\sЗС$</Rule>
		<Rule color="Mnemonic">,ЗС$</Rule>
		
		<!--Ключ С-->
		<Rule color="Mnemonic">\sС\s</Rule>
		<Rule color="Mnemonic">,С\s</Rule>
		<Rule color="Mnemonic">\sС,</Rule>
		<Rule color="Mnemonic">,С,</Rule>
		<Rule color="Mnemonic">\sС$</Rule>
		<Rule color="Mnemonic">,С$</Rule>

		<!--Ключ П-->
		<Rule color="Mnemonic">\sП\s</Rule>
		<Rule color="Mnemonic">,П\s</Rule>
		<Rule color="Mnemonic">\sП,</Rule>
		<Rule color="Mnemonic">,П,</Rule>
		<Rule color="Mnemonic">\sП$</Rule>
		<Rule color="Mnemonic">,П$</Rule>

		<!--Ключ И-->
		<Rule color="Mnemonic">\sИ\s</Rule>
		<Rule color="Mnemonic">,И\s</Rule>
		<Rule color="Mnemonic">\sИ,</Rule>
		<Rule color="Mnemonic">,И,</Rule>
		<Rule color="Mnemonic">\sИ$</Rule>
		<Rule color="Mnemonic">,И$</Rule>

		<!--Ключ Г-->
		<Rule color="Mnemonic">\sГ\s</Rule>
		<Rule color="Mnemonic">,Г\s</Rule>
		<Rule color="Mnemonic">\sГ,</Rule>
		<Rule color="Mnemonic">,Г,</Rule>
		<Rule color="Mnemonic">\sГ$</Rule>
		<Rule color="Mnemonic">,Г$</Rule>

		<!--Ключ T1-->
		<Rule color="Mnemonic">\sТ1\s</Rule>
		<Rule color="Mnemonic">,Т1\s</Rule>
		<Rule color="Mnemonic">\sТ1,</Rule>
		<Rule color="Mnemonic">,Т1,</Rule>
		<Rule color="Mnemonic">\sТ1$</Rule>
		<Rule color="Mnemonic">,Т1$</Rule>

		<!--Ключ I-->
		<Rule color="Mnemonic">\sШ\s</Rule>
		<Rule color="Mnemonic">,Ш\s</Rule>
		<Rule color="Mnemonic">\sШ,</Rule>
		<Rule color="Mnemonic">,Ш,</Rule>
		<Rule color="Mnemonic">\sШ$</Rule>
		<Rule color="Mnemonic">,Ш$</Rule>

		<!--Ключ T-->
		<Rule color="Mnemonic">\sТ\s</Rule>
		<Rule color="Mnemonic">,Т\s</Rule>
		<Rule color="Mnemonic">\sТ,</Rule>
		<Rule color="Mnemonic">,Т,</Rule>
		<Rule color="Mnemonic">\sТ$</Rule>
		<Rule color="Mnemonic">,Т$</Rule>

		<!--Ключ Б-->
		<Rule color="Mnemonic">\sБ\s</Rule>
		<Rule color="Mnemonic">,Б\s</Rule>
		<Rule color="Mnemonic">\sБ,</Rule>
		<Rule color="Mnemonic">,Б,</Rule>
		<Rule color="Mnemonic">\sБ$</Rule>
		<Rule color="Mnemonic">,Б$</Rule>

		<!--Ключ Н-->
		<Rule color="Mnemonic">\sН\s</Rule>
		<Rule color="Mnemonic">,Н\s</Rule>
		<Rule color="Mnemonic">\sН,</Rule>
		<Rule color="Mnemonic">,Н,</Rule>
		<Rule color="Mnemonic">\sН$</Rule>
		<Rule color="Mnemonic">,Н$</Rule>

		<!--Ключ Д-->
		<Rule color="Mnemonic">\sД\s</Rule>
		<Rule color="Mnemonic">,Д\s</Rule>
		<Rule color="Mnemonic">\sД,</Rule>
		<Rule color="Mnemonic">,Д,</Rule>
		<Rule color="Mnemonic">\sД$</Rule>
		<Rule color="Mnemonic">,Д$</Rule>

		<!-- ОПК, ИК, ЦЕХ, ЗАКАЗ, КД, Прим в начале строки (с пробелами до и после) -->
		<Rule color="OkParam">^\s*ОПК\b</Rule>
		<Rule color="OkParam">^\s*ИК\b</Rule>
		<Rule color="OkParam">^\s*ЦЕХ\b</Rule>
		<Rule color="OkParam">^\s*ЗАКАЗ\b</Rule>
		<Rule color="OkParam">^\s*КД\b</Rule>
		<Rule color="OkParam">^\s*Прим\b</Rule>

		<!--Время-->
		<Rule color="Time">\s\d+\s*[мm]?[сs]\b</Rule>
		
		<!--Напряжение-->
		<Rule color="Voltage">\s\+?\d+\s*[ВVv]\b</Rule>

		<!--Сопротивление-->

		<!-- Диапазон типа 94<кОм<106 -->
		<Rule color="Resistance">(?i)\d+(?:[.,]\d+)?&lt;(?:Ом|кОм|МОм|ГОм|нф|мкф|пф)&lt;\d+(?:[.,]\d+)?</Rule>

		<!-- Случаи с R> -->
		<Rule color="Resistance">(?i)R&gt;\d+(?:[.,]\d+)?(Ом|кОм|МОм|ГОм|нф|мкф|пф)</Rule>

		<!-- Универсальное правило -->
		<Rule color="Resistance">(?i)(Ом|кОм|МОм|ГОм|нф|мкф|пф)&lt;\d+(?:[.,]\d+)?</Rule>

		<!-- Универсальное правило — только с < -->
		<Rule color="Resistance">(?i)\d+(?:[.,]\d+)?\s?&lt;\s?(Ом|кОм|МОм|ГОм|нф|мкф|пф)</Rule>

		<!--Комментарии-->
		<!-->Span color="Comment" begin="{" end="}" multiline="true"/>
		<Span color="Comment" begin="//" end="\n" />
		<Span color="Comment" begin="/\*" end="\*/" multiline="true" /-->

	</RuleSet>
</SyntaxDefinition>

