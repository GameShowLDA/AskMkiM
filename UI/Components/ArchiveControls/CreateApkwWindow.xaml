<Window x:Class="UI.Components.ArchiveControls.CreateApkwWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UI.Components.ArchiveControls"
        xmlns:WinButton="clr-namespace:UI.Components"
        
        mc:Ignorable="d"
        Title="Создание нового архива программ контроля" 
        Height="Auto" 
        Width="600"
        SizeToContent="Height"
        MaxHeight="1000"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground = "{StaticResource ForegroundSolidColorBrush}"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        WindowState="Normal"
        Focusable="True">
    <Window.Resources>
        <Style TargetType="WinButton:WindowButtons">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource ActiveForegroundSolidColorBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>


    <Border  
        BorderThickness="0" 
        CornerRadius="5">
        <DockPanel  >
            <Border DockPanel.Dock="Top" 
                BorderThickness="0,0,0,1"
                CornerRadius="10,10,0,0"
                Background="{StaticResource IsCheckedColorSolidColorBrush}"
                MouseLeftButtonDown="Border_MouseLeftButtonDown" Height="45">
                <Grid>
                    <TextBlock Text="Создание нового архива программ контроля"
                         Margin="10,5"
                         FontWeight="SemiBold"
                           FontSize="18"/>
                    <WinButton:WindowButtons 
                        HorizontalAlignment="Right"
                        ChoiceElement="Exit"  
                        Width="45" 
                        Height="45"
                        PreviewMouseDown="CloseButton_Click" Cursor="Hand"
                        />
                </Grid>
            </Border>
            <Border Background="{StaticResource SecondarySolidColorBrush}">

                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="0.7*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Введите название"
                       Margin="5, 0"
                       FontWeight="SemiBold"
                       FontSize="20"
                       Grid.Row="0"
                           VerticalAlignment="Center"/>
                    <TextBlock Text="Введите описание"
                   Margin="5, 25,0,0"
                   FontWeight="SemiBold"
                   FontSize="20"
                   Grid.Row="2"
                       VerticalAlignment="Center"/>

                    <TextBox 
                     x:Name="newArchiveName"
                     Grid.Row="1"
                     Grid.ColumnSpan="3"
                     Margin="5, 10"
                     HorizontalContentAlignment="Left"
                     Style="{StaticResource MetrologyTextBox}"
                     BorderThickness="0,0,0,3"
                     BorderBrush="{StaticResource ForegroundSolidColorBrush}"
                     Text="Введите название архива"
                     Tag="Введите название архива"/>

                    <RichTextBox 
                x:Name="newArchiveDescription"
                MaxHeight="300"
                Grid.Row="3"
                Grid.ColumnSpan="3"
                Margin="5, 10"
                BorderThickness="0,0,0,3"
                BorderBrush="{StaticResource ForegroundSolidColorBrush}"
                HorizontalContentAlignment="Left"
                VerticalContentAlignment="Top"
                FontSize="18"
                Foreground="White"
                Background="Transparent"
                Tag="Введите описание архива">
                        <RichTextBox.Document>
                            <FlowDocument>
                                <Paragraph>
                                    <Run Text="Введите описание архива"/>
                                </Paragraph>
                            </FlowDocument>
                        </RichTextBox.Document>
                    </RichTextBox>

                    <Button
                Grid.Row="4"
                Grid.Column="2"
                Content="Сохранить" 
                Padding="5"
                Style="{StaticResource CustomButtonStyle}"
                PreviewMouseDown="CreateApkButton_Click"/>

                    <Grid Grid.Row="4" Margin="10,0,0,0" x:Name="choseArchiveType" Visibility="Hidden">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <CheckBox 
                    x:Name="main" 
                    VerticalAlignment="Center" 
                    Style="{StaticResource AnimatedSwitch}" 
                    HorizontalAlignment="Left" 
                    Width="20" 
                        IsChecked="False"
                        Checked="Switch_Checked"
                    Unchecked="Switch_Unchecked"
                    Margin="0,0,20,0"
                    />
                        <CheckBox 
                    x:Name="additional" 
                    VerticalAlignment="Center" 
                    Style="{StaticResource AnimatedSwitch}" 
                    Grid.Row="1"
                    HorizontalAlignment="Left" 
                    Width="20" 
                    IsChecked="True"
                    Checked="Switch_Checked"
                    Unchecked="Switch_Unchecked"/>

                        <TextBlock Text="Системный архив"
                       Margin="5,0,10,0"
                       FontWeight="Normal"
                       FontSize="20"
                       Grid.Column="1"
                        VerticalAlignment="Center" TextAlignment="Left" TextWrapping="Wrap"/>

                        <TextBlock Text="Пользовательский архив"
                        Margin="5,10,10,10"
                        FontWeight="Normal"
                        FontSize="20"
                        Grid.Row="4"
                        Grid.Column="1"
                        VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Right" HorizontalAlignment="Right"/>
                    </Grid>

                </Grid>
            </Border>
        </DockPanel>
    </Border>
</Window>
