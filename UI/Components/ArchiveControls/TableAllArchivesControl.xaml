<UserControl x:Class="UI.Components.ArchiveControls.TableAllArchivesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components.ArchiveControls"
             xmlns:CustomControls="clr-namespace:UI.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" Name="PanelManagment"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Grid Background="{StaticResource SecondarySolidColorBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"></RowDefinition>
                    <RowDefinition  Height="*"></RowDefinition>
                </Grid.RowDefinitions>



                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"></ColumnDefinition>
                        <ColumnDefinition Width="40"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <CustomControls:MenuButton x:Name="MenuButton" 
                                               Margin="3" 
                                               Grid.Column="1" 
                                               PreviewMouseDown="MenuButton_PreviewMouseDownAsync" 
                                               Style="{StaticResource MenuButtonActive}"/>

                    <Border Background="{StaticResource CategoryPanelBackgroundColor}" PreviewMouseDown="MenuButton_PreviewMouseDownAsync" Grid.Column="2">
                        <TextBlock Style="{StaticResource MetrologyTextBlockStyle}" Foreground="{StaticResource ActiveBorderSolidColorBrush}" Margin="10,0" HorizontalAlignment="Center" VerticalAlignment="Center">Меню</TextBlock>
                    </Border>
                </Grid>


                <Border Grid.Row="1"  Name="ButtonPanel">
                    <Grid >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"></RowDefinition>
                        </Grid.RowDefinitions>

                        <Button Margin="10,10,10,0"
                    Content="Создать"
                    Style="{StaticResource MetrologyButtonStyle}"
                            PreviewMouseDown="CreateApk_PreviewMouseDownAsync"
                    >
                        </Button>

                    </Grid>
                </Border>

            </Grid>
            <DataGrid AutoGenerateColumns="False" 
                  x:Name="apkFilesDataGrid" 
                  CanUserAddRows="False" 
                  IsReadOnly="True" 
                  CanUserDeleteRows="False"
                  ClipboardCopyMode="None"
                  SelectionMode="Single"
                  Background="Transparent"
                  Grid.Column="1"
                  HeadersVisibility="Column"
                  PreviewMouseDoubleClick="apkFilesDataGrid_PreviewMouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название архива" Binding="{Binding Path=ArchiveName}" Width="Auto"/>
                    <DataGridTextColumn Header="Примечание" Binding="{Binding Path=Description}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
