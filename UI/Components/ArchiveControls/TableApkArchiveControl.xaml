<UserControl x:Class="UI.Components.ArchiveControls.TableApkArchiveControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components.ArchiveControls"
             xmlns:CustomControls="clr-namespace:UI.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" Name="PanelManagment"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid Background="{StaticResource SecondarySolidColorBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"></RowDefinition>
                <RowDefinition  Height="*"></RowDefinition>
            </Grid.RowDefinitions>



            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5"></ColumnDefinition>
                    <ColumnDefinition Width="40"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <CustomControls:MenuButton x:Name="CustomMenuButton"
                                           Margin="3" 
                                           Grid.Column="1" 
                                           PreviewMouseDown="Border_PreviewMouseDownAsync" 
                                           Style="{StaticResource MenuButtonActive}"/>

                <Border Background="{StaticResource CategoryPanelBackgroundColor}" PreviewMouseDown="Border_PreviewMouseDownAsync" Grid.Column="2">
                    <TextBlock Style="{StaticResource MetrologyTextBlockStyle}" Foreground="{StaticResource ActiveBorderSolidColorBrush}" Margin="10,0" HorizontalAlignment="Center" VerticalAlignment="Center">Меню</TextBlock>
                </Border>
            </Grid>


            <Border Grid.Row="1"  Name="ButtonPanel">
                <Grid x:Name="buttonsGrid" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>

                    <Button 
                    Margin="15,10,10,0"
                    Content="Добавить"
                    Style="{StaticResource MetrologyButtonStyle}"
                    PreviewMouseDown="Add_PreviewMouseDown"
                    Grid.Row="0"
                    HorizontalAlignment="Left">
                    </Button>

                    <Button 
                    Margin="15,10,10,0"
                    Content="Обновить"
                    Style="{StaticResource MetrologyButtonStyle}"
                    Grid.Row="1"
                    PreviewMouseDown="Update_PreviewMouseDown"
                    HorizontalAlignment="Left"
                    >
                    </Button>

                    <Button 
                    Margin="15,10,10,0"
                    Content="Удалить"
                    Style="{StaticResource MetrologyButtonStyle}"
                    Grid.Row="2"
                    PreviewMouseDown="Delete_PreviewMouseDown"
                    HorizontalAlignment="Left"
                    >
                    </Button>

                    <Button x:Name="saveAsButton" 
                    Margin="15,10,10,0"
                    Style="{StaticResource MetrologyButtonStyle}"
                    PreviewMouseDown="SaveAs_PreviewMouseDown"
                    Grid.Row="3"
                    HorizontalAlignment="Left"
                    Visibility="Hidden">
                        <TextBlock Text="Сохранить как" 
                           TextTrimming="CharacterEllipsis" 
                           TextWrapping="NoWrap" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Center"/>
                    </Button>

                    <Button x:Name="viewButton" 
                    Margin="15,10,10,0"
                    Style="{StaticResource MetrologyButtonStyle}"
                    PreviewMouseDown="viewButton_PreviewMouseDown"
                    Grid.Row="4"
                    HorizontalAlignment="Left"
                    Visibility="Hidden">
                        <TextBlock Text="Просмотр" 
                       TextTrimming="CharacterEllipsis" 
                       TextWrapping="NoWrap" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center"/>
                    </Button>

                    <Button x:Name="translateButton" 
                    Margin="15,10,10,0"
                    Style="{StaticResource MetrologyButtonStyle}"
                    PreviewMouseDown="translateButton_PreviewMouseDown"
                    Grid.Row="5"
                    HorizontalAlignment="Left"
                    Visibility="Hidden" >
                        <TextBlock Text="Транслировать" 
                           TextTrimming="CharacterEllipsis" 
                           TextWrapping="NoWrap" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

        </Grid>

        <DataGrid AutoGenerateColumns="False" 
              x:Name="opkFilesDataGrid"
              CanUserAddRows="False" 
              IsReadOnly="True" 
              CanUserDeleteRows="False"
              ClipboardCopyMode="None"
              SelectionMode="Single"
              Background="Transparent"
              Grid.Column="1"
              SelectionChanged="opkFilesDataGrid_SelectionChanged"
              PreviewMouseDoubleClick="viewOpkFilesDataGrid_PreviewMouseDoubleClick"
              HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Обозначение" Binding="{Binding Path=Marking}" Width="*"/>
                <DataGridTextColumn Header="Наименование ОК" Binding="{Binding Path=Name}" Width="*"/>
                <DataGridTextColumn Header="ЗАКАЗ" Binding="{Binding Path=Order}" Width="0.5*"/>
                <DataGridTextColumn Header="Файл ОПК" Binding="{Binding Path=OpkFilename}" Width="*"/>
                <DataGridTextColumn Header="Создан" Binding="{Binding Path=Creation, StringFormat={}{0:dd.MM.yyyy}}" Width="*"  />
                <DataGridTextColumn Header="Цех" Binding="{Binding Path=Department}" Width="0.5*"/>
                <DataGridTextColumn Header="Примечание" Binding="{Binding Path=Description}" Width="*"/>
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</UserControl>
