<UserControl x:Class="UI.Components.PowerButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components"
             mc:Ignorable="d" 
         d:DesignHeight="40" d:DesignWidth="180"
         >
    <Grid Name="GridBlock"  Background="#b23a48" Opacity="0.5">

        <TextBlock Name="nameTextBlock"
               Foreground="{StaticResource ForegroundSolidColorBrush}" 
               VerticalAlignment="Center"
               HorizontalAlignment="Center"
               Padding="5"
               
               FontSize="15"
               TextWrapping="Wrap"
               TextTrimming="CharacterEllipsis"
               ToolTipService.IsEnabled="True"
               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
               >
        Подключить питание
        </TextBlock>
    </Grid>
</UserControl>
