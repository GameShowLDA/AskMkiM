<UserControl x:Class="UI.Components.PowerButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components"
             mc:Ignorable="d" 
         d:DesignHeight="40" d:DesignWidth="180"
         >
    <Grid 
        Background="{DynamicResource GreenColorSolidColorBrush}" 
        Name="GridBlock"  
        Opacity="0.5"
        Cursor="Hand"
        >

        <TextBlock Name="nameTextBlock"
               Foreground="{DynamicResource MainTitleSolidColorBrush}" 
               VerticalAlignment="Center"
               HorizontalAlignment="Center"
               Padding="5"
               Text="Подключить систему"
               FontSize="15"
               TextWrapping="Wrap"
               TextTrimming="CharacterEllipsis"
               ToolTipService.IsEnabled="True"
               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
               />
    </Grid>
</UserControl>
