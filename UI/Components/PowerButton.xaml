<UserControl x:Class="UI.Components.PowerButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:UI.Components"
             xmlns:askUiIcons="clr-namespace:Ask.UI.Shared.Components.Icons;assembly=Ask.UI"
             mc:Ignorable="d"
             d:DesignHeight="38"
             d:DesignWidth="38">
  <UserControl.Resources>
    <LinearGradientBrush x:Key="PowerButtonFaceNormalBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
      <GradientStop Color="#4CFFFFFF" Offset="0.00" />
      <GradientStop Color="#26FFFFFF" Offset="0.44" />
      <GradientStop Color="#35000000" Offset="1.00" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PowerButtonFacePressedBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
      <GradientStop Color="#30000000" Offset="0.00" />
      <GradientStop Color="#1CFFFFFF" Offset="1.00" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PowerButtonRimBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
      <GradientStop Color="#65FFFFFF" Offset="0.00" />
      <GradientStop Color="#1CFFFFFF" Offset="0.50" />
      <GradientStop Color="#5A000000" Offset="1.00" />
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="PowerButtonTopHighlightBrush"
                         Center="0.30,0.28"
                         GradientOrigin="0.30,0.28"
                         RadiusX="0.82"
                         RadiusY="0.82">
      <GradientStop Color="#7AFFFFFF" Offset="0.00" />
      <GradientStop Color="#0FFFFFFF" Offset="1.00" />
    </RadialGradientBrush>
  </UserControl.Resources>

  <Grid Name="GridBlock"
        Background="Transparent">
    <Button x:Name="PowerActionButton"
            Width="32"
            Height="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="0"
            BorderThickness="0"
            Background="Transparent"
            Focusable="False"
            Cursor="Hand"
            Click="OnPowerActionButtonClick"
            ToolTip="Подключить систему">
      <Button.Template>
        <ControlTemplate TargetType="{x:Type Button}">
          <Grid Width="{TemplateBinding Width}"
                Height="{TemplateBinding Height}">
            <Ellipse x:Name="ShadowLayer"
                     Fill="#A0000000"
                     Margin="0,1.4,0,0"
                     Opacity="0.38"
                     IsHitTestVisible="False">
              <Ellipse.Effect>
                <BlurEffect Radius="6.0" />
              </Ellipse.Effect>
            </Ellipse>

            <Ellipse x:Name="ButtonFace"
                     Fill="{StaticResource PowerButtonFaceNormalBrush}"
                     Stroke="{StaticResource PowerButtonRimBrush}"
                     StrokeThickness="1.0"
                     SnapsToDevicePixels="True">
            </Ellipse>

            <Ellipse x:Name="TopLight"
                     Margin="2.6,2.6,2.6,5.2"
                     Fill="{StaticResource PowerButtonTopHighlightBrush}"
                     Opacity="0.42"
                     IsHitTestVisible="False" />

            <Ellipse x:Name="InnerShadow"
                     Margin="1.8"
                     Opacity="0"
                     IsHitTestVisible="False">
              <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5"
                                     GradientOrigin="0.5,0.5"
                                     RadiusX="0.60"
                                     RadiusY="0.60">
                  <GradientStop Color="#00000000" Offset="0.55" />
                  <GradientStop Color="#77000000" Offset="1.00" />
                </RadialGradientBrush>
              </Ellipse.Fill>
            </Ellipse>

            <Grid x:Name="IconHost"
                  Width="18"
                  Height="18"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  IsHitTestVisible="False">
              <askUiIcons:PowerOffIcon x:Name="PowerOffStateIcon"
                                       Size="18"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource PowerButtonOffForegroundBrush}" />

              <askUiIcons:PowerOnIcon x:Name="PowerOnStateIcon"
                                      Size="18"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Visibility="Collapsed"
                                      Foreground="{DynamicResource PowerButtonOnForegroundBrush}" />
            </Grid>
          </Grid>

          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver"
                     Value="True">
              <Setter TargetName="ShadowLayer"
                      Property="Opacity"
                      Value="0.50" />
              <Setter TargetName="ShadowLayer"
                      Property="Margin"
                      Value="0,2.0,0,0" />
              <Setter TargetName="TopLight"
                      Property="Opacity"
                      Value="0.48" />
            </Trigger>

            <Trigger Property="IsPressed"
                     Value="True">
              <Setter TargetName="ButtonFace"
                      Property="Fill"
                      Value="{StaticResource PowerButtonFacePressedBrush}" />
              <Setter TargetName="ButtonFace"
                      Property="Margin"
                      Value="0,1.15,0,-1.15" />
              <Setter TargetName="IconHost"
                      Property="Margin"
                      Value="0,0.85,0,-0.85" />
              <Setter TargetName="ShadowLayer"
                      Property="Opacity"
                      Value="0.22" />
              <Setter TargetName="ShadowLayer"
                      Property="Margin"
                      Value="0,0,0,0" />
              <Setter TargetName="TopLight"
                      Property="Opacity"
                      Value="0.14" />
              <Setter TargetName="InnerShadow"
                      Property="Opacity"
                      Value="0.44" />
            </Trigger>

            <Trigger Property="IsEnabled"
                     Value="False">
              <Setter TargetName="ButtonFace"
                      Property="Opacity"
                      Value="0.55" />
              <Setter TargetName="TopLight"
                      Property="Opacity"
                      Value="0.08" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Button.Template>
    </Button>
  </Grid>
</UserControl>
