<UserControl x:Class="UI.Components.Invoke.InvokeRichTextBox.InvokeRichTextBoxUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components.Invoke.InvokeRichTextBox"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Border CornerRadius="20" Style="{StaticResource RichBoxBorder}" Background="{StaticResource IsCheckedColorSolidColorBrush}" Margin="0">
        <RichTextBox Name="protocolTextBox"
        Background="Transparent"
        BorderThickness="0"
        Focusable="True">
            
        </RichTextBox>
        <Border.Effect>
            <DropShadowEffect Color="{StaticResource ForegroundColor}" BlurRadius="15" ShadowDepth="4" Opacity="0.5"/>
        </Border.Effect>
    </Border>
    
</UserControl>
