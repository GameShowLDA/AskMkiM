<UserControl x:Class="UI.Components.MultiEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components"
             xmlns:avalonEdit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel x:Name="TopPanel" 
                    Grid.Row="0" 
                    Background="{StaticResource SecondarySolidColorBrush}"  
                    Orientation="Horizontal" 
                    MouseLeftButtonDown="TopPanel_MouseLeftButtonDown"/>
        <DockPanel x:Name="ContentPanel" Grid.Row="1" Background="{StaticResource PrimarySolidColorBrush}"/>
        <ProgressBar x:Name="SearchProgressBar"
             Minimum="0"
             Maximum="100"
             Value="0"
             Height="20"
             Visibility="Collapsed"/>

    </Grid>
</UserControl>
