<Window x:Class="UI.Components.FileComparerControls.FileCompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UI.Components.FileComparerControls"
        xmlns:Components="clr-namespace:UI.Components"
        mc:Ignorable="d"
        Title="Создание нового архива программ контроля" 
        Height="Auto" 
        Width="600"
        SizeToContent="Height"
        MaxHeight="1000"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground = "{StaticResource ForegroundSolidColorBrush}"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        WindowState="Normal"
        Focusable="True">
    <Window.Resources>
        <Style TargetType="Components:WindowButtons">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource ActiveForegroundSolidColorBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>


    <Border  
    BorderThickness="0" 
    CornerRadius="5">
        <DockPanel  >
            <Border DockPanel.Dock="Top" 
            BorderThickness="0,0,0,1"
            CornerRadius="10,10,0,0"
            Background="{StaticResource IsCheckedColorSolidColorBrush}"
            MouseLeftButtonDown="Border_MouseLeftButtonDown" Height="45">
                <Grid>
                    <TextBlock Text="Сравнение файлов"
                     Margin="10,5"
                     FontWeight="SemiBold"
                       FontSize="18"/>
                    <Components:WindowButtons 
                    HorizontalAlignment="Right"
                    ChoiceElement="Exit"  
                    Width="45" 
                    Height="45"
                    PreviewMouseDown="CloseButton_Click" Cursor="Hand"
                    />
                </Grid>
            </Border>
            <Border Background="{StaticResource SecondarySolidColorBrush}">

                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Row="1" Grid.ColumnSpan="2" Background="{StaticResource ActiveBorderSolidColorBrush}" 
                        CornerRadius="10" Margin="0,10"
                        Name="FirstFileContainer"
                        >
                        <Grid >
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                                <TextBlock Text="Путь к первому файлу для сравнения" Foreground="{StaticResource ForegroundSolidColorBrush}" 
                                       FontSize="20" FontWeight="Bold" Margin="7"
                                       />

                                <Components:TextBoxPlaceholder x:Name="FirstFileTextBlock" 
                                                               Grid.Row="1"
                                                               Text="Укажите путь к первому файлу"
                                                               Placeholder="Укажите путь к первому файлу" 
                                                               ToolTip="Введите путь к файлу или выпоните двойной щелчок по полю ввода для выбора файла"
                                                               PreviewMouseDoubleClick="FirstFileTextBlock_PreviewMouseDoubleClick"/>

                        </Grid>
                    </Border>
                    
                    <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{StaticResource ActiveBorderSolidColorBrush}" 
                        CornerRadius="10" Margin="0, 10"
                        Name="SecondFileContainer"
                        >
                        <Grid >
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                                <TextBlock Text="Путь ко второму файлу для сравнения" Foreground="{StaticResource ForegroundSolidColorBrush}" 
                                       FontSize="20" FontWeight="Bold" Margin="7"
                                       />

                            <Components:TextBoxPlaceholder x:Name="SecondFileTextBlock" 
                               Grid.Row="1"
                               VerticalAlignment="Center"
                               Placeholder="Укажите путь ко второму файлу" 
                               Text="Укажите путь ко второму файлу"
                              ToolTip="Введите путь к файлу или выпоните двойной щелчок по полю ввода для выбора файла"
                               PreviewMouseDoubleClick="FirstFileTextBlock_PreviewMouseDoubleClick"/>
                        </Grid>
                    </Border>
                    
                    <Button Name="SaveButton" Grid.Row="3" Grid.Column="1" Content="Сравнить" 
                            Style="{DynamicResource ButtonStyleV10}" 
                            Width="250" HorizontalAlignment="Right" 
                            PreviewMouseDown="CompareButton_PreviewMouseDown"
                            />
                </Grid>
            </Border>
        </DockPanel>
    </Border>
</Window>

