<Window x:Class="UI.Components.FileComparerControls.FileCompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UI.Components.FileComparerControls"
          xmlns:WinButton="clr-namespace:UI.Components"
        mc:Ignorable="d"
        Title="Создание нового архива программ контроля" 
        Height="Auto" 
        Width="600"
        SizeToContent="Height"
        MaxHeight="1000"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground = "{StaticResource ForegroundSolidColorBrush}"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        WindowState="Normal"
        Focusable="True">
    <Window.Resources>
        <Style TargetType="WinButton:WindowButtons">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource ActiveForegroundSolidColorBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>


    <Border  
    BorderThickness="0" 
    CornerRadius="5">
        <DockPanel  >
            <Border DockPanel.Dock="Top" 
            BorderThickness="0,0,0,1"
            CornerRadius="10,10,0,0"
            Background="{StaticResource IsCheckedColorSolidColorBrush}"
            MouseLeftButtonDown="Border_MouseLeftButtonDown" Height="45">
                <Grid>
                    <TextBlock Text="Сравнение файлов"
                     Margin="10,5"
                     FontWeight="SemiBold"
                       FontSize="18"/>
                    <WinButton:WindowButtons 
                    HorizontalAlignment="Right"
                    ChoiceElement="Exit"  
                    Width="45" 
                    Height="45"
                    PreviewMouseDown="CloseButton_Click" Cursor="Hand"
                    />
                </Grid>
            </Border>
            <Border Background="{StaticResource SecondarySolidColorBrush}">

                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="1" Grid.ColumnSpan="2" Background="{StaticResource PrimarySolidColorBrush}" 
                        CornerRadius="10" Margin="0,10"
                        Name="FirstFileContainer"
                        >
                        <Grid >
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>

                            <Border CornerRadius="10" Background="{StaticResource ActiveBorderSolidColorBrush}" Height="40" Padding="5">
                                <TextBlock Text="Путь к первому файлу для сравнения" Foreground="{StaticResource ForegroundSolidColorBrush}" 
                                       FontSize="20" FontWeight="Bold" Margin="7,0"
                                       />
                            </Border>

                            <Border Grid.Row="1" Background="{StaticResource LightPrimarySolidColorBrush}" CornerRadius="5" Margin="5,5">
                                <TextBox 
                                Background="Transparent" 
                                 BorderThickness="0" 
                                VerticalAlignment="Center" 
                                 FontSize="20" Foreground="{StaticResource ForegroundSolidColorBrush}"
                                 Name="FirstFileTextBlock"
                                    PreviewMouseDoubleClick="FirstFileTextBlock_PreviewMouseDoubleClick"
                                 />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{StaticResource PrimarySolidColorBrush}" 
                        CornerRadius="10" Margin="0,10"
                        Name="SecondFileContainer"
                        >
                        <Grid >
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>

                            <Border CornerRadius="10" Background="{StaticResource ActiveBorderSolidColorBrush}" Height="40" Padding="5">
                                <TextBlock Text="Путь ко второму файлу для сравнения" Foreground="{StaticResource ForegroundSolidColorBrush}" 
                                       FontSize="20" FontWeight="Bold" Margin="7,0"
                                       />
                            </Border>

                            <Border Grid.Row="1" Background="{StaticResource LightPrimarySolidColorBrush}" CornerRadius="5" Margin="5,5">
                                <TextBox 
                                Background="Transparent" 
                                 BorderThickness="0" 
                                VerticalAlignment="Center" 
                                 FontSize="20" Foreground="{StaticResource ForegroundSolidColorBrush}"
                                 Name="SecondFileTextBlock"
                                    PreviewMouseDoubleClick="FirstFileTextBlock_PreviewMouseDoubleClick"
                                 />
                            </Border>
                        </Grid>
                    </Border>
                    <Button Name="SaveButton" Grid.Row="3" Grid.Column="1" Content="Сравнить" 
                            Style="{StaticResource ConfigButtonStyle}" 
                            Width="250" HorizontalAlignment="Right" 
                            PreviewMouseDown="CompareButton_PreviewMouseDown"
                            />
                </Grid>
            </Border>
        </DockPanel>
    </Border>
</Window>

