<UserControl x:Class="UI.Components.FileComparerControls.FileCompareControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components.FileComparerControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel x:Name="TopPanel" 
            Grid.Row="0" 
            Grid.ColumnSpan="5"
            Background="{StaticResource SecondarySolidColorBrush}"  
            Orientation="Horizontal" 
            />

        <Grid x:Name="ContentGrid" Grid.Row="2" Grid.ColumnSpan="5" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="5" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Горизонтальное деление по умолчанию -->
            <RichTextBox Grid.Row="0" Grid.ColumnSpan="3" x:Name="TopBox" Background="Transparent"/>
            <GridSplitter Grid.Row="1" Grid.ColumnSpan="3" Height="5" Background="Gray" HorizontalAlignment="Stretch" ResizeDirection="Rows"/>
            <RichTextBox Grid.Row="2" Grid.ColumnSpan="3" x:Name="BottomBox" Background="Transparent"/>

            <!-- Вертикальное деление (скрыто по умолчанию) -->
            <RichTextBox Grid.Column="0" Grid.RowSpan="3" x:Name="LeftBox" Visibility="Collapsed" Background="Transparent"/>
            <GridSplitter Grid.Column="1" Grid.RowSpan="3" Width="5" Background="Gray" ResizeDirection="Columns" Visibility="Collapsed"/>
            <RichTextBox Grid.Column="2" Grid.RowSpan="3" x:Name="RightBox" Visibility="Collapsed" Background="Transparent"/>
        </Grid>

        <Button Name="ChangeFirstFile" Grid.Row="1" Grid.Column="0" Content="Заменить первый файл" 
                Style="{StaticResource CompareButtonStyle}" 
                />

        <Button Name="ChangeSecondFile" Grid.Row="1" Grid.Column="1" Content="Заменить второй файл" 
                        Style="{StaticResource CompareButtonStyle}" 

        />

        <Button Name="CompareFiles" Grid.Row="1" Grid.Column="2" Content="Сравнить" 
                        Style="{StaticResource CompareButtonStyle}" />

        <Button Name="UpDown" Grid.Row="1" Grid.Column="3" Content="Сверху/снизу" 
                        Style="{StaticResource CompareButtonStyle}" />

        <Button Name="LeftRight" Grid.Row="1" Grid.Column="4" Content="Слева/справа"                
                Style="{StaticResource CompareButtonStyle}" />
    </Grid>
</UserControl>
