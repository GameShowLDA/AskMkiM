<UserControl x:Class="UI.Components.FileComparerControls.FileCompareControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components.FileComparerControls"
             xmlns:Controls="clr-namespace:UI.Controls.TextEditor"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel x:Name="TopPanel" 
            Grid.Row="0" 
            Grid.ColumnSpan="5"
            Background="{StaticResource SecondarySolidColorBrush}"  
            Orientation="Horizontal" 
            />

        <Grid x:Name="HorizontalPanel" Grid.Column="1" Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="60"/>
                <!-- верхний блок -->
                <RowDefinition Height="5"/>
                <RowDefinition Height="*" MinHeight="60"/>
                <!-- нижний блок -->
            </Grid.RowDefinitions>

            <!-- Верхняя часть: название + редактор -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                Background="{StaticResource IsCheckedColorSolidColorBrush}">
                    <TextBlock 
                x:Name="FirstFileName"
                Text="test1.txt"
                Margin="10,5"
                FontWeight="SemiBold"
                FontSize="14"
                Foreground="{StaticResource ActiveForegroundSolidColorBrush}"/>
                </Border>

                <Controls:TextEditorUI Grid.Row="1" x:Name="TopBox"/>
            </Grid>

            <!-- Сплиттер -->
            <GridSplitter Grid.Row="1"
                  Height="5"
                  Background="{StaticResource RedColorSolidColorBrush}"
                  HorizontalAlignment="Stretch"
                  ResizeDirection="Rows"/>

            <!-- Нижняя часть: название + редактор -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                Background="{StaticResource IsCheckedColorSolidColorBrush}">
                    <TextBlock 
                x:Name="SecondFileName"
                Text="test2.txt"
                Margin="10,5"
                FontWeight="SemiBold"
                FontSize="14"
                Foreground="{StaticResource ActiveForegroundSolidColorBrush}"/>
                </Border>

                <Controls:TextEditorUI Grid.Row="1" x:Name="BottomBox"/>
            </Grid>
        </Grid>


        <!-- Вертикальный режим -->
        <Grid x:Name="VerticalPanel" Grid.Column="1" Visibility="Collapsed" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="20"/>
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="20" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" MinHeight="10"/>
                <RowDefinition Height="*" MinHeight="10"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Grid.Column="0"
                    BorderThickness="0,0,0,1"
                    Background="{StaticResource IsCheckedColorSolidColorBrush}" Height="30">
                <Grid>
                    <TextBlock 
                        x:Name="FirstVerticalFileName"
                        Text="Сравнение файлов"
                        Margin="10,5"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Foreground="{StaticResource LightPrimarySolidColorBrush}"/>

                </Grid>
            </Border>
            <Controls:TextEditorUI Grid.Column="0" Grid.Row="1" x:Name="LeftBox"/>
            <GridSplitter Grid.Column="1" Width="5" Grid.RowSpan="2" Background="{StaticResource RedColorSolidColorBrush}" 
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ResizeDirection="Columns"/>
            <Border Grid.Row="0" Grid.Column="2"
                    BorderThickness="0,0,0,1"
                    Background="{StaticResource IsCheckedColorSolidColorBrush}" Height="30">
                <Grid>
                    <TextBlock 
                        x:Name="SecondVerticalFileName"
                        Text="Сравнение файлов"
                        Margin="10,5"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Foreground="{StaticResource LightPrimarySolidColorBrush}"/>

                </Grid>
            </Border>
            <Controls:TextEditorUI Grid.Column="2"  Grid.Row="1" x:Name="RightBox"/>
        </Grid>

        <Grid x:Name="ButtonsGrid" Grid.Row="1" Grid.Column="0" Background="{StaticResource SecondarySolidColorBrush}">

            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            <Button x:Name="ChangeFirstFile" Grid.Row="0" Content="Заменить первый файл" PreviewMouseDown="ChangeFile_PreviewMouseDown"
                Style="{StaticResource CompareButtonStyle}" 
                />

            <Button x:Name="ChangeSecondFile" Grid.Row="1"  Content="Заменить второй файл" PreviewMouseDown="ChangeFile_PreviewMouseDown"
                            Style="{StaticResource CompareButtonStyle}" />

            <Button Name="CompareFiles" Grid.Row="2"  Content="Сравнить" 
                            Style="{StaticResource CompareButtonStyle}" />

            <Button x:Name="UpDown" Grid.Row="3" Content="Сверху/снизу" 
                            Style="{StaticResource CompareButtonStyle}" PreviewMouseDown="ToggleOrientation" Visibility="Collapsed"/>

            <Button x:Name="LeftRight" Grid.Row="3"  Content="Слева/справа"                
                    Style="{StaticResource CompareButtonStyle}" PreviewMouseDown="ToggleOrientation" />
        </Grid>
    </Grid>
</UserControl>
