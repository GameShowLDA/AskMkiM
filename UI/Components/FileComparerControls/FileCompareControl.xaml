<UserControl x:Class="UI.Components.FileComparerControls.FileCompareControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components.FileComparerControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="Transparent">

    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Margin" Value="5"/>

        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel x:Name="TopPanel" 
            Grid.Row="0" 
            Grid.ColumnSpan="5"
            Background="{StaticResource SecondarySolidColorBrush}"  
            Orientation="Horizontal" 
            />
        <DockPanel x:Name="ContentPanel" Grid.Row="2" Grid.ColumnSpan="5" Background="{StaticResource PrimarySolidColorBrush}"/>
        <Button Name="ChangeFirstFile" Grid.Row="1" Grid.Column="0" Content="Сохранить" 
                Style="{StaticResource ConfigButtonStyle}" 
                Width="Auto"
                Height="40"
                Margin="5"
                />

        <Button Name="ChangeSecondFile" Grid.Row="1" Grid.Column="1" Content="Сохранить" 
        Style="{StaticResource ConfigButtonStyle}" 
        Width="250" HorizontalAlignment="Left" 
        Margin="20,0"
        />

        <Button Name="CompareFiles" Grid.Row="1" Grid.Column="2" Content="Сохранить" 
        Style="{StaticResource ConfigButtonStyle}" 
        Width="250" HorizontalAlignment="Left" 
        Margin="20,0"
        />

        <Button Name="UpDown" Grid.Row="1" Grid.Column="3" Content="Сохранить" 
        Style="{StaticResource ConfigButtonStyle}" 
        Width="250" HorizontalAlignment="Left" 
        Margin="20,0"
        />

        <Button Name="LeftRight" Grid.Row="1" Grid.Column="4" Content="Сохранить" 
        Style="{StaticResource ConfigButtonStyle}" 
        Width="250" HorizontalAlignment="Left" 
        Margin="20,0"
        />
    </Grid>
</UserControl>
