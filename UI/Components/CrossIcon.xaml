<UserControl x:Class="UI.Components.CrossIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root"
             Width="{Binding Size, ElementName=root}"
             Height="{Binding Size, ElementName=root}">
    <Viewbox Stretch="Fill">
        <Grid Width="100" Height="100">
            <Ellipse Fill="#F44336" Width="100" Height="100"/>
            <!-- Крестик -->
            <Path Stroke="#1E1E1E" StrokeThickness="16" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 30,30 L 70,70 M 70,30 L 30,70"/>
        </Grid>
    </Viewbox>
</UserControl>