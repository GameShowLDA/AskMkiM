<UserControl x:Class="UI.Components.InputField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="250">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border  Margin="5" Grid.Row="0" Background="{StaticResource ActiveBorderSolidColorBrush}" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock 
                    Name="headerFirstData" 
                    FontFamily="{DynamicResource WinstonMedium}" 
                    TextWrapping="Wrap" TextTrimming="None" 
                    Text="{Binding Source={StaticResource Point_StartingPoint}, Path=Value}" FontSize="18" 
                    Foreground="{StaticResource ForegroundSolidColorBrush}"  
                    Margin="0,5" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Padding="5"/>
                <local:TextBoxPlaceholder Grid.Row="1" FontFamily="{DynamicResource WinstonLight}" x:Name="FirstTextBox" Placeholder="Введите значение..." Text="1.1.1" Height="40" Background="{StaticResource LightPrimarySolidColorBrush}"/>
            </Grid>
        </Border>

        <Border  Margin="5" Grid.Row="1" Background="{StaticResource ActiveBorderSolidColorBrush}" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock 
                    Name="headerSecondData" 
                    FontFamily="{DynamicResource WinstonMedium}" 
                    TextWrapping="Wrap" 
                    TextTrimming="None" 
                    Text="{Binding Source={StaticResource Point_FinalPoint}, Path=Value}"
                    FontSize="18" Foreground="{StaticResource ForegroundSolidColorBrush}" Margin="0,5" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="5"/>
                <local:TextBoxPlaceholder x:Name="SecondTextBox" FontFamily="{DynamicResource WinstonLight}" Grid.Row="1" Placeholder="Введите значение..." Text="1.1.100" Height="40" Background="{StaticResource LightPrimarySolidColorBrush}"/>
            </Grid>
        </Border>


        <Border  Margin="5" Grid.Row="2" Background="{StaticResource ActiveBorderSolidColorBrush}" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Name="headerElectricalData" FontFamily="{DynamicResource WinstonMedium}" TextWrapping="Wrap" TextTrimming="None" Text="Электрический параметр" FontSize="18" Foreground="{StaticResource ForegroundSolidColorBrush}" Margin="0,5" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="5"/>
                <local:TextBoxPlaceholder x:Name="ElectricalTextBox" Grid.Row="2" Placeholder="Введите значение..." Height="40" FontFamily="{DynamicResource WinstonLight}"
                                           Unit="{Binding UnitElectrical, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource LightPrimarySolidColorBrush}"/>
            </Grid>
        </Border>

        <Border  Margin="5" Grid.Row="3" Background="{StaticResource ActiveBorderSolidColorBrush}" CornerRadius="10"
                 Visibility="{Binding IsTimeVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                 >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="headerTimeData" FontFamily="{DynamicResource WinstonMedium}" TextWrapping="Wrap" TextTrimming="None" Text="Время выполнения в сек." FontSize="18" Foreground="{StaticResource ForegroundSolidColorBrush}" Margin="0,5" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="5"/>
                <local:TextBoxPlaceholder x:Name="TimeTextBox" Grid.Row="1" Placeholder="от 1 до 999 сек."  Height="40" FontFamily="{DynamicResource WinstonLight}" Background="{StaticResource LightPrimarySolidColorBrush}" Unit=",сек."/>
            </Grid>
        </Border>


        <Border  Margin="5" Grid.Row="4" Background="{StaticResource ActiveBorderSolidColorBrush}" CornerRadius="10"
                 Visibility="{Binding IsTimeRampVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                 >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="headerTimeRampData" FontFamily="{DynamicResource WinstonMedium}" TextWrapping="Wrap" TextTrimming="None" Text="Время нарастания в сек." FontSize="18" Foreground="{StaticResource ForegroundSolidColorBrush}" Margin="0,5" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="5" />
                <local:TextBoxPlaceholder x:Name="TimeRampTextBox" Grid.Row="4" Placeholder="от 0.1 до 999.9 сек." Unit=",сек." Height="40" FontFamily="{DynamicResource WinstonLight}" Background="{StaticResource LightPrimarySolidColorBrush}"/>
            </Grid>
        </Border>


        <Border  Margin="5" Grid.Row="5" Background="{StaticResource ActiveBorderSolidColorBrush}" CornerRadius="10"
                  Visibility="{Binding IsVoltageVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                 >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="headerVoltageData" FontFamily="{DynamicResource WinstonMedium}" TextWrapping="Wrap" TextTrimming="None" Text="Напряжение в В." FontSize="18" Foreground="{StaticResource ForegroundSolidColorBrush}" Margin="0,5" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="5"/>
                <local:TextBoxPlaceholder x:Name="VoltageTextBox" Grid.Row="5" Placeholder="Введите значение..." Unit=",В." Height="40" FontFamily="{DynamicResource WinstonLight}" Background="{StaticResource LightPrimarySolidColorBrush}"/>
            </Grid>
        </Border>

        <Border Margin="5" Grid.Row="6" Background="{StaticResource ActiveBorderSolidColorBrush}" CornerRadius="10"
                  Visibility="{Binding IsBusVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Name="headerBusData" FontFamily="{DynamicResource WinstonMedium}"  TextWrapping="Wrap" TextTrimming="None"  Text="Шина для проверки" FontSize="18" Foreground="{StaticResource ForegroundSolidColorBrush}" Margin="0,5" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="5"/>
                <Border Name="BusBorder" Grid.Row="1" Background="{StaticResource LightPrimarySolidColorBrush}" CornerRadius="10" Margin="0,5,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>

                        <CheckBox x:Name="ShinaACheckBox" VerticalAlignment="Center" Style="{StaticResource AnimatedSwitch}" HorizontalAlignment="Left" Width="20" Checked="Switch_Checked" Unchecked="Switch_Unchecked" Margin="5" />
                        <TextBlock Text="Шина A" FontFamily="{DynamicResource WinstonMedium}" Grid.Column="1" Foreground="{StaticResource ForegroundSolidColorBrush}" VerticalAlignment="Center" FontSize="18" Padding="5"/>

                        <CheckBox x:Name="ShinaBCheckBox" Grid.Row="1" VerticalAlignment="Center" Style="{StaticResource AnimatedSwitch}" HorizontalAlignment="Left" Width="20" Checked="Switch_Checked" Unchecked="Switch_Unchecked" Margin="5"/>
                        <TextBlock Grid.Row="1" FontFamily="{DynamicResource WinstonMedium}" Text="Шина B" Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource ForegroundSolidColorBrush}" FontSize="18" Padding="5"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>

</UserControl>
