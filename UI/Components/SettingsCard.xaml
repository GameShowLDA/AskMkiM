<UserControl x:Class="UI.Components.SettingsCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="84" d:DesignWidth="320" MaxWidth="300">
    <UserControl.Resources>
        <!-- Палитра по твоему UI -->
        <SolidColorBrush x:Key="CardBorder"     Color="#415163"/>
        <SolidColorBrush x:Key="TitleBrush"     Color="#E7EDF4"/>
        <SolidColorBrush x:Key="DescBrush"      Color="#A9B5C3"/>
        <SolidColorBrush x:Key="CheckBg"        Color="#2B333D"/>
        <SolidColorBrush x:Key="CheckBorder"    Color="#415163"/>

        <!-- Стиль чекбокса под макет -->
        <Style x:Key="SettingsCheckBox" TargetType="CheckBox">
            <!-- компактный размер + выравнивание -->
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <!-- размер берём у самого CheckBox -->
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"
              SnapsToDevicePixels="True">
                            <!-- база -->
                            <Border x:Name="Box"
                                Background="{StaticResource SecondarySolidColorBrush}"
                                BorderBrush="#415163"
                                BorderThickness="1"
                                CornerRadius="4"
                                SnapsToDevicePixels="True"
                                RenderOptions.EdgeMode="Aliased"/>
                            <!-- опциональный лёгкий внутренний блик для объёма -->
                            <Border x:Name="Inset"
                                CornerRadius="4"
                                BorderThickness="1"
                                BorderBrush="#20FFFFFF"
                                IsHitTestVisible="False"/>

                           
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Checked -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource ActiveBorderSolidColorBrush}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource ActiveForegroundSolidColorBrush80}"/>
                            </Trigger>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#50657B"/>
                            </Trigger>

                            <!-- Pressed (слегка темнее) -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource ActiveForegroundSolidColorBrush80}"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Box" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- Карточка -->
    <Border Background="{StaticResource SecondarySolidColorBrush}"
          BorderBrush="{StaticResource CardBorder}"
          BorderThickness="1"
          CornerRadius="14"
          Padding="10"
          SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Чекбокс слева: привязываем к DP IsChecked -->
            <CheckBox Grid.Column="0"
                Style="{StaticResource SettingsCheckBox}"
                IsChecked="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                      Cursor="Hand"
                      />

            <!-- Текстовый блок справа -->
            <Grid Grid.Column="2" x:Name="TextHost" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
             Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
             FontSize="15"
             FontWeight="SemiBold"
             Foreground="{StaticResource TitleBrush}"
             Margin="0,0,0,2"
             FontFamily="{DynamicResource WinstonMedium}"
             TextWrapping="Wrap"/>

                <TextBlock Grid.Row="1"
             Text="{Binding Description, RelativeSource={RelativeSource AncestorType=UserControl}}"
             FontSize="12"
             Foreground="{StaticResource DescBrush}"
             TextWrapping="Wrap"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
