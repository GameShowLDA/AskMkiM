<UserControl x:Class="UI.Components.PlusButtonControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components"
             mc:Ignorable="d" 
             Width="30" Height="30" Foreground="White" FontSize="3">
    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
     StrokeThickness="{Binding FontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
     Data="M 0.2,0.5 L 0.8,0.5 M 0.5,0.2 L 0.5,0.8"
     Stretch="Fill"
     HorizontalAlignment="Stretch"
     VerticalAlignment="Stretch"
     StrokeStartLineCap="Round"
     StrokeEndLineCap="Round"
     Margin="6"/>
</UserControl>
