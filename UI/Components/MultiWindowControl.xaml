<UserControl x:Class="UI.Components.MultiWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Верхняя панель -->
            <RowDefinition Height="*"/>
            <!-- Контейнер редакторов -->
            <RowDefinition Height="5"/>
            <!-- Разделитель -->
            <RowDefinition Height="0" x:Name="SearchResultsRow"/>
            <!-- Окно поиска -->
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <StackPanel x:Name="TopPanel" Grid.Row="0" Background="Gray" Orientation="Horizontal"/>

        <!-- Контейнер для редакторов -->
        <local:MultiEditorControl x:Name="MultiEditor" Grid.Row="1"/>

            <!-- Разделитель -->
        <GridSplitter Grid.Row="2" Height="5" Background="Gray"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      ShowsPreview="True" DragDelta="GridSplitter_DragDelta"/>

        <!-- Окно результатов поиска -->
        <Border x:Name="SearchResults" Grid.Row="3" Background="LightGray" Visibility="Collapsed">
            <DataGrid x:Name="ResultsDataGrid"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          IsReadOnly="True"
          ClipboardCopyMode="None"
          SelectionMode="Single"
          HeadersVisibility="Column"
          Background="Transparent"
          PreviewMouseDoubleClick="ResultsDataGrid_PreviewMouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Документ" Binding="{Binding FileName}" Width="200"/>
                    <DataGridTextColumn Header="Строка" Binding="{Binding LineNumber}" Width="100"/>
                    <DataGridTextColumn Header="Текст" Binding="{Binding LineText}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Кнопка "Результаты поиска" (когда панель скрыта) -->
        <Border x:Name="ShowResultsPanel" Grid.Row="3" Height="30" Background="Gray"
                Visibility="Collapsed" MouseDown="ShowResultsPanel_MouseDown">
            <TextBlock Text="Результаты поиска для: ..." FontSize="14" Foreground="White"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
