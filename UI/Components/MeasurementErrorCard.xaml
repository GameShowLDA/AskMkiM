<UserControl x:Class="UI.Components.MeasurementErrorCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components"
             mc:Ignorable="d" 
             d:DesignHeight="220" d:DesignWidth="300">
    <Border Background="{StaticResource ActiveBorderSolidColorBrush}" CornerRadius="20">
        <Border Background="{StaticResource PrimarySolidColorBrush}" CornerRadius="20" Margin="5,0,0,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TitleTextBlock" Text="Команда" FontSize="20" FontWeight="Bold" Foreground="White" Grid.Row="0" VerticalAlignment="Center"/>

                <Grid Grid.Row="1" Margin="0,10,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <local:TextBoxPlaceholder VerticalAlignment="Center" Margin="0,0,5,0" Height="40" Background="{StaticResource SecondarySolidColorBrush}"/>
                    <TextBlock Text="%" VerticalAlignment="Center" Foreground="White" Grid.Column="1" FontSize="16"/>
                </Grid>

                <!-- Числовая погрешность -->
                <Grid Grid.Row="2" Margin="0,10,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <local:TextBoxPlaceholder VerticalAlignment="Center" Margin="0,0,5,0" Height="40" Background="{StaticResource SecondarySolidColorBrush}"/>
                    <TextBlock x:Name="UnitTextBlock" Text="..." VerticalAlignment="Center" Foreground="White" Grid.Column="1" FontSize="16"/>
                </Grid>


                <!-- Кнопка -->
                <Button Content="Сохранить"  Grid.Row="3" Style="{StaticResource CompareButtonStyle}" Margin="0,10" />

            </Grid>
        </Border>
    </Border>
</UserControl>
