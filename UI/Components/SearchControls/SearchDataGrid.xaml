<UserControl x:Class="UI.Components.SearchControls.SearchDataGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components.SearchControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             >
    <UserControl.Resources>
        <local:SearchHighlightConverter x:Key="SearchHighlightConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <!-- Фиксированная шапка DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Прокручиваемая область DataGrid -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Фиксированная шапка DataGrid -->
        <DataGrid x:Name="ResultsHeaderGrid"
    AutoGenerateColumns="False"
    CanUserAddRows="False"
    CanUserDeleteRows="False"
    IsReadOnly="True"
    HeadersVisibility="Column"
    RowHeaderWidth="0"
    Background="Transparent"
    Grid.Row="0"
    BorderThickness="0"
    ScrollViewer.CanContentScroll="True"
    ScrollViewer.HorizontalScrollBarVisibility="Hidden"
    ScrollViewer.VerticalScrollBarVisibility="Hidden"
          CanUserResizeColumns="False"
          CanUserReorderColumns="False"
          >
            <DataGrid.Columns>
                <DataGridTextColumn Header="Строка" Width="100"/>
                <DataGridTextColumn Header="Текст" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <DataGrid x:Name="ResultsDataGrid"
          Grid.Row="1"
        AutoGenerateColumns="False"
        CanUserAddRows="False"
        CanUserDeleteRows="False"
        IsReadOnly="True"
        HeadersVisibility="None"
        RowHeaderWidth="0"
        Background="{StaticResource PrimarySolidColorBrush}"
        BorderThickness="0"
        VerticalAlignment="Top"
        EnableRowVirtualization="False"
        PreviewMouseDoubleClick="ResultsDataGrid_PreviewMouseDoubleClick"
        ScrollViewer.CanContentScroll="True">
            <DataGrid.Resources>
                <Style TargetType="DataGridRow">
                    <EventSetter Event="RequestBringIntoView" Handler="ResultsDataGrid_RequestBringIntoView"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding LineNumber}" Width="100" />
                <DataGridTemplateColumn Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <local:HighlightingTextBlock TextWrapping="Wrap"
                                     TextTrimming="CharacterEllipsis"
                                     MainText="{Binding SubstringFromWord}"
                                     HighlightText="{Binding SearchText}"
                                     HighlightBrush= "#b23a48"
                                     IsCaseSensitive="{Binding IsCaseSensitive}"
                                     IsWholeWord="{Binding IsWholeWord}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
