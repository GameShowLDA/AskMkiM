<UserControl x:Class="UI.Components.SearchControls.SearchArrow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components.SearchControls"
             mc:Ignorable="d" 
             d:DesignHeight="20" d:DesignWidth="20">
    <Grid>
        <Path x:Name="searchArrow" Stroke="{StaticResource ForegroundSolidColorBrush}" Fill="Transparent"
                Data="
                     M 2 10 L 18 10   
                     M 15 8 L 18 10 L 15 12"
               StrokeThickness="1"/>

    </Grid>
</UserControl>
