<UserControl x:Class="UI.Components.SearchControls.SearchSliderHandle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="16" d:DesignWidth="20">
    <Grid Background="Transparent" Cursor="SizeWE" Width="20" Height="16">
        <Grid.Resources>
            <Geometry x:Key="SliderHandleGeometry">
                M 3 8 L 8 8 M 6 5 L 2 8 L 6 11
                M 8 8 L 12 8
                M 12 8 L 17 8 M 14 5 L 18 8 L 14 11
            </Geometry>
        </Grid.Resources>
        <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Path Data="{StaticResource SliderHandleGeometry}"
                  Stroke="{StaticResource ForegroundSolidColorBrush}"
                  Fill="Transparent"
                  StrokeThickness="2"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Width="20"
                  Height="20"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"/>
        </Viewbox>
    </Grid>
</UserControl>
