<UserControl x:Class="UI.Components.SearchControls.SearchArrows"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components.SearchControls"
             mc:Ignorable="d" 
             d:DesignHeight="20" d:DesignWidth="20">
    <Grid Background="Transparent">
        <ComboBox x:Name="searchArrowsComboBox"
                  Width="45"
                  Height="20"
                  SelectedValuePath="GeometryData"
                  SelectedIndex="0"
                  Foreground="{StaticResource ForegroundSolidColorBrush}"
                  Background="Transparent"
                  BorderThickness="0"
                  Margin="-4,-1,-21,1"
                  PreviewMouseDown="searchArrowsComboBox_PreviewMouseDown"
                  SelectionChanged="searchArrowsComboBox_SelectionChanged"
                  > 

            <!-- Шаблон для стрелок в выпадающем списке -->
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <Path Stroke="{StaticResource ForegroundSolidColorBrush}"
                          Fill="Transparent"
                          Data="{Binding GeometryData}"
                          ToolTip="{Binding Description}"
                          StrokeThickness="2"
                          Width="20"
                          Height="20"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>

            <!-- Шаблон для отображения выбранного элемента -->
            <ComboBox.Template>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- Отображение выбранной стрелки -->
                        <Border
                            x:Name="ComboBoxBorder"
                                Background="Transparent"
                            MouseEnter="ComboBoxBorder_MouseEnter"
                            MouseLeave="ComboBoxBorder_MouseLeave"
                                Cursor="Hand">
                            <ContentPresenter x:Name="PART_ContentPresenter"
                                 Content="{Binding Path=SelectedItem, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                 ContentTemplate="{TemplateBinding ItemTemplate}"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"
                                 Margin="5,3"
                                 Cursor="Hand"
                                 Focusable="False"
                          PreviewMouseDown="PART_ContentPresenter_PreviewMouseDown"
                            />
                        </Border>


                        <!-- Кнопка раскрытия списка -->
                        <ToggleButton x:Name="ComboBoxToggleButton"
                          Width="20"
                          Height="20"
                          HorizontalAlignment="Right"
                          Content="▼"
                          Foreground="{StaticResource ForegroundSolidColorBrush}"
                          Background="Transparent"
                          BorderThickness="0"
                          Focusable="False"
                          Cursor="Hand"
                          Tag="ListElements"
                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                          MouseEnter="ComboBoxToggleButton_MouseEnter"
                          MouseLeave="ComboBoxToggleButton_MouseLeave"/>

                        <!-- Выпадающий список -->
                        <Popup x:Name="PART_Popup"
                   Placement="Bottom"
                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                   Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                   StaysOpen="False">
                            <Border BorderThickness="0" Background="{StaticResource SecondarySolidColorBrush}">
                                <ScrollViewer>
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ComboBoxToggleButton" Property="Foreground" Value="{StaticResource SecondarySolidColorBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ComboBox.Template>
        </ComboBox>
    </Grid>
</UserControl>
