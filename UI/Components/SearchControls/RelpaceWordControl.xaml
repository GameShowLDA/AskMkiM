<UserControl x:Class="UI.Components.SearchControls.ReplaceWordControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression.blend/2008"
             xmlns:local="clr-namespace:UI.Components.SearchControls"
             mc:Ignorable="d"
             d:DesignHeight="25" d:DesignWidth="25" Width="25" Height="25">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Верхний текст (B) -->
        <TextBlock Grid.Column="1" 
                   FontSize="14" FontWeight="Bold"
                   Foreground="White"
                   VerticalAlignment="Center" HorizontalAlignment="Center">B</TextBlock>

        <!-- Нижний текст (C) -->
        <TextBlock Grid.Row="1"
                   FontSize="14" FontWeight="Bold"
                   Foreground="White"
                   VerticalAlignment="Center" HorizontalAlignment="Center">C</TextBlock>

        <!-- Тонкая угловатая стрелка -->
    </Grid>
</UserControl>
