<UserControl x:Class="UI.Components.SearchControls.WholeWordToggleButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression.blend/2008"
             xmlns:local="clr-namespace:UI.Components.SearchControls"
             mc:Ignorable="d"
             d:DesignHeight="40" d:DesignWidth="40">

    <Grid>
        <Border x:Name="ButtonBorder"
                BorderThickness="0"
                BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Background="Transparent">
            <Button x:Name="ToggleButton"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Cursor="Hand"
                    Focusable="False"
                    Click="ToggleButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Rectangle Fill="Transparent"/>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="LabelText"
                                           Text="АЫ"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           HorizontalAlignment="Center"/>
                                <Rectangle Width="18" Height="2" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Меняем цвет при наведении -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LabelText" Property="Foreground"
                                        Value="{Binding HoverTextColor, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Border>
    </Grid>
</UserControl>
