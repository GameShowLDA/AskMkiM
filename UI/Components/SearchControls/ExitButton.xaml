<UserControl x:Class="UI.Components.SearchControls.ExitButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components.SearchControls"
             mc:Ignorable="d" 
             d:DesignHeight="25" d:DesignWidth="25"
             Width="25" Height="25">
    <Border Background="Transparent" Margin="2" CornerRadius="10" x:Name="BackgroundBorder">
        <Grid x:Name="CrossGrid">
            <!-- Первая линия -->
            <Rectangle x:Name="CrossLine1" Width="15" Height="2" 
                       Fill="{StaticResource ForegroundSolidColorBrush}" 
                       RadiusX="1.5" RadiusY="1.5"
                       RenderTransformOrigin="0.5,0.5" 
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                <Rectangle.RenderTransform>
                    <RotateTransform Angle="45"/>
                </Rectangle.RenderTransform>
            </Rectangle>

            <!-- Вторая линия -->
            <Rectangle x:Name="CrossLine2" Width="15" Height="2" 
                       Fill="{StaticResource ForegroundSolidColorBrush}" 
                       RadiusX="1.5" RadiusY="1.5"
                       RenderTransformOrigin="0.5,0.5" 
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                <Rectangle.RenderTransform>
                    <RotateTransform Angle="-45"/>
                </Rectangle.RenderTransform>
            </Rectangle>
        </Grid>

        <!-- Перенесли стили на `Grid` -->
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="Transparent"/>
                        <!-- Можно убрать -->
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
    </Border>

    <!-- Триггеры для смены цвета крестика -->
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
            <BeginStoryboard>
                <Storyboard>
                    <ColorAnimation Storyboard.TargetName="CrossLine1" 
                                    Storyboard.TargetProperty="Fill.Color"
                                    To="{StaticResource WindowButtonActiveForegroundColor}" 
                                    Duration="0:0:0.2"/>
                    <ColorAnimation Storyboard.TargetName="CrossLine2" 
                                    Storyboard.TargetProperty="Fill.Color"
                                    To="{DynamicResource WindowButtonActiveForegroundColor}" 
                                    Duration="0:0:0.2"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>

        <EventTrigger RoutedEvent="MouseLeave">
            <BeginStoryboard>
                <Storyboard>
                    <ColorAnimation Storyboard.TargetName="CrossLine1" 
                                    Storyboard.TargetProperty="Fill.Color"
                                    To="{StaticResource ForegroundSolidColorBrush}" 
                                    Duration="0:0:0.2"/>
                    <ColorAnimation Storyboard.TargetName="CrossLine2" 
                                    Storyboard.TargetProperty="Fill.Color"
                                    To="{StaticResource ForegroundSolidColorBrush}" 
                                    Duration="0:0:0.2"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>
