<UserControl x:Class="UI.Components.MenuButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="40" Foreground="White" Background="Transparent">

    <UserControl.Resources>
        <Style TargetType="Border">
            <Setter Property="Background" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Path=Foreground}"/>
        </Style>
    </UserControl.Resources>
    <Grid MouseEnter="Grid_MouseEnter" MouseLeave="Grid_MouseLeave">
        <Grid.RowDefinitions>
            <RowDefinition Height="8"/>
            <RowDefinition/>
            <RowDefinition Height="4"/>
            <RowDefinition/>
            <RowDefinition Height="4"/>
            <RowDefinition/>
            <RowDefinition Height="8"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1" Margin="0,0,10,0"/>
        <Border Grid.Row="3" Margin="0,0,0,0"/>
        <Border Grid.Row="5" Margin="0,0,10,0"/>
    </Grid>
</UserControl>
