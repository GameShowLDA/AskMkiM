<UserControl x:Class="UI.Components.DateControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Components"
             mc:Ignorable="d" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             
             d:DesignHeight="30" d:DesignWidth="80" >
    <Grid>
        <TextBlock
            x:Name="Date"
            Text="00.00.0000"
            FontFamily="{DynamicResource WinstonMedium}"
            Foreground="{StaticResource ForegroundSolidColorBrush}"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Cursor="Hand"
            MouseLeftButtonUp="Date_MouseLeftButtonDown"
        />
        <Popup x:Name="CalendarPopup"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border>
                <Calendar x:Name="CalendarControl"/>
            </Border>
        </Popup>
    </Grid>
</UserControl>
