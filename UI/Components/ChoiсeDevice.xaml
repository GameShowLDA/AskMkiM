<UserControl x:Class="UI.Components.ChoiceDevice"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="300">
    <Border CornerRadius="10"
          Background="{StaticResource PrimarySolidColorBrush}">
        <Grid>
            <ToggleButton x:Name="toggleButton"
                    Content="{Binding SelectedDisplayText}"
                    Cursor="Hand"
                    Foreground="White"
                    FontSize="16"
                    BorderThickness="0"
                    Padding="8"
                    Background="Transparent"
                    Checked="toggleButton_Checked"
                    Unchecked="toggleButton_Unchecked"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center" />

            <Popup x:Name="popup"
             IsOpen="{Binding IsChecked, ElementName=toggleButton}"
             StaysOpen="True"
             Placement="Bottom"
             AllowsTransparency="True"
             PlacementTarget="{Binding ElementName=toggleButton}">
                <Border Background="{StaticResource PrimarySolidColorBrush}"
                CornerRadius="8"
                BorderBrush="Gray"
                BorderThickness="1"
                MinWidth="200">
                    <ListView x:Name="deviceList"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="White"
                    SelectionChanged="deviceList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Padding="8" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
