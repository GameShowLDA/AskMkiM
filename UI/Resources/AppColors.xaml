    <SolidColorBrush x:Key="LightPrimarySolidColorBrush" Color="{DynamicResource LightPrimaryColor}"/>
    <SolidColorBrush x:Key="PrimarySolidColorBrush" Color="{DynamicResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondarySolidColorBrush" Color="{DynamicResource SecondaryColor}"/>
    <SolidColorBrush x:Key="ForegroundSolidColorBrush" Color="{DynamicResource ForegroundColor}"/>
    <SolidColorBrush x:Key="ForegroundSolidColorBrush60" Color="{DynamicResource ForegroundColor60}"/>
    <SolidColorBrush x:Key="ForegroundSolidColorBrush80" Color="{DynamicResource ForegroundColor80}"/>
    <SolidColorBrush x:Key="ActiveForegroundSolidColorBrush80" Color="{DynamicResource ActiveColor80}"/>
    <SolidColorBrush x:Key="ActiveForegroundSolidColorBrush" Color="{DynamicResource ActiveColor}"/>
    <SolidColorBrush x:Key="ActiveBorderSolidColorBrush" Color="{DynamicResource ActiveColor}"/>
    <SolidColorBrush x:Key="IsCheckedColorSolidColorBrush" Color="{DynamicResource IsCheckedColor}"/>
    <SolidColorBrush x:Key="IsCheckedColorSolidColorBrush80" Color="{DynamicResource IsCheckedColor80}"/>
    <SolidColorBrush x:Key="RedColorSolidColorBrush" Color="{DynamicResource RedColor}"/>
    <SolidColorBrush x:Key="GreenColorSolidColorBrush" Color="{DynamicResource GreenColor}"/>
    <SolidColorBrush x:Key="YellowColorSolidColorBrush" Color="{DynamicResource YellowColor}"/>
    <SolidColorBrush x:Key="LightBlueColorSolidColorBrush" Color="{DynamicResource LightBlueColor}"/>
    <SolidColorBrush x:Key="FadedRedSolidColorBrush" Color="{DynamicResource FadedRed}"/>

</ResourceDictionary>