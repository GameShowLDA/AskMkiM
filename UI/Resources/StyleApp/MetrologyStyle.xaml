<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:CustomControls="clr-namespace:UI.Components" 
                    >

    <!--#region Стили метрологии -->

    <!--Границы полей ввода-->
    <Style x:Key="MetrologyTextBoxBorder" TargetType="Border">
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SecondarySolidColorBrush}"/>
        <Setter Property="Margin" Value="0,0,0,15"/>
    </Style>

    <!--Поля ввода-->
    <Style x:Key="MetrologyTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CaretBrush" Value="{DynamicResource ForegroundSolidColorBrush}"/>
    </Style>

    <!--#region Стили кнопки меню -->
    <Style x:Key="MenuButtonActive" TargetType="CustomControls:MenuButton">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource ActiveForegroundSolidColorBrush}"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <!--#endregion-->

    <!--#region Текст метрологии -->
    <Style x:Key ="MetrologyTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
    </Style>
    <!--#endregion-->

    <!--#endregion-->

</ResourceDictionary>