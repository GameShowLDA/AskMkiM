<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="DataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource SecondarySolidColorBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource SecondarySolidColorBrush}"/>
        <Setter Property="RowBackground" Value="{DynamicResource SecondarySolidColorBrush}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource ActiveBorderSolidColorBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
        <Setter Property="Padding" Value="7"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ForegroundSolidColorBrush}"/>
        <Setter Property="BorderThickness" Value="0.5"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="18"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Height" Value="30"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Background" Value="{DynamicResource PrimarySolidColorBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Bottom"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Padding="{TemplateBinding Padding}" 
                    BorderBrush="{DynamicResource PrimarySolidColorBrush}"
                    BorderThickness="0"
                    Background="{DynamicResource PrimarySolidColorBrush}">
                        <ContentPresenter
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Left"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#1f242b"/>
                <Setter Property="Foreground" Value="{DynamicResource ActiveForegroundSolidColorBrush}"/>
                <Setter Property="Height" Value="30"/>
                <Setter Property="VerticalContentAlignment" Value="Bottom"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="False">
                <Setter Property="Background" Value="{DynamicResource SecondarySolidColorBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridRow" >
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Background" Value="{DynamicResource SecondarySolidColorBrush}"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="VerticalContentAlignment" Value="Bottom"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Trigger>

            <Trigger Property="IsSelected" Value="False">
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Admin DB table styles -->
    <Style x:Key="AdminDbDataGridTextStyle" TargetType="TextBlock">
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="{DynamicResource WinstonLight}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="ToolTip" Value="{Binding}"/>
    </Style>

    <Style x:Key="AdminDbDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource SecondarySolidColorBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontFamily" Value="{DynamicResource WinstonMedium}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <Style x:Key="AdminDbDataGridCellStyle" TargetType="DataGridCell">
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ForegroundSolidColorBrush60}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource SettingsInteractiveHoverSolidColorBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AdminDbDataGridRowStyle" TargetType="DataGridRow">
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ForegroundSolidColorBrush60}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ActiveForegroundSolidColorBrush80}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource SettingsInteractiveHoverSolidColorBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AdminDbScrollBarThumbStyle" TargetType="Thumb">
        <Setter Property="Background" Value="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="MinWidth" Value="20"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Margin="2"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource SettingsInteractiveHoverSolidColorBrush}"/>
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
                <Setter Property="Background" Value="{DynamicResource SettingsInteractivePressedSolidColorBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AdminDbScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Background" Value="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsInteractiveHoverSolidColorBrush}"/>
        <Setter Property="Width" Value="10"/>
        <Setter Property="Height" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" IsTabStop="False"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource AdminDbScrollBarThumbStyle}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" IsTabStop="False"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AdminDbDataGridStyle" TargetType="DataGrid" BasedOn="{StaticResource DataGrid}">
        <Setter Property="Background" Value="{DynamicResource PrimarySolidColorBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="RowBackground" Value="{DynamicResource PrimarySolidColorBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource SecondarySolidColorBrush}"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="RowHeaderWidth" Value="0"/>
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource AdminDbDataGridColumnHeaderStyle}"/>
        <Setter Property="CellStyle" Value="{StaticResource AdminDbDataGridCellStyle}"/>
        <Setter Property="RowStyle" Value="{StaticResource AdminDbDataGridRowStyle}"/>
        <Setter Property="FontFamily" Value="{DynamicResource WinstonLight}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="SelectionMode" Value="Extended"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="EnableColumnVirtualization" Value="True"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarStyle" Value="{StaticResource AdminDbScrollBarStyle}"/>
        <Setter Property="ScrollViewer.VerticalScrollBarStyle" Value="{StaticResource AdminDbScrollBarStyle}"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
    </Style>

</ResourceDictionary>
