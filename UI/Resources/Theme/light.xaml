<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:Controls ="clr-namespace:UI.Controls"
                    xmlns:avalonEdit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
                    xmlns:Components="clr-namespace:UI.Components">
    <!--#region Базовые стили -->
    <SolidColorBrush x:Key="ForegrounfBrushes" Color="#000000"/>
    <SolidColorBrush x:Key="ForegrounfBrushes35" Color="#000000" Opacity="0.35"/>
    <SolidColorBrush x:Key="ForegrounfBrushes45" Color="#000000" Opacity="0.45"/>
    <SolidColorBrush x:Key="ForegrounfBrushes85" Color="#000000" Opacity="0.85"/>
    
    <SolidColorBrush x:Key="BackgroundBrushes" Color="#dedddf"/>
    <SolidColorBrush x:Key="ActiveColorBrushes" Color="#90465945"/>
    <SolidColorBrush x:Key="SettingsMainBackground" Color="#E9E8E9"/>
    <!--#endregion-->

    <!--#region Главное окно -->

    <!--#region Кнопки свернуть, развернуть, закрыть -->

    <Style x:Key="StyleWindowsButtons" TargetType="Components:WindowButtons">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource ActiveColorBrushes}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--#endregion-->

    <!--#region Меню -->

    <Style x:Key="StyleTopMenu" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrushes}"/>
    </Style>

    <!-- ======= Главное меню ======= -->
    <Style x:Key="StyleMenuItem" TargetType="{x:Type MenuItem}">
        <!-- Базовые визуальные параметры -->
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="5,10,10,10"/>
        <Setter Property="Background" Value="{DynamicResource BackgroundBrushes}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Cursor" Value="Hand"/>

        <!-- Шаблон отображения MenuItem -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Grid SnapsToDevicePixels="True">
                        <DockPanel x:Name="ItemDockPanel" Background="Transparent">

                            <!-- Иконка (если задана) -->
                            <ContentPresenter x:Name="Icon"
                                              ContentSource="Icon"
                                              Margin="4,0,6,0"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                              VerticalAlignment="Center"/>

                            <!-- Дополнительный значок (галочка, стрелка и т.п.) -->
                            <Path x:Name="GlyphPanel"
                                  Fill="#000000"
                                  FlowDirection="LeftToRight"
                                  Margin="7,0,0,0"
                                  Visibility="Collapsed"
                                  VerticalAlignment="Center"/>

                            <!-- Основной текст -->
                            <TextBlock x:Name="HeaderText"
                                       Text="{TemplateBinding Header}"
                                       Foreground="{DynamicResource ForegrounfBrushes}"
                                       VerticalAlignment="Center"
                                       Margin="{TemplateBinding Padding}"/>

                            <!-- Горячая клавиша -->
                            <TextBlock x:Name="HotkeyText"
                                       Text="{Binding InputGestureText, RelativeSource={RelativeSource TemplatedParent}}"
                                       Foreground="{DynamicResource ForegrounfBrushes}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="10,0,10,0"/>
                        </DockPanel>

                        <!-- Подменю -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               HorizontalOffset="1"
                               VerticalOffset="-1"
                               Placement="Bottom"
                               IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}">
                            <Border Background="{TemplateBinding Background}">
                                <ScrollViewer x:Name="SubMenuScrollViewer"
                                              CanContentScroll="True"
                                              Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                    <Grid RenderOptions.ClearTypeHint="Enabled">
                                        <ItemsPresenter x:Name="ItemsPresenter"
                                                        KeyboardNavigation.DirectionalNavigation="Cycle"
                                                        Grid.IsSharedSizeScope="True"
                                                        Margin="2"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                        KeyboardNavigation.TabNavigation="Cycle"/>
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Триггеры -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemDockPanel" Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ItemDockPanel" Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ======= Боковое меню (на основе основного) ======= -->
    <Style x:Key="SideMenuItemStyle" TargetType="{x:Type MenuItem}" BasedOn="{StaticResource StyleMenuItem}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Grid SnapsToDevicePixels="True">
                        <DockPanel x:Name="ItemDockPanel" Background="Transparent">

                            <ContentPresenter x:Name="Icon"
                                              ContentSource="Icon"
                                              Margin="4,0,6,0"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                              VerticalAlignment="Center"/>

                            <Path x:Name="GlyphPanel"
                                  Fill="#000000"
                                  FlowDirection="LeftToRight"
                                  Margin="7,0,0,0"
                                  Visibility="Collapsed"
                                  VerticalAlignment="Center"/>

                            <TextBlock x:Name="HeaderText"
                                       Text="{TemplateBinding Header}"
                                       Foreground="{DynamicResource ForegrounfBrushes}"
                                       VerticalAlignment="Center"
                                       Margin="{TemplateBinding Padding}"/>

                            <TextBlock x:Name="HotkeyText"
                                       Text="{Binding InputGestureText, RelativeSource={RelativeSource TemplatedParent}}"
                                       Foreground="{DynamicResource ForegrounfBrushes}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="10,0,0,0"/>
                        </DockPanel>

                        <!-- Подменю -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               HorizontalOffset="0"
                               VerticalOffset="0"
                               Placement="Right"
                               IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}">
                            <Border Background="{TemplateBinding Background}">
                                <ScrollViewer x:Name="SubMenuScrollViewer"
                                              CanContentScroll="True"
                                              Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                    <Grid RenderOptions.ClearTypeHint="Enabled">
                                        <ItemsPresenter x:Name="ItemsPresenter"
                                                        KeyboardNavigation.DirectionalNavigation="Cycle"
                                                        Grid.IsSharedSizeScope="True"
                                                        Margin="2"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                        KeyboardNavigation.TabNavigation="Cycle"/>
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Триггеры -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemDockPanel" Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ItemDockPanel" Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ======= Разделитель между вкладками в подменю ======= -->
    <Style x:Key="SeparatorMenuStyle" TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
    </Style>

    <!--#endregion-->

    <!--#region Пустая область -->

    <!-- Центральное мягкое свечение -->
    <RadialGradientBrush x:Key="CenterGlowBrush"
                         ColorInterpolationMode="ScRgbLinearInterpolation"
                         RadiusX="0.55" RadiusY="0.55"
                         Center="0.52,0.60" GradientOrigin="0.52,0.60">
        <GradientStop Color="#26000000" Offset="0.00"/>
        <GradientStop Color="#00000000" Offset="1.00"/>
    </RadialGradientBrush>

    <!-- Виньетка по краям -->
    <RadialGradientBrush x:Key="VignetteBrush"
                         ColorInterpolationMode="ScRgbLinearInterpolation"
                         RadiusX="0.98" RadiusY="0.98"
                         Center="0.5,0.5" GradientOrigin="0.5,0.5">
        <GradientStop Color="#00000000" Offset="0.68"/>
        <GradientStop Color="#26000000" Offset="0.85"/>
        <GradientStop Color="#66000000" Offset="1.00"/>
    </RadialGradientBrush>

    <!-- Градиентный фон с «дыханием» -->
    <RadialGradientBrush x:Key="EmptyBackgroundBrush"
                         ColorInterpolationMode="ScRgbLinearInterpolation"
                         GradientOrigin="0.50,0.40"
                         Center="0.50,0.40"
                         RadiusX="1.20" RadiusY="1.20">
        <GradientStop Color="#EFEEF0" Offset="0.00"/>
        <GradientStop Color="#303843" Offset="1.00"/>
    </RadialGradientBrush>

    <!-- центральное свечение -->
    <Style x:Key="CenterGlowStyle" TargetType="Rectangle">
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Fill" Value="{DynamicResource CenterGlowBrush}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <BlurEffect Radius="4"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Приветственный блок -->
    <SolidColorBrush x:Key="MainGreetingBackgroundBrush" Color="#DEDDDF" />
    <SolidColorBrush x:Key="MainGreetingBorderBrush" Color="#000000" />
    <SolidColorBrush x:Key="MainTitleSolidColorBrush" Color="#000000" />

    <!--#endregion-->

    
    <!--#endregion-->

    <!--#region Настрйоки приложения -->

    <SolidColorBrush x:Key="SettingCardBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SettingCardBorderBrush" Color="#000000"/>
    
    <Style x:Key="SettingCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SettingCardBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingCardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
    </Style>

    <SolidColorBrush x:Key="SettingsTitleSolidColorBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SettingsDescriptionSolidColorBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SettingsHeaderSolidColorBrush" Color="#000000"/>

    <Style x:Key="SettingsTitleStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource SettingsTitleSolidColorBrush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource WinstonMedium}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="18"/>
    </Style>

    <Style x:Key="SettingsHeaderStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource SettingsTitleSolidColorBrush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource WinstonMedium}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="SettingsDescriptionStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource SettingsDescriptionSolidColorBrush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource WinstonLight}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!--#region Чек бокс и кнопки -->
    <SolidColorBrush x:Key="SettingsInteractiveBackgroundSolidColorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SettingsInteractiveBorderSolidColorBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SettingsInteractiveHoverSolidColorBrush" Color="#A4EB9E"/>
    <SolidColorBrush x:Key="SettingsInteractiveActiveSolidColorBrush" Color="#A4EB9E"/>
    <SolidColorBrush x:Key="SettingsInteractivePressedSolidColorBrush" Color="#79E171"/>
    <!--#endregion-->

    <!--#region Весь элемент управления настройками -->
    <SolidColorBrush x:Key="SettingsMainBackgroundSolidColorBrush" Color="#DDDDDD"/>

    <!--#endregion-->

    <!--#region Общая панель с настройками -->
    <SolidColorBrush x:Key="SettingsPanelBackgroundSolidColorBrush" Color="#EBEBEB"/>
    <SolidColorBrush x:Key="SettingsPanelBorderSolidColorBrush" Color="#EBEBEB"/>

    <Style x:Key="SettingPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SettingsPanelBackgroundSolidColorBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsPanelBorderSolidColorBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="15"/>
    </Style>
    <!--#endregion-->

    <!--#region Панель выбора -->

    <SolidColorBrush x:Key="SettingsSliderBackgroundSolidColorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SettingsSelectorBackgroundSolidColorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SettingsSelectorHoverSolidColorBrush" Color="#A4EB9E"/>
    <SolidColorBrush x:Key="SettingsSelectorSelectedSolidColorBrush" Color="#79E171"/>
    <SolidColorBrush x:Key="SettingsSliderBorderSolidColorBrush" Color="#000000"/>

    <!--#endregion-->

    <!--#region Конфигурация -->
    <SolidColorBrush x:Key="SettingsCongifButtonBackgroundSolidColorBrush" Color="#80A4EB9E"/>
    <SolidColorBrush x:Key="SettingsCongifButtonHoverBackgroundSolidColorBrush" Color="#A4EB9E"/>
    <SolidColorBrush x:Key="SettingsCongifButtonBorderSolidColorBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SettingsInfoTabloBackgroundSolidColorBrush" Color="#A4EB9E"/>
    <SolidColorBrush x:Key="SettingsConfigDataInputTabloBackgroundSolidColorBrush" Color="#FFFFFF"/>

    <!--#endregion-->

    <!--#endregion-->

    <!--#region Тектовый редактор -->

    <Style x:Key="StyleTextEditor" TargetType="avalonEdit:TextEditor">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#000000"/>
    </Style>

    <!--#endregion-->

    <!--#region Протокол оборудования -->

    <SolidColorBrush x:Key="TestsInputBackgroundInputPanelBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TestsInputBackgroundHeaderPanelBrush" Color="#A4EB9E"/>
    <SolidColorBrush x:Key="TestsMainPanelBackgroundBrush" Color="#DDDDDD"/>
    
    <SolidColorBrush x:Key="TestsMainButtonBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TestsMainButtonForegroundBrush" Color="#000000"/>

    <SolidColorBrush x:Key="TestsInputHeaderSolidColorBrush" Color="#000000"/>
    <SolidColorBrush x:Key="TestsInputDescriptionSolidColorBrush" Color="#000000"/>

    <SolidColorBrush x:Key="TestsMainButtonOrangeStartBrush" Color="#90F47842"/>
    <SolidColorBrush x:Key="TestsMainButtonOrangeEndBrush" Color="#90FCAA3F"/>

    <SolidColorBrush x:Key="TestsMainButtonGreenStartBrush" Color="#90459C3C"/>
    <SolidColorBrush x:Key="TestsMainButtonGreenEndBrush" Color="#9067C66E"/>

    <SolidColorBrush x:Key="TestsInteractiveBackgroundSolidColorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TestsInteractiveBorderSolidColorBrush" Color="#000000"/>
    <SolidColorBrush x:Key="TestsInteractivePressedSolidColorBrush" Color="#79E171"/>

    <SolidColorBrush x:Key="TestsProtocolBackgroundBrush" Color="#FFFFFF"/>
    
    <SolidColorBrush x:Key="TestsProtocolMessageSucces" Color="#2FA84F"/>
    <SolidColorBrush x:Key="TestsProtocolMessageError" Color="#F1301B"/>
    <SolidColorBrush x:Key="TestsProtocolHeaderForeground" Color="#000000"/>
    <SolidColorBrush x:Key="TestsProtocolMessageForeground" Color="#000000"/>
    <SolidColorBrush x:Key="TestsProtocolTimeForeground" Color="YellowGreen"/>

    <SolidColorBrush x:Key="ErrorListBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ErrorListHeaderBackground" Color="#DDDDDD"/>
    <SolidColorBrush x:Key="ErrorListSelection" Color="#264F78"/>

    <!--#endregion-->
    
</ResourceDictionary>