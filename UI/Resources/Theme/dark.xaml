    <!--#region Главное меню -->

    <!--#region Кнопки свернуть, развернуть, закрыть -->

    <Style x:Key="StyleWindowsButtons" TargetType="Components:WindowButtons">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource ActiveColorBrushes}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--#endregion-->

    <!--#region Меню -->

    <Style x:Key="StyleTopMenu" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrushes}"/>
    </Style>

    <!-- ======= Главное меню ======= -->
    <Style x:Key="StyleMenuItem" TargetType="{x:Type MenuItem}">
        <!-- Базовые визуальные параметры -->
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="5,10,10,10"/>
        <Setter Property="Background" Value="{DynamicResource MenuBackgroundBrushes}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Cursor" Value="Hand"/>

        <!-- Шаблон отображения MenuItem -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="ItemBg" Background="Transparent">
                            <Grid Margin="6,2,6,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="IconCol"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="ArrowCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="GestureCol"/>
                                </Grid.ColumnDefinitions>

                                <!-- Иконка (если задана) -->
                                <ContentPresenter x:Name="Icon"
                                                  Grid.Column="0"
                                                  ContentSource="Icon"
                                                  Margin="0,0,8,0"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                  VerticalAlignment="Center"/>

                                <!-- Основной текст -->
                                <TextBlock x:Name="HeaderText"
                                           Grid.Column="1"
                                           Text="{TemplateBinding Header}"
                                           Foreground="{DynamicResource ForegrounfBrushes}"
                                           VerticalAlignment="Center"
                                           Margin="{TemplateBinding Padding}"/>

                                <!-- Стрелка для подменю -->
                                <Path x:Name="GlyphPanel"
                                      Grid.Column="2"
                                      Width="6"
                                      Height="10"
                                      Stretch="Uniform"
                                      SnapsToDevicePixels="True"
                                      Stroke="{DynamicResource ForegrounfBrushes}"
                                      StrokeThickness="1.2"
                                      StrokeEndLineCap="Round"
                                      StrokeStartLineCap="Round"
                                      Opacity="0.75"
                                      FlowDirection="LeftToRight"
                                      Margin="8,0,4,0"
                                      Visibility="Collapsed"
                                      VerticalAlignment="Center">
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="ArrowRotate" Angle="0" CenterX="3" CenterY="5"/>
                                    </Path.RenderTransform>
                                </Path>

                                <!-- Горячая клавиша -->
                                <TextBlock x:Name="HotkeyText"
                                           Grid.Column="3"
                                           Text="{Binding InputGestureText, RelativeSource={RelativeSource TemplatedParent}}"
                                           Foreground="{DynamicResource ForegrounfBrushes}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="10,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Подменю -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               HorizontalOffset="1"
                               VerticalOffset="-1"
                               Placement="Bottom"
                               IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}">
                            <Border Background="{TemplateBinding Background}">
                                <ScrollViewer x:Name="SubMenuScrollViewer"
                                              CanContentScroll="True"
                                              Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                    <Grid RenderOptions.ClearTypeHint="Enabled">
                                        <ItemsPresenter x:Name="ItemsPresenter"
                                                        KeyboardNavigation.DirectionalNavigation="Cycle"
                                                        Grid.IsSharedSizeScope="True"
                                                        Margin="2"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                        KeyboardNavigation.TabNavigation="Cycle"/>
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Триггеры -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="Header" Value="">
                            <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes85}"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter TargetName="ItemBg" Property="CornerRadius" Value="8"/>
                            <Setter TargetName="HeaderText" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="Icon" Property="Grid.ColumnSpan" Value="4"/>
                            <Setter TargetName="Icon" Property="HorizontalAlignment" Value="Center"/>
                            <Setter TargetName="Icon" Property="VerticalAlignment" Value="Center"/>
                            <Setter TargetName="Icon" Property="Margin" Value="0"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Header" Value=""/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Header" Value=""/>
                                <Condition Property="IsKeyboardFocused" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                        </MultiTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBg" Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ItemBg" Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                        </Trigger>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="GlyphPanel" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="GlyphPanel" Property="Data" Value="M0,1 L4,5 L0,9"/>
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ArrowRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         To="90"
                                                         Duration="0:0:0.12"
                                                         FillBehavior="HoldEnd"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ArrowRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         To="0"
                                                         Duration="0:0:0.12"
                                                         FillBehavior="Stop"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ======= Боковое меню (на основе основного) ======= -->
    <Style x:Key="SideMenuItemStyle" TargetType="{x:Type MenuItem}" BasedOn="{StaticResource StyleMenuItem}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="ItemBg" Background="Transparent">
                            <Grid Margin="6,2,6,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="IconCol"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="ArrowCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="GestureCol"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="Icon"
                                                  Grid.Column="0"
                                                  ContentSource="Icon"
                                                  Margin="0,0,8,0"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                  VerticalAlignment="Center"/>

                                <TextBlock x:Name="HeaderText"
                                           Grid.Column="1"
                                           Text="{TemplateBinding Header}"
                                           Foreground="{DynamicResource ForegrounfBrushes}"
                                           VerticalAlignment="Center"
                                           Margin="{TemplateBinding Padding}"/>

                                <Path x:Name="GlyphPanel"
                                      Grid.Column="2"
                                      Width="6"
                                      Height="10"
                                      Stretch="Uniform"
                                      SnapsToDevicePixels="True"
                                      Stroke="{DynamicResource ForegrounfBrushes}"
                                      StrokeThickness="1.2"
                                      StrokeEndLineCap="Round"
                                      StrokeStartLineCap="Round"
                                      Opacity="0.75"
                                      FlowDirection="LeftToRight"
                                      Margin="8,0,4,0"
                                      Visibility="Collapsed"
                                      VerticalAlignment="Center">
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="ArrowRotate" Angle="0" CenterX="3" CenterY="5"/>
                                    </Path.RenderTransform>
                                </Path>

                                <TextBlock x:Name="HotkeyText"
                                           Grid.Column="3"
                                           Text="{Binding InputGestureText, RelativeSource={RelativeSource TemplatedParent}}"
                                           Foreground="{DynamicResource ForegrounfBrushes}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="10,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Подменю -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               HorizontalOffset="0"
                               VerticalOffset="0"
                               Placement="Right"
                               IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}">
                            <Border Background="{TemplateBinding Background}">
                                <ScrollViewer x:Name="SubMenuScrollViewer"
                                              CanContentScroll="True"
                                              Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                    <Grid RenderOptions.ClearTypeHint="Enabled">
                                        <ItemsPresenter x:Name="ItemsPresenter"
                                                        KeyboardNavigation.DirectionalNavigation="Cycle"
                                                        Grid.IsSharedSizeScope="True"
                                                        Margin="2"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                        KeyboardNavigation.TabNavigation="Cycle"/>
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Триггеры -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBg" Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ItemBg" Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                        </Trigger>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="GlyphPanel" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="GlyphPanel" Property="Data" Value="M0,1 L4,5 L0,9"/>
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ArrowRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         To="90"
                                                         Duration="0:0:0.12"
                                                         FillBehavior="HoldEnd"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ArrowRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         To="0"
                                                         Duration="0:0:0.12"
                                                         FillBehavior="Stop"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ======= Разделитель между вкладками в подменю ======= -->
    <Style x:Key="SeparatorMenuStyle" TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
    </Style>

    <!--#endregion-->

    <!--#region Пустая область -->
    <!-- Центральное мягкое свечение -->
    <RadialGradientBrush x:Key="CenterGlowBrush"
                         ColorInterpolationMode="ScRgbLinearInterpolation"
                         RadiusX="0.55" RadiusY="0.55"
                         Center="0.52,0.60" GradientOrigin="0.52,0.60">
        <GradientStop Color="#26000000" Offset="0.00"/>
        <GradientStop Color="#00000000" Offset="1.00"/>
    </RadialGradientBrush>

    <!-- Виньетка по краям -->
    <RadialGradientBrush x:Key="VignetteBrush"
                         ColorInterpolationMode="ScRgbLinearInterpolation"
                         RadiusX="0.98" RadiusY="0.98"
                         Center="0.5,0.5" GradientOrigin="0.5,0.5">
        <GradientStop Color="#00000000" Offset="0.68"/>
        <GradientStop Color="#26000000" Offset="0.85"/>
        <GradientStop Color="#66000000" Offset="1.00"/>
    </RadialGradientBrush>

    <!-- Градиентный фон с «дыханием» -->
    <RadialGradientBrush x:Key="EmptyBackgroundBrush"
                         ColorInterpolationMode="ScRgbLinearInterpolation"
                         GradientOrigin="0.50,0.40"
                         Center="0.50,0.40"
                         RadiusX="1.20" RadiusY="1.20">
        <GradientStop Color="#303843" Offset="0.00"/>
        <GradientStop Color="#3a4655" Offset="1.00"/>
    </RadialGradientBrush>

    <!-- центральное свечение -->
    <Style x:Key="CenterGlowStyle" TargetType="Rectangle">
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Fill" Value="{DynamicResource CenterGlowBrush}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <BlurEffect Radius="4"/>
            </Setter.Value>
        </Setter>
    </Style>

