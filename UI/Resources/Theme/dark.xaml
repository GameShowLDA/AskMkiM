<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:Controls ="clr-namespace:UI.Controls"
                    xmlns:avalonEdit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
                    xmlns:Components="clr-namespace:UI.Components">
    <!--#region Базовые стили -->
    <SolidColorBrush x:Key="ForegrounfBrushes" Color="#f3f0f9"/>
    <SolidColorBrush x:Key="ForegrounfBrushes35" Color="#f3f0f9" Opacity="0.35"/>
    <SolidColorBrush x:Key="ForegrounfBrushes45" Color="#f3f0f9" Opacity="0.45"/>
    <SolidColorBrush x:Key="ForegrounfBrushes85" Color="#f3f0f9" Opacity="0.85"/>

    <SolidColorBrush x:Key="MenuBackgroundBrushes" Color="#232932"/>
    <SolidColorBrush x:Key="MenuPopupBackgroundBrush" Color="#F0232932"/>
    <SolidColorBrush x:Key="BackgroundBrushes" Color="#303843"/>
    <SolidColorBrush x:Key="ActiveColorBrushes" Color="#1ca3e9"/>
    <SolidColorBrush x:Key="SettingsMainBackground" Color="#3a4655"/>
    <!--#endregion-->

    <!--#region Главное меню -->

    <!--#region Кнопки свернуть, развернуть, закрыть -->

    <Style x:Key="StyleWindowsButtons" TargetType="Components:WindowButtons">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource ActiveColorBrushes}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--#endregion-->

    <!--#region Меню -->

    <Style x:Key="StyleTopMenu" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrushes}"/>
    </Style>

    <!-- ======= Главное меню ======= -->
    <Style x:Key="StyleMenuItem" TargetType="{x:Type MenuItem}">
        <!-- Базовые визуальные параметры -->
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="12,4,14,4"/>
        <Setter Property="MinHeight" Value="26"/>
        <Setter Property="Background" Value="{DynamicResource MenuBackgroundBrushes}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>

        <!-- Шаблон отображения MenuItem -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="ItemBackground"
                                Background="Transparent"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="MenuIconCol"/>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="MenuHotkeyCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="MenuArrowCol"/>
                                </Grid.ColumnDefinitions>

                                <!-- Иконка (если задана) -->
                                <ContentPresenter x:Name="Icon"
                                                  Grid.Column="0"
                                                  ContentSource="Icon"
                                                  Margin="0,0,8,0"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                  VerticalAlignment="Center"/>

                                <!-- Основной текст -->
                                <TextBlock x:Name="HeaderText"
                                           Grid.Column="1"
                                           Text="{TemplateBinding Header}"
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Горячая клавиша -->
                                <TextBlock x:Name="HotkeyText"
                                           Grid.Column="2"
                                           Text="{Binding InputGestureText, RelativeSource={RelativeSource TemplatedParent}}"
                                           Foreground="{DynamicResource ForegrounfBrushes45}"
                                           VerticalAlignment="Center"
                                           Margin="14,0,6,0"/>

                                <!-- Индикатор подменю -->
                                <Path x:Name="SubmenuIndicator"
                                      Grid.Column="3"
                                      Data="M 0 0 L 4 4 L 0 8"
                                      Stroke="{DynamicResource ForegrounfBrushes45}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      VerticalAlignment="Center"
                                      Margin="6,0,2,0"
                                      Visibility="Collapsed"
                                      SnapsToDevicePixels="True"
                                      Stretch="Uniform"
                                      Width="8"
                                      Height="8"/>
                            </Grid>
                        </Border>

                        <!-- Подменю -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               HorizontalOffset="1"
                               VerticalOffset="-1"
                               Placement="Bottom"
                               IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}">
                            <Border Background="{DynamicResource MenuPopupBackgroundBrush}">
                                <ScrollViewer x:Name="SubMenuScrollViewer"
                                              CanContentScroll="True"
                                              Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                    <Grid RenderOptions.ClearTypeHint="Enabled">
                                        <ItemsPresenter x:Name="ItemsPresenter"
                                                        KeyboardNavigation.DirectionalNavigation="Cycle"
                                                        Grid.IsSharedSizeScope="True"
                                                        Margin="2"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                        KeyboardNavigation.TabNavigation="Cycle"/>
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Триггеры -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                            <Setter TargetName="SubmenuIndicator" Property="Stroke" Value="{DynamicResource ForegrounfBrushes}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                            <Setter TargetName="SubmenuIndicator" Property="Stroke" Value="{DynamicResource ForegrounfBrushes}"/>
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
                            <Setter TargetName="SubmenuIndicator" Property="Stroke" Value="{DynamicResource ForegrounfBrushes}"/>
                        </Trigger>
                        <Trigger Property="HasItems" Value="True">
                            <Setter TargetName="SubmenuIndicator" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding InputGestureText, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                            <Setter TargetName="HotkeyText" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding InputGestureText, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                            <Setter TargetName="HotkeyText" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <Trigger Property="Role" Value="TopLevelHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter TargetName="HeaderText" Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,4,12,4"/>
                            <Setter TargetName="SubmenuIndicator" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ======= Боковое меню (на основе основного) ======= -->
    <Style x:Key="SideMenuItemStyle" TargetType="{x:Type MenuItem}" BasedOn="{StaticResource StyleMenuItem}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="ItemBackground"
                                Background="Transparent"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="MenuIconCol"/>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="MenuHotkeyCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="MenuArrowCol"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="Icon"
                                                  Grid.Column="0"
                                                  ContentSource="Icon"
                                                  Margin="0,0,8,0"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                  VerticalAlignment="Center"/>

                                <TextBlock x:Name="HeaderText"
                                           Grid.Column="1"
                                           Text="{TemplateBinding Header}"
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock x:Name="HotkeyText"
                                           Grid.Column="2"
                                           Text="{Binding InputGestureText, RelativeSource={RelativeSource TemplatedParent}}"
                                           Foreground="{DynamicResource ForegrounfBrushes45}"
                                           VerticalAlignment="Center"
                                           Margin="14,0,6,0"/>

                                <Path x:Name="SubmenuIndicator"
                                      Grid.Column="3"
                                      Data="M 0 0 L 4 4 L 0 8"
                                      Stroke="{DynamicResource ForegrounfBrushes45}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      VerticalAlignment="Center"
                                      Margin="6,0,2,0"
                                      Visibility="Collapsed"
                                      SnapsToDevicePixels="True"
                                      Stretch="Uniform"
                                      Width="8"
                                      Height="8"/>
                            </Grid>
                        </Border>

                        <!-- Подменю -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               HorizontalOffset="0"
                               VerticalOffset="0"
                               Placement="Right"
                               IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}">
                            <Border Background="{DynamicResource MenuPopupBackgroundBrush}">
                                <ScrollViewer x:Name="SubMenuScrollViewer"
                                              CanContentScroll="True"
                                              Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                    <Grid RenderOptions.ClearTypeHint="Enabled">
                                        <ItemsPresenter x:Name="ItemsPresenter"
                                                        KeyboardNavigation.DirectionalNavigation="Cycle"
                                                        Grid.IsSharedSizeScope="True"
                                                        Margin="2"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                        KeyboardNavigation.TabNavigation="Cycle"/>
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Триггеры -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                            <Setter TargetName="SubmenuIndicator" Property="Stroke" Value="{DynamicResource ForegrounfBrushes}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                            <Setter TargetName="SubmenuIndicator" Property="Stroke" Value="{DynamicResource ForegrounfBrushes}"/>
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
                            <Setter TargetName="SubmenuIndicator" Property="Stroke" Value="{DynamicResource ForegrounfBrushes}"/>
                        </Trigger>
                        <Trigger Property="HasItems" Value="True">
                            <Setter TargetName="SubmenuIndicator" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding InputGestureText, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                            <Setter TargetName="HotkeyText" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding InputGestureText, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                            <Setter TargetName="HotkeyText" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <Trigger Property="Role" Value="TopLevelHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter TargetName="HeaderText" Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,4,12,4"/>
                            <Setter TargetName="SubmenuIndicator" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ======= Разделитель между вкладками в подменю ======= -->
    <Style x:Key="SeparatorMenuStyle" TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource ActiveColorBrushes}"/>
    </Style>

    <!--#endregion-->

    <!--#region Пустая область -->
    <!-- Центральное мягкое свечение -->
    <RadialGradientBrush x:Key="CenterGlowBrush"
                         ColorInterpolationMode="ScRgbLinearInterpolation"
                         RadiusX="0.55" RadiusY="0.55"
                         Center="0.52,0.60" GradientOrigin="0.52,0.60">
        <GradientStop Color="#26000000" Offset="0.00"/>
        <GradientStop Color="#00000000" Offset="1.00"/>
    </RadialGradientBrush>

    <!-- Виньетка по краям -->
    <RadialGradientBrush x:Key="VignetteBrush"
                         ColorInterpolationMode="ScRgbLinearInterpolation"
                         RadiusX="0.98" RadiusY="0.98"
                         Center="0.5,0.5" GradientOrigin="0.5,0.5">
        <GradientStop Color="#00000000" Offset="0.68"/>
        <GradientStop Color="#26000000" Offset="0.85"/>
        <GradientStop Color="#66000000" Offset="1.00"/>
    </RadialGradientBrush>

    <!-- Градиентный фон с «дыханием» -->
    <RadialGradientBrush x:Key="EmptyBackgroundBrush"
                         ColorInterpolationMode="ScRgbLinearInterpolation"
                         GradientOrigin="0.50,0.40"
                         Center="0.50,0.40"
                         RadiusX="1.20" RadiusY="1.20">
        <GradientStop Color="#303843" Offset="0.00"/>
        <GradientStop Color="#3a4655" Offset="1.00"/>
    </RadialGradientBrush>

    <!-- центральное свечение -->
    <Style x:Key="CenterGlowStyle" TargetType="Rectangle">
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Fill" Value="{DynamicResource CenterGlowBrush}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <BlurEffect Radius="4"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Приветственный блок -->
    <SolidColorBrush x:Key="MainGreetingBackgroundBrush" Color="#303843" />
    <SolidColorBrush x:Key="MainGreetingBorderBrush" Color="#f3f0f9" />
    <SolidColorBrush x:Key="MainTitleSolidColorBrush" Color="#f3f0f9" />

    <!--#endregion-->

    <!--#endregion-->

    <!--#region Настройки приложения -->

    <SolidColorBrush x:Key="SettingCardBackground" Color="#303843"/>
    <SolidColorBrush x:Key="SettingCardBorderBrush" Color="#415163"/>
    
    <Style x:Key="SettingCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SettingCardBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingCardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
    </Style>
    
    <SolidColorBrush x:Key="SettingsTitleSolidColorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SettingsDescriptionSolidColorBrush" Color="#A9B5C3"/>
    <SolidColorBrush x:Key="SettingsHeaderSolidColorBrush" Color="#FFFFFF"/>

    <Style x:Key="SettingsTitleStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource SettingsTitleSolidColorBrush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource WinstonMedium}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="18"/>
    </Style>

    <Style x:Key="SettingsHeaderStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource SettingsTitleSolidColorBrush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource WinstonMedium}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="SettingsDescriptionStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource SettingsDescriptionSolidColorBrush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource WinstonLight}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!--#region Чек бокс и кнопки -->
    <SolidColorBrush x:Key="SettingsInteractiveBackgroundSolidColorBrush" Color="#1F242B"/>
    <SolidColorBrush x:Key="SettingsInteractiveBorderSolidColorBrush" Color="#415163"/>
    <SolidColorBrush x:Key="SettingsInteractiveHoverSolidColorBrush" Color="#1CA3E9"/>
    <SolidColorBrush x:Key="SettingsInteractiveActiveSolidColorBrush" Color="#1CA3E9"/>
    <SolidColorBrush x:Key="SettingsInteractivePressedSolidColorBrush" Color="#93D2F4"/>
    <!--#endregion-->

    <!--#region Весь элемент управления настройками -->
    <SolidColorBrush x:Key="SettingsMainBackgroundSolidColorBrush" Color="#303843"/>

    <!--#endregion-->

    <!--#region Общая панель с настройками -->
    <SolidColorBrush x:Key="SettingsPanelBackgroundSolidColorBrush" Color="#282E37"/>
    <SolidColorBrush x:Key="SettingsPanelBorderSolidColorBrush" Color="#282E37"/>

    <Style x:Key="SettingPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SettingsPanelBackgroundSolidColorBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsPanelBorderSolidColorBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="15"/>
    </Style>
    <!--#endregion-->

    <!--#region Панель выбора -->

    <SolidColorBrush x:Key="SettingsSliderBackgroundSolidColorBrush" Color="#303843"/>
    <SolidColorBrush x:Key="SettingsSelectorBackgroundSolidColorBrush" Color="#303843"/>
    <SolidColorBrush x:Key="SettingsSelectorHoverSolidColorBrush" Color="#93D2F4"/>
    <SolidColorBrush x:Key="SettingsSelectorSelectedSolidColorBrush" Color="#1CA3E9"/>
    <SolidColorBrush x:Key="SettingsSliderBorderSolidColorBrush" Color="#415163"/>

    <!--#endregion-->

    <!--#region Конфигурация -->
    <SolidColorBrush x:Key="SettingsCongifButtonBackgroundSolidColorBrush" Color="#801CA3E9"/>
    <SolidColorBrush x:Key="SettingsCongifButtonHoverBackgroundSolidColorBrush" Color="#93D2F4"/>
    <SolidColorBrush x:Key="SettingsCongifButtonBorderSolidColorBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SettingsInfoTabloBackgroundSolidColorBrush" Color="#1CA3E9"/>
    <SolidColorBrush x:Key="SettingsConfigDataInputTabloBackgroundSolidColorBrush" Color="#6A7689"/>

    <!--#endregion-->

    <!--#endregion-->

    <!--#region Тектовый редактор -->

    <Style x:Key="StyleTextEditor" TargetType="avalonEdit:TextEditor">
        <Setter Property="Background" Value="#303843"/>
        <Setter Property="Foreground" Value="#f3f0f9"/>
    </Style>
    
    <!--#endregion-->

    <!--#region Протокол оборудования -->

    <SolidColorBrush x:Key="TestsInputBackgroundInputPanelBrush" Color="#6a7689"/>
    <SolidColorBrush x:Key="TestsInputBackgroundHeaderPanelBrush" Color="#303843"/>
    <SolidColorBrush x:Key="TestsMainPanelBackgroundBrush" Color="#1f242b"/>

    <SolidColorBrush x:Key="TestsMainButtonBackgroundBrush" Color="#303843"/>
    <SolidColorBrush x:Key="TestsMainButtonForegroundBrush" Color="#f3f0f9"/>

    <SolidColorBrush x:Key="TestsInputHeaderSolidColorBrush" Color="#f3f0f9"/>
    <SolidColorBrush x:Key="TestsInputDescriptionSolidColorBrush" Color="#f3f0f9"/>

    <SolidColorBrush x:Key="TestsMainButtonOrangeStartBrush" Color="#fcaa3f"/>
    <SolidColorBrush x:Key="TestsMainButtonOrangeEndBrush" Color="#f47842"/>

    <SolidColorBrush x:Key="TestsMainButtonGreenStartBrush" Color="#67c66e"/>
    <SolidColorBrush x:Key="TestsMainButtonGreenEndBrush" Color="#459c3c"/>

    <SolidColorBrush x:Key="TestsInteractiveBackgroundSolidColorBrush" Color="#1f242b"/>
    <SolidColorBrush x:Key="TestsInteractiveBorderSolidColorBrush" Color="#415163"/>
    <SolidColorBrush x:Key="TestsInteractivePressedSolidColorBrush" Color="#93d2f4"/>

    <SolidColorBrush x:Key="TestsProtocolBackgroundBrush" Color="#3a4655"/>

    <SolidColorBrush x:Key="TestsProtocolMessageSuccesForeground" Color="#2FA84F"/>
    <SolidColorBrush x:Key="TestsProtocolMessageErrorForeground" Color="#F1301B"/>
    <SolidColorBrush x:Key="TestsProtocolHeaderForeground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TestsProtocolMessageForeground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TestsProtocolTimeForeground" Color="YellowGreen"/>

    <SolidColorBrush x:Key="ErrorListBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ErrorListHeaderBackground" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="ErrorListSelection" Color="#264F78"/>
    
    
    <!--#endregion-->
</ResourceDictionary>
