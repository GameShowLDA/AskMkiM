<UserControl x:Class="UI.Controls.Settings.AskMkiConfig.AskMkiGroupEditorDrawerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:UI.Controls.Settings.AskMkiConfig"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="430">

    <UserControl.Resources>
        <DropShadowEffect x:Key="ShadowEffect"
                          BlurRadius="20"
                          ShadowDepth="0"
                          Opacity="0.5"
                          Color="Black"/>

        <Style x:Key="AskMkiDrawerInputTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
        </Style>

        <Style x:Key="AskMkiDrawerInputBorderStyle"
               TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SettingsConfigDataInputTabloBackgroundSolidColorBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="14,8,14,8"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style x:Key="AskMkiDrawerSectionCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource DeviceInputSectionCardStyle}"/>

        <Style x:Key="AskMkiDrawerSectionTitleBarStyle"
               TargetType="Border"
               BasedOn="{StaticResource DeviceInputSectionTitleBarStyle}"/>

        <DataTemplate x:Key="AskMkiDrawerSettingItemTemplate"
                      DataType="{x:Type local:AskMkiSettingItem}">
            <Border x:Name="SectionRoot"
                    Style="{StaticResource AskMkiDrawerSectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource AskMkiDrawerSectionTitleBarStyle}">
                        <TextBlock Text="{Binding Label}"
                                   Foreground="{DynamicResource ForegrounfBrushes}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="7,0"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Grid Grid.Row="1">
                        <Border x:Name="TextEditorHost"
                                Style="{StaticResource AskMkiDrawerInputBorderStyle}"
                                Visibility="Collapsed">
                            <TextBox Text="{Binding TextValue, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AskMkiDrawerInputTextBoxStyle}"/>
                        </Border>

                        <ComboBox x:Name="ChoiceEditorHost"
                                  ItemsSource="{Binding Options}"
                                  SelectedItem="{Binding SelectedOption, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="Label"
                                  Style="{StaticResource CustomComboBoxStyle}"
                                  HorizontalAlignment="Stretch"
                                  Margin="14,8,14,8"
                                  Height="40"
                                  Visibility="Collapsed"/>

                        <CheckBox x:Name="ToggleEditorHost"
                                  Content="{Binding Label}"
                                  IsChecked="{Binding ToggleValue, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource SettingsCheckBox}"
                                  Foreground="{DynamicResource ForegrounfBrushes}"
                                  FontSize="18"
                                  FontWeight="Bold"
                                  Margin="16,14"
                                  Visibility="Collapsed"/>

                        <TextBlock x:Name="InfoEditorHost"
                                   Text="{Binding Description}"
                                   Foreground="{DynamicResource ForegrounfBrushes}"
                                   Opacity="0.75"
                                   TextWrapping="Wrap"
                                   Margin="16,12"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Border>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding EditorKind}" Value="Text">
                    <Setter TargetName="TextEditorHost" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EditorKind}" Value="Choice">
                    <Setter TargetName="ChoiceEditorHost" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EditorKind}" Value="Toggle">
                    <Setter TargetName="ToggleEditorHost" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EditorKind}" Value="Info">
                    <Setter TargetName="InfoEditorHost" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="AskMkiDrawerSwitchRowTemplate"
                      DataType="{x:Type local:AskMkiSwitchRangeRow}">
            <Border Style="{StaticResource AskMkiDrawerSectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource AskMkiDrawerSectionTitleBarStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Name}"
                                       Foreground="{DynamicResource ForegrounfBrushes}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Margin="7,0"
                                       VerticalAlignment="Center"/>

                            <CheckBox x:Name="PresentCheckBox"
                                      Grid.Column="1"
                                      IsChecked="{Binding IsPresent, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource SettingsCheckBox}"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="БКнач"
                                       Foreground="{DynamicResource ForegrounfBrushes}"
                                       FontWeight="SemiBold"
                                       Margin="16,6,16,0"/>
                            <Border Style="{StaticResource AskMkiDrawerInputBorderStyle}">
                                <TextBox Text="{Binding FirstBk, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource AskMkiDrawerInputTextBoxStyle}"
                                         MaxLength="2"
                                         PreviewTextInput="SmallNumberTextBox_PreviewTextInput"
                                         DataObject.Pasting="SmallNumberTextBox_Pasting"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="БКкон"
                                       Foreground="{DynamicResource ForegrounfBrushes}"
                                       FontWeight="SemiBold"
                                       Margin="16,6,16,0"/>
                            <Border Style="{StaticResource AskMkiDrawerInputBorderStyle}">
                                <TextBox Text="{Binding LastBk, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource AskMkiDrawerInputTextBoxStyle}"
                                         MaxLength="2"
                                         PreviewTextInput="SmallNumberTextBox_PreviewTextInput"
                                         DataObject.Pasting="SmallNumberTextBox_Pasting"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsFixedPresent}" Value="True">
                    <Setter TargetName="PresentCheckBox" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{DynamicResource DeviceInputShellBackgroundBrush}"
            CornerRadius="20"
            Padding="12"
            Margin="8,8,8,12"
            HorizontalAlignment="Stretch"
            Effect="{DynamicResource ShadowEffect}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding Title, StringFormat='Настройка: {0}'}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Stretch"
                       Margin="6,4,6,10"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource ForegrounfBrushes}"
                       FontSize="25"
                       FontWeight="Bold"/>

            <ScrollViewer Grid.Row="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          VerticalScrollBarVisibility="Auto"
                          Padding="2,0">
                <Grid>
                    <ItemsControl x:Name="ItemsEditor"
                                  ItemsSource="{Binding Items}"
                                  ItemTemplate="{StaticResource AskMkiDrawerSettingItemTemplate}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSwitchMatrixGroup}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>

                    <ItemsControl x:Name="SwitchRowsEditor"
                                  ItemsSource="{Binding SwitchRows}"
                                  ItemTemplate="{StaticResource AskMkiDrawerSwitchRowTemplate}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSwitchMatrixGroup}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>

            <Grid Grid.Row="2"
                  Margin="18,18,18,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Content="Отменить"
                        Style="{StaticResource BackButtonStyle}"
                        MinWidth="120"
                        Height="50"
                        FontSize="16"
                        Click="CancelButton_Click"/>

                <Button Grid.Column="3"
                        Content="Сохранить"
                        Style="{StaticResource SaveButtonStyle}"
                        MinWidth="120"
                        Height="50"
                        FontSize="16"
                        Click="SaveButton_Click"/>
            </Grid>
        </Grid>
    </Border>

</UserControl>
