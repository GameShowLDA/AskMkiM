                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.D.Main"/>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.D.Timing"/>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.D.Protocol"/>
                </local:AskMkiGroupDefinition.Children>
            </local:AskMkiGroupDefinition>

            <local:AskMkiGroupDefinition Code="E" Title="Параметры АЦП" Description="Наличие АЦП, тестовые параметры и задержки." Summary="АЦП, Imax, U теста, задержки.">
                <local:AskMkiGroupDefinition.Children>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.E.Main"/>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.E.Timing"/>
                </local:AskMkiGroupDefinition.Children>
            </local:AskMkiGroupDefinition>

