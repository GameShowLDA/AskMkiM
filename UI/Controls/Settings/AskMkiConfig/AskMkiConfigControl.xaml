        </x:Array>

        <x:Array x:Key="AskMki.Fields.C.Main" Type="{x:Type local:AskMkiFieldDefinition}">
            <local:AskMkiFieldDefinition Label="ПКИ имеется" EditorKind="Toggle" Path="HardwareConfig.IsPki"/>
            <local:AskMkiFieldDefinition Label="Аппаратный контроль Uпки" EditorKind="Toggle" Path="HardwareAux.IsTstUpki"/>
