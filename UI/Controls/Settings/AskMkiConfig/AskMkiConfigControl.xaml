            Margin="15,10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
               Text="{StaticResource AskMki.Text.HeaderTitle}"
               Padding="10,10"
               Style="{DynamicResource SettingsTitleStyle}"/>

                <Grid Grid.Column="1"
          Margin="20,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Icons:ArrowButton x:Name="ToggleAskMkiConfigButton"
                           Grid.Column="0"
                           HorizontalAlignment="Right"
                           Width="30"
                           Height="30"
                           IsArrowUp="True"
                           ButtonBackground="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                           ButtonBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                           ArrowBrush="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                           ArrowHoverBrush="{DynamicResource SettingsInteractivePressedSolidColorBrush}"
                           VerticalAlignment="Center"/>

                    <Icons:SuccessIconControlV2 
                            Visibility="Collapsed"
                            Grid.Column="1"
                            x:Name="SuccessAskMkiConfig"
                            Width="30"
                            Height="30"
                            Margin="10,0,0,0"
                            CheckThickness="4"
                            CircleBackground="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                            CircleBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                            ToolTip="{StaticResource AskMki.Text.SaveTooltip}"
                            Cursor="Hand"
                            PreviewMouseDown="SaveConfigIcon_PreviewMouseDown"/>

                    <Icons:ErrorIconControlV2
                            Visibility="Collapsed"  
                            Grid.Column="2"
                            x:Name="ErrorAskMkiConfig"
                            Width="30"
                            Height="30"
                            Margin="10,0,0,0"
                            CrossThickness="4"
                            CircleBackground="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                            CircleBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                            ToolTip="{StaticResource AskMki.Text.CancelTooltip}"
                            Cursor="Hand"
                            PreviewMouseDown="CancelConfigIcon_PreviewMouseDown"/>
                </Grid>
            </Grid>

            <ContentControl Grid.Row="1"
                            VerticalAlignment="Stretch">
                <ContentControl.Style>
                    <Style TargetType="{x:Type ContentControl}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=ToggleAskMkiConfigButton, Path=IsArrowUp}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>

                <Border Style="{DynamicResource SettingPanelStyle}"
                        Margin="10,8,10,12"
                        Padding="14">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Путь к mkiw.exe"
                                   Style="{StaticResource AskMkiSectionTitleStyle}"/>

                        <TextBlock Grid.Row="1"
                                   Text="Здесь задаются путь к старой программе и путь к mki_hrd.cfg. Ниже редактируется активная legacy-конфигурация через новый интерфейс без открытия старого MKI."
                                   Style="{StaticResource AskMkiDescriptionStyle}"/>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="MkiPathTextBox"
                                     Grid.Column="0"
                                     Style="{StaticResource AskMkiPathTextBoxStyle}"/>

                            <Button Grid.Column="2"
                                    Content="Выбрать EXE"
                                    Style="{StaticResource DeviceInputSecondaryActionButton}"
                                    MinWidth="140"
                                    Click="SelectMkiPathButton_Click"/>

                            <Button x:Name="ClearMkiPathButton"
                                    Grid.Column="4"
                                    Content="Очистить"
                                    Style="{StaticResource DeviceInputSecondaryActionButton}"
                                    MinWidth="140"
                                    Click="ClearMkiPathButton_Click"/>
                        </Grid>

                        <TextBlock Grid.Row="5"
                                   Text="Путь к mki_hrd.cfg"
                                   Style="{StaticResource AskMkiSectionTitleStyle}"/>

                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="ConfigPathTextBox"
                                     Grid.Column="0"
                                     Style="{StaticResource AskMkiPathTextBoxStyle}"/>

                            <Button Grid.Column="2"
                                    Content="Выбрать CFG"
                                    Style="{StaticResource DeviceInputSecondaryActionButton}"
                                    MinWidth="140"
                                    Click="SelectConfigPathButton_Click"/>
                        </Grid>

                        <TextBlock Grid.Row="8"
                                   Text="Параметры конфигурации"
                                   Style="{StaticResource AskMkiSectionTitleStyle}"/>

                        <TextBlock Grid.Row="9"
                                   Text="Каждый старый блок конфигурации вынесен в отдельную сворачиваемую группу. Подпункты A1/B1/C1 скрыты, все параметры показаны сразу внутри основной группы."
                                   Style="{StaticResource AskMkiDescriptionStyle}"/>

                        <ScrollViewer x:Name="ProfileGroupsScrollViewer"
              Grid.Row="11"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
              CanContentScroll="False"
              Focusable="False"
              PreviewMouseWheel="ProfileGroupsScrollViewer_PreviewMouseWheel">

                            <ItemsControl x:Name="ProfileGroupsItemsControl"
                  PreviewMouseWheel="ProfileGroupsScrollViewer_PreviewMouseWheel">

                                <ItemsControl.Resources>
                                    <DataTemplate x:Key="AskMkiSettingItemTemplate"
                          DataType="{x:Type local:AskMkiSettingItem}">
                                        <Border x:Name="ItemBorder"
                        BorderBrush="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="0,10">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2.2*"/>
                                                    <ColumnDefinition Width="18"/>
                                                    <ColumnDefinition Width="1.3*"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid x:Name="InfoStack"
                              Grid.Column="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <CheckBox x:Name="InlineToggleCheckBox"
                                      Grid.Column="0"
                                      Grid.Row="0"
                                      Grid.RowSpan="2"
                                      Style="{StaticResource AskMkiToggleCheckBoxStyle}"
                                      IsChecked="{Binding ToggleValue, UpdateSourceTrigger=PropertyChanged}"/>

                                                    <TextBlock x:Name="LabelText"
                                       Grid.Column="1"
                                       Grid.Row="0"
                                       Text="{Binding Label}"
                                       Style="{DynamicResource SettingsTitleStyle}"
                                       FontWeight="SemiBold"/>

                                                    <TextBlock Grid.Column="1"
                                       Grid.Row="1"
                                       Text="{Binding Description}"
                                       Style="{StaticResource AskMkiDescriptionStyle}"/>
                                                </Grid>

                                                <Grid x:Name="EditorHost"
                              Grid.Column="2">

                                                    <TextBox Text="{Binding TextValue, UpdateSourceTrigger=PropertyChanged}">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox"
                                           BasedOn="{StaticResource AskMkiEditorTextBoxStyle}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding EditorKind}" Value="Text">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>

                                                    <ComboBox ItemsSource="{Binding Options}"
                                      SelectedItem="{Binding SelectedOption, UpdateSourceTrigger=PropertyChanged}"
                                      DisplayMemberPath="Label"
                                      Height="38"
                                      VerticalContentAlignment="Center">
                                                        <ComboBox.Style>
                                                            <Style TargetType="ComboBox"
                                           BasedOn="{StaticResource CustomComboBoxStyle}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding EditorKind}" Value="Choice">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ComboBox.Style>
                                                    </ComboBox>

                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding EditorKind}" Value="Toggle">
                                                <Setter TargetName="EditorHost" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="InfoStack" Property="Grid.ColumnSpan" Value="3"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding EditorKind}" Value="Info">
                                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="0"/>
                                                <Setter TargetName="ItemBorder" Property="Padding" Value="0,14,0,6"/>
                                                <Setter TargetName="EditorHost" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="InfoStack" Property="Grid.ColumnSpan" Value="3"/>
                                                <Setter TargetName="LabelText" Property="FontSize" Value="18"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.Resources>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:AskMkiSettingGroup}">
                                        <Border Style="{StaticResource AskMkiCardBorderStyle}">

                                            <Expander Style="{StaticResource AskMkiGroupExpanderStyle}"
                              IsExpanded="{Binding IsExpanded}">

                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0"
                                       Text="{Binding Description}"
                                       Style="{StaticResource AskMkiDescriptionStyle}"
                                       Margin="0,12,0,6"/>

                                                    <!-- Специальная таблица для группы СК/БК -->
                                                    <Grid x:Name="SwitchMatrixContainer"
      Grid.Row="1"
      Visibility="Collapsed"
      HorizontalAlignment="Left"
      Margin="0,10,0,0">

                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- Заголовки колонок -->
                                                        <Grid Grid.Row="0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="260"/>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="110"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Column="0"
                   Text="Коммутатор"
                   Style="{StaticResource AskMkiMatrixHeaderTextStyle}"/>

                                                            <TextBlock Grid.Column="1"
                   Text="БКнач"
                   Style="{StaticResource AskMkiMatrixHeaderTextStyle}"/>

                                                            <TextBlock Grid.Column="2"
                   Text="БКкон"
                   Style="{StaticResource AskMkiMatrixHeaderTextStyle}"/>
                                                        </Grid>

                                                        <!-- Строки -->
                                                        <ItemsControl Grid.Row="1"
                  ItemsSource="{Binding SwitchRows}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="{x:Type local:AskMkiSwitchRangeRow}">
                                                                    <Border BorderBrush="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="0,9">

                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="260"/>
                                                                                <ColumnDefinition Width="100"/>
                                                                                <ColumnDefinition Width="110"/>
                                                                            </Grid.ColumnDefinitions>

                                                                            <!-- Название + чекбокс -->
                                                                            <Grid Grid.Column="0">
                                                                                <Grid x:Name="EditablePresentPanel">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                    </Grid.ColumnDefinitions>

                                                                                    <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsPresent, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource SettingsCheckBox}"
                                          Margin="0,1,10,0"
                                          VerticalAlignment="Center"/>

                                                                                    <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           Style="{StaticResource AskMkiMatrixNameTextStyle}"/>
                                                                                </Grid>

                                                                                <StackPanel x:Name="FixedPresentPanel"
                                        Visibility="Collapsed">
                                                                                    <TextBlock Text="{Binding Name}"
                                           Style="{StaticResource AskMkiMatrixNameTextStyle}"/>

                                                                                    <TextBlock Text="{Binding FixedDescription}"
                                           Style="{StaticResource AskMkiMatrixDescriptionTextStyle}"/>
                                                                                </StackPanel>
                                                                            </Grid>

                                                                            <!-- Первый БК -->
                                                                            <TextBox Grid.Column="1"
                                 Text="{Binding FirstBk, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AskMkiSmallNumberTextBoxStyle}"
                                 MaxLength="2"
                                 PreviewTextInput="SmallNumberTextBox_PreviewTextInput"
                                 DataObject.Pasting="SmallNumberTextBox_Pasting"/>

                                                                            <!-- Последний БК -->
                                                                            <TextBox Grid.Column="2"
                                 Text="{Binding LastBk, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AskMkiSmallNumberTextBoxStyle}"
                                 MaxLength="2"
                                 PreviewTextInput="SmallNumberTextBox_PreviewTextInput"
                                 DataObject.Pasting="SmallNumberTextBox_Pasting"/>
                                                                        </Grid>
                                                                    </Border>

                                                                    <DataTemplate.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFixedPresent}" Value="True">
                                                                            <Setter TargetName="EditablePresentPanel" Property="Visibility" Value="Collapsed"/>
                                                                            <Setter TargetName="FixedPresentPanel" Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </DataTemplate.Triggers>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>

                                                    <!-- Обычный вид для остальных групп -->
                                                    <StackPanel x:Name="DefaultItemsContainer"
                                        Grid.Row="1">

                                                        <ItemsControl ItemsSource="{Binding Items}"
                                              ItemTemplate="{StaticResource AskMkiSettingItemTemplate}"
                                              Margin="0,8,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Expander>
                                        </Border>

                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsSwitchMatrixGroup}" Value="True">
                                                <Setter TargetName="SwitchMatrixContainer" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="DefaultItemsContainer" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </ContentControl>
        </Grid>
    </Border>
</UserControl>
