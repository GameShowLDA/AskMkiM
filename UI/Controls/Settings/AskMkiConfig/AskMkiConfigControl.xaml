                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.C.Dividers"/>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.C.Nr4"/>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.C.Timing"/>
                </local:AskMkiGroupDefinition.Children>
            </local:AskMkiGroupDefinition>

