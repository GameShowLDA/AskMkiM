            <local:AskMkiSettingOption Value="8" Label="COM8 IBM"/>
            <local:AskMkiSettingOption Value="9" Label="COMx4/Канал 1"/>
            <local:AskMkiSettingOption Value="10" Label="COMx4/Канал 2"/>
            <local:AskMkiSettingOption Value="11" Label="COMx4/Канал 3"/>
            <local:AskMkiSettingOption Value="12" Label="COMx4/Канал 4"/>
        </x:Array>

