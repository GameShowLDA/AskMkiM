                <local:AskMkiGroupDefinition.Children>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.F.Main"/>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.F.Kop"/>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.F.CommonTiming"/>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.F.ModeTiming"/>
                </local:AskMkiGroupDefinition.Children>
            </local:AskMkiGroupDefinition>

