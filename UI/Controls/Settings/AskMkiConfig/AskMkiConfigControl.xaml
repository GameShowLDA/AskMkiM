            <local:AskMkiSettingOption Value="11" Label="COMx4/Канал 3"/>
            <local:AskMkiSettingOption Value="12" Label="COMx4/Канал 4"/>
        </x:Array>

        <x:Array x:Key="AskMki.Groups" Type="{x:Type local:AskMkiGroupDefinition}">
            <local:AskMkiGroupDefinition Code="A" Title="Параметры СК, БК" Description="Наличие коммутаторов СК/ТКИ и диапазоны БК, используемых в стойке." Summary="Стойки, ТКИ и диапазоны БК.">
                <local:AskMkiGroupDefinition.Children>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.A.Switches"/>
                </local:AskMkiGroupDefinition.Children>
            </local:AskMkiGroupDefinition>

            <local:AskMkiGroupDefinition Code="B" Title="Параметры ПИНТов" Description="Наличие, тип, ток, напряжение и временные параметры ПИНТ3/ПИНТ4." Summary="ПИНТ3, ПИНТ4, токи, напряжения, задержки.">
                <local:AskMkiGroupDefinition.Children>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.B.Types"/>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.B.Current"/>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.B.Voltage"/>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.B.Timing"/>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.B.Load"/>
                </local:AskMkiGroupDefinition.Children>
            </local:AskMkiGroupDefinition>

            <local:AskMkiGroupDefinition Code="C" Title="Параметры ПКИ" Description="Проверка сопротивления изоляции." Summary="Umax, Rиз, dU, dI, НР-4.">
