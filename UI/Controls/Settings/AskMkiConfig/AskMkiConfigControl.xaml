            <local:AskMkiSettingOption Value="9" Label="Вольтметр неисправен/отсутствует"/>
        </x:Array>

        <x:Array x:Key="AskMki.Options.CurrentSource" Type="{x:Type local:AskMkiSettingOption}">
            <local:AskMkiSettingOption Value="0" Label="ПИТ"/>
            <local:AskMkiSettingOption Value="1" Label="ПИНТ4"/>
