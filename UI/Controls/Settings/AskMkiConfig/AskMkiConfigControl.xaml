                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.K.Main"/>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.K.Ek"/>
                    <local:AskMkiGroupDefinition FieldsKey="AskMki.Fields.K.Accuracy"/>
                </local:AskMkiGroupDefinition.Children>
            </local:AskMkiGroupDefinition>
