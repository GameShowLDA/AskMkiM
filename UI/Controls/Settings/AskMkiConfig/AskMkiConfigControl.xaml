            <local:AskMkiSettingOption Value="0" Label="Не используется"/>
            <local:AskMkiSettingOption Value="1" Label="COM1 IBM"/>
            <local:AskMkiSettingOption Value="2" Label="COM2 IBM"/>
            <local:AskMkiSettingOption Value="3" Label="COM3 IBM"/>
            <local:AskMkiSettingOption Value="4" Label="COM4 IBM"/>
            <local:AskMkiSettingOption Value="5" Label="COM5 IBM"/>
