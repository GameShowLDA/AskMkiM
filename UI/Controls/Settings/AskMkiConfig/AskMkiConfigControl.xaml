            <sys:String>СК-2400 2</sys:String>
            <sys:String>СК-2400 3</sys:String>
            <sys:String>СК-2400 4</sys:String>
            <sys:String>СК-2400 5</sys:String>
            <sys:String>СК-2400 6</sys:String>
            <sys:String>СК-2400 7</sys:String>
            <sys:String>СК-2400 8</sys:String>
        </x:Array>

