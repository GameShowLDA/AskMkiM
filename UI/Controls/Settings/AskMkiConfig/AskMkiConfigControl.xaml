        <sys:String x:Key="AskMki.Text.SaveTooltip">Сохранить</sys:String>
        <sys:String x:Key="AskMki.Text.CancelTooltip">Отменить изменения</sys:String>
        <sys:String x:Key="AskMki.Text.SectionMkiPath">Путь к mkiw.exe</sys:String>
        <sys:String x:Key="AskMki.Text.SectionIntro">Здесь задаются путь к старой программе и путь к mki_hrd.cfg. Ниже редактируется активная legacy-конфигурация через новый интерфейс без открытия старого MKI.</sys:String>
        <sys:String x:Key="AskMki.Text.SelectExeButton">Выбрать EXE</sys:String>
        <sys:String x:Key="AskMki.Text.ClearButton">Очистить</sys:String>
        <sys:String x:Key="AskMki.Text.SectionConfigPath">Путь к mki_hrd.cfg</sys:String>
        <sys:String x:Key="AskMki.Text.SelectCfgButton">Выбрать CFG</sys:String>
        <sys:String x:Key="AskMki.Text.SectionConfigEditor">Параметры конфигурации</sys:String>
        <sys:String x:Key="AskMki.Text.SectionConfigEditorDescription">Каждый старый блок конфигурации вынесен в отдельную сворачиваемую группу. Подпункты A1/B1/C1 скрыты, все параметры показаны сразу внутри основной группы.</sys:String>
        <sys:String x:Key="AskMki.Text.CheckBoxEnabled">Включено</sys:String>

        <sys:String x:Key="AskMki.Dialog.SelectMki.Title">Выберите mkiw.exe</sys:String>
        <sys:String x:Key="AskMki.Dialog.SelectMki.Filter">mkiw.exe|mkiw.exe|EXE-файлы (*.exe)|*.exe|Все файлы (*.*)|*.*</sys:String>
        <sys:String x:Key="AskMki.Dialog.SelectCfg.Title">Выберите mki_hrd.cfg</sys:String>
        <sys:String x:Key="AskMki.Dialog.SelectCfg.Filter">mki_hrd.cfg|mki_hrd.cfg|CFG-файлы (*.cfg)|*.cfg|Все файлы (*.*)|*.*</sys:String>

        <sys:String x:Key="AskMki.Message.Title">Конфигурация АСК-МКИ</sys:String>
        <sys:String x:Key="AskMki.Message.Warning.ConfigPathRequired">Сначала укажите путь к mki_hrd.cfg.</sys:String>
        <sys:String x:Key="AskMki.Message.Warning.ConfigFileMissing">Файл mki_hrd.cfg не найден. Сначала загрузите существующий файл.</sys:String>
        <sys:String x:Key="AskMki.Message.SaveSuccess">Конфигурация сохранена в:{0}{1}</sys:String>
        <sys:String x:Key="AskMki.Message.LoadSuccess">Файл mki_hrd.cfg загружен:{0}{1}</sys:String>
        <sys:String x:Key="AskMki.Message.SaveErrorTitle">Ошибка сохранения mki_hrd.cfg</sys:String>
        <sys:String x:Key="AskMki.Message.LoadErrorTitle">Ошибка загрузки mki_hrd.cfg</sys:String>

        <sys:String x:Key="AskMki.Error.UnknownEditorType">Неизвестный тип редактора: {0}.</sys:String>
        <sys:String x:Key="AskMki.Error.OptionsKeyMissing">Для поля "{0}" не указан OptionsKey.</sys:String>
        <sys:String x:Key="AskMki.Error.OptionNotSelected">Для поля "{0}" не выбран вариант.</sys:String>
        <sys:String x:Key="AskMki.Error.ProfileNotLoaded">Профиль legacy-конфигурации не загружен.</sys:String>
        <sys:String x:Key="AskMki.Error.PropertyNotFound">Свойство "{0}" не найдено в {1}.</sys:String>
        <sys:String x:Key="AskMki.Error.PropertyIsNotArray">Свойство "{0}" не является массивом.</sys:String>
        <sys:String x:Key="AskMki.Error.ArrayElementTypeMissing">Не удалось определить тип элемента массива "{0}".</sys:String>
        <sys:String x:Key="AskMki.Error.PathWriteFailed">Не удалось записать значение по пути "{0}".</sys:String>
        <sys:String x:Key="AskMki.Error.InvalidPathSegment">Некорректный сегмент пути: "{0}".</sys:String>

