        Label="ТКИ: имеется"
        Description="Всегда"
        EditorKind="Info"/>

            <local:AskMkiFieldDefinition
        LabelFormat="{}{0}: имеется"
        EditorKind="Toggle"
        PathFormat="HardwareConfig.SkIs[{0}]"
        Count="7"
        StartIndex="1"
        NamesKey="AskMki.SwitchNames"/>

            <local:AskMkiFieldDefinition
        LabelFormat="{}{0}: первый БК"
        EditorKind="Text"
        PathFormat="HardwareConfig.SkBkBeg[{0}]"
        Count="8"
        NamesKey="AskMki.SwitchNames"/>

            <local:AskMkiFieldDefinition
        LabelFormat="{}{0}: последний БК"
        EditorKind="Text"
        PathFormat="HardwareConfig.SkBkEnd[{0}]"
        Count="8"
        NamesKey="AskMki.SwitchNames"/>

        </x:Array>

