<UserControl x:Class="UI.Controls.Settings.UserInterface.UiSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.Settings.UserInterface"
             xmlns:Icons="clr-namespace:UI.Icon"
             xmlns:Components ="clr-namespace:UI.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="{StaticResource IsCheckedColorSolidColorBrush80}" Margin="15,10" CornerRadius="15" BorderThickness="1" BorderBrush="{StaticResource ForegroundSolidColorBrush60}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>


                <TextBlock 
                 Text="Интерфейс" 
                 FontSize="18" 
                 Padding="10,10"
                 Foreground="{StaticResource ForegroundSolidColorBrush}"
                 FontFamily="{StaticResource WinstonMedium}"
                 VerticalAlignment="Center"  
                 Grid.Row="0"/>

                <Grid Grid.Column="1"  Margin="20,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Icons:SuccessIconControlV2 
                     Grid.Column="1"
                     x:Name="Success" 
                     Width="30"
                     Margin="10,0,0,0"
                     Height="30" 
                     CheckThickness="4"
                     CircleBackground ="{StaticResource IsCheckedColorSolidColorBrush}"
                     CircleBorder="{StaticResource PrimarySolidColorBrush}"
                     />

                    <Icons:ErrorIconControlV2 
                      x:Name="Error"
                        Grid.Column="2"
                      Width="30"
                      Height="30" 
                        Margin="10,0,0,0"
                        CrossThickness="4"
                      CircleBackground ="{StaticResource IsCheckedColorSolidColorBrush}"
                      CircleBorder="{StaticResource PrimarySolidColorBrush}"
                      />


                    <Icons:ArrowButton x:Name="ToggleSettingsButton" 
                        Grid.Column="0"
                        HorizontalAlignment="Right"
                        Width="30" Height="30"
                        ButtonBackground="{StaticResource IsCheckedColorSolidColorBrush}"
                        ButtonBorder="{StaticResource PrimarySolidColorBrush}"
                        ArrowBrush="{StaticResource ForegroundSolidColorBrush}"
                        ArrowHoverBrush="{StaticResource ActiveForegroundSolidColorBrush80}"
                        VerticalAlignment="Center"/>
                </Grid>
            </Grid>

            <WrapPanel Orientation="Horizontal" Grid.Row="1">
                <WrapPanel.Style>
                    <Style TargetType="WrapPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </WrapPanel.Style>

                <Components:SettingsCardSelect
                    Margin="10,10"
                    x:Name="LanguageSelect"
                    Title="Язык"
                    Description="Выберите язык интерфейса, на котором будут надписи и сообщения"
                    DisplayMemberPath="Title"
                    SelectedValuePath="Key"/>

            </WrapPanel>
        </Grid>
    </Border>
</UserControl>
