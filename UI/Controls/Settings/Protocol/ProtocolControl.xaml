<UserControl x:Class="UI.Controls.Settings.Protocol.ProtocolControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.Settings.Protocol"
             xmlns:Components ="clr-namespace:UI.Components"
             xmlns:Icons="clr-namespace:UI.Icon"
             xmlns:DeviceInfo="clr-namespace:UI.Controls.Settings.DeviceInfo"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">
    <UserControl.Resources>

        <Style x:Key="SettingCardWithToggleStyle" TargetType="Border">

            <!-- копия базового стиля -->
            <Setter Property="Background" Value="{DynamicResource SettingCardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SettingCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>

            <!-- твой функциональный сеттер -->
            <Setter Property="Visibility" Value="Visible"/>

            <!-- триггер на кнопку -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}"
                         Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>

        </Style>

    </UserControl.Resources>

    <Border 
       Style="{DynamicResource SettingPanelStyle}" Margin="15,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock 
                    Text="Протокол"
                    Padding="10,10"
                    Style="{DynamicResource SettingsTitleStyle}"
                    />

                <Grid Grid.Column="1"  Margin="20,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Icons:SuccessIconControlV2 
                        Grid.Column="1"
                        x:Name="Success" 
                        Width="30"
                        Margin="10,0,0,0"
                        Height="30" 
                        CheckThickness="4"
                        CircleBackground ="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                        CircleBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                        />

                    <Icons:ErrorIconControlV2 
                      x:Name="Error"
                        Grid.Column="2"
                      Width="30"
                      Height="30" 
                      Margin="10,0,0,0"
                      CrossThickness="4"
                      CircleBackground ="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                      CircleBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                      />


                    <Icons:ArrowButton x:Name="ToggleSettingsButton" 
                                           Grid.Column="0"
                                           HorizontalAlignment="Right"
                                           Width="30" Height="30"
                                           ButtonBackground="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                                           ButtonBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                           ArrowBrush="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                           ArrowHoverBrush="{DynamicResource SettingsInteractivePressedSolidColorBrush}"
                                           VerticalAlignment="Center"/>
                </Grid>

            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>


                <WrapPanel Orientation="Horizontal" >
                    <WrapPanel.Style>
                        <Style TargetType="WrapPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>

                    <Components:SettingsCard
                        Title="Вывод времени операции"
                        Description="Показывает, сколько времени прошло с момента запуска на каждом шаге выполнения."
                        IsChecked="{Binding IdleMode, Mode=TwoWay}"
                        Margin="10,10"
                        x:Name="OperationTime"
                        VerticalAlignment="Top"/>

                    <Components:SettingsCard
                        Title="Отображение заголовков действий"
                        Description="Отображает краткое описание текущего шага выполнения в виде заголовка."
                        IsChecked="{Binding IdleMode, Mode=TwoWay}"
                        Margin="10,10"
                        x:Name="Header"
                        VerticalAlignment="Top"/>

                    <Components:SettingsCard
                        Title="Сохранение протокола"
                        Description="Автоматически сохраняет протокол каждого запуска. Имя файла содержит дату, время и название выполняемых действий."
                        IsChecked="{Binding IdleMode, Mode=TwoWay}"
                        Margin="10,10"
                        x:Name="AutoSave"
                        VerticalAlignment="Top"/>

                    <Components:SettingsCard
                        Title="Печать протокола"
                        Description="По завершении выполнения отображает диалог выбора принтера для печати итогового протокола."
                        IsChecked="{Binding IdleMode, Mode=TwoWay}"
                        x:Name="AutoPrint"
                        Margin="10,10"
                        VerticalAlignment="Top"/>

                    <Components:SettingsCard
                        Title="Вывод протокола в ПО"
                        Description="По завершении выполнения протокол отображается в программном обеспечении, по умолчанию открывается как PDF-файл."
                        IsChecked="{Binding IdleMode, Mode=TwoWay}"
                        x:Name="ProtocolFromPO"
                        Margin="10,10"
                        VerticalAlignment="Top"/>

                    <Components:SettingsCard
                        Title="Формирование протокола"
                        Description="Протокол будет формироваться после выполнения программ контроля."
                        IsChecked="{Binding IdleMode, Mode=TwoWay}"
                        Margin="10,10"
                        VerticalAlignment="Top"
                        x:Name="ProtocolGeneration"/>


                </WrapPanel>

                <DeviceInfo:DeviceDisplaySettingsControl x:Name="DeviceDisplaySettingsCon" Grid.Row="1">
                    <DeviceInfo:DeviceDisplaySettingsControl.Style>
                        <Style TargetType="DeviceInfo:DeviceDisplaySettingsControl">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DeviceInfo:DeviceDisplaySettingsControl.Style>
                </DeviceInfo:DeviceDisplaySettingsControl>

                <Border Grid.Row="2" 
                        Style="{DynamicResource SettingCardWithToggleStyle}" 
                        Margin="15,10" 
                        >

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock 
                                    Text="Текст протокола без ошибок" 
                                    Style="{DynamicResource SettingsTitleStyle}"
                                    Padding="10,10"
                                    Grid.Row="0"/>

                            <Grid Grid.Column="1"  Margin="20,0">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Icons:ArrowButton x:Name="ToggleSettingsTextProtocolButton" 
                                                    Grid.Column="0"
                                                    HorizontalAlignment="Right"
                                                    Width="30" Height="30"
                                                   ButtonBackground="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                                                    ButtonBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                                    ArrowBrush="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                                    ArrowHoverBrush="{DynamicResource SettingsInteractivePressedSolidColorBrush}"
                                                    VerticalAlignment="Center"/>

                                <Icons:RepeatIcon x:Name="RestartClearProtocol" Grid.Column="1" Margin="10,0" Size="20" PreviewMouseDown="RepeatIcon_PreviewMouseDown"/>
                            </Grid>
                        </Grid>

                        <local:ProtocolTemplateEditorControl Grid.Row="1" Margin="10" x:Name="BaseTextProtocol" IsErrorsTemplate="False">
                            <local:ProtocolTemplateEditorControl.Style>
                                <Style TargetType="local:ProtocolTemplateEditorControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding ElementName=ToggleSettingsTextProtocolButton, Path=IsArrowUp}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>

                                    </Style.Triggers>
                                </Style>
                            </local:ProtocolTemplateEditorControl.Style>
                        </local:ProtocolTemplateEditorControl>
                    </Grid>
                </Border>

                <Border Grid.Row="3" 
                        Style="{DynamicResource SettingCardWithToggleStyle}" 
                        Margin="15,10" 
                        >
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>


                            <TextBlock 
                                Text="Текст протокола с ошибками" 
                                Padding="10,10"
                                Style="{DynamicResource SettingsTitleStyle}"
                                Grid.Row="0"/>

                            <Grid Grid.Column="1"  Margin="20,0">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Icons:ArrowButton x:Name="ToggleSettingsTextProtocolErrorsButton" 
                                    Grid.Column="0"
                                    HorizontalAlignment="Right"
                                    Width="30" Height="30"
                                    ButtonBackground="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                                    ButtonBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                    ArrowBrush="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                    ArrowHoverBrush="{DynamicResource SettingsInteractivePressedSolidColorBrush}"
                                    VerticalAlignment="Center"/>

                                <Icons:RepeatIcon x:Name="RestartClearProtocolErrors" Grid.Column="1" Margin="10,0" Size="20" PreviewMouseDown="RepeatErrorIcon_PreviewMouseDown"/>
                            </Grid>
                        </Grid>

                        <local:ProtocolTemplateEditorControl Grid.Row="1" Margin="10" x:Name="BaseTextProtocolErrors" IsErrorsTemplate="True">
                            <local:ProtocolTemplateEditorControl.Style>
                                <Style TargetType="local:ProtocolTemplateEditorControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding ElementName=ToggleSettingsTextProtocolErrorsButton, Path=IsArrowUp}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>

                                    </Style.Triggers>
                                </Style>
                            </local:ProtocolTemplateEditorControl.Style>
                        </local:ProtocolTemplateEditorControl>
                    </Grid>
                </Border>

            </Grid>

        </Grid>
    </Border>
</UserControl>
