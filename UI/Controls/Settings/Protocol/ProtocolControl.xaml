<UserControl x:Class="UI.Controls.Settings.Protocol.ProtocolControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.Settings.Protocol"
             xmlns:Components ="clr-namespace:UI.Components"
             xmlns:Icons="clr-namespace:UI.Icon"
             xmlns:DeviceInfo="clr-namespace:UI.Controls.Settings.DeviceInfo"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">
    <Border 
       Style="{DynamicResource SettingPanelStyle}" Margin="15,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock 
                    Text="Протокол"
                    Padding="10,10"
                    Style="{DynamicResource SettingsTitleStyle}"
                    />

                <Grid Grid.Column="1"  Margin="20,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Icons:SuccessIconControlV2 
                        Grid.Column="1"
                        x:Name="Success" 
                        Width="30"
                        Margin="10,0,0,0"
                        Height="30" 
                        CheckThickness="4"
                        CircleBackground ="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                        CircleBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                        />

                    <Icons:ErrorIconControlV2 
                      x:Name="Error"
                        Grid.Column="2"
                      Width="30"
                      Height="30" 
                      Margin="10,0,0,0"
                      CrossThickness="4"
                      CircleBackground ="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                      CircleBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                      />


                    <Icons:ArrowButton x:Name="ToggleSettingsButton" 
                                           Grid.Column="0"
                                           HorizontalAlignment="Right"
                                           Width="30" Height="30"
                                           ButtonBackground="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                                           ButtonBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                           ArrowBrush="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                           ArrowHoverBrush="{DynamicResource SettingsInteractivePressedSolidColorBrush}"
                                           VerticalAlignment="Center"/>
                </Grid>

            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>


                <WrapPanel Orientation="Horizontal" >
                    <WrapPanel.Style>
                        <Style TargetType="WrapPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>

                    <Components:SettingsCard
                        Title="Вывод времени операции"
                        Description="Показывает, сколько времени прошло с момента запуска на каждом шаге выполнения."
                        IsChecked="{Binding IdleMode, Mode=TwoWay}"
                        Margin="10,10"
                        x:Name="OperationTime"
                        VerticalAlignment="Top"/>

                    <Components:SettingsCard
                        Title="Отображение заголовков действий"
                        Description="Отображает краткое описание текущего шага выполнения в виде заголовка."
                        IsChecked="{Binding IdleMode, Mode=TwoWay}"
                        Margin="10,10"
                        x:Name="Header"
                        VerticalAlignment="Top"/>

                    <Components:SettingsCard
                        Title="Сохранение протокола"
                        Description="Автоматически сохраняет протокол каждого запуска. Имя файла содержит дату, время и название выполняемых действий."
                        IsChecked="{Binding IdleMode, Mode=TwoWay}"
                        Margin="10,10"
                        x:Name="AutoSave"
                        VerticalAlignment="Top"/>

                    <Components:SettingsCard
                        Title="Печать протокола"
                        Description="По завершении выполнения отображает диалог выбора принтера для печати итогового протокола."
                        IsChecked="{Binding IdleMode, Mode=TwoWay}"
                        x:Name="AutoPrint"
                        Margin="10,10"
                        VerticalAlignment="Top"/>

                    <Components:SettingsCard
                        Title="Вывод протокола в ПО"
                        Description="По завершении выполнения протокол отображается в программном обеспечении, по умолчанию открывается как PDF-файл."
                        IsChecked="{Binding IdleMode, Mode=TwoWay}"
                        x:Name="ProtocolFromPO"
                        Margin="10,10"
                        VerticalAlignment="Top"/>

                    <Components:SettingsCard
                        Title="Формирование протокола"
                        Description="Протокол будет формироваться после выполнения программ контроля."
                        IsChecked="{Binding IdleMode, Mode=TwoWay}"
                        Margin="10,10"
                        VerticalAlignment="Top"
                        x:Name="ProtocolGeneration"/>


                </WrapPanel>

                <WrapPanel Grid.Row="1" Orientation="Horizontal">
                    <WrapPanel.Style>
                        <Style TargetType="WrapPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>

                    <DeviceInfo:DeviceDisplaySettingsControl x:Name="DeviceDisplaySettingsCon"
                                                             VerticalAlignment="Top">
                        <DeviceInfo:DeviceDisplaySettingsControl.Style>
                            <Style TargetType="DeviceInfo:DeviceDisplaySettingsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DeviceInfo:DeviceDisplaySettingsControl.Style>
                    </DeviceInfo:DeviceDisplaySettingsControl>

                    <Border Margin="15,10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Padding="10"
                            Background="{DynamicResource SettingsNestedGroupBackgroundSolidColorBrush}"
                            Style="{DynamicResource SettingCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock 
                                Grid.Column="0"
                                Text="Текст протокола без ошибок" 
                                Style="{DynamicResource SettingsTitleStyle}"
                                Padding="0,4,0,4"
                                Margin="0,0,6,0"/>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Icons:ArrowButton x:Name="ToggleSettingsTextProtocolButton"
                                                   HorizontalAlignment="Left"
                                                   Width="30"
                                                   Height="30"
                                                   Margin="0"
                                                   ButtonBackground="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                                                   ButtonBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                                   ArrowBrush="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                                   ArrowHoverBrush="{DynamicResource SettingsInteractivePressedSolidColorBrush}"
                                                   VerticalAlignment="Center"/>

                                <Icons:RepeatIcon x:Name="RestartClearProtocol"
                                                  Margin="8,0,0,0"
                                                  Size="20"
                                                  PreviewMouseDown="RepeatIcon_PreviewMouseDown"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Margin="15,10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Padding="10"
                            Background="{DynamicResource SettingsNestedGroupBackgroundSolidColorBrush}"
                            Style="{DynamicResource SettingCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock 
                                Grid.Column="0"
                                Text="Текст протокола с ошибками" 
                                Padding="0,4,0,4"
                                Style="{DynamicResource SettingsTitleStyle}"
                                Margin="0,0,6,0"/>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Icons:ArrowButton x:Name="ToggleSettingsTextProtocolErrorsButton"
                                                   HorizontalAlignment="Left"
                                                   Width="30"
                                                   Height="30"
                                                   Margin="0"
                                                   ButtonBackground="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                                                   ButtonBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                                   ArrowBrush="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                                   ArrowHoverBrush="{DynamicResource SettingsInteractivePressedSolidColorBrush}"
                                                   VerticalAlignment="Center"/>

                                <Icons:RepeatIcon x:Name="RestartClearProtocolErrors"
                                                  Margin="8,0,0,0"
                                                  Size="20"
                                                  PreviewMouseDown="RepeatErrorIcon_PreviewMouseDown"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </WrapPanel>

                <StackPanel Grid.Row="2">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <ContentControl Margin="15,0,15,10">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ToggleSettingsTextProtocolButton, Path=IsArrowUp}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>

                        <Border HorizontalAlignment="Left"
                                Padding="10"
                                Background="{DynamicResource SettingsNestedGroupBackgroundSolidColorBrush}"
                                Style="{DynamicResource SettingCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Настройка текста протокола для сценариев без ошибок."
                                           Style="{DynamicResource SettingsDescriptionStyle}"
                                           Margin="0,0,0,8"/>

                                <local:ProtocolTemplateEditorControl x:Name="BaseTextProtocol" IsErrorsTemplate="False"/>
                            </StackPanel>
                        </Border>
                    </ContentControl>

                    <ContentControl Margin="15,0,15,10">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ToggleSettingsTextProtocolErrorsButton, Path=IsArrowUp}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>

                        <Border HorizontalAlignment="Left"
                                Padding="10"
                                Background="{DynamicResource SettingsNestedGroupBackgroundSolidColorBrush}"
                                Style="{DynamicResource SettingCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Настройка текста протокола для сценариев с ошибками."
                                           Style="{DynamicResource SettingsDescriptionStyle}"
                                           Margin="0,0,0,8"/>

                                <local:ProtocolTemplateEditorControl x:Name="BaseTextProtocolErrors" IsErrorsTemplate="True"/>
                            </StackPanel>
                        </Border>
                    </ContentControl>
                </StackPanel>

            </Grid>

        </Grid>
    </Border>
</UserControl>
