<UserControl x:Class="UI.Controls.Settings.Protocol.ProtocolControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.Settings.Protocol"
             xmlns:Components ="clr-namespace:UI.Components"
             xmlns:SearchControl="clr-namespace:UI.Components.SearchControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Border Background="{StaticResource IsCheckedColorSolidColorBrush80}" Margin="15,10" CornerRadius="15" BorderThickness="1" BorderBrush="{StaticResource ForegroundSolidColorBrush60}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock 
                    Text="Протокол"
                    FontSize="18"
                    Padding="10,10"
                    Foreground="{StaticResource ForegroundSolidColorBrush}"
                    FontFamily="{StaticResource WinstonMedium}"
                    VerticalAlignment="Center"/>

                <SearchControl:ArrowButton x:Name="ToggleSettingsButton" 
                                           Grid.Column="1"
                                           Margin="10,0,0,0"
                                           Width="24" Height="24"
                                           HorizontalAlignment="Right"
                                           HoverArrowColor="{StaticResource ActiveBorderSolidColorBrush}" 
                                           VerticalAlignment="Center"/>

            </Grid>

            <WrapPanel Orientation="Horizontal" Grid.Row="1">
                <WrapPanel.Style>
                    <Style TargetType="WrapPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </WrapPanel.Style>

                <!-- Карточки настроек -->
                <Components:SettingsCard
                Title="Отображение оборудования"
                Description="Отображение информации выполняемых устройствами операций. В режиме отключения выводятся лишь измеренные значения. Ошибки показываются независимо от настройки."
                IsChecked="{Binding IdleMode, Mode=TwoWay}"
                Margin="10,10"
                VerticalAlignment="Top"
                    x:Name="DeviceInfo"
                    />

                <Components:SettingsCard
                Title="Вывод времени операции"
                Description="Показывает, сколько времени прошло с момента запуска на каждом шаге выполнения."
                IsChecked="{Binding IdleMode, Mode=TwoWay}"
                Margin="10,10"
                    x:Name="OperationTime"
                VerticalAlignment="Top"/>

                <Components:SettingsCard
                Title="Сохранение протокола"
                Description="Автоматически сохраняет протокол каждого запуска. Имя файла содержит дату, время и название выполняемых действий."
                IsChecked="{Binding IdleMode, Mode=TwoWay}"
                Margin="10,10"
                    x:Name="AutoSave"
                VerticalAlignment="Top"/>

                <Components:SettingsCard
                Title="Печать протокола"
                Description="По завершении выполнения отображает диалог выбора принтера для печати итогового протокола."
                IsChecked="{Binding IdleMode, Mode=TwoWay}"
                    x:Name="AutoPrint"
                Margin="10,10"
                VerticalAlignment="Top"/>
            </WrapPanel>
        </Grid>
    </Border>
</UserControl>
