<UserControl x:Class="UI.Controls.Settings.DeviceConfig.Controls.DeviceListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.Settings.DeviceConfig.Controls"
             xmlns:askUiIcons="clr-namespace:Ask.UI.Shared.Components.Icons;assembly=Ask.UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="TopMenuLikeIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource TestsInteractiveBackgroundSolidColorBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TestsInteractiveBorderSolidColorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource TestsInteractiveBackgroundSolidColorBrush}"/>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource TestsInteractiveBorderSolidColorBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource IsCheckedColorSolidColorBrush}"/>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource TestsInteractivePressedSolidColorBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RemoveButtonStyle" TargetType="Button" BasedOn="{StaticResource TopMenuLikeIconButtonStyle}">
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="#22E45757"/>
            <Setter Property="BorderBrush" Value="#66E45757"/>
            <Setter Property="Foreground" Value="#FFE57A7A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33E45757"/>
                    <Setter Property="BorderBrush" Value="#AAE45757"/>
                    <Setter Property="Foreground" Value="#FFFFA8A8"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#66E45757"/>
                    <Setter Property="BorderBrush" Value="#FFE45757"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditButtonStyle" TargetType="Button" BasedOn="{StaticResource TopMenuLikeIconButtonStyle}">
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="#2B4F8BFF"/>
            <Setter Property="BorderBrush" Value="#9C4F8BFF"/>
            <Setter Property="Foreground" Value="#FFBFD4FF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3F5F9FFF"/>
                    <Setter Property="BorderBrush" Value="#CF5F9FFF"/>
                    <Setter Property="Foreground" Value="#FFE5EEFF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#6A4F8BFF"/>
                    <Setter Property="BorderBrush" Value="#FF4F8BFF"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AddButtonStyle" TargetType="Button" BasedOn="{StaticResource TopMenuLikeIconButtonStyle}">
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Background" Value="#3D2FA84F"/>
            <Setter Property="BorderBrush" Value="#B02FA84F"/>
            <Setter Property="Foreground" Value="#FF7BFF8A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#553BCB61"/>
                    <Setter Property="BorderBrush" Value="#E03BCB61"/>
                    <Setter Property="Foreground" Value="#FFA8FFB2"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#7A2FA84F"/>
                    <Setter Property="BorderBrush" Value="#FF2FA84F"/>
                    <Setter Property="Foreground" Value="#FFD9FFD9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Border CornerRadius="10" Background="{DynamicResource BackgroundBrushes}"  
            Margin="5" BorderThickness="0" BorderBrush="{DynamicResource ActiveColorBrushes}">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="0"/>
        </Border.Effect>

        <StackPanel>
            <!-- Заголовок -->
            <Border Background="{DynamicResource SettingsMainBackground}" Padding="10" CornerRadius="10" Margin="0,0,0,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding DeviceTitle, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                               FontSize="20" Foreground="{DynamicResource ForegrounfBrushes}" VerticalAlignment="Center"/>

                    <!-- Кнопка добавления нового устройства -->
                    <Button x:Name="AddButtonContainer"
                            Grid.Column="1"
                            Margin="5,0"
                            Style="{StaticResource AddButtonStyle}"
                            PreviewMouseDown="PlusPreviewMouseDown"
                            ToolTip="Добавить устройство">
                        <askUiIcons:PlusCircleIcon Size="16"
                                                   ToolTip="Добавить устройство"
                                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                    </Button>
                </Grid>
            </Border>

            <!-- Список устройств -->
            <ItemsControl x:Name="DeviceList" ItemsSource="{Binding Devices}" Background="Transparent" Margin="0,0,0,5">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="Transparent" Padding="10" CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource ForegrounfBrushes}" FontSize="18" VerticalAlignment="Center"/>

                                <Button Grid.Column="1"
                                        Style="{StaticResource EditButtonStyle}"
                                        Click="EditDeviceButton_Click"
                                        CommandParameter="{Binding}"
                                        ToolTip="Редактировать устройство"
                                        Margin="0,0,6,0">
                                    <askUiIcons:EditIcon Size="14"
                                                         ToolTip="Редактировать устройство"
                                                         Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                </Button>

                                <Button Grid.Column="2"
                                        Style="{StaticResource RemoveButtonStyle}"
                                        Click="RemoveDeviceButton_Click"
                                        CommandParameter="{Binding}"
                                        ToolTip="Удалить устройство">
                                    <askUiIcons:TrashDeleteIcon Size="14"
                                                                 ToolTip="Удалить устройство"
                                                                 IsLidOpen="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}"
                                                                 Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>


        </StackPanel>
    </Border>
</UserControl>
