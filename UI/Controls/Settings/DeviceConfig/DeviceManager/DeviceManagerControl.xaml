<UserControl x:Class="UI.Controls.Settings.DeviceConfig.DeviceManager.DeviceManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.Settings.DeviceConfig.DeviceManager"
             xmlns:CustomControls="clr-namespace:UI.Components;assembly=UI"
             xmlns:DeviceList="clr-namespace:UI.Controls.Settings.DeviceConfig.Controls"
             mc:Ignorable="d" 
             Width="Auto"
             Height="Auto">
    <UserControl.Resources>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}" />
    </UserControl.Resources>
    <Border CornerRadius="0,0,0,0" Width="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

                
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="ButtonsPanel" Background="Transparent">
                        <StackPanel Background="Transparent" Margin="2">
                            <DeviceList:DeviceListControl x:Name="SwitchingDeviceControl" DeviceTitle="Устройство коммутации шин" Margin="5,5,5,0"/>
                            <DeviceList:DeviceListControl x:Name="RelaySwitchModuleControl" DeviceTitle="Модуль коммутации релейный" Margin="5,5,5,0"/>
                            <DeviceList:DeviceListControl x:Name="PowerSourceModuleControl" DeviceTitle="Модуль ист. напряжения и тока" Margin="5,5,5,0"/>
                            <DeviceList:DeviceListControl x:Name="PrecisionMeterControl" DeviceTitle="Измеритель (точный)" Margin="5,5,5,0"/>
                            <DeviceList:DeviceListControl x:Name="FastMeterControl" DeviceTitle="Измеритель (быстрый)" Margin="5,5,5,0"/>
                            <DeviceList:DeviceListControl x:Name="BreakdownTesterControl" DeviceTitle="Пробойная установка" Margin="5,5,5,0"/>
                            <DeviceList:DeviceListControl x:Name="UninterruptiblePowerSupplyControl" DeviceTitle="Бесперебойник" Margin="5,5,5,0"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
