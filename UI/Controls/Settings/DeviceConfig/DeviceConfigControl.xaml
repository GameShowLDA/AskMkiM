<UserControl x:Class="UI.Controls.Settings.DeviceConfig.DeviceConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.Settings.DeviceConfig"
             xmlns:Chassis="clr-namespace:UI.Controls.Settings.DeviceConfig.ChassisManager"
             mc:Ignorable="d"
             >

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" x:Name="Column1"/>
            <ColumnDefinition Width="*" x:Name="Column2"/>
            <ColumnDefinition Width="Auto" x:Name="Column3"/>
        </Grid.ColumnDefinitions>


        <Chassis:ChassisManagerControl x:Name="chassisManager"/>
        
        <Border Grid.Column="1" 
            Name="deviceBorder"
            >
        </Border>

        <Border Grid.Column="2" Name="settingsBorder" Visibility="Collapsed"/>

    </Grid>
</UserControl>
