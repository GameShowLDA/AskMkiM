<UserControl x:Class="UI.Controls.Settings.DeviceConfig.Base.BaseSettingsConfig.DeviceSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.Settings.DeviceConfig.Base.BaseSettingsConfig"
             mc:Ignorable="d" 
             d:DesignHeight="600" 
             d:DesignWidth="400"
             >
    <UserControl.Resources>
        <Style x:Key="DeviceSettingsUnifiedComboBoxStyle"
               TargetType="ComboBox"
               BasedOn="{StaticResource CustomComboBoxStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="14,8,14,8"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style x:Key="DeviceSettingsUnifiedInputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SettingsConfigDataInputTabloBackgroundSolidColorBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="14,8,14,8"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style x:Key="DeviceSettingsUnifiedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
        </Style>

        <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}" />

        <DropShadowEffect x:Key="ShadowEffect" 
                         BlurRadius="20" 
                         ShadowDepth="0" 
                         Opacity="0.5" 
                         Color="Black"/>
    </UserControl.Resources>

    <Border Background="{DynamicResource DeviceInputShellBackgroundBrush}"
            CornerRadius="20"
            Padding="12,12"
            Margin="8,8,8,12"
            HorizontalAlignment="Stretch"
            Effect="{DynamicResource ShadowEffect}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Name="Header" Text="Настройка устройства:  Имя устройства"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Stretch"
                       Margin="6,4,6,10"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource ForegrounfBrushes}" FontSize="25" FontWeight="Bold"/>

            <ScrollViewer Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" VerticalScrollBarVisibility="Auto" Padding="2,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!--Модель устройства-->
                    <Border Grid.Row="0" Style="{StaticResource DeviceInputSectionCardStyle}"
                        Name="DeviceModelContainer"
                        >
                        <Grid >
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource DeviceInputSectionTitleBarStyle}">
                                <TextBlock Text="Модель устройства" Foreground="{DynamicResource ForegrounfBrushes}" 
                                   FontSize="20" FontWeight="Bold" Margin="7,0"
                                   />
                            </Border>

                            <ComboBox Grid.Row="1" 
                                  Name="DeviceModelSelectionBox" 
                                  Style="{StaticResource DeviceSettingsUnifiedComboBoxStyle}"
                                  SelectionChanged="DeviceModelSelectionBox_SelectionChanged"
                        >
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!--Модель устройства-->
                    <Border Grid.Row="1" Style="{StaticResource DeviceInputSectionCardStyle}"
                            Name="BusTypeContainer"
                            >
                        <Grid >
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource DeviceInputSectionTitleBarStyle}">
                                <TextBlock Text="Тип структурной шины" Foreground="{DynamicResource ForegrounfBrushes}" 
                           FontSize="20" FontWeight="Bold" Margin="7,0"
                           />
                            </Border>

                            <ComboBox Grid.Row="1" 
                                Name="BusTypeSelectionBox" 
                                Style="{StaticResource DeviceSettingsUnifiedComboBoxStyle}"
                                SelectionChanged="BusTypeSelectionBox_SelectionChanged"
                                >
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!--Номер устройства-->
                    <Border Grid.Row="2" Style="{StaticResource DeviceInputSectionCardStyle}"
                        Name="DeviceNumberContainer"
                        >
                        <Grid >
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource DeviceInputSectionTitleBarStyle}">
                                <TextBlock Text="Номер устройства" Foreground="{DynamicResource ForegrounfBrushes}" 
                                       FontSize="20" FontWeight="Bold" Margin="7,0"
                                       />
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource DeviceSettingsUnifiedInputBorderStyle}">
                                <TextBox 
                                     Style="{StaticResource DeviceSettingsUnifiedTextBoxStyle}"
                                     PreviewTextInput="NumberDevice_PreviewTextInput"
                                     TextChanged="NumberDevice_TextChanged"
                                     Name="DeviceNumberTextBox"
                                     />
                            </Border>
                        </Grid>
                    </Border>

                    <!--Номер устройства-->
                    <Border Grid.Row="3" Style="{StaticResource DeviceInputSectionCardStyle}"
                            Name="ResistanceContainer"
                            >
                        <Grid >
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource DeviceInputSectionTitleBarStyle}">
                                <TextBlock Text="Сопротивление коммутатора, Ом" Foreground="{DynamicResource ForegrounfBrushes}" 
                                           FontSize="20" FontWeight="Bold" Margin="7,0"/>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource DeviceSettingsUnifiedInputBorderStyle}">
                                <TextBox 
                                    Style="{StaticResource DeviceSettingsUnifiedTextBoxStyle}"
                                    PreviewTextInput="ResistanceDevice_PreviewTextInput"
                                    TextChanged="ResistanceDevice_TextChanged"
                                    Name="ResistanceTextBox"
                                    />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4" Style="{StaticResource DeviceInputSectionCardStyle}"
                            Name="CapacitanceContainer"
                            >
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource DeviceInputSectionTitleBarStyle}">
                                <TextBlock Text="Ёмкость коммутатора, нФ" Foreground="{DynamicResource ForegrounfBrushes}"
                                           FontSize="20" FontWeight="Bold" Margin="7,0"/>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource DeviceSettingsUnifiedInputBorderStyle}">
                                <TextBox
                                    Style="{StaticResource DeviceSettingsUnifiedTextBoxStyle}"
                                    PreviewTextInput="ResistanceDevice_PreviewTextInput"
                                    TextChanged="ResistanceDevice_TextChanged"
                                    Name="CapacitanceTextBox"
                                    />
                            </Border>
                        </Grid>
                    </Border>

                    <!--Тип подлючения устройства-->
                    <Border Grid.Row="5" 
                        Style="{StaticResource DeviceInputSectionCardStyle}"
                        Name="ConnectionTypeContainer"
                        >
                        <Grid >
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource DeviceInputSectionTitleBarStyle}">
                                <TextBlock Text="Тип подключения устройства" Foreground="{DynamicResource ForegrounfBrushes}" 
                             FontSize="20" FontWeight="Bold" Margin="7,0"
                             />
                            </Border>

                            <ComboBox Grid.Row="1" 
                                Name="ConnectionTypeSelectionBox" 
                                Style="{StaticResource DeviceSettingsUnifiedComboBoxStyle}"
                                SelectionChanged="ConnectionTypeSelectionBox_SelectionChanged"
                                PreviewMouseWheel="ConnectionTypeSelectionBox_OnPreviewMouseWheel">

                                <ComboBoxItem IsEnabled="False" Content="Выбор типа подключения:" IsSelected="True" Foreground="Gray"/>
                                <ComboBoxItem Content="IP" Name="ConnectionTypeIPItem"/>
                                <ComboBoxItem Content="COM" Name="ConnectionTypeCOMItem"/>
                                <ComboBoxItem Content="USB" Name="ConnectionTypeUSBItem"/>

                            </ComboBox>

                        </Grid>
                    </Border>

                    <!--IP address устройства-->
                    <Border Grid.Row="6" Style="{StaticResource DeviceInputSectionCardStyle}"
                        Name="IPAddressContainer"
                        >
                        <Grid >
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource DeviceInputSectionTitleBarStyle}">
                                <TextBlock Text="IP Address" Foreground="{DynamicResource ForegrounfBrushes}" 
                                       FontSize="20" FontWeight="Bold" Margin="7,0"
                                       />
                            </Border>

                            <Grid Grid.Row="1" Height="40" Margin="10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="5"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="5"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="5"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="{DynamicResource SettingsConfigDataInputTabloBackgroundSolidColorBrush}" CornerRadius="5" >
                                    <TextBox Background="Transparent" 
                                         BorderThickness="0" VerticalAlignment="Center" 
                                         HorizontalAlignment="Center" FontSize="20" Foreground="{DynamicResource ForegrounfBrushes}"
                                         Name="IpPart1"
                                         />
                                </Border>

                                <TextBlock Grid.Column="1" Text="." FontSize="20" Foreground="{DynamicResource ForegrounfBrushes}"
                                       VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                       />


                                <Border Grid.Column="2" Background="{DynamicResource SettingsConfigDataInputTabloBackgroundSolidColorBrush}" CornerRadius="5" >
                                    <TextBox Background="Transparent"  BorderThickness="0" VerticalAlignment="Center" 
                                         HorizontalAlignment="Center" FontSize="20" Foreground="{DynamicResource ForegrounfBrushes}"
                                         Name="IpPart2"
                                         />
                                </Border>
                                <TextBlock Grid.Column="3" Text="." FontSize="20" Foreground="{DynamicResource ForegrounfBrushes}"
                                       VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                       />


                                <Border Grid.Column="4" Background="{DynamicResource SettingsConfigDataInputTabloBackgroundSolidColorBrush}" CornerRadius="5" >
                                    <TextBox Background="Transparent" BorderThickness="0" VerticalAlignment="Center" 
                                         HorizontalAlignment="Center" FontSize="20" Foreground="{DynamicResource ForegrounfBrushes}"
                                         Name="IpPart3"
                                         />
                                </Border>
                                <TextBlock Grid.Column="5" Text="." FontSize="20" Foreground="{DynamicResource ForegrounfBrushes}"
                                       VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                       />


                                <Border Grid.Column="6" Background="{DynamicResource SettingsConfigDataInputTabloBackgroundSolidColorBrush}" CornerRadius="5" >
                                    <TextBox Background="Transparent"  BorderThickness="0" VerticalAlignment="Center" 
                                         HorizontalAlignment="Center" FontSize="20" Foreground="{DynamicResource ForegrounfBrushes}"
                                         Name="IpPart4"
                                         />
                                </Border>

                            </Grid>

                        </Grid>
                    </Border>

                    <!--COM устройства-->
                    <Border Grid.Row="7" Background="{DynamicResource PrimarySolidColorBrush}" 
                        CornerRadius="10" Margin="0,10"
                        Name="COMContainer"
                        >
                        <Grid >
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource DeviceInputSectionTitleBarStyle}">
                                <TextBlock Text="COM PORT" Foreground="{DynamicResource ForegroundSolidColorBrush}" 
                                       FontSize="20" FontWeight="Bold" Margin="7,0"
                                       />
                            </Border>

                            <Border Grid.Row="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <Grid Margin="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>

                                        <!--Выбор COM-->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="COM-порт:" Foreground="{DynamicResource ForegroundSolidColorBrush}" 
                                                   FontSize="20" FontWeight="Bold" Margin="7,0"/>

                                            <ComboBox Grid.Column="1"
                                                  x:Name="COMPortSelectionBox"
                                                  MinWidth="100"
                                                  Style="{StaticResource CustomComboBoxStyle}"
                                                  VerticalAlignment="Center"
                                                  SelectionChanged="COMPortSelectionBox_SelectionChanged"
                                                  />
                                        </Grid>

                                        <!--VID-->
                                        <Grid Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>


                                            <TextBlock Text="VID:" Foreground="{DynamicResource ForegroundSolidColorBrush}" 
                                                   FontSize="20" FontWeight="Bold" Margin="7,0"/>

                                            <Border Grid.Column="1" Background="{DynamicResource SettingsConfigDataInputTabloBackgroundSolidColorBrush}" CornerRadius="5" >
                                                <TextBox x:Name="VIDData" Background="Transparent"  BorderThickness="0" VerticalAlignment="Center" 
                                         HorizontalAlignment="Center" FontSize="20" Foreground="{DynamicResource ForegroundSolidColorBrush}"/>
                                            </Border>
                                        </Grid>

                                        <!--PID-->
                                        <Grid Grid.Column="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>


                                            <TextBlock Text="PID:" Foreground="{DynamicResource ForegroundSolidColorBrush}" 
                                                   FontSize="20" FontWeight="Bold" Margin="7,0"/>

                                            <Border Grid.Column="1" Background="{DynamicResource SettingsConfigDataInputTabloBackgroundSolidColorBrush}" CornerRadius="5" >
                                                <TextBox x:Name="PIDData" Background="Transparent"  BorderThickness="0" VerticalAlignment="Center" 
                                                     HorizontalAlignment="Center" FontSize="20" Foreground="{DynamicResource ForegroundSolidColorBrush}"/>
                                            </Border>
                                        </Grid>
                                    </Grid>

                                    <Grid Grid.Row="1" Margin="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>

                                            <!--Бит в секунlу-->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Бит в секунду:" Foreground="{DynamicResource ForegroundSolidColorBrush}" 
                                                       FontSize="20" FontWeight="Bold" Margin="7,0"/>

                                                <ComboBox Grid.Column="1"
                                                      SelectedIndex="3"
                                                      MinWidth="100"
                                                      x:Name="BaudRateSelectionBox"
                                                      Style="{StaticResource CustomComboBoxStyle}"
                                                      VerticalAlignment="Center"
                                                      >
                                                    <ComboBoxItem>1200</ComboBoxItem>
                                                    <ComboBoxItem>2400</ComboBoxItem>
                                                    <ComboBoxItem>4800</ComboBoxItem>
                                                    <ComboBoxItem>9600</ComboBoxItem>
                                                    <ComboBoxItem>14400</ComboBoxItem>
                                                    <ComboBoxItem>19200</ComboBoxItem>
                                                    <ComboBoxItem>38400</ComboBoxItem>
                                                    <ComboBoxItem>57600</ComboBoxItem>
                                                    <ComboBoxItem>115200</ComboBoxItem>
                                                </ComboBox>
                                            </Grid>

                                            <!--Стоповые биты-->
                                            <Grid Grid.Column="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Стоповые биты:" Foreground="{DynamicResource ForegroundSolidColorBrush}" 
                                                FontSize="20" FontWeight="Bold" Margin="7,0"/>

                                                <ComboBox Grid.Column="1"
                                                SelectedIndex="0"
                                                Style="{StaticResource CustomComboBoxStyle}"
                                                VerticalAlignment="Center"
                                                x:Name="StopBitsSelectionBox"
                                                >
                                                    <ComboBoxItem>1</ComboBoxItem>
                                                    <ComboBoxItem>1.5</ComboBoxItem>
                                                    <ComboBoxItem>2</ComboBoxItem>
                                                </ComboBox>
                                            </Grid>
                                        </Grid>
                                    </Grid>

                                    <Grid Grid.Row="2" Margin="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>

                                            <!--Биты данных-->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Биты данных:" Foreground="{DynamicResource ForegroundSolidColorBrush}" 
                                                       FontSize="20" FontWeight="Bold" Margin="7,0"/>


                                                <ComboBox Grid.Column="1"
                                                    SelectedIndex="4"
                                                    MinWidth="100"
                                                    x:Name="DataBitsSelectionBox"
                                                    Style="{StaticResource CustomComboBoxStyle}"
                                                    VerticalAlignment="Center"
                                                    >
                                                    <ComboBoxItem>4</ComboBoxItem>
                                                    <ComboBoxItem>5</ComboBoxItem>
                                                    <ComboBoxItem>6</ComboBoxItem>
                                                    <ComboBoxItem>7</ComboBoxItem>
                                                    <ComboBoxItem>8</ComboBoxItem>
                                                </ComboBox>
                                            </Grid>

                                            <!--Чётность-->
                                            <Grid Grid.Column="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Чётность:" Foreground="{DynamicResource ForegroundSolidColorBrush}" 
                                            FontSize="20" FontWeight="Bold" Margin="7,0"/>

                                                <ComboBox Grid.Column="1"
                                                      SelectedIndex="2"
                                                      Style="{StaticResource CustomComboBoxStyle}"
                                                      VerticalAlignment="Center"
                                                      x:Name="ParitySelectionBox"
                                                      >
                                                    <ComboBoxItem>Чет</ComboBoxItem>
                                                    <ComboBoxItem>Нечет</ComboBoxItem>
                                                    <ComboBoxItem>Нет</ComboBoxItem>
                                                    <ComboBoxItem>Маркер</ComboBoxItem>
                                                    <ComboBoxItem>Пробел</ComboBoxItem>
                                                </ComboBox>
                                            </Grid>
                                        </Grid>
                                    </Grid>

                                    <Grid Grid.Row="3" Margin="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>

                                            <!--Управление потоком-->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Управление потоком:" Foreground="{DynamicResource ForegroundSolidColorBrush}" 
                                                       FontSize="20" FontWeight="Bold" Margin="7,0"/>

                                                <ComboBox Grid.Column="1"
                                                      SelectedIndex="2"
                                                      MinWidth="100"
                                                      Style="{StaticResource CustomComboBoxStyle}"
                                                      VerticalAlignment="Center"
                                                      x:Name="FlowControlSelectionBox"     
                                                      >
                                                    <ComboBoxItem>Xon/Xoff</ComboBoxItem>
                                                    <ComboBoxItem>Аппаратное</ComboBoxItem>
                                                    <ComboBoxItem>Нет</ComboBoxItem>
                                                </ComboBox>
                                            </Grid>

                                        </Grid>
                                    </Grid>

                                </Grid>
                            </Border>

                        </Grid>
                    </Border>

                    <Border Grid.Row="8"
                        Style="{StaticResource DeviceInputSectionCardStyle}"
                        Name="USBContainer">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource DeviceInputSectionTitleBarStyle}">
                                <TextBlock Text="USB устройство" Foreground="{DynamicResource ForegrounfBrushes}"
                                           FontSize="20" FontWeight="Bold" Margin="7,0"/>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource DeviceSettingsUnifiedInputBorderStyle}" Height="Auto" MinHeight="40" Padding="0,6">
                                <TextBlock x:Name="USBStatusData"
                                           Foreground="{DynamicResource ForegrounfBrushes}"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           Margin="12,0"
                                           TextWrapping="Wrap"
                                           Text="Ожидание поиска..." />
                            </Border>

                            <Grid Grid.Row="2" Margin="14,8,14,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Порт:" Foreground="{DynamicResource ForegroundSolidColorBrush}" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Border Grid.Column="1" Background="{DynamicResource SettingsConfigDataInputTabloBackgroundSolidColorBrush}" CornerRadius="5">
                                    <TextBox x:Name="USBPortData" Background="Transparent" BorderThickness="0" IsReadOnly="True"
                                             VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource ForegroundSolidColorBrush}" Padding="8,4"/>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="3" Margin="14,0,14,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="ID:" Foreground="{DynamicResource ForegroundSolidColorBrush}" FontSize="16" VerticalAlignment="Top" Margin="0,6,8,0"/>
                                    <Border Grid.Column="1" Background="{DynamicResource SettingsConfigDataInputTabloBackgroundSolidColorBrush}" CornerRadius="5">
                                        <TextBox x:Name="USBDeviceIdData" Background="Transparent" BorderThickness="0" IsReadOnly="True"
                                                 VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource ForegroundSolidColorBrush}" Padding="8,6"
                                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="52"/>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="VID:" Foreground="{DynamicResource ForegroundSolidColorBrush}" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Border Grid.Column="1" Background="{DynamicResource SettingsConfigDataInputTabloBackgroundSolidColorBrush}" CornerRadius="5" Margin="0,0,12,0">
                                        <TextBox x:Name="USBVIDData" Background="Transparent" BorderThickness="0" IsReadOnly="True"
                                                 VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource ForegroundSolidColorBrush}" Padding="8,4"/>
                                    </Border>

                                    <TextBlock Grid.Column="2" Text="PID:" Foreground="{DynamicResource ForegroundSolidColorBrush}" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Border Grid.Column="3" Background="{DynamicResource SettingsConfigDataInputTabloBackgroundSolidColorBrush}" CornerRadius="5">
                                        <TextBox x:Name="USBPIDData" Background="Transparent" BorderThickness="0" IsReadOnly="True"
                                                 VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource ForegroundSolidColorBrush}" Padding="8,4"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <ContentControl x:Name="AdditionalSettingsContainer" Grid.Row="9" Margin="0,10,0,10"/>
                </Grid>

            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Name="CancelButton" Grid.Column="0" Content="Отменить" 
                    Style="{StaticResource DeviceInputSecondaryActionButton}" 
                    Margin="0,10,8,10"
                    MinWidth="120"
                    MaxWidth="170"
                    HorizontalAlignment="Center"
                    PreviewMouseDown="CancelButton_PreviewMouseDown"
                    />

                <Button Name="SaveButton" Grid.Column="1" Content="Сохранить" 
             Style="{StaticResource DeviceInputPrimaryActionButton}" 
             MinWidth="120"
             MaxWidth="170"
             HorizontalAlignment="Center"
             Margin="8,10,0,10"
             PreviewMouseDown="SaveButton_PreviewMouseDown"       
             />
            </Grid>
        </Grid>
    </Border>
</UserControl>

