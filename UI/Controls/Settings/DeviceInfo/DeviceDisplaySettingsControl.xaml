<UserControl x:Class="UI.Controls.Settings.DeviceInfo.DeviceDisplaySettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.Settings.DeviceInfo"
             xmlns:Components ="clr-namespace:UI.Components"
             xmlns:Icons="clr-namespace:UI.Icon"    
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border 
     Margin="15,10" 
     Style="{DynamicResource SettingPanelStyle}">
        <Grid>
            <StackPanel>
                <Border HorizontalAlignment="Left"
                        Padding="10"
                        Background="{DynamicResource SettingsNestedGroupBackgroundSolidColorBrush}"
                        Style="{DynamicResource SettingCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Информация об оборудовании"
                                       Style="{DynamicResource SettingsTitleStyle}"
                                       Padding="0,4,0,4"
                                       Margin="0,0,6,0"/>

                            <Icons:ArrowButton x:Name="ToggleDeviceInfoSettingsButton"
                                               Grid.Column="1"
                                               HorizontalAlignment="Left"
                                               Width="30"
                                               Height="30"
                                               Margin="0"
                                               ButtonBackground="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                                               ButtonBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                               ArrowBrush="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                               ArrowHoverBrush="{DynamicResource SettingsInteractivePressedSolidColorBrush}"
                                               VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Grid.Row="1">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=ToggleDeviceInfoSettingsButton, Path=IsArrowUp}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="Настройка отображения информации об оборудовании в протоколе выполнения."
                                       Style="{DynamicResource SettingsDescriptionStyle}"
                                       Margin="0,0,0,8"/>

                            <WrapPanel Orientation="Horizontal">
                                <Components:SettingsCard
                                    Title="Машинные адреса"
                                    Description="Отображение машинных адресов точек системы АСК-МКИ-М."
                                    IsChecked="{Binding IdleMode, Mode=TwoWay}" 
                                    Margin="0,6,10,0"
                                    VerticalAlignment="Top"
                                    x:Name="MachineAddressesCard"/>

                                <Components:SettingsCard
                                    Title="Подключение точек и шин"
                                    Description="Отображает информацию о подключении точек и шин на устройствах."
                                    Margin="0,6,10,0"
                                    VerticalAlignment="Top"
                                    x:Name="ConnectionInfo"/>

                                <Components:SettingsCard
                                    Title="Параметры устройств"
                                    Description="Отображает параметры, которые устанавливаются на устройства в ходе выполнения."
                                    Margin="0,6,10,0"
                                    VerticalAlignment="Top"
                                    x:Name="DeviceExecutionParameters"/>

                                <Components:SettingsCard
                                    Title="Результаты измерений"
                                    Description="Отображает результаты измерений, полученные в ходе выполнения программ контроля."
                                    Margin="0,6,0,0"
                                    VerticalAlignment="Top"
                                    x:Name="MeasurementResults"/>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
