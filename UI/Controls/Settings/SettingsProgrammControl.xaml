<UserControl x:Class="UI.Controls.Settings.SettingsProgrammControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.Settings"
             
             xmlns:Components ="clr-namespace:UI.Components"
             xmlns:Execution="clr-namespace:UI.Controls.Settings.Execution"
             xmlns:Procol="clr-namespace:UI.Controls.Settings.Protocol"
             xmlns:Config="clr-namespace:UI.Controls.Settings.DeviceConfig"
             xmlns:UiSetting="clr-namespace:UI.Controls.Settings.UserInterface"
             xmlns:Icons="clr-namespace:UI.Icon"
             xmlns:LocalizeStrings="clr-namespace:Ask.UI.Infrastructure.Localization;assembly=Ask.UI"
             
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <LocalizeStrings:LocalizedString x:Key="Settings_Main_Title" Key="settings.main.title" />
        <LocalizeStrings:LocalizedString x:Key="Settings_Config_Title" Key="settings.config.title" />
        <LocalizeStrings:LocalizedString x:Key="Settings_Config_PrintButton" Key="settings.config.printButton" />

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand" 
                                              Background="Transparent" 
                                              BorderThickness="0" 
                                              Height="10"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Name="Thumb" 
                                       Background="{StaticResource SecondarySolidColorBrush}" 
                                       BorderThickness="0"
                                       Cursor="ScrollNS">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="Transparent" 
                                                    BorderThickness="0"
                                                    CornerRadius="10"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand" 
                                              Background="Transparent" 
                                              BorderThickness="0" 
                                              Height="10"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource SettingsMainBackgroundSolidColorBrush}" CornerRadius="20" Margin="20">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock 
            Text="{Binding Source={StaticResource Settings_Main_Title}, Path=Value}" 
            Padding="15,10"
            Style="{DynamicResource SettingsTitleStyle}"
            FontFamily="{DynamicResource WinstonBold}"
            FontSize="22" 
            Grid.Row="0"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="1">
                <Grid >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" x:Name="ConfigManager" 
                        Style="{DynamicResource SettingPanelStyle}"
                        Margin="15,10" 
                        >
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>


                                <TextBlock 
                                Text="{Binding Source={StaticResource Settings_Config_Title}, Path=Value}" 
                                Padding="10,10"
                                Style="{DynamicResource SettingsTitleStyle}"
                                VerticalAlignment="Center"  
                                Grid.Row="0"/>

                                <Button 
                                Grid.Column="2"
                                Width="100"
                                Height="30"
                                Style="{DynamicResource ButtonStyleV10}"
                                BorderThickness="1"
                                Content="{Binding Source={StaticResource Settings_Config_PrintButton}, Path=Value}"
                                Foreground="{DynamicResource ForegrounfBrushes}"
                                PreviewMouseDown="PrintConfig"
                                    />

                                <Grid Grid.Column="1"  Margin="20,0">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Icons:ArrowButton x:Name="ToggleSettingsButton" 
                                    Grid.Column="0"
                                    HorizontalAlignment="Right"
                                    Width="30" Height="30"
                                    ButtonBackground="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                                    ButtonBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                    ArrowBrush="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                    ArrowHoverBrush="{DynamicResource SettingsInteractivePressedSolidColorBrush}"
                                    IsArrowUp ="True"
                                    VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>

                            <Config:DeviceConfigControl Grid.Row="1">
                                <Config:DeviceConfigControl.Style>
                                    <Style TargetType="{x:Type Config:DeviceConfigControl}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Config:DeviceConfigControl.Style>
                            </Config:DeviceConfigControl>

                        </Grid>
                    </Border>

                    <Execution:ExecutionControl Grid.Row="1" x:Name="ExecutionManager"/>

                    <Procol:ProtocolControl Grid.Row="2" x:Name="ProtocolManager"/>

                    <UiSetting:UiSettingsControl Grid.Row="3" x:Name="InterfaceManager"/>


                </Grid>
            </ScrollViewer>

        </Grid>

    </Border>
</UserControl>
