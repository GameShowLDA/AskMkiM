<Window x:Class="UI.Controls.Search.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Elements="clr-namespace:UI.Components.SearchControls"
        Title="SearchWindow" Height="100" Width="350"
        MinWidth="350"
        MinHeight="100" MaxHeight="100"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded">
    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="87"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <!-- Скрытая строка по умолчанию -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Строка 1 -->
        <Elements:ArrowButton x:Name="ToggleArrow"
                              Width="25" Height="25" 
                              VerticalAlignment="Center" 
                              HorizontalAlignment="Center"  
                              ArrowColor="Black" 
                              HoverArrowColor="Red" 
                              IsArrowUp="False"
                              />

        <TextBox Grid.Column="1" Margin="2" Text="Поиск..." VerticalAlignment="Stretch"/>
        <Grid Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*"/>
                <ColumnDefinition Width="50*"/>
            </Grid.ColumnDefinitions>

            <ComboBox Margin="2" VerticalAlignment="Stretch">
                <ComboBoxItem Content="->" IsSelected="True"/>
                <ComboBoxItem Content="&lt;-" />
                <ComboBoxItem Content="O-" />
            </ComboBox>

            <Button Content="X" Grid.Column="1" Height="25" Width="25"/>
        </Grid>

        <!-- Строка 2 (По умолчанию скрыта) -->
        <TextBox Grid.Column="1" Grid.Row="1" Text="Замена..." Margin="2" VerticalAlignment="Stretch"/>
        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*"/>
                <ColumnDefinition Width="50*"/>
            </Grid.ColumnDefinitions>
            <Button Content="b/c" Height="25" Width="25"/>
            <Button Content="ab/ac" Height="25" Width="25" Grid.Column="1"/>
        </Grid>

        <!-- Строка 3 -->
        <Grid Grid.Row="2" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="12*"/>
                <ColumnDefinition Width="12*"/>
                <ColumnDefinition Width="12*"/>
                <ColumnDefinition Width="12*"/>
                <ColumnDefinition Width="52*"/>
            </Grid.ColumnDefinitions>

            <Button Content="Aa" Height="25" Width="25"/>
            <Button Content="АБ" Height="25" Width="25" Grid.Column="1"/>
            <Button Content="*" Height="25" Width="25" Grid.Column="2"/>
            <Button Content="AB" Height="25" Width="25" Grid.Column="3"/>
            <ComboBox Grid.Column="4" Margin="2" VerticalAlignment="Stretch">
                <ComboBoxItem Content="Текущий документ" Tag="document" IsSelected="True"/>
                <ComboBoxItem Content="Все открытые документы" Tag="allDocuments"/>
            </ComboBox>
        </Grid>
    </Grid>
</Window>
