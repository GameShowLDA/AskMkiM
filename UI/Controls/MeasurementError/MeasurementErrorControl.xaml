<UserControl x:Class="UI.Controls.MeasurementError.MeasurementErrorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.MeasurementError"
             mc:Ignorable="d" 
             xmlns:ErrCard="clr-namespace:UI.Components" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{StaticResource SecondarySolidColorBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ErrCard:MeasurementErrorCard Margin="5" HorizontalAlignment="Left" Width="280" Height="270" TypeCommand="KC"/>
            <ErrCard:MeasurementErrorCard Margin="5" HorizontalAlignment="Left" Width="280" Height="270" TypeCommand="PR" Grid.Column="1"/>
            <ErrCard:MeasurementErrorCard Margin="5" HorizontalAlignment="Left" Width="280" Height="270" TypeCommand="CI"  Grid.Column="2"/>
        </Grid>
        

    </Grid>
</UserControl>
