<UserControl x:Class="UI.Controls.TranslatorTextEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls"
             xmlns:askUiIcons="clr-namespace:Ask.UI.Shared.Components.Icons;assembly=Ask.UI"
             xmlns:TextEditor="clr-namespace:UI.Controls.TextEditorControl"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
            Height="40"
            MaxHeight="40"
            Margin="5"
            Padding="6,4"
            Background="{DynamicResource SettingsNestedGroupBackgroundSolidColorBrush}"
            Style="{DynamicResource SettingCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="SaveButton"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Click="SaveButton_Click"
                        ToolTip="Сохранить файл"
                        Style="{StaticResource SaveButtonStyle}">
                    <askUiIcons:SaveIcon Size="16"
                                         Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                </Button>

                <Button x:Name="OpenFolderButton"
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Click="OpenFolderButton_Click"
                        ToolTip="Показать файл в папке"
                        Style="{StaticResource ActionButtonStyle}">
                    <askUiIcons:FolderOpenIcon Size="16"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                </Button>

                <Button x:Name="PrintButton"
                        Grid.Column="2"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Click="PrintButton_Click"
                        ToolTip="Печать файла"
                        Style="{StaticResource ActionButtonStyle}">
                    <askUiIcons:PrintIcon Size="16"
                                          IsPrinting="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}"
                                          Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                </Button>

                <TextBlock x:Name="FileName" 
                       Grid.Column = "3" 
                       Text="Some text"
                       FontSize="16"
                       Margin="12,0"
                       FontFamily="{DynamicResource WinstonBold}"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource ForegrounfBrushes}"
                       />
            </Grid>
        </Border>

        <Border Grid.Row="1"
            Style="{DynamicResource SettingCardStyle}"
            BorderThickness="0"
            ClipToBounds="True">
            <ContentControl x:Name="EditorHost">
                <TextEditor:TextEditorUI x:Name="TextEditor"
                                     FontSize="14"
                                     IsReadOnly="False"/>
            </ContentControl>
        </Border>
    </Grid>
</UserControl>
