<UserControl x:Class="UI.Controls.FileCompare.FileCompareSelectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI;component/Windows/WpfDocking/Themes/Generic/TabControl.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="DiffListBoxItemStyle" TargetType="ListBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CompareCardBorderStyle" TargetType="Border" BasedOn="{StaticResource SettingCardStyle}">
                <Setter Property="Padding" Value="12"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"/>
            </Style>

            <Style x:Key="CompareCardTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource MainTitleSolidColorBrush}"/>
                <Setter Property="FontFamily" Value="{DynamicResource WinstonBold}"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="CompareItemTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{DynamicResource WinstonRegular}"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
            </Style>

            <Style x:Key="ComparePathTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CompareItemTextStyle}">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Opacity" Value="0.75"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="CompareBodyTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{DynamicResource WinstonRegular}"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="CompareTabControlStyle" TargetType="{x:Type TabControl}" BasedOn="{StaticResource BottomTabControlStyle}">
                <Setter Property="Background" Value="{DynamicResource SettingCardBackground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"/>
                <Setter Property="Padding" Value="0"/>
            </Style>

            <DataTemplate x:Key="DiffLineTemplate">
                <Border Background="{Binding BackgroundBrush}"
                        BorderBrush="{Binding BorderBrush}"
                        BorderThickness="0"
                        Padding="6,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Prefix}"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{Binding ForegroundBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LineNumberText}"
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   Opacity="0.75"
                                   TextAlignment="Right"
                                   Foreground="{Binding ForegroundBrush}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Text}"
                                   Margin="10,0,0,0"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   TextWrapping="NoWrap"
                                   Foreground="{Binding ForegroundBrush}"/>
                    </Grid>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="12,0,0,0">
                <Button Content="Обновить список"
                        Padding="10,6"
                        FontFamily="{DynamicResource WinstonBold}"
                        FontSize="16"
                        Style="{DynamicResource SaveButtonStyle}"
                        IsEnabled="{Binding CanRefresh}"
                        Click="RefreshButton_Click" />
                <Button Content="Запустить сравнение"
                        MinWidth="180"
                        Padding="12,7"
                        Margin="10,0,0,0"
                        IsEnabled="{Binding CanStartCompare}"
                        FontFamily="{DynamicResource WinstonBold}"
                        FontSize="16"
                        Style="{DynamicResource SaveButtonStyle}"
                        Click="StartCompareButton_Click" />
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Сравнение файлов"
                           FontSize="22"
                           FontFamily="{DynamicResource WinstonBold}"
                           Foreground="{DynamicResource MainTitleSolidColorBrush}" />
                <TextBlock Text="Выберите исходный файл и один или несколько открытых файлов справа. После запуска каждый правый файл будет показан отдельной вкладкой."
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           FontSize="15"
                           Foreground="{DynamicResource ForegrounfBrushes}"
                           FontFamily="{DynamicResource WinstonRegular}" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1" Visibility="{Binding SelectionPanelVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,12"
                    Style="{StaticResource CompareCardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Исходный файл"
                               Margin="0,0,0,8"
                               Style="{StaticResource CompareCardTitleStyle}"
                               Foreground="{DynamicResource MainTitleSolidColorBrush}" />
                    <ComboBox ItemsSource="{Binding OpenFiles}"
                              SelectedItem="{Binding SelectedSourceFile, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              IsEnabled="{Binding HasEnoughFiles}"
                              Style="{DynamicResource CustomComboBoxStyle}" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CompareCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Файлы для сравнения"
                                   Margin="0,0,0,8"
                                   Style="{StaticResource CompareCardTitleStyle}"/>

                        <ListBox ItemsSource="{Binding TargetFiles}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ItemContainerStyle="{StaticResource DiffListBoxItemStyle}"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Margin="0,4"
                                              Style="{DynamicResource SettingsCheckBox2}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding File.DisplayName}"
                                                       Style="{StaticResource CompareItemTextStyle}" />
                                            <TextBlock Text="{Binding File.FilePath}"
                                                       Style="{StaticResource ComparePathTextStyle}" />
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource CompareCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Текущий список"
                                   Margin="0,0,0,8"
                                   Style="{StaticResource CompareCardTitleStyle}"/>
                        <TextBlock Margin="0,0,0,8"
                                   Text="{Binding SelectionSummary}"
                                   Style="{StaticResource CompareBodyTextStyle}" />
                        <ListBox ItemsSource="{Binding SelectedTargetFiles}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ItemContainerStyle="{StaticResource DiffListBoxItemStyle}"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,4">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Style="{StaticResource CompareItemTextStyle}" />
                                        <TextBlock Text="{Binding FilePath}"
                                                   Style="{StaticResource ComparePathTextStyle}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Visibility="{Binding ResultsPanelVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding ComparisonSummary}"
                       Margin="0,0,0,10"
                       Style="{StaticResource CompareBodyTextStyle}" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CompareCardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="{Binding ActiveComparison.SourceTitle}"
                                   Padding="12,8"
                                   FontFamily="{DynamicResource WinstonBold}"
                                   FontSize="16"
                                   Foreground="{DynamicResource MainTitleSolidColorBrush}" />
                        <ListBox x:Name="SourceLinesListBox"
                                 Grid.Row="1"
                                 ItemsSource="{Binding ActiveComparison.SourceLines}"
                                 ItemTemplate="{StaticResource DiffLineTemplate}"
                                 ItemContainerStyle="{StaticResource DiffListBoxItemStyle}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.ScrollChanged="SourceLinesListBox_ScrollChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource CompareCardBorderStyle}">
                    <TabControl x:Name="ComparisonTabControl"
                                ItemsSource="{Binding ComparisonResults}"
                                TabStripPlacement="Bottom"
                                Style="{StaticResource CompareTabControlStyle}"
                                ItemContainerStyle="{StaticResource BottomTabItemStyle}"
                                SelectedItem="{Binding ActiveComparison, Mode=TwoWay}"
                                Background="Transparent">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TargetTitle}" FontFamily="{DynamicResource WinstonRegular}" />
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="{Binding TargetHeader}"
                                               Padding="12,8"
                                               FontFamily="{DynamicResource WinstonBold}"
                                               FontSize="16"
                                               Foreground="{DynamicResource MainTitleSolidColorBrush}" />
                                    <ListBox x:Name="TargetLinesListBox"
                                             Grid.Row="1"
                                             ItemsSource="{Binding TargetLines}"
                                             ItemTemplate="{StaticResource DiffLineTemplate}"
                                             ItemContainerStyle="{StaticResource DiffListBoxItemStyle}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             ScrollViewer.ScrollChanged="TargetLinesListBox_ScrollChanged"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling"/>
                                </Grid>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Style="{StaticResource CompareCardBorderStyle}">
            <TextBlock Text="{Binding StateText}"
                       VerticalAlignment="Center"
                       Style="{StaticResource CompareBodyTextStyle}" />
        </Border>
    </Grid>
</UserControl>

