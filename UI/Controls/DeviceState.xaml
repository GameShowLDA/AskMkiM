<UserControl x:Class="UI.Controls.DeviceState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Border Background="{DynamicResource SettingsMainBackgroundSolidColorBrush}" CornerRadius="20" Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock 
                Text="Название устройства" 
                Padding="15,10"
                Style="{DynamicResource SettingsTitleStyle}"
                FontFamily="{DynamicResource WinstonBold}"
                FontSize="22" 
                Grid.Row="0"
                x:Name="Header"
                />

            <StackPanel Grid.Row="1" VerticalAlignment="Top" >
                <Border 
                    Style="{DynamicResource SettingCardStyle}"
                      Padding="10"
                      SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                Text="Состояние оборудования"
                                Margin="0,0,0,2"
                                Style="{DynamicResource SettingsHeaderStyle}" />

                            <TextBlock Grid.Row="1"
                                Text="{Binding DeviceStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Style="{DynamicResource SettingsDescriptionStyle}" FontSize="14" />
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>

        </Grid>
    </Border>
</UserControl>
