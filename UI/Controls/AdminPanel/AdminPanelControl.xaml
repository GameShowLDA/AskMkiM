<UserControl x:Class="UI.Controls.AdminPanel.AdminPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.AdminPanel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Style="{DynamicResource CategoryPanel}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock 
                Text="ADMIN PANEL" 
                Margin="10" 
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                FontSize="24"
                Style="{DynamicResource SettingsTitleStyle}"
                />

            <Button Grid.Row="1" Style="{DynamicResource ButtonStyleV13}" Content="База данных" Margin="10" PreviewMouseDown="DatabaseButton_Click"/>
            <Button Grid.Row="2" Style="{DynamicResource ButtonStyleV13}" Content="USB" Margin="10" PreviewMouseDown="UsbButton_Click"/>
            <Button Grid.Row="3" Style="{DynamicResource ButtonStyleV13}" Content="SetCommand" Margin="10" PreviewMouseDown="SetCommandButton_Click"/>
            <Button Grid.Row="4" Style="{DynamicResource ButtonStyleV13}" Content="Сопротивление МКР" Margin="10" PreviewMouseDown="ResistanceButton_Click"/>
            <Button Grid.Row="5" Style="{DynamicResource ButtonStyleV13}" Content="GPT" Margin="10" PreviewMouseDown="Gpt_PreviewMouseDown"/>
            <Button Grid.Row="6" Style="{DynamicResource ButtonStyleV13}" Content="Meter" Margin="10" PreviewMouseDown="Meter_PreviewMouseDown"/>

        </Grid>

        <Border Grid.Column="1" Padding="10">
            <ContentControl x:Name="RightContentPresenter"/>
        </Border>

    </Grid>
</UserControl>
