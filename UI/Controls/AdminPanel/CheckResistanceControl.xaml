<UserControl x:Class="UI.Controls.AdminPanel.CheckResistanceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.AdminPanel"
             xmlns:Components ="clr-namespace:UI.Components"
             xmlns:Icons="clr-namespace:UI.Icon"
             xmlns:DeviceInfo="clr-namespace:UI.Controls.Settings.DeviceInfo"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">
    <UserControl.Resources>

        <Style x:Key="SettingCardWithToggleStyle" TargetType="Border">

            <!-- копия базового стиля -->
            <Setter Property="Background" Value="{DynamicResource SettingCardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SettingCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>

            <!-- твой функциональный сеттер -->
            <Setter Property="Visibility" Value="Visible"/>

            <!-- триггер на кнопку -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}"
                         Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>

        </Style>

    </UserControl.Resources>

    <Border 
       Style="{DynamicResource SettingPanelStyle}" Margin="15,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock 
                    Text="Сопротивление коммутаторов"
                    Padding="10,10"
                    Style="{DynamicResource SettingsTitleStyle}"
                    />

                <Grid Grid.Column="1"  Margin="20,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Icons:SuccessIconControlV2 
                        Grid.Column="1"
                        x:Name="Success" 
                        Width="30"
                        Margin="10,0,0,0"
                        Height="30" 
                        CheckThickness="4"
                        CircleBackground ="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                        CircleBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                        />

                    <Icons:ErrorIconControlV2 
                      x:Name="Error"
                        Grid.Column="2"
                      Width="30"
                      Height="30" 
                      Margin="10,0,0,0"
                      CrossThickness="4"
                      CircleBackground ="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                      CircleBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                      />


                    <Icons:ArrowButton x:Name="ToggleSettingsButton" 
                                           Grid.Column="0"
                                           HorizontalAlignment="Right"
                                           Width="30" Height="30"
                                           ButtonBackground="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                                           ButtonBorder="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                           ArrowBrush="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                           ArrowHoverBrush="{DynamicResource SettingsInteractivePressedSolidColorBrush}"
                                           VerticalAlignment="Center"/>
                </Grid>

            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>


                <WrapPanel Orientation="Horizontal" x:Name="DevicesControl" >
                    <WrapPanel.Style>
                        <Style TargetType="WrapPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>


                </WrapPanel>

            </Grid>

        </Grid>
    </Border>
</UserControl>

