<UserControl x:Class="UI.Controls.AdminPanel.SetCommand"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.AdminPanel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="#CC1E1E1E" CornerRadius="10" Padding="10"
        BorderThickness="1" BorderBrush="#33FFFFFF">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="ConsoleScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Grid.Row="0">
                <StackPanel x:Name="ConsolePanel"/>
            </ScrollViewer>

            <TextBox x:Name="CommandInput"
                 Grid.Row="1"
                 FontFamily="Consolas"
                 FontSize="14"
                 Margin="0,10,0,0"
                 Padding="6"
                 Background="#FF1E1E1E"
                 Foreground="White"
                 BorderThickness="1"
                 BorderBrush="#555"
                 PreviewKeyDown="CommandInput_KeyDown"
                />

            <ListBox x:Name="AutocompleteBox"
                     Grid.Row="2"
                     FontFamily="Consolas"
                     FontSize="13"
                     Background="#222"
                     Foreground="White"
                     Visibility="Collapsed"
                     BorderThickness="1"
                     BorderBrush="#555"
                     MaxHeight="100"
                     />
        </Grid>
    </Border>
</UserControl>
