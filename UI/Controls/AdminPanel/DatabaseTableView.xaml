<UserControl x:Class="UI.Controls.AdminPanel.DatabaseTableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.AdminPanel"
             mc:Ignorable="d">
    <Border Padding="10" Margin="5" CornerRadius="10" Style="{DynamicResource ConfigAdditionalBlockStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TableTitle"
                   Margin="0 0 0 10"
                   FontSize="20"
                   FontWeight="Bold"
                   Style="{DynamicResource ConfigInfoStyle}"
                   />

            <DataGrid x:Name="Grid"
                    Grid.Row="1"
                    AutoGenerateColumns="True"
                    IsReadOnly="True"
                    Style="{DynamicResource DataGrid}"

                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.CanContentScroll="True"

                    HorizontalAlignment="Left"
                      AutoGeneratedColumns="Grid_AutoGeneratedColumns"/>
        </Grid>
    </Border>
</UserControl>
