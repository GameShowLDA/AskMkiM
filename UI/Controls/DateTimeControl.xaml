<UserControl x:Class="UI.Controls.DateTimeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls"
             xmlns:Component="clr-namespace:UI.Components"
             xmlns:Calendar ="clr-namespace:UI.Controls.Calendar"
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="160">
    <Grid>  
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Component:TimeControl x:Name="Time" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0"/>
        <Component:DateControl x:Name="Date" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <Popup x:Name="CalendarPopup"
         Placement="Bottom"
         VerticalOffset="8"
         PopupAnimation="Fade"
         StaysOpen="False"
         AllowsTransparency="True">
            <Border Background="Transparent">
                <Calendar:CalendarControl x:Name="CalendarControl" />
            </Border>
        </Popup>
    </Grid>
</UserControl>
