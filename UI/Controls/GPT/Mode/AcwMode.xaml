<UserControl x:Class="UI.Controls.GPT.Mode.AcwMode"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="1000" d:DesignWidth="800" FontWeight="Bold" Background="{StaticResource PrimarySolidColorBrush}" FontSize="20" Foreground="{StaticResource ForegroundSolidColorBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Button Name="ConnectButton" Style="{DynamicResource ButtonStyleV8}" Content="Включить режим ACW" PreviewMouseDown="Button_PreviewMouseDown"/>
        </Grid>
        
        <Grid Grid.Row="1" Name="PanelManagment" Visibility="Collapsed">
            <!-- Определение строк -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!-- Определение столбцов -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <!-- Левая колонка -->
                <ColumnDefinition Width="*" />
                <!-- Правая колонка -->
            </Grid.ColumnDefinitions>

            <!-- MANU_ACW_VOLTAGE -->
            <TextBlock Grid.Row="0" Text="Напряжение ACW (100 - 1000 В):" TextAlignment="Right" VerticalAlignment="Center" Margin="10" FontWeight="Bold" />
            <Slider x:Name="VoltageSlider" 
                    Style="{StaticResource CustomSliderStyle}"  
                    Grid.Row="0" Grid.Column="1" Margin="10" Minimum="100" Maximum="1000" TickFrequency="100" 
                    IsSnapToTickEnabled="True"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Value, ElementName=VoltageSlider, StringFormat='Выбранное напряжение: {0} В'}" HorizontalAlignment="Center" Margin="0,30,0,0" />

            <!-- MANU_ACW_CHISET -->
            <TextBlock Grid.Row="1" Text="Высокий предел тока ACW (1 - 110 мА):" TextAlignment="Right" VerticalAlignment="Center" Margin="10" FontWeight="Bold" />
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="10">
                <Slider x:Name="ChiSlider" Style="{StaticResource CustomSliderStyle}"  Minimum="1" 
                        Maximum="110" TickFrequency="1" IsSnapToTickEnabled="True" 
                        />
                <TextBlock Text="{Binding Value, ElementName=ChiSlider, StringFormat='Текущее значение: {0} мА'}" HorizontalAlignment="Center" Margin="0,5,0,0" />
            </StackPanel>

            <!-- MANU_ACW_CLOSET -->
            <TextBlock Grid.Row="2" Text="Низкий предел тока ACW (0 - 109 мА):" TextAlignment="Right" VerticalAlignment="Center" Margin="10" FontWeight="Bold" />
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="10">
                <Slider x:Name="CloSlider" Style="{StaticResource CustomSliderStyle}"  Minimum="0" 
                        Maximum="109" TickFrequency="1" IsSnapToTickEnabled="True" 
                        />
                <TextBlock Text="{Binding Value, ElementName=CloSlider, StringFormat='Текущее значение: {0} мА'}" HorizontalAlignment="Center" Margin="0,5,0,0" />
            </StackPanel>

            <!-- MANU_ACW_TTIME -->
            <TextBlock Grid.Row="3" Text="Время теста ACW (0.5 - 10 сек):" TextAlignment="Right" VerticalAlignment="Center" Margin="10" FontWeight="Bold" />
            <Slider x:Name="TimeSlider" Style="{StaticResource CustomSliderStyle}"  Grid.Row="3" 
                    Grid.Column="1" Margin="10" Minimum="0.5" Maximum="10" TickFrequency="0.1" 
                    IsSnapToTickEnabled="True"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Value, ElementName=TimeSlider, StringFormat='Выбранное время: {0:F1} сек'}" HorizontalAlignment="Center" Margin="0,30,0,0" />

            <TextBlock Grid.Row="4" Text="Время наростания ACW (0.1 - 10 сек):" TextAlignment="Right" VerticalAlignment="Center" Margin="10" FontWeight="Bold" />
            <Slider x:Name="RampTimeSlider" Style="{StaticResource CustomSliderStyle}"  Grid.Row="4" 
                    Grid.Column="1" Margin="10" Minimum="0.1" Maximum="10" TickFrequency="0.1" 
                    IsSnapToTickEnabled="True"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Value, ElementName=RampTimeSlider, StringFormat='Выбранное время: {0:F1} сек'}" HorizontalAlignment="Center" Margin="0,30,0,0" />


            <!-- MANU_ACW_FREQUENCY -->
            <TextBlock Grid.Row="5" Text="Частота ACW (50 Гц или 60 Гц):" TextAlignment="Right" VerticalAlignment="Center" Margin="10" FontWeight="Bold" />
            <ComboBox x:Name="FrequencyComboBox" Grid.Row="5" Grid.Column="1" Margin="10" SelectedIndex="0" Width="80" HorizontalAlignment="Left" Style="{StaticResource CustomComboBoxStyle}" FontWeight="Bold">
                <ComboBoxItem Content="50 Гц" />
                <ComboBoxItem Content="60 Гц" />
            </ComboBox>

            <!-- MANU_ACW_REF -->
            <TextBlock Grid.Row="6" Text="Смещение ACW (0 - 109 мА):" TextAlignment="Right" VerticalAlignment="Center" Margin="10" FontWeight="Bold" />
            <StackPanel Grid.Row="6" Grid.Column="1" Margin="10">
                <Slider x:Name="RefSlider" Style="{StaticResource CustomSliderStyle}"  Minimum="0" 
                        Maximum="109" TickFrequency="1" IsSnapToTickEnabled="True" 
                        />
                <TextBlock Text="{Binding Value, ElementName=RefSlider, StringFormat='Текущее значение: {0} мА'}" HorizontalAlignment="Center" Margin="0,5,0,0" />
            </StackPanel>

            <!-- MANU_ACW_ARCCURRENT -->
            <TextBlock Grid.Row="7" Text="Значение тока ACW (2.000 - 200.0 мА):" TextAlignment="Right" VerticalAlignment="Center" Margin="10"  />
            <StackPanel Grid.Row="7" Grid.Column="1" Margin="10">
                <Slider x:Name="ArcCurrentSlider" Style="{StaticResource CustomSliderStyle}"  Minimum="2" 
                        Maximum="200" TickFrequency="1" IsSnapToTickEnabled="True" 
                        />
                <TextBlock Text="{Binding Value, ElementName=ArcCurrentSlider, StringFormat='Текущее значение: {0:F3} мА'}" HorizontalAlignment="Center" Margin="0,5,0,0" />
            </StackPanel>

            <!-- MANU_ACW_ARCCURRENT -->
            <Button Grid.Row="8" Grid.Column="0" 
                    Style="{DynamicResource ButtonStyleV8}" Content="Сохранить" 
                    Margin="10"
                    PreviewMouseDown="Button_PreviewMouseDown_1"
                    >
            </Button>

            <!-- Последняя строка: левая колонка (конфигурация) -->
            <Border Grid.Row="9" Grid.Column="0" Margin="10" Background="{StaticResource SecondarySolidColorBrush}" Padding="10" CornerRadius="15">
                <StackPanel>
                    <TextBlock Text="Последнее считывание конфигурации:" FontWeight="Bold" />
                    <TextBlock x:Name="LastReadTimeText" Text="Дата и время: Нет данных" Margin="0,10,0,50" FontWeight="Bold"/>
                    <TextBlock x:Name="VoltageValueText" Text="Напряжение ACW: Нет данных" Margin="0,5,0,0" />
                    <TextBlock x:Name="ChiValueText" Text="Высокий предел тока ACW: Нет данных" Margin="0,5,0,0" />
                    <TextBlock x:Name="CloValueText" Text="Низкий предел тока ACW: Нет данных" Margin="0,5,0,0" />
                    <TextBlock x:Name="TimeValueText" Text="Время теста ACW: Нет данных" Margin="0,5,0,0" />
                    <TextBlock x:Name="FrequencyValueText" Text="Частота ACW: Нет данных" Margin="0,5,0,0" />
                    <TextBlock x:Name="RefValueText" Text="Смещение ACW: Нет данных" Margin="0,5,0,0" />
                    <TextBlock x:Name="ArcCurrentValueText" Text="Текущее значение тока ACW: Нет данных" Margin="0,5,0,0" />
                    <Button Content="Считать конфигурацию" Click="ReadConfigurationButton_Click" Width="250" HorizontalAlignment="Left" Margin="0,20" Style="{StaticResource CustomButtonStyle}" Background="{StaticResource IsCheckedColorSolidColorBrush}"/>
                </StackPanel>
            </Border>

            <!-- Последняя строка: правая колонка (тесты) -->
            <Border Grid.Row="9" Grid.Column="1" Margin="10" Background="{StaticResource SecondarySolidColorBrush}" Padding="10" CornerRadius="15">

                <StackPanel>
                    <TextBlock Text="Управление тестами:" FontWeight="Bold" />
                    <TextBlock x:Name="TestResultText" Text="Результат теста: Нет данных" Margin="0,10,0,0" />
                    <Button Content="Запустить тест" Click="StartTestButton_Click" Width="200"  HorizontalAlignment="Left" Margin="0,10,0,0" Style="{StaticResource CustomButtonStyle}" Background="{StaticResource IsCheckedColorSolidColorBrush}" />
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</UserControl>