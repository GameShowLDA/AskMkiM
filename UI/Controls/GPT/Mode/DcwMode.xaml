<UserControl x:Class="UI.Controls.GPT.Mode.DcwMode"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.GPT.Mode"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{StaticResource PrimarySolidColorBrush}" FontWeight="Bold" FontSize="20">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Button Name="ConnectButton" Style="{DynamicResource ButtonStyleV8}" Content="Включить режим DCW" PreviewMouseDown="Button_PreviewMouseDown"/>
        </Grid>
        <Grid Grid.Row="1" Name="PanelManagment" Visibility="Collapsed">
            <!-- Определение строк -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <!-- Левая колонка -->
                <ColumnDefinition Width="*" />
                <!-- Правая колонка -->
            </Grid.ColumnDefinitions>

            <!-- MANU_DCW_VOLTAGE -->
            <TextBlock Grid.Row="0" Text="Напряжение DCW (100 - 1000 В):" TextAlignment="Right" VerticalAlignment="Center" Margin="10" />
            <Slider x:Name="VoltageSlider" Style="{StaticResource CustomSliderStyle}" Grid.Row="0"
                    Grid.Column="1" Margin="10" Minimum="100" Maximum="1000" TickFrequency="100" 
                    IsSnapToTickEnabled="True"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Value, ElementName=VoltageSlider, StringFormat='Выбранное напряжение: {0} В'}" HorizontalAlignment="Center" Margin="0,30,0,0" />

            <!-- MANU_DCW_CHISET -->
            <TextBlock Grid.Row="1" Text="Высокий предел тока DCW (1 - 20 мА):" TextAlignment="Right" VerticalAlignment="Center" Margin="10" />
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="10">
                <Slider x:Name="ChiSlider" Minimum="1" Style="{StaticResource CustomSliderStyle}" 
                        Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True" 
                        />
                <TextBlock Text="{Binding Value, ElementName=ChiSlider, StringFormat='Текущее значение: {0} мА'}" HorizontalAlignment="Center" Margin="0,5,0,0" />
            </StackPanel>

            <!-- MANU_DCW_CLOSET -->
            <TextBlock Grid.Row="2" Text="Низкий предел тока DCW (0 - 20 мА):" TextAlignment="Right" VerticalAlignment="Center" Margin="10" />
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="10">
                <Slider x:Name="CloSlider" Minimum="0" Style="{StaticResource CustomSliderStyle}" 
                        Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True" 
                        />
                <TextBlock Text="{Binding Value, ElementName=CloSlider, StringFormat='Текущее значение: {0} мА'}" HorizontalAlignment="Center" Margin="0,5,0,0" />
            </StackPanel>

            <!-- MANU_DCW_TTIME -->
            <TextBlock Grid.Row="3" Text="Время теста DCW (0.5 - 10 сек):" TextAlignment="Right" VerticalAlignment="Center" Margin="10" />
            <Slider x:Name="TimeSlider" Grid.Row="3" Style="{StaticResource CustomSliderStyle}" 
                    Grid.Column="1" Margin="10" Minimum="0.5" Maximum="10" TickFrequency="0.1" 
                    IsSnapToTickEnabled="True"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Value, ElementName=TimeSlider, StringFormat='Выбранное время: {0:F1} сек'}" HorizontalAlignment="Center" Margin="0,30,0,0" />

            <TextBlock Grid.Row="4" Text="Время нарастания DCW (0.1 - 10 сек):" TextAlignment="Right" VerticalAlignment="Center" Margin="10" />
            <Slider x:Name="RampSlider" Grid.Row="4" Style="{StaticResource CustomSliderStyle}" 
                    Grid.Column="1" Margin="10" Minimum="0.1" Maximum="10" TickFrequency="0.1" 
                    IsSnapToTickEnabled="True"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Value, ElementName=RampSlider, StringFormat='Выбранное время: {0:F1} сек'}" HorizontalAlignment="Center" Margin="0,30,0,0" />

            <!-- MANU_DCW_REF -->
            <TextBlock Grid.Row="5" Text="Смещение DCW (0 - 109 мА):" TextAlignment="Right" VerticalAlignment="Center" Margin="10" />
            <StackPanel Grid.Row="5" Grid.Column="1" Margin="10">
                <Slider x:Name="RefSlider" Minimum="0" Style="{StaticResource CustomSliderStyle}" 
                        Maximum="109" TickFrequency="1" IsSnapToTickEnabled="True" 
                        />
                <TextBlock Text="{Binding Value, ElementName=RefSlider, StringFormat='Текущее значение: {0} мА'}" HorizontalAlignment="Center" Margin="0,5,0,0" />
            </StackPanel>

            <!-- MANU_DCW_ARCCURRENT -->
            <TextBlock Grid.Row="6" Text="Текущее значение тока ACW (2.000 - 200.0 мА):"  TextAlignment="Right" VerticalAlignment="Center" Margin="10" />
            <StackPanel Grid.Row="6" Grid.Column="1" Margin="10">
                <Slider x:Name="ArcCurrentSlider" Style="{StaticResource CustomSliderStyle}" 
                        Minimum="2" Maximum="200" TickFrequency="1" IsSnapToTickEnabled="True" 
                        />
                <TextBlock Text="{Binding Value, ElementName=ArcCurrentSlider, StringFormat='Текущее значение: {0:F3} мА'}" HorizontalAlignment="Center" Margin="0,5,0,0" />
            </StackPanel>

            <!-- MANU_ACW_ARCCURRENT -->
            <Button Grid.Row="7" Grid.Column="0" 
                    Style="{DynamicResource ButtonStyleV8}" Content="Сохранить" 
                    Margin="10"
                    PreviewMouseDown="Button_PreviewMouseDown_1"
                    >
            </Button>
            
            <!-- Последняя строка: левая колонка (конфигурация) -->
            <Border Grid.Row="8" Grid.Column="0" Margin="10" Background="{StaticResource SecondarySolidColorBrush}" Padding="10" CornerRadius="15">
                <StackPanel >
                    <TextBlock Text="Последнее считывание конфигурации:" FontWeight="Bold" />
                    <TextBlock x:Name="LastReadTimeText" Text="Дата и время: Нет данных" Margin="0,10,0,50" />
                    <TextBlock x:Name="VoltageValueText" Text="Напряжение ACW: Нет данных" Margin="0,5,0,0" />
                    <TextBlock x:Name="ChiValueText" Text="Высокий предел тока ACW: Нет данных" Margin="0,5,0,0" />
                    <TextBlock x:Name="CloValueText" Text="Низкий предел тока ACW: Нет данных" Margin="0,5,0,0" />
                    <TextBlock x:Name="TimeValueText" Text="Время теста ACW: Нет данных" Margin="0,5,0,0" />
                    <TextBlock x:Name="RefValueText" Text="Смещение ACW: Нет данных" Margin="0,5,0,0" />
                    <TextBlock x:Name="ArcCurrentValueText" Text="Текущее значение тока ACW: Нет данных" Margin="0,5,0,0" />
                    <Button Content="Считать конфигурацию" Click="ReadConfigurationButton_Click" Width="250" Margin="0,20" Style="{StaticResource CustomButtonStyle}" Background="{StaticResource IsCheckedColorSolidColorBrush}" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <Border Grid.Row="8" Grid.Column="1" Margin="10" Background="{StaticResource SecondarySolidColorBrush}" Padding="10" CornerRadius="15">
                <StackPanel >
                    <TextBlock Text="Управление тестами:" FontWeight="Bold" />
                    <TextBlock x:Name="TestResultText" Text="Результат теста: Нет данных" Margin="0,10,0,0" />
                    <Button Content="Запустить тест" Click="StartTestButton_Click" Width="200" Margin="0,20" Style="{StaticResource CustomButtonStyle}" Background="{StaticResource IsCheckedColorSolidColorBrush}" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
