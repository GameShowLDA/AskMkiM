<UserControl x:Class="UI.Controls.Runner.RunControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:UI.Controls.Runner"
             mc:Ignorable="d" 
             xmlns:Controls="clr-namespace:UI.Controls.TextEditor"
             xmlns:Protocol="clr-namespace:Ask.UI.Controls.ProtocolNew;assembly=Ask.UI"
             xmlns:ErrorList="clr-namespace:UI.Controls.ErrorList"
             xmlns:MultiWindow="clr-namespace:UI.Components"
             xmlns:Icons="clr-namespace:UI.Icon"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="50*"/>
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
                <RowDefinition x:Name="BottomRow" Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid x:Name="RightBox" Grid.Column="0" >
                    <ContentControl  x:Name="MainContent"/>
                </Grid>
            </Grid>

            <GridSplitter  Grid.Row="1" 
              Height="5"
              Background="{StaticResource RedColorSolidColorBrush}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              ResizeDirection="Rows"
              DragStarted="BottomSplitter_OnDragStarted"
              DragCompleted="BottomSplitter_OnDragCompleted" Cursor="SizeNS"/>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <ErrorList:ErrorListControl  
                x:Name="ErrorListBoxVertical" 
                MinHeight="60"
                StringsNumberVisible="Visible" 
                MeasureResultVisible="Visible" 
                Grid.ColumnSpan="3"
                SizeChanged="ErrorListBoxVertical_OnSizeChanged"/>
            </Grid>
        </Grid>

        <GridSplitter Grid.Column="1" Background="{StaticResource RedColorSolidColorBrush}" 
        HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ResizeDirection="Columns"/>

        <Grid Grid.Column="2">
            <Grid Grid.Column="2" x:Name="TranstatedFile">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>


                <Grid x:Name="LeftBox" Grid.Row="1">
                    <Controls:TextEditorContainer x:Name="ChildTextEditorContainer"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>

</UserControl>

