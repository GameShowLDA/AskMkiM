<UserControl x:Class="UI.Controls.Runner.RunControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:UI.Controls.Runner"
             mc:Ignorable="d" 
             xmlns:Controls="clr-namespace:UI.Controls.TextEditor"
             xmlns:Protocol="clr-namespace:UI.Controls.ProtocolNew"
             xmlns:ErrorList="clr-namespace:UI.Controls.ErrorList"
             xmlns:Icons="clr-namespace:UI.Icon"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto" MinHeight="50"/>
        </Grid.RowDefinitions>

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="75*"/>
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="40*"/>
            </Grid.ColumnDefinitions>

            <Grid x:Name="LeftBox" Grid.Column="2">
                <Controls:TextEditorUI/>
            </Grid>

            <GridSplitter Grid.Column="1" Background="{StaticResource RedColorSolidColorBrush}" 
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ResizeDirection="Columns"/>

            <Grid x:Name="RightBox" Grid.Column="0" >
                <ContentControl  x:Name="MainContent"/>
            </Grid>
        </Grid>

        <GridSplitter  Grid.Row="1" 
               Height="5"
               Background="{StaticResource RedColorSolidColorBrush}"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               ResizeDirection="Rows"/>


        <Grid Grid.Row="2">
            <ErrorList:ErrorListControl   x:Name="ErrorListBoxVertical" StringsNumberVisible="Collapsed" MeasureResultVisible="Visible"/>
        </Grid>

    </Grid>

</UserControl>
