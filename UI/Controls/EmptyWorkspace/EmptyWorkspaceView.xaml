<UserControl x:Class="UI.Controls.EmptyWorkspace.EmptyWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:UI.Controls.EmptyWorkspace"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             IsHitTestVisible="True"
             Language="ru-RU">

    <!-- ===== РЕСУРСЫ ===== -->
    <UserControl.Resources>

        <!-- Конвертеры -->
        <local:DateTimeToStringConverter x:Key="DateTimeToString"/>
        <local:TimeOfDayGreetingConverter x:Key="TimeOfDayGreeting"/>
    </UserControl.Resources>


    <!-- ===== КОРНЕВОЙ GRID ===== -->
    <Grid Background="{DynamicResource EmptyBackgroundBrush}">

        <!-- центральное свечение -->
        <Rectangle IsHitTestVisible="False" Fill="{DynamicResource CenterGlowBrush}">
            <Rectangle.Effect>
                <BlurEffect Radius="4"/>
            </Rectangle.Effect>
        </Rectangle>

        <!-- виньетка -->
        <Rectangle IsHitTestVisible="False" Fill="{DynamicResource VignetteBrush}"/>

        <!-- ===== ЦЕНТРАЛЬНЫЙ БЛОК ===== -->
        <Border x:Name="CenterBlock"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#00000000"
            Padding="0">
            <Border.Effect>
                <!-- деликатная подсветка блока -->
                <DropShadowEffect BlurRadius="12"
                                  ShadowDepth="0"
                                  Opacity="0.18"
                                  Color="{DynamicResource EmptyWorkspaceBlockShadowColor}"/>
            </Border.Effect>

            <Grid TextOptions.TextFormattingMode="Display" SnapsToDevicePixels="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Время -->
                <Grid Grid.Row="0"
                      HorizontalAlignment="Center">
                    <TextBlock x:Name="TimeGhostText"
                       Text=""
                       Opacity="0"
                       IsHitTestVisible="False"
                       Foreground="{DynamicResource ForegrounfBrushes}"
                       FontFamily="{DynamicResource WinstonBold}"
                       FontSize="60"
                       TextAlignment="Center"
                       HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="18"
                                              ShadowDepth="0"
                                              Opacity="0.55"
                                              Color="{DynamicResource EmptyWorkspaceTimeGlowColor}"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <TextBlock x:Name="TimeText"
                       Text="{Binding CurrentDateTime,
                                      RelativeSource={RelativeSource AncestorType=UserControl},
                                      Converter={StaticResource DateTimeToString},
                                      ConverterParameter=HH:mm:ss}"
                       Foreground="{DynamicResource ForegrounfBrushes}"
                       FontFamily="{DynamicResource WinstonBold}"
                       FontSize="60"
                       TextAlignment="Center"
                       HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="18"
                                              ShadowDepth="0"
                                              Opacity="0.75"
                                              Color="{DynamicResource EmptyWorkspaceTimeGlowColor}"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>

                <!-- День недели | Дата -->
                <TextBlock x:Name="DateText"
                   Grid.Row="1"
                   Margin="0,8,0,0"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"
                   FontFamily="{DynamicResource WinstonLight}"
                   Foreground="{DynamicResource ForegrounfBrushes}" 
                   FontSize="20"
                   >

          <!-- День недели -->
          <Run Text="{Binding CurrentDateTime,
                              RelativeSource={RelativeSource AncestorType=UserControl},
                              Converter={StaticResource DateTimeToString},
                              ConverterParameter=dddd|TitleCase}"
                   Foreground="{DynamicResource ForegrounfBrushes85}"/>

          <!-- Разделитель -->
          <Run Text="  |  " Foreground="{DynamicResource ForegrounfBrushes35}" />

          <!-- Дата -->
          <Run Text="{Binding CurrentDateTime,
                              RelativeSource={RelativeSource AncestorType=UserControl},
                              Converter={StaticResource DateTimeToString},
                              ConverterParameter=d MMMM yyyy}"
               Foreground="{DynamicResource ForegrounfBrushes85}"
               FontSize="22">

          </Run>
                </TextBlock>

                <!-- Подсказка под датой -->
                <TextBlock x:Name="HintText"
                   Grid.Row="2"
                   Margin="0,15,0,0"
                   Text="Откройте файл, чтобы начать работу"
                   Foreground="{DynamicResource ForegrounfBrushes}"
                   FontFamily="{DynamicResource WinstonLight}"
                   FontSize="16"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ===== ПЛАШКА ЗАМЕТКИ НА СЕГОДНЯ ===== -->
        <StackPanel x:Name="TodayNoteHost"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,20"
                    Panel.ZIndex="100">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasTodayNote, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <Border x:Name="TodayNotePreviewPanel"
                    Margin="0,0,0,8"
                    Padding="16,14"
                    MaxWidth="520"
                    Visibility="Collapsed"
                    CornerRadius="12"
                    Background="{DynamicResource MainGreetingBackgroundBrush}"
                    BorderBrush="{DynamicResource MainGreetingBorderBrush}"
                    BorderThickness="1"
                    Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="TodayNotePreviewTransform" Y="18"/>
                </Border.RenderTransform>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="160">
                    <TextBlock Text="{Binding TodayNoteText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Foreground="{DynamicResource MainTitleSolidColorBrush}"
                               FontFamily="{DynamicResource WinstonLight}"
                               FontSize="17"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <Border x:Name="TodayNoteBar"
                    HorizontalAlignment="Center"
                    Cursor="Hand"
                    Padding="20,10"
                    CornerRadius="10"
                    Background="{DynamicResource MainGreetingBackgroundBrush}"
                    BorderBrush="{DynamicResource MainGreetingBorderBrush}"
                    BorderThickness="1"
                    MouseLeftButtonDown="TodayNoteBar_MouseLeftButtonDown">
                <TextBlock Text="{Binding TodayNoteBarText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Foreground="{DynamicResource MainTitleSolidColorBrush}"
                           FontFamily="{DynamicResource WinstonBold}"
                           FontSize="18"
                           TextAlignment="Center"
                           TextWrapping="NoWrap"
                           LineStackingStrategy="BlockLineHeight"
                           LineHeight="22"
                           MaxHeight="22"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="420"/>
            </Border>
        </StackPanel>

        <!-- ===== ВЕРСИЯ ПО / ДАТА СБОРКИ (внизу справа) ===== -->
        <TextBlock HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,14,10"
               FontFamily="{DynamicResource WinstonLight}"
               FontSize="18"
               Opacity="0.45"
               Foreground="{DynamicResource ForegroundSolidColorBrush}"
                Text="{Binding AppVersion, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    </Grid>
</UserControl>
