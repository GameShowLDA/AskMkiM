<UserControl x:Class="UI.Controls.EmptyWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"             
             IsHitTestVisible="False">
    <Grid Background="{StaticResource PrimarySolidColorBrush}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Добро пожаловать"
                       Foreground="{StaticResource ForegroundSolidColorBrush}"
                       FontFamily="{DynamicResource WinstonBold}"
                       FontSize="22" TextAlignment="Center"/>
            <TextBlock Text="Откройте файл, чтобы начать"
                       Foreground="{StaticResource ForegroundSolidColorBrush}"
                       FontFamily="{DynamicResource WinstonLight}"
                       Opacity="0.7"
                       FontSize="16" TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
