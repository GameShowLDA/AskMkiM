<UserControl x:Class="UI.Controls.DevicesStatus"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="{DynamicResource SecondarySolidColorBrush}" >

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border>
            <Grid>
                <Button x:Name="UpdateState" Content="Обновить состояние" Style="{DynamicResource CompareButtonStyle}" HorizontalAlignment="Left" Width="230" />
            </Grid>
        </Border>

        <ScrollViewer 
    Grid.Row="1"
    VerticalScrollBarVisibility="Auto"
    HorizontalScrollBarVisibility="Disabled">

            <WrapPanel
        x:Name="RootPanel"
        Orientation="Horizontal"
        VerticalAlignment="Top">

                <WrapPanel.Style>
                    <Style TargetType="WrapPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=ToggleSettingsButton, Path=IsArrowUp}"
                                 Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </WrapPanel.Style>

            </WrapPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
