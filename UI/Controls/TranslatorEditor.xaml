<UserControl x:Class="UI.Controls.TranslatorEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:TextEditor="clr-namespace:UI.Controls.TextEditor"
             xmlns:icons="clr-namespace:Ask.UI.Shared.Components.Icons;assembly=Ask.UI"
             xmlns:LocalizeStrings="clr-namespace:Ask.UI.Infrastructure.Localization;assembly=Ask.UI"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <LocalizeStrings:LocalizedString x:Key="LS_TranslatorEditor_Tooltip_Back" Key="translator.editor.tooltip.back" />
        <LocalizeStrings:LocalizedString x:Key="LS_TranslatorEditor_Tooltip_SaveArchive" Key="translator.editor.tooltip.save.archive" />

        <Style x:Key="TopMenuLikeIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource TestsInteractiveBackgroundSolidColorBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TestsInteractiveBorderSolidColorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BackButtonStyle" TargetType="Button" BasedOn="{StaticResource TopMenuLikeIconButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource DeviceListEditButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DeviceListEditButtonBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DeviceListEditButtonForegroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DeviceListEditButtonHoverBackgroundBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource DeviceListEditButtonHoverBorderBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DeviceListEditButtonHoverForegroundBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DeviceListEditButtonPressedBackgroundBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource DeviceListEditButtonPressedBorderBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DeviceListEditButtonPressedForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SaveButtonStyle" TargetType="Button" BasedOn="{StaticResource TopMenuLikeIconButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource DeviceListAddButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DeviceListAddButtonBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DeviceListAddButtonForegroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DeviceListAddButtonHoverBackgroundBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource DeviceListAddButtonHoverBorderBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DeviceListAddButtonHoverForegroundBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DeviceListAddButtonPressedBackgroundBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource DeviceListAddButtonPressedBorderBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DeviceListAddButtonPressedForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Height="40"
                MaxHeight="40"
                Margin="5"
                Padding="6,4"
                Background="{DynamicResource SettingsNestedGroupBackgroundSolidColorBrush}"
                Style="{DynamicResource SettingCardStyle}">
            <Grid Cursor="">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <icons:ArrowButton x:Name="BackButton"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Width="30"
                                   Height="30"
                                   ToolTip="{Binding Source={StaticResource LS_TranslatorEditor_Tooltip_Back}, Path=Value}"
                                   ToggleOnClick="False"
                                   ButtonBackground="{DynamicResource DeviceListEditButtonBackgroundBrush}"
                                   ButtonBorder="{DynamicResource DeviceListEditButtonBorderBrush}"
                                   ArrowBrush="{DynamicResource DeviceListEditButtonForegroundBrush}"
                                   ArrowHoverBrush="{DynamicResource DeviceListEditButtonHoverForegroundBrush}"
                                   RenderTransformOrigin="0.5,0.5"
                                   Click="BackButton_Click">
                    <icons:ArrowButton.RenderTransform>
                        <RotateTransform Angle="90"/>
                    </icons:ArrowButton.RenderTransform>
                </icons:ArrowButton>

                <TextBlock x:Name="TranslationFileName" 
                           Grid.Column = "2" 
                           Text="Some text"
                           FontSize="16"
                           FontFamily="{DynamicResource WinstonBold}"
                           Margin="12,0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"/>

                <Button x:Name="SaveButton"
                        Grid.Column="1"
                        Style="{StaticResource SaveButtonStyle}"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Click="SaveButton_Click"
                        ToolTip="{Binding Source={StaticResource LS_TranslatorEditor_Tooltip_SaveArchive}, Path=Value}">
                    <icons:ArchiveIcon Size="18"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{DynamicResource SettingCardStyle}" BorderThickness="0"
                ClipToBounds="True">
            <ContentControl x:Name="EditorHost">
                <TextEditor:TextEditorUI x:Name="TranslatorTextEditor"
                                         FontSize="14"
                                         IsReadOnly="False"/>
            </ContentControl>
        </Border>
    </Grid>
</UserControl>
