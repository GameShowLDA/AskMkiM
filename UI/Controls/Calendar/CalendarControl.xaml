<UserControl x:Class="UI.Controls.Calendar.CalendarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.Calendar"
             mc:Ignorable="d" 
             xmlns:Clock="clr-namespace:UI.Components"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <local:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
        <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <local:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>
    </UserControl.Resources>

    <Border Background="#252526" CornerRadius="10" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Clock:TimeControl FontSize="30" Margin="10" x:Name="ClockControl" FullTime="True" />
            <DockPanel Grid.Row="1">
                <!-- Заголовок с месяцем и стрелками -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0 0 0 10">
                    <Button Command="{Binding PrevMonthCommand}" Width="30" Height="30" Margin="0 0 10 0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Path Data="M 10 20 L 20 10 L 0 10 Z" Fill="#888" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform Angle="180"/>
                            </Path.RenderTransform>
                        </Path>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Opacity" Value="0.7"/>
                                        <Setter Property="Foreground" Value="#333"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <TextBlock Text="{Binding MonthYear}" Foreground="White" FontWeight="Bold" FontSize="20" VerticalAlignment="Center" />

                    <Button Command="{Binding NextMonthCommand}" Width="30" Height="30" Margin="10 0 0 0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Path Data="M 10 20 L 20 10 L 0 10 Z" Fill="#888" Stretch="Uniform" RenderTransformOrigin="0.5,0.5"/>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Opacity" Value="0.7"/>
                                        <Setter Property="Foreground" Value="#333"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Дни недели -->
                <UniformGrid Rows="1" Columns="7" DockPanel.Dock="Top" Margin="0 0 0 5">
                    <TextBlock Text="Пн" Foreground="#aaa" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Вт" Foreground="#aaa" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Ср" Foreground="#aaa" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Чт" Foreground="#aaa" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Пт" Foreground="#aaa" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Сб" Foreground="#aaa" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Вс" Foreground="#aaa" FontWeight="Bold" HorizontalAlignment="Center"/>
                </UniformGrid>

                <!-- Сетка дней -->
                <ItemsControl ItemsSource="{Binding Days}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="6" Columns="7"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="4" Margin="3" CornerRadius="6"
                                Background="{Binding IsToday, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Highlight'}"
                                Opacity="{Binding IsCurrentMonth, Converter={StaticResource BoolToOpacityConverter}}">
                                <TextBlock Text="{Binding DayNumber}" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding IsToday, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Foreground'}"
                                       FontWeight="{Binding IsToday, Converter={StaticResource BoolToFontWeightConverter}}" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
