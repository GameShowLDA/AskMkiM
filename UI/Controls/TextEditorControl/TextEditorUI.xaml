<UserControl x:Class="UI.Controls.TextEditorControl.TextEditorUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.TextEditorControl"
             
             xmlns:avalonEdit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
             
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
        <avalonEdit:TextEditor x:Name="textEditor" 
        Grid.Row="0"
        ShowLineNumbers="True"
        Style="{DynamicResource StyleTextEditor}"
        FontFamily="Consolas"
        FontSize="20"
        WordWrap="True"
        ScrollViewer.HorizontalScrollBarVisibility="Auto"
        ScrollViewer.VerticalScrollBarVisibility="Auto"
        AllowDrop="True" 
        Tag="hotkeys" 
        PreviewMouseWheel="TextEditor_PreviewMouseWheel">

            <avalonEdit:TextEditor.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}" />
            </avalonEdit:TextEditor.Resources>
        </avalonEdit:TextEditor>
</UserControl>
