<UserControl x:Class="UI.Controls.ProtocolNew.ProtocolUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.ProtocolNew"
             xmlns:InvokeConrols="clr-namespace:UI.Components.Invoke.InvokeRichTextBox"
             xmlns:TextEditor="clr-namespace:UI.Components.ProtocolListBox"
             xmlns:Icons="clr-namespace:UI.Icon"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>

        <Style x:Key="BorderedTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="Wheat"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="BorderStyle" TargetType="Border">
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <DataTemplate x:Key="DynamicContentTemplate">
            <StackPanel>
                <ContentPresenter Content="{Binding}" />
            </StackPanel>
        </DataTemplate>

        <Style x:Key="ShadowButtonStyle" TargetType="Button" BasedOn="{StaticResource ConfigButtonStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource WinstonRegular}"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Background="{StaticResource IsCheckedColorSolidColorBrush}" Name="TopMenuButton" Visibility="{Binding IsTopMenuVisible, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Icons:ContinueIcon x:Name="ContinueButtonTop" Grid.Column="0"  Size="20"/>
            <Grid x:Name="StartButtonTop" Grid.Column="1" Background="{StaticResource IsCheckedColorSolidColorBrush}" Cursor="Hand" Margin="5,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Icons:PlayIcon  Size="20"/>
                <TextBlock Name="headerFile" Text="Название файла" Grid.Column="2" Foreground="{StaticResource ForegroundSolidColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>

            </Grid>

            <Icons:PauseIcon x:Name="PauseButtonTop" Grid.Column="2" Margin="5,0" Size="20"/>
            <Icons:StopIcon x:Name="StopButtonTop" Grid.Column="3" Margin="5,0" Size="20"/>
            <Icons:RepeatIcon x:Name="RepeatButtonTop" Grid.Column="4" Size="15" Margin="5,2,5,2" HorizontalAlignment="Left" Width="15"/>
            <Icons:StepOverIcon x:Name="StepOverTop" Grid.Column="5" Size="20" Margin="5,0"  HorizontalAlignment="Left" Width="15"/>
            <Icons:StepIntoIcon x:Name="StepIntoTop" Grid.Column="6" Size="20" Margin="5,0" HorizontalAlignment="Left" Width="15"/>

        </Grid>

        <Border CornerRadius="0,0,0,0" Grid.Row="1" Background="{StaticResource PrimarySolidColorBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border  Padding="0,10" Margin="5" CornerRadius="20" Name="MenuButton" Width="300" Visibility="{Binding IsTopMenuVisible, Converter={StaticResource InverseBoolToVis}}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource IsCheckedColor}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Name="header" 
                               Text="Ваша надпись" 
                               Foreground="{StaticResource ForegroundSolidColorBrush}" 
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Left"
                               TextAlignment="Center"
                               Padding="30,10,10,10" 
                               FontSize="25"
                               TextWrapping="Wrap" TextTrimming="None"
                               FontFamily="{DynamicResource WinstonBold}"
                               />

                        <ContentControl Content="{Binding ContentView}" Grid.Row="1" Margin="20,10,20,10"/>

                        <StackPanel Grid.Row="2" Margin="20,0,20,20">

                            <Button x:Name="StartButton" Content="ЗАПУСТИТЬ(Enter)" Cursor="Hand" 
                                Style="{StaticResource ShadowButtonStyle}" 
                        />

                            <Button x:Name="RepeatButton" Content="ПОВТОРИТЬ(R)" Margin="0,10,0,0" Cursor="Hand" 
                        Style="{StaticResource ShadowButtonStyle}" 
                        />

                            <Button x:Name="loopButton" Content="ЗАЦИКЛИТЬ" Margin="0,10,0,0" Cursor="Hand" 
                        Style="{StaticResource ShadowButtonStyle}" 
                        />

                            <Button x:Name="PauseButton" Content="ОСТАНОВИТЬ(P)" Cursor="Hand" Margin="0,10,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ShadowButtonStyle}">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#fcaa3f" Offset="1"/>
                                                    <GradientStop Color="#f47842" Offset="0"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="#f3f0f9"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#fcaa3f" Offset="1"/>
                                                            <GradientStop Color="#f47842" Offset="0"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="StepOver" Content="Поверх(F10)" FontSize="18" Grid.Column="0" Margin="0,10,5,0" Cursor="Hand" Style="{StaticResource ShadowButtonStyle}" PreviewMouseDown="stepOverButton_PreviewMouseDown" />
                                <Button x:Name="StepInto" Content="Вглубь(F11)" FontSize="18" Grid.Column="1" Margin="5,10,0,0" Cursor="Hand" Style="{StaticResource ShadowButtonStyle}" PreviewMouseDown="stepIntoButton_PreviewMouseDown"/>

                            </Grid>

                            <Button x:Name="ContinueButton"  Content="ПРОДОЛЖИТЬ(P)" FontSize="18" Grid.Column="0" Margin="0,10,0,0" Cursor="Hand" >
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ShadowButtonStyle}">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#67c66e" Offset="1"/>
                                                    <GradientStop Color="#459c3c" Offset="0"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="#f3f0f9"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#67c66e" Offset="1"/>
                                                            <GradientStop Color="#459c3c" Offset="0"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button x:Name="StopButton" Content="ЗАВЕРШИТЬ(Esc)" FontSize="18" Grid.Column="1" Margin="0,10,0,0" Cursor="Hand" >
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ShadowButtonStyle}">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#fcaa3f" Offset="1"/>
                                                    <GradientStop Color="#f47842" Offset="0"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="#f3f0f9"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#fcaa3f" Offset="1"/>
                                                            <GradientStop Color="#f47842" Offset="0"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button x:Name="adminContinue" Content="ПРОПУСТИТЬ" FontSize="18" Margin="0,10,0,0" Cursor="Hand" >
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ShadowButtonStyle}">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="{StaticResource RedColor}" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="#f3f0f9"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#fcaa3f" Offset="1"/>
                                                            <GradientStop Color="#f47842" Offset="0"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button x:Name="adminExit" Content="ЗАВЕРШИТЬ" FontSize="18" Margin="0,10,0,0" Cursor="Hand" >
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ShadowButtonStyle}">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="{StaticResource RedColor}" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="#f3f0f9"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#fcaa3f" Offset="1"/>
                                                            <GradientStop Color="#f47842" Offset="0"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="5">
                    <TextEditor:ProtocolListBoxUI x:Name="protocolTextBox"/>
                </Grid>


            </Grid>
        </Border>

    </Grid>
</UserControl>
