<UserControl x:Class="UI.Controls.StatusBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls"
             mc:Ignorable="d" >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource MainTitleSolidColorBrush}" Text="{Binding Line, StringFormat=Строка: {0}}" Margin="10,0"/>
        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource MainTitleSolidColorBrush}" Text="{Binding Column, StringFormat=Столбец: {0}}" Margin="10,0"/>
        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource MainTitleSolidColorBrush}" Text="{Binding LineCount, StringFormat=Всего строк: {0}}" Margin="10,0"/>
        <TextBlock Grid.Column="3"
                   VerticalAlignment="Center"
                   FontSize="14"
                   Foreground="{DynamicResource MainTitleSolidColorBrush}"
                   Text="{Binding EncodingName}"
                   TextDecorations="Underline"
                   Cursor="Hand"
                   MouseRightButtonUp="EncodingTextBlock_MouseRightButtonUp"
                   MouseLeftButtonUp="EncodingTextBlock_MouseLeftButtonUp"
                   Margin="10,0"/>
    </Grid>
</UserControl>
