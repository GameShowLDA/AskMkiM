<Window x:Class="UI.Controls.Message.MessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UI.Controls.Message"
        mc:Ignorable="d"
        Title="MessageBox"  
        Width="600"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="{StaticResource SecondarySolidColorBrush}" 
        ShowInTaskbar="False"
        VerticalAlignment="Stretch"
        Topmost="True" 
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Name="TopPanel">
            <TextBlock x:Name="Header" Text="Заголовок сообщения" FontFamily="{DynamicResource WinstonBold}" Foreground="{StaticResource ForegroundSolidColorBrush}" VerticalAlignment="Center" Padding="10" FontSize="20"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Name="IconContainer" Background="Transparent" Margin="10" Width="50" Height="50" HorizontalAlignment="Left"/>

            <StackPanel Grid.Column="1" Margin="10" VerticalAlignment="Center" >
                <TextBox Name="MessageText" TextWrapping="Wrap" FontSize="18" Background="Transparent"
                         Foreground="{StaticResource ForegroundSolidColorBrush}" BorderThickness="0" IsReadOnly="True"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Margin="10" VerticalAlignment="Center" Orientation="Horizontal">
            <Button Name="OkButton" PreviewMouseDown="OkButton_PreviewMouseDown" Content="Ок" Height="30" Margin="5"  Width="50" Style="{StaticResource CustomButtonStyle}"/>
            <Button Name="CancelButton" PreviewMouseDown="CancelButton_PreviewMouseDown" Content="Отмена" Height="30"  Margin="5" Width="80" Style="{StaticResource CustomButtonStyle}"/>
            <Button Name="YesButton" PreviewMouseDown="YesButton_PreviewMouseDown" Content="Да" Height="30"  Margin="5" Width="50" Style="{StaticResource CustomButtonStyle}"/>
            <Button Name="NoButton" PreviewMouseDown="NoButton_PreviewMouseDown" Content="Нет" Height="30"  Margin="5" Width="50" Style="{StaticResource CustomButtonStyle}"/>
        </StackPanel>

    </Grid>
</Window>
