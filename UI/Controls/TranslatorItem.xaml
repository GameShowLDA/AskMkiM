<UserControl x:Class="UI.Controls.TranslatorItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Controls.TextEditorControl"
             xmlns:avalonEdit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
             xmlns:DefaultGUI="clr-namespace:UI.Components" 
             xmlns:Controls="clr-namespace:UI.Controls"
             xmlns:ErrorList="clr-namespace:Ask.UI.Controls.ErrorList;assembly=Ask.UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Background="Transparent">
        <!-- Вертикальный режим -->
        <Grid x:Name="VerticalPanel" Grid.Column="1" Visibility="Visible" Grid.Row="2" Cursor="">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" MinHeight="30"/>
                <!-- Заголовок -->
                <RowDefinition Height="0.7*" MinHeight="30"/>
                <!-- Редакторы (split) -->
                <RowDefinition Height="Auto"/>
                <!-- Сплиттер -->
                <RowDefinition x:Name="ErrorListRow" Height="Auto" MinHeight="50"/>
                <!-- Окно ошибок -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="30"/>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="30" />
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            
            <Grid Grid.Column="0" Grid.RowSpan="2"  x:Name="LeftBox" >
                <Controls:TranslatorTextEditor />

            </Grid>


            <GridSplitter 
                Grid.Column="1" 
                Grid.RowSpan="2" 
                Width="5"
                Background="Transparent" 
               HorizontalAlignment="Stretch" 
                VerticalAlignment="Stretch" 
                ResizeDirection="Columns"
                 BorderThickness="2,0,0,0"
 BorderBrush="{DynamicResource VioletColorSolidColorBrush}"
                />


            <Grid Grid.Column="2" Grid.RowSpan="2"  x:Name="RightBox" >
                <Controls:TranslatorEditor />
            </Grid>

            <GridSplitter  Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
               Height="5"
                           Background="Transparent"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           ResizeDirection="Rows"
                           DragStarted="ErrorListSplitter_DragStarted"
                           DragDelta="ErrorListSplitter_DragDelta"
                           DragCompleted="ErrorListSplitter_DragCompleted"
                           BorderThickness="0,2,0,0"
                           BorderBrush="{DynamicResource VioletColorSolidColorBrush}"
                           />

            <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ErrorList:ErrorListControl Grid.Row="0" x:Name="ErrorListBoxVertical"/>
            </Grid>
        </Grid>


    </Grid>
</UserControl>
