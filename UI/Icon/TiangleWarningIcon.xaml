<UserControl x:Class="UI.Icon.TiangleWarningIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root"
             Width="{Binding Size, ElementName=root}"
             Height="{Binding Size, ElementName=root}">
    <Viewbox Stretch="Uniform">
        <Grid Width="100" Height="100">
            <!-- Треугольник -->
            <Path Fill="{Binding TriangleColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  Stroke="{Binding IconStrokeColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  StrokeThickness="1"
                  Data="M 50 5 L 95 85 L 5 85 Z"
                  SnapsToDevicePixels="True"/>

            <!-- Восклицательный знак -->
            <Grid VerticalAlignment="Center">
                <Rectangle Width="11" Height="33"
                           Fill="{Binding IconStrokeColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           RadiusX="100" RadiusY="100"
                           Margin="0,0,0,11"/>
                <Ellipse Width="11" Height="11"
                         Fill="{Binding IconStrokeColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         VerticalAlignment="Bottom"/>
            </Grid>
        </Grid>
    </Viewbox>
</UserControl>
