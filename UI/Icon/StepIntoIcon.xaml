<UserControl x:Class="UI.Icon.StepIntoIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root"
             Width="{Binding Size, ElementName=root}"
             Height="{Binding Size, ElementName=root}"
             Cursor="Hand"
             >
    <Viewbox Stretch="Uniform">
        <Canvas Width="100" Height="100">
            <!-- Вертикальная стрелка -->
            <Line X1="50" Y1="20" X2="50" Y2="60"
                  Stroke="#3d7dab"
                  StrokeThickness="15"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round" />

            <!-- Лапки стрелки -->
            <Line X1="40" Y1="50" X2="50" Y2="60"
                  Stroke="#3d7dab"
                  StrokeThickness="15"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round" />
            <Line X1="60" Y1="50" X2="50" Y2="60"
                  Stroke="#3d7dab"
                  StrokeThickness="15"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round" />

            <!-- Кружочек под стрелкой -->
            <Ellipse Width="16" Height="15"
                     Canvas.Left="42" Canvas.Top="75"
                     Fill="#3d7dab"/>
        </Canvas>
    </Viewbox>
</UserControl>
