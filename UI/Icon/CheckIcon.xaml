<UserControl x:Class="UI.Icon.CheckIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding Size, RelativeSource={RelativeSource Self}}"
             Height="{Binding Size, RelativeSource={RelativeSource Self}}">
    <Grid>
        <Ellipse Fill="{Binding CircleColor, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

        <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Canvas Width="64" Height="64">
                <Path Data="M18,34 L28,44 L46,20"
                      Stroke="{Binding IconStrokeColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      StrokeThickness="6"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"/>
            </Canvas>
        </Viewbox>
    </Grid>
</UserControl>
