<UserControl x:Class="UI.Icon.WarningIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Icon"
             mc:Ignorable="d"
             Width="{Binding Size, RelativeSource={RelativeSource Self}}"
             Height="{Binding Size, RelativeSource={RelativeSource Self}}">
    <Grid>
        <Ellipse Fill="{Binding CircleColor, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Rectangle Width="8" Height="24"
                       Fill="{Binding IconStrokeColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       RadiusX="2" RadiusY="2" Margin="0,0,0,4"/>
            <Ellipse Width="8" Height="8"
                     Fill="{Binding IconStrokeColor, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </StackPanel>
    </Grid>
</UserControl>
