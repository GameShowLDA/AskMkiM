<UserControl x:Class="UI.Icon.StepOverIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding Size, RelativeSource={RelativeSource Self}}"
             Height="{Binding Size, RelativeSource={RelativeSource Self}}"
             Cursor="Hand"
             >
    <Viewbox Stretch="Uniform">
        <Canvas Width="100" Height="100">
            <!-- Вертикальная стрелка -->
            <Line X1="50" Y1="20" X2="50" Y2="60"
                  Stroke="#3d7dab"
                  StrokeThickness="15"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round" HorizontalAlignment="Center" Canvas.Left="2" VerticalAlignment="Top" Canvas.Top="18" />

            <!-- Лапки стрелки -->
            <Line X1="40" Y1="50" X2="50" Y2="60"
                  Stroke="#3d7dab"
                  StrokeThickness="15"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round" HorizontalAlignment="Center" Canvas.Left="2" VerticalAlignment="Top" Canvas.Top="18" />
            <Line X1="60" Y1="50" X2="50" Y2="60"
                  Stroke="#3d7dab"
                  StrokeThickness="15"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round" HorizontalAlignment="Center" Canvas.Left="2" VerticalAlignment="Top" Canvas.Top="18" />

            <!-- Кружочек под стрелкой -->
            <Ellipse Width="16" Height="16"
                     Canvas.Left="44"
                     Fill="#3d7dab" RenderTransformOrigin="0.467,-1.4" HorizontalAlignment="Center" VerticalAlignment="Top" Canvas.Top="5"/>
        </Canvas>
    </Viewbox>
</UserControl>
