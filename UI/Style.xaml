                <Setter Property="BorderBrush" Value="{StaticResource ActiveBorderSolidColorBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Margin" Value="0,5,0,7"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Background" Value="{StaticResource ToggleButtonActiveBackgroundColor}"/>
        <Setter Property="Foreground" Value="{StaticResource ToggleButtonForegroundColor}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}" 
                         CornerRadius="0" 
                         BorderThickness="{TemplateBinding BorderThickness}" 
                         BorderBrush="{TemplateBinding BorderBrush}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!-- Триггер для изменения цвета фона и текста при наведении -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ToggleButtonActiveBackgroundColor}"/>
                <Setter Property="Foreground" Value="{StaticResource ToggleButtonActiveForegroundColor}"/>
                <Setter Property="BorderBrush" Value="{StaticResource ToggleButtonActiveBorderColor}"/>
                <Setter Property="BorderThickness" Value="5,0,0,0"/>
            </Trigger>
            <!-- Триггер для изменения цвета фона и текста при нажатии -->
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{StaticResource ToggleButtonSecondActiveBorderColor}" />
                <Setter Property="Foreground" Value="{StaticResource ToggleButtonActiveForegroundColor}"/>
                <Setter Property="BorderBrush" Value="{StaticResource ToggleButtonActiveBorderColor}"/>
                <Setter Property="BorderThickness" Value="5,0,0,0"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="CustomComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource ComboBoxBackgroundColor}"/>
        <Setter Property="Foreground" Value="{StaticResource ComboBoxForegroundColor}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="BorderBrush" Value="{StaticResource ComboBoxBorderColor}"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground" Value="{StaticResource ComboBoxForegroundColor}"/>
                    <Setter Property="FontSize" Value="18"/>
                    <Setter Property="HorizontalContentAlignment" Value="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                    <Setter Property="VerticalContentAlignment" Value="{Binding VerticalContentAlignment, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Border" Background="{StaticResource ComboBoxBackgroundColor}" BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource ComboBoxBackgroundColor}"/>
                                        <Setter Property="Foreground" Value="{StaticResource ComboBoxForegroundColor}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource ComboBoxAcriveBackgroundColor}"/>
                                        <Setter Property="Foreground"  Value="{StaticResource ComboBoxForegroundColor}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton Name="ToggleButton"
                                  Grid.Column="2"
                                  Focusable="false"
                                  IsChecked="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                  ClickMode="Press"
                                  Background="{StaticResource ComboBoxBackgroundColor}"
                                  BorderThickness="0">
                            <Grid>
                                <ContentPresenter Name="ContentSite"
                                              IsHitTestVisible="False"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              HorizontalAlignment="Left"
                                              Margin="3,3,23,3"
                                              VerticalAlignment="Center">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource ComboBoxForegroundColor}"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                                <TextBox x:Name="PART_EditableTextBox"
                                     Style="{x:Null}"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Margin="3,3,23,3"
                                     Focusable="True"
                                     Background="{StaticResource ComboBoxBackgroundColor}"
                                     Foreground="{StaticResource ComboBoxForegroundColor}"
                                     FontSize="18"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}" />
                                <Path x:Name="Arrow" 
                                  Data="M 0 0 L 4 4 L 8 0 Z" 
                                  Fill="{StaticResource ComboBoxForegroundColor}"
                                  HorizontalAlignment="Right" 
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"/>
                            </Grid>
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{StaticResource ComboBoxBackgroundColor}" BorderThickness="0">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        <Popup Name="Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide">
                            <Grid Name="DropDown"
                              SnapsToDevicePixels="True"
                              MinWidth="{TemplateBinding ActualWidth}"
                              MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border x:Name="DropDownBorder"
                                    Background="{StaticResource ComboBoxSecondActiveBorderColor}"
                                    BorderThickness="1">
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="false">
                            <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter Property="Foreground" Value="{StaticResource ComboBoxForegroundColor}"/>
                        </Trigger>
                        <Trigger Property="IsGrouping" Value="true">
                            <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
                        </Trigger>
                        <Trigger SourceName="Popup" Property="Popup.AllowsTransparency" Value="true">
                            <Setter TargetName="DropDownBorder" Property="CornerRadius" Value="0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CustomList" TargetType="TreeViewItem">
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style x:Key="CustomItemList" TargetType="TreeViewItem">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="BorderBrush" Value="White"/>
        <Setter Property="Padding" Value="5"/>
    </Style>

    <Style x:Key="ScrollBarButtonStyle" TargetType="RepeatButton">
        <Setter Property="Background" Value="#465060"/>
        <Setter Property="BorderBrush" Value="#1e2828"/>
        <Setter Property="Foreground" Value="#f3f0f9"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
        <Setter Property="Background" Value="{StaticResource ActiveBorderSolidColorBrush}"/>
        <Setter Property="BorderBrush" Value="#1e2828"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track Name="PART_Track" IsDirectionReversed="true">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineUpCommand" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Height="10"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Name="Thumb" 
                          Background="{StaticResource SecondarySolidColorBrush}" 
                          BorderThickness="0"
                          Cursor="ScrollNS">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{TemplateBinding Background}" 
                                  BorderBrush="Transparent" 
                                  BorderThickness="0"
                                  CornerRadius="10"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineDownCommand" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Height="10"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="Thumb">
        <Setter Property="Background" Value="{StaticResource SecondarySolidColorBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="{TemplateBinding Background}" 
          BorderBrush="Transparent" 
          BorderThickness="0"></Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListViewItem">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Foreground" Value="#f3f0f9"/>
        <Setter Property="Background" Value="#465060"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                         BorderBrush="{TemplateBinding BorderBrush}" 
                         BorderThickness="{TemplateBinding BorderThickness}" 
                         Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#303843"/>
                            <Setter Property="Foreground" Value="{StaticResource ActiveForegroundSolidColorBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1f242b"/>
                            <Setter Property="Foreground" Value="{StaticResource ActiveForegroundSolidColorBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BorderedTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="BorderStyle" TargetType="Border">
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="BorderBrush" Value="{StaticResource BackButtonForegroundColor}"/>
        <Setter Property="Margin" Value="0,0,0,15"/>
    </Style>

    <Style x:Key="TopPanel" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource TopPanelBackgroundColor}"/>
    </Style>

    <Style x:Key="CategoryPanel" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource CategoryPanelBackgroundColor}"/>
    </Style>

    <Style x:Key="MainPanel" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource MainPanelBackgroundColor}"/>
    </Style>

    <Style x:Key="WindowsButtonStyle" TargetType="CustomControls:WindowButtons">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource WindowButtonForegroundColor}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource WindowButtonActiveForegroundColor}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="CategoriesControlStyle" TargetType="Grid">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{DynamicResource SecondaryColor}" Offset="0.2"/>
                    <GradientStop Color="{DynamicResource IsCheckedColor}" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RichBoxBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource RichBoxBackgroundColor}"/>
        <Setter Property="CornerRadius" Value="25"/>
    </Style>

    <Style x:Key="RichBoxText" TargetType="RichTextBox">
        <Setter Property="Foreground" Value="{StaticResource RichBoxForegroundColor}"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>


    <!-- Стиль для Slider -->
    <Style x:Key="CustomSliderStyle" TargetType="Slider">
        <Setter Property="Background" Value="{StaticResource IsCheckedColorSolidColorBrush}" />
        <Setter Property="Foreground" Value="{StaticResource IsCheckedColorSolidColorBrush}" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid Height="20">
                        <!-- Общий трек -->
                        <Rectangle x:Name="TrackBackground"
                                   Height="4"
                                   Fill="{TemplateBinding Background}"
                                   VerticalAlignment="Center"
                                   Width="{TemplateBinding ActualWidth}" />

                        <!-- Активная часть трека -->
                        <Rectangle x:Name="TrackForeground"
                                   Height="4"
                                   Fill="{TemplateBinding Foreground}"
                                   VerticalAlignment="Center">
                            <Rectangle.Width>
                                <MultiBinding Converter="{StaticResource SliderValueToWidthConverter}">
                                    <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="Minimum" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="Maximum" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource TemplatedParent}" />
                                </MultiBinding>
                            </Rectangle.Width>
                        </Rectangle>

                        <!-- Ползунок -->
                        <Track x:Name="PART_Track">
                            <Track.Thumb>
                                <Thumb x:Name="Thumb">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse Width="16" Height="16"
                                                     Fill="{StaticResource ActiveBorderSolidColorBrush}"
                                                     VerticalAlignment="Center" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Стиль для текстового поля -->
    <Style x:Key="ComboBoxTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Name="comboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />

    </Style>
    <!-- Стиль для ToggleButton -->
    <Style TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource ActiveForegroundSolidColorBrush}"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Стиль для элементов списка -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{StaticResource SecondarySolidColorBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource ActiveBorderSolidColorBrush}"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Trigger>
        </Style.Triggers>
    </Style>


    <!-- Стиль для Datagrid -->
    <Style x:Key="DataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource SecondarySolidColorBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource SecondarySolidColorBrush}"/>
        <Setter Property="RowBackground" Value="{StaticResource SecondarySolidColorBrush}"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource ActiveBorderSolidColorBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}"/>
        <Setter Property="Padding" Value="7"/>
        <Setter Property="BorderBrush" Value="{StaticResource ForegroundSolidColorBrush}"/>
        <Setter Property="BorderThickness" Value="0.5"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="18"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Height" Value="30"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Background" Value="{StaticResource PrimarySolidColorBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Bottom"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Padding="{TemplateBinding Padding}" 
                    BorderBrush="{StaticResource PrimarySolidColorBrush}"
                    BorderThickness="0"
                    Background="{StaticResource PrimarySolidColorBrush}">
                        <ContentPresenter VerticalAlignment="Bottom"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#1f242b"/>
                <Setter Property="Foreground" Value="{StaticResource ActiveForegroundSolidColorBrush}"/>
                <Setter Property="Height" Value="30"/>
                <Setter Property="VerticalContentAlignment" Value="Bottom"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="False">
                <Setter Property="Background" Value="{StaticResource SecondarySolidColorBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource ForegroundSolidColorBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridRow" >
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Background" Value="{StaticResource SecondarySolidColorBrush}"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="VerticalContentAlignment" Value="Bottom"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Trigger>

            <Trigger Property="IsSelected" Value="False">
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Стиль для списка кнопок в MkrControl -->
    <Style x:Key="MkrPointStyle" TargetType="Button">
        <Setter Property="Content" Value="{Binding PointNumber}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="White"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding A}" Value="True">
                <Setter Property="Background" Value="Aqua"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding B}" Value="True">
                <Setter Property="Background" Value="Plum"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding A}" Value="True"/>
                    <Condition Binding="{Binding B}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="DarkViolet"/>
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>