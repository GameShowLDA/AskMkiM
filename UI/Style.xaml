<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:CustomControls="clr-namespace:UI.Components"
                    xmlns:SliderConcerter="clr-namespace:UI"
                    xmlns:LocalizeConv="clr-namespace:Ask.UI.Shared.Converters.Localization;assembly=Ask.UI"
                    xmlns:LocalizeStrings="clr-namespace:Ask.UI.Infrastructure.Localization;assembly=Ask.UI">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Ask.UI;component/Resources/Localization/Localization.Merged.xaml"/>
        <ResourceDictionary Source="/Ask.UI;component/Resources/Styles/Styles.Merged.xaml"/>

        <ResourceDictionary Source="/UI;component/Resources/Theme/dark.xaml"/>
        <ResourceDictionary Source="/UI;component/Resources/Theme/light.xaml"/>
        <ResourceDictionary Source="/UI;component/Resources/Theme/Colors.Dark.xaml"/>

        <ResourceDictionary Source="/UI;component/Resources/Font/Font.xaml"/>
        <ResourceDictionary Source="/UI;component/Resources/AppColors.xaml"/>
        <ResourceDictionary Source="/UI;component/Resources/StyleApp/DeviceConfigStyle.xaml"/>
        <ResourceDictionary Source="/UI;component/Resources/StyleApp/MetrologyStyle.xaml"/>
        <ResourceDictionary Source="/UI;component/Resources/ColorsStyle/SettingsStyle.xaml"/>
        <ResourceDictionary Source="/UI;component/Resources/ColorsStyle/MainStyle.xaml"/>
        <ResourceDictionary Source="/UI;component/Resources/ColorsStyle/TestsStyle.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <SliderConcerter:SliderValueToWidthConverter x:Key="SliderValueToWidthConverter" />
    <LocalizeConv:LocalizationConverter x:Key="Loc" />

    <SolidColorBrush x:Key="TopPanelBackgroundColor" Color="{DynamicResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CategoryPanelBackgroundColor" Color="{DynamicResource SecondaryColor}"/>
    <SolidColorBrush x:Key="MainPanelBackgroundColor" Color="{DynamicResource PrimaryColor}"/>
    <SolidColorBrush x:Key="BackButtonForegroundColor" Color="{DynamicResource ForegroundColor}"/>

    <SolidColorBrush x:Key="RichBoxBackgroundColor" Color="{DynamicResource SecondaryColor}"/>
    <SolidColorBrush x:Key="RichBoxForegroundColor" Color="{DynamicResource ForegroundColor}"/>

    <SolidColorBrush x:Key="WindowButtonForegroundColor" Color="{DynamicResource ForegroundColor}"/>
    <SolidColorBrush x:Key="WindowButtonActiveForegroundColor" Color="{DynamicResource ActiveColor}"/>

    <SolidColorBrush x:Key="ToggleButtonBackgroundColor" Color="{DynamicResource PrimaryColor}"/>
    <SolidColorBrush x:Key="ToggleButtonBackgroundIsCheckedColor" Color="{DynamicResource SecondaryColor}"/>
    <SolidColorBrush x:Key="ToggleButtonForegroundColor" Color="{DynamicResource ForegroundColor}"/>
    <SolidColorBrush x:Key="ToggleButtonActiveBackgroundColor" Color="{DynamicResource SecondaryColor}"/>
    <SolidColorBrush x:Key="ToggleButtonActiveForegroundColor" Color="{DynamicResource ActiveColor}"/>
    <SolidColorBrush x:Key="ToggleButtonActiveBorderColor" Color="{DynamicResource ActiveColor}"/>
    <SolidColorBrush x:Key="ToggleButtonSecondActiveBorderColor" Color="{DynamicResource IsCheckedColor}"/>

    <SolidColorBrush x:Key="Cb_BackBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="Cb_BorderBrush" Color="{StaticResource ForegroundColor}"/>
    <SolidColorBrush x:Key="Cb_DisabledBrush" Color="{StaticResource ForegroundColor}"/>

    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="Background" Value="{DynamicResource SecondarySolidColorBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FadedRedSolidColorBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="MaxWidth" Value="420"/>
        <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">
                    <Border Background="Transparent" SnapsToDevicePixels="True">
                        <Border CornerRadius="9"
                                Background="{TemplateBinding BorderBrush}"
                                Padding="{TemplateBinding BorderThickness}">
                            <Border CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AnimatedSwitch" TargetType="{x:Type ToggleButton}">
        <Setter Property="Foreground" Value="Black" />
        <Setter Property="Background" Value="#FAFAFB" />
        <Setter Property="BorderBrush" Value="#EAEAEB" />
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Width" Value="20"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Viewbox Stretch="Uniform">
                        <Canvas Name="Layer_1" Width="20" Height="20" Canvas.Left="10" Canvas.Top="0">
                            <Ellipse Canvas.Left="0" Width="20" Height="20" Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="0.5"/>
                            <Ellipse Canvas.Left="15" Width="20" Height="20" Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="0.5"/>
                            <Border Canvas.Left="10" Width="15" Height="20" Name="rect416927" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0,0.5,0,0.5"/>
                            <Ellipse x:Name="ellipse" Canvas.Left="0" Width="20" Height="20" Fill="White" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="0.3">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0" Y="0" />
                                </Ellipse.RenderTransform>
                                <Ellipse.BitmapEffect>
                                    <DropShadowBitmapEffect Softness="0.1" ShadowDepth="0.7" Direction="270" Color="#BBBBBB"/>
                                </Ellipse.BitmapEffect>
                            </Ellipse>
                        </Canvas>
                    </Viewbox>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="Background.Color" To="#52D468" Duration="0:0:0.2" />
                                        <ColorAnimation Storyboard.TargetProperty="BorderBrush.Color" To="#41C955" Duration="0:0:0.2" />
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(Ellipse.RenderTransform).(TranslateTransform.X)" Storyboard.TargetName="ellipse">
                                            <SplineDoubleKeyFrame KeyTime="0" Value="0"/>
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="15" KeySpline="0, 1, 0.6, 1"/>
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="Background.Color" To="#FAFAFB" Duration="0:0:0.2" />
                                        <ColorAnimation Storyboard.TargetProperty="BorderBrush.Color" To="#EAEAEB" Duration="0:0:0.2" />
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(Ellipse.RenderTransform).(TranslateTransform.X)" Storyboard.TargetName="ellipse">
                                            <SplineDoubleKeyFrame KeyTime="0" Value="15"/>
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.3" Value="0" KeySpline="0, 0.5, 0.5, 1"/>
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Margin" Value="0,5,0,7"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Background" Value="{DynamicResource ToggleButtonActiveBackgroundColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource ToggleButtonForegroundColor}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="0"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ToggleButtonActiveBackgroundColor}"/>
                <Setter Property="Foreground" Value="{DynamicResource ToggleButtonActiveForegroundColor}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ToggleButtonActiveBorderColor}"/>
                <Setter Property="BorderThickness" Value="5,0,0,0"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource ToggleButtonSecondActiveBorderColor}" />
                <Setter Property="Foreground" Value="{DynamicResource ToggleButtonActiveForegroundColor}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ToggleButtonActiveBorderColor}"/>
                <Setter Property="BorderThickness" Value="5,0,0,0"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="VsFilterButtonStyle" TargetType="ToggleButton">
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="FontFamily" Value="{DynamicResource WinstonMedium}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="MinWidth" Value="130"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Tag" Value="Warning">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="{DynamicResource ErrorListWarningFilterButtonBackgroundBrush}"/>
                            <Setter TargetName="border"
                                    Property="BorderBrush"
                                    Value="{DynamicResource ErrorListWarningFilterButtonBorderBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource ErrorListWarningFilterButtonForegroundBrush}"/>
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Tag" Value="Warning"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="{DynamicResource ErrorListWarningFilterButtonHoverBackgroundBrush}"/>
                            <Setter TargetName="border"
                                    Property="BorderBrush"
                                    Value="{DynamicResource ErrorListWarningFilterButtonHoverBorderBrush}"/>
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Tag" Value="Warning"/>
                                <Condition Property="IsChecked" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="{DynamicResource ErrorListWarningFilterButtonCheckedBackgroundBrush}"/>
                            <Setter TargetName="border"
                                    Property="BorderBrush"
                                    Value="{DynamicResource ErrorListWarningFilterButtonCheckedBorderBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource ErrorListWarningFilterButtonCheckedForegroundBrush}"/>
                        </MultiTrigger>

                        <Trigger Property="Tag" Value="Error">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="{DynamicResource ErrorListErrorFilterButtonBackgroundBrush}"/>
                            <Setter TargetName="border"
                                    Property="BorderBrush"
                                    Value="{DynamicResource ErrorListErrorFilterButtonBorderBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource ErrorListErrorFilterButtonForegroundBrush}"/>
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Tag" Value="Error"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="{DynamicResource ErrorListErrorFilterButtonHoverBackgroundBrush}"/>
                            <Setter TargetName="border"
                                    Property="BorderBrush"
                                    Value="{DynamicResource ErrorListErrorFilterButtonHoverBorderBrush}"/>
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Tag" Value="Error"/>
                                <Condition Property="IsChecked" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="{DynamicResource ErrorListErrorFilterButtonCheckedBackgroundBrush}"/>
                            <Setter TargetName="border"
                                    Property="BorderBrush"
                                    Value="{DynamicResource ErrorListErrorFilterButtonCheckedBorderBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource ErrorListErrorFilterButtonCheckedForegroundBrush}"/>
                        </MultiTrigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CustomList" TargetType="TreeViewItem">
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style x:Key="CustomItemList" TargetType="TreeViewItem">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="BorderBrush" Value="White"/>
        <Setter Property="Padding" Value="5"/>
    </Style>

    <Style x:Key="ScrollBarButtonStyle" TargetType="RepeatButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes35}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Focusable" Value="False"/>
    </Style>

    <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
        <Setter Property="Background" Value="{DynamicResource ScrollBarThumbBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ScrollBarThumbHoverBackgroundBrush}"/>
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
                <Setter Property="Background" Value="{DynamicResource ScrollBarThumbPressedBackgroundBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track Name="PART_Track" IsDirectionReversed="true">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineUpCommand"
                                              Style="{StaticResource ScrollBarButtonStyle}"
                                              Height="10"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Name="Thumb"
                                       Style="{StaticResource ScrollBarThumbStyle}"
                                       Cursor="ScrollNS"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineDownCommand"
                                              Style="{StaticResource ScrollBarButtonStyle}"
                                              Height="10"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Margin" Value="0,0,5,0"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Thumb">
        <Setter Property="Background" Value="{DynamicResource SecondarySolidColorBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="0"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListViewItem">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Foreground" Value="#f3f0f9"/>
        <Setter Property="Background" Value="#465060"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#303843"/>
                            <Setter Property="Foreground" Value="{DynamicResource ActiveForegroundSolidColorBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1f242b"/>
                            <Setter Property="Foreground" Value="{DynamicResource ActiveForegroundSolidColorBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BorderedTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="BorderStyle" TargetType="Border">
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BackButtonForegroundColor}"/>
        <Setter Property="Margin" Value="0,0,0,15"/>
    </Style>

    <Style x:Key="TopPanel" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource TopPanelBackgroundColor}"/>
    </Style>

    <Style x:Key="CategoryPanel" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource CategoryPanelBackgroundColor}"/>
    </Style>

    <Style x:Key="MainPanel" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource MainPanelBackgroundColor}"/>
    </Style>

    <Style x:Key="WindowsButtonStyle" TargetType="CustomControls:WindowButtons">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource WindowButtonForegroundColor}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource WindowButtonActiveForegroundColor}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="CategoriesControlStyle" TargetType="Grid">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{DynamicResource SecondaryColor}" Offset="0.2"/>
                    <GradientStop Color="{DynamicResource IsCheckedColor}" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RichBoxBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource RichBoxBackgroundColor}"/>
        <Setter Property="CornerRadius" Value="25"/>
    </Style>

    <Style x:Key="RichBoxText" TargetType="RichTextBox">
        <Setter Property="Foreground" Value="{DynamicResource RichBoxForegroundColor}"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style x:Key="CustomSliderStyle" TargetType="Slider">
        <Setter Property="Background" Value="{DynamicResource IsCheckedColorSolidColorBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource IsCheckedColorSolidColorBrush}" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid Height="20">
                        <Rectangle x:Name="TrackBackground"
                                   Height="4"
                                   Fill="{TemplateBinding Background}"
                                   VerticalAlignment="Center"
                                   Width="{TemplateBinding ActualWidth}" />

                        <Rectangle x:Name="TrackForeground"
                                   Height="4"
                                   Fill="{TemplateBinding Foreground}"
                                   VerticalAlignment="Center">
                            <Rectangle.Width>
                                <MultiBinding Converter="{StaticResource SliderValueToWidthConverter}">
                                    <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="Minimum" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="Maximum" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource TemplatedParent}" />
                                </MultiBinding>
                            </Rectangle.Width>
                        </Rectangle>

                        <Track x:Name="PART_Track">
                            <Track.Thumb>
                                <Thumb x:Name="Thumb">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse Width="16" Height="16"
                                                     Fill="{DynamicResource ActiveBorderSolidColorBrush}"
                                                     VerticalAlignment="Center" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ComboBoxTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Name="comboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource ActiveForegroundSolidColorBrush}"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource SecondarySolidColorBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource ActiveBorderSolidColorBrush}"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MkrPointStyle" TargetType="Button">
        <Setter Property="Content" Value="{Binding PointNumber}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="White"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding A}" Value="True">
                <Setter Property="Background" Value="Aqua"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding B}" Value="True">
                <Setter Property="Background" Value="Plum"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding A}" Value="True"/>
                    <Condition Binding="{Binding B}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="DarkViolet"/>
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AppContextMenuStyle" TargetType="{x:Type ContextMenu}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="{DynamicResource SecondarySolidColorBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ActiveBorderSolidColorBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="ItemContainerStyle" Value="{DynamicResource AppMenuItemStyle}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <ScrollViewer CanContentScroll="True">
                            <StackPanel IsItemsHost="True" Margin="2" Grid.IsSharedSizeScope="True"/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppMenuItemStyle" TargetType="{x:Type MenuItem}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="Bg"
                                Background="Transparent"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"/>
                        <Grid Margin="8,2,8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="IconCol"/>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="GestureCol"/>
                            </Grid.ColumnDefinitions>

                            <ContentPresenter Grid.Column="0"
                                              ContentSource="Icon"
                                              Margin="0,0,8,0"
                                              VerticalAlignment="Center"/>

                            <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>

                            <ContentPresenter Grid.Column="2"
                                              ContentSource="InputGestureText"
                                              Margin="12,0,0,0"
                                              VerticalAlignment="Center"/>
                        </Grid>

                        <Popup x:Name="SubmenuPopup"
                               Placement="Right"
                               IsOpen="{TemplateBinding IsSubmenuOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade">
                            <Border Background="{DynamicResource SecondarySolidColorBrush}"
                                    BorderBrush="{DynamicResource ActiveBorderSolidColorBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer CanContentScroll="True">
                                    <StackPanel IsItemsHost="True" Margin="2" Grid.IsSharedSizeScope="True"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource IsCheckedColorSolidColorBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                            <Setter TargetName="Bg" Property="Background" Value="Transparent"/>
                        </Trigger>

                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource IsCheckedColorSolidColorBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppSeparatorStyle" TargetType="{x:Type Separator}">
        <Setter Property="Margin" Value="8,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Background="{DynamicResource ActiveBorderSolidColorBrush}" Height="1"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SettingsCheckBox" TargetType="CheckBox">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}" SnapsToDevicePixels="True">
                        <Border x:Name="Box"
                                Background="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                                BorderBrush="{DynamicResource SettingsInteractiveBorderSolidColorBrush}"
                                BorderThickness="2"
                                CornerRadius="4"
                                SnapsToDevicePixels="True"
                                RenderOptions.EdgeMode="Aliased"/>

                        <Border x:Name="Inset"
                                CornerRadius="4"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource SettingsInteractiveBackgroundSolidColorBrush}"
                                Opacity="0.65"
                                IsHitTestVisible="False"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource VioletColorSolidColorBrush}"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource VioletColorSolidColorBrush}"/>
                            <Setter TargetName="Inset" Property="BorderBrush" Value="#55FFFFFF"/>
                            <Setter TargetName="Inset" Property="Opacity" Value="1"/>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource VioletColorSolidColorBrush}"/>
                            <Setter TargetName="Inset" Property="Opacity" Value="0.85"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource SettingsInteractivePressedSolidColorBrush}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Box" Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MarkingCheckBox" TargetType="{x:Type CheckBox}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Grid x:Name="Root" SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="Box"
                                Width="20"
                                Height="20"
                                Background="{StaticResource Cb_BackBrush}"
                                BorderBrush="{StaticResource Cb_BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect Color="Black"
                                                  BlurRadius="5"
                                                  ShadowDepth="0"
                                                  Opacity="0.20"/>
                            </Border.Effect>

                            <TextBlock x:Name="CheckMark"
                                       Text="✓"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="0"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform ScaleX="0.4" ScaleY="0.4"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Border>

                        <ContentPresenter Grid.Column="1"
                                          Margin="6,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Opacity" Value="1"/>
                            <Setter TargetName="CheckMark" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Cb_DisabledBrush}"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Cb_DisabledBrush}"/>
                            <Setter Property="Foreground" Value="#FF777777"/>
                            <Setter TargetName="CheckMark" Property="Opacity" Value="0.5"/>
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Box" Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ArchiveDataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource MainPanelBackgroundColor}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MainPanelBackgroundColor}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,6,8,6" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridHeaderHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource ToggleButtonBackgroundIsCheckedColor}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ArchiveDataGridRowStyle" TargetType="{x:Type DataGridRow}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="2,1,2,1" />
        <Setter Property="MinHeight" Value="30" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ToggleButtonBackgroundIsCheckedColor}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource ToggleButtonBackgroundIsCheckedColor}" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsSelected" Value="True" />
                    <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{DynamicResource ToggleButtonActiveForegroundColor}" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ArchiveDataGridCellStyle" TargetType="{x:Type DataGridCell}">
        <Setter Property="Padding" Value="12,0,8,0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="#1F2A38" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ArchiveDataGridStyle" TargetType="{x:Type DataGrid}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource MainPanelBackgroundColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource MainPanelBackgroundColor}" />
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource MainPanelBackgroundColor}" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="ColumnHeaderStyle" Value="{DynamicResource ArchiveDataGridHeaderStyle}" />
        <Setter Property="RowStyle" Value="{DynamicResource ArchiveDataGridRowStyle}" />
        <Setter Property="CellStyle" Value="{DynamicResource ArchiveDataGridCellStyle}" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
    </Style>

</ResourceDictionary>
