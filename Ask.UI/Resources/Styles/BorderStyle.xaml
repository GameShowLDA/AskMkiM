<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="DeviceInputSectionCardStyle" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource SettingsMainBackground}" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Margin" Value="0,10" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{DynamicResource DeviceInputSectionBorderBrush}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect BlurRadius="14"
                          ShadowDepth="0"
                          Opacity="0.18"
                          Color="{DynamicResource DeviceInputSectionShadowColor}" />
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="DeviceInputSectionTitleBarStyle" TargetType="Border">
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Background" Value="{DynamicResource SettingsInfoTabloBackgroundSolidColorBrush}" />
    <Setter Property="Height" Value="42" />
    <Setter Property="Padding" Value="8,5" />
  </Style>

</ResourceDictionary>
