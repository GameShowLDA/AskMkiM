<UserControl x:Class="Ask.UI.Components.ProtocolListBox.ProtocolListBoxUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Ask.UI.Components.ProtocolListBox"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <UserControl.Resources>
        <local:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
        <local:IndentToMarginConverter x:Key="IndentToMarginConverter"/>
        <local:MessageToColonConverter x:Key="MessageToColonConverter"/>
        <local:TimeToSeparatorConverter x:Key="TimeToSeparatorConverter"/>
        <local:MessageToLeadingNewLineConverter x:Key="MessageToLeadingNewLineConverter"/>
        <local:HeaderToBrushIfNoMessageConverter x:Key="HeaderToBrushIfNoMessageConverter"/>

        <!-- Шаблон одной обычной строки -->
        <DataTemplate x:Key="ProtocolLineTemplate">
            <Border Background="{Binding Message.HeaderBackgroundColor, Converter={StaticResource ColorToBrushConverter}}"
                    BorderThickness="0"
                    Padding="0">
                <TextBlock TextWrapping="Wrap"
                           FontSize="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:ProtocolListBoxUI}}, Path=ProtocolFontSize}"
                           FontFamily="Consolas"
                           SnapsToDevicePixels="True"
                           TextOptions.TextFormattingMode="Display"
                           Margin="{Binding Message.IndentLevel, Converter={StaticResource IndentToMarginConverter}}">

                    <Run>
                        <Run.Text>
                            <MultiBinding Converter="{StaticResource MessageToLeadingNewLineConverter}">
                                <Binding Path="Message.Header"/>
                                <Binding Path="Message.Message"/>
                            </MultiBinding>
                        </Run.Text>
                    </Run>

                    <Run Text="{Binding Message.Header}">
                        <Run.Foreground>
                            <MultiBinding Converter="{StaticResource HeaderToBrushIfNoMessageConverter}">
                                <Binding Path="Message.Header"/>
                                <Binding Path="Message.Message"/>
                                <Binding Path="Message.HeaderColor"
                                         Converter="{StaticResource ColorToBrushConverter}"/>
                            </MultiBinding>
                        </Run.Foreground>
                    </Run>

                    <Run Text="{Binding Message.Message, Converter={StaticResource MessageToColonConverter}}"
                         Foreground="{Binding Message.HeaderColor, Converter={StaticResource ColorToBrushConverter}}"/>

                    <Run Text="{Binding Message.Message}"
                         Foreground="{Binding Message.MessageColor, Converter={StaticResource ColorToBrushConverter}}"/>

                    <Run Text="{Binding Message.Time, Converter={StaticResource TimeToSeparatorConverter}}"
                         Foreground="{Binding Message.TimeColor, Converter={StaticResource ColorToBrushConverter}}"/>

                    <Run Text="{Binding Message.Time}"
                         Foreground="{Binding Message.TimeColor, Converter={StaticResource ColorToBrushConverter}}"/>

                    <Run Text="{Binding Message.Debug}" Foreground="DarkGray"/>
                </TextBlock>
            </Border>
        </DataTemplate>

        <!-- Шаблон группы -->
        <DataTemplate x:Key="ProtocolGroupTemplate">
            <Expander IsExpanded="{Binding IsExpanded}"
                      Background="Transparent"
                      BorderThickness="0">
                <Expander.Header>
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource ProtocolLineTemplate}"/>
                </Expander.Header>

                <ItemsControl ItemsSource="{Binding Children}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}"
                                            ContentTemplate="{StaticResource ProtocolLineTemplate}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Border CornerRadius="20,20,0,0"
                Background="{DynamicResource TestsProtocolBackgroundBrush}">
            <ListBox x:Name="ProtocolListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemsSource="{Binding DisplayItems, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     FontSize="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:ProtocolListBoxUI}}, Path=ProtocolFontSize}"
                     FontFamily="Consolas"
                     HorizontalContentAlignment="Stretch"
                     UseLayoutRounding="True"
                     SnapsToDevicePixels="True"
                     TextOptions.TextFormattingMode="Display"
                     TextOptions.TextRenderingMode="ClearType"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionMode="Single"
                     Focusable="True"
                     IsHitTestVisible="True"
                     PreviewMouseWheel="ProtocolListBox_PreviewMouseWheel"
                     
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     VirtualizingPanel.CacheLength="1"
                     VirtualizingPanel.CacheLengthUnit="Page">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding}">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Setter Property="ContentTemplate"
                                            Value="{StaticResource ProtocolLineTemplate}"/>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                            <Setter Property="ContentTemplate"
                                                    Value="{StaticResource ProtocolGroupTemplate}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>
    </Grid>
</UserControl>