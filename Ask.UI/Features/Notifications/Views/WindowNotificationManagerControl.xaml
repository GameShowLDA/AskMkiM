<UserControl x:Class="Ask.UI.Features.Notifications.Views.WindowNotificationManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:Ask.UI.Features.Notifications.Models"
             xmlns:viewModels="clr-namespace:Ask.UI.Features.Notifications.ViewModels"
             xmlns:local="clr-namespace:Ask.UI.Features.Notifications.Views"
             mc:Ignorable="d"
             IsHitTestVisible="False"
             Focusable="False">
  <UserControl.Resources>
    <local:StringHasTextToVisibilityConverter x:Key="StringHasTextToVisibility" />
    <local:NotificationTypeToGlyphConverter x:Key="NotificationTypeToGlyph" />

    <Style x:Key="NotificationIconPathStyle" TargetType="Path">
      <Setter Property="Fill" Value="{DynamicResource NotificationInfoIconBrush}" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding Type}" Value="{x:Static models:NotificationType.Success}">
          <Setter Property="Fill" Value="{DynamicResource NotificationSuccessIconBrush}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Type}" Value="{x:Static models:NotificationType.Warning}">
          <Setter Property="Fill" Value="{DynamicResource NotificationWarningIconBrush}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Type}" Value="{x:Static models:NotificationType.Error}">
          <Setter Property="Fill" Value="{DynamicResource NotificationErrorIconBrush}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="NotificationTitleTextStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource NotificationTitleBrush}" />
    </Style>

    <Style x:Key="NotificationMessageTextStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource NotificationMessageBrush}" />
    </Style>
  </UserControl.Resources>

  <Grid>
    <ItemsControl ItemsSource="{Binding Items}"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="{Binding HostMargin}"
                  IsHitTestVisible="True">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <StackPanel Orientation="Vertical" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>

      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="{x:Type viewModels:NotificationItemViewModel}">
          <Border x:Name="NotificationCard"
                  Margin="8,0,8,8"
                  MinWidth="320"
                  MaxWidth="420"
                  Padding="18,14,12,14"
                  Opacity="0"
                  Background="{DynamicResource NotificationCardBackgroundBrush}"
                  BorderBrush="{DynamicResource NotificationCardBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  SnapsToDevicePixels="True"
                  Loaded="OnNotificationCardLoaded"
                  Unloaded="OnNotificationCardUnloaded"
                  MouseLeftButtonDown="OnNotificationCardMouseLeftButtonDown">
            <Border.Effect>
              <DropShadowEffect BlurRadius="12"
                                ShadowDepth="0"
                                Color="{DynamicResource NotificationCardShadowColor}"
                                Opacity="1" />
            </Border.Effect>

            <Border.RenderTransform>
              <TransformGroup>
                <ScaleTransform x:Name="CardScaleTransform" ScaleX="0.85" ScaleY="0.85" />
                <TranslateTransform x:Name="CardTranslateTransform" X="0" Y="20" />
              </TransformGroup>
            </Border.RenderTransform>

            <DockPanel MinWidth="320">
              <Viewbox Width="20"
                       Height="20"
                       Margin="0,0,12,0"
                       VerticalAlignment="Top"
                       Stretch="Uniform">
                <Path Data="{Binding Type, Converter={StaticResource NotificationTypeToGlyph}}"
                      Style="{StaticResource NotificationIconPathStyle}" />
              </Viewbox>

              <StackPanel>
                <TextBlock Text="{Binding Title}"
                           Visibility="{Binding Title, Converter={StaticResource StringHasTextToVisibility}}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Style="{StaticResource NotificationTitleTextStyle}" />

                <TextBlock Margin="0,2,0,0"
                           Text="{Binding Message}"
                           Visibility="{Binding Message, Converter={StaticResource StringHasTextToVisibility}}"
                           TextWrapping="Wrap"
                           FontSize="14"
                           Style="{StaticResource NotificationMessageTextStyle}" />
              </StackPanel>
            </DockPanel>

          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </Grid>
</UserControl>
