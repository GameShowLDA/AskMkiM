<UserControl x:Class="Ask.UI.Features.ExecutionSelection.Views.DrawerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Focusable="True"
             KeyboardNavigation.TabNavigation="Cycle"
             KeyboardNavigation.DirectionalNavigation="Contained">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
  </UserControl.Resources>

  <Grid Visibility="{Binding IsOpen, Converter={StaticResource BoolToVisibility}}">
    <Border x:Name="Backdrop"
            Background="{DynamicResource DrawerBackdropBrush}"
            Opacity="0" />

    <Border x:Name="Panel"
            HorizontalAlignment="Right"
            Width="900"
            Margin="0,14,0,14"
            Background="{DynamicResource DrawerPanelBackgroundBrush}"
            BorderBrush="{DynamicResource DrawerBorderBrush}"
            BorderThickness="1,1,0,1"
            CornerRadius="20,0,0,20"
            SnapsToDevicePixels="True">
      <Border.Effect>
        <DropShadowEffect BlurRadius="26"
                          ShadowDepth="0"
                          Color="#000000"
                          Opacity="0.30" />
      </Border.Effect>
      <Border.RenderTransform>
        <TranslateTransform x:Name="PanelTranslate" X="900" />
      </Border.RenderTransform>

      <Grid ClipToBounds="True">
        <Border Height="1"
                VerticalAlignment="Top"
                Margin="22,0,26,0"
                Background="{DynamicResource DrawerAccentBrush}"
                Opacity="0.45" />

        <Grid Margin="18">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="2,0,2,14">
            <TextBlock Foreground="{DynamicResource DrawerTextBrush}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Text="{Binding Title}" />
            <TextBlock Foreground="{DynamicResource DrawerSecondaryTextBrush}"
                       FontSize="13"
                       Margin="0,2,0,0"
                       Text="{Binding Subtitle}" />
          </StackPanel>

          <Grid Grid.Row="1"
                Grid.ColumnSpan="3">
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsCustomContent}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="350" />
              <ColumnDefinition Width="14" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    CornerRadius="14"
                    Background="{DynamicResource DrawerSurfaceBackgroundBrush}"
                    BorderBrush="{DynamicResource DrawerBorderBrush}"
                    BorderThickness="1"
                    Padding="2"
                    SnapsToDevicePixels="True">
              <ListBox x:Name="CommandsList"
                       ItemsSource="{Binding Commands}"
                       SelectedItem="{Binding SelectedCommand, Mode=TwoWay}"
                       Background="Transparent"
                       Foreground="{DynamicResource DrawerTextBrush}"
                       BorderThickness="0"
                       ScrollViewer.CanContentScroll="True"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       VirtualizingStackPanel.IsVirtualizing="True"
                       VirtualizingStackPanel.VirtualizationMode="Recycling"
                       VirtualizingPanel.ScrollUnit="Item"
                       KeyboardNavigation.TabNavigation="None">
                <ListBox.ItemContainerStyle>
                  <Style TargetType="{x:Type ListBoxItem}">
                    <Setter Property="Padding" Value="10,8" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Margin" Value="5,4" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Template">
                      <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                          <Border Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  CornerRadius="11"
                                  Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                          </Border>
                          <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                              <Setter Property="Background" Value="{DynamicResource DrawerItemHoverBrush}" />
                              <Setter Property="BorderBrush" Value="{DynamicResource DrawerBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                              <Setter Property="Background" Value="{DynamicResource DrawerItemSelectedBrush}" />
                              <Setter Property="BorderBrush" Value="{DynamicResource DrawerAccentBrush}" />
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Setter.Value>
                    </Setter>
                    <EventSetter Event="MouseDoubleClick" Handler="OnItemDoubleClick" />
                  </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource DrawerSurfaceBackgroundBrush}"
                    BorderBrush="{DynamicResource DrawerBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14"
                    SnapsToDevicePixels="True">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding SelectedCommandText}"
                           Foreground="{DynamicResource DrawerTextBrush}"
                           FontFamily="Consolas"
                           FontSize="15"
                           LineHeight="22"
                           TextWrapping="Wrap" />
              </ScrollViewer>
            </Border>
          </Grid>

          <Border Grid.Row="1"
                  Grid.ColumnSpan="3"
                  Background="{DynamicResource DrawerSurfaceBackgroundBrush}"
                  BorderBrush="{DynamicResource DrawerBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="14"
                  Padding="12"
                  SnapsToDevicePixels="True"
                  Visibility="{Binding IsCustomContent, Converter={StaticResource BoolToVisibility}}">
            <ContentPresenter Content="{Binding CustomContent}" />
          </Border>
        </Grid>
      </Grid>
    </Border>

  </Grid>
</UserControl>

