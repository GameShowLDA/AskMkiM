<UserControl x:Class="Ask.UI.Controls.ErrorList.ErrorListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Ask.UI.Controls.ErrorList"
             xmlns:Icon="clr-namespace:Ask.UI.Shared.Components.Icons"
             xmlns:DiagnosticsConv="clr-namespace:Ask.Core.Shared.Metadata.Converters;assembly=Ask.Core"
             xmlns:help="clr-namespace:Ask.Support;assembly=Ask.Support"
             MinHeight="28"
             x:Name="root">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI;component/Windows/WpfDocking/Themes/Generic/TabControl.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <local:ErrorCountToHeaderConverter x:Key="ErrorCountConverter"/>
            <DiagnosticsConv:DiagnosticCodeToTagConverter x:Key="DiagnosticCodeToTagConverter"/>
            <local:DiagnosticsCodeLinePairConverter x:Key="DiagnosticsCodeLinePairConverter"/>

            <DataTemplate x:Key="ErrorIconTemplate">
                <Icon:CrossIcon Size="13"
                                CircleColor="{DynamicResource ErrorListErrorIconBrush}"
                                IconStrokeColor="{DynamicResource ErrorListErrorIconForegroundBrush}"/>
            </DataTemplate>

            <DataTemplate x:Key="WarningIconTemplate">
                <Icon:TiangleWarningIcon Size="17"
                                         TriangleColor="{DynamicResource ErrorListWarningIconBrush}"
                                         IconStrokeColor="{DynamicResource ErrorListWarningIconForegroundBrush}"/>
            </DataTemplate>

            <local:IssueIconSelector x:Key="IssueIconSelector"
                                     ErrorTemplate="{StaticResource ErrorIconTemplate}"
                                     WarningTemplate="{StaticResource WarningIconTemplate}" />

            <SolidColorBrush x:Key="PaginationAccentBrush" Color="#6B4BA3"/>
            <SolidColorBrush x:Key="PaginationAccentForegroundBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="PaginationButtonBackgroundBrush" Color="#211A2E"/>
            <SolidColorBrush x:Key="PaginationButtonBorderBrush" Color="#3B2E51"/>
            <SolidColorBrush x:Key="PaginationButtonDisabledBrush" Color="#71667F"/>

            <Style x:Key="PaginationBaseButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                <Setter Property="Background" Value="{StaticResource PaginationButtonBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource PaginationButtonBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="7,2"/>
                <Setter Property="Margin" Value="2,0"/>
                <Setter Property="MinWidth" Value="26"/>
                <Setter Property="Height" Value="21"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="{DynamicResource WinstonRegular}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="RootBorder" Property="Opacity" Value="0.92"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="RootBorder" Property="Opacity" Value="0.82"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{StaticResource PaginationButtonDisabledBrush}"/>
                                    <Setter TargetName="RootBorder" Property="Opacity" Value="0.55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PaginationNavButtonStyle" TargetType="Button" BasedOn="{StaticResource PaginationBaseButtonStyle}">
                <Setter Property="MinWidth" Value="58"/>
                <Setter Property="Padding" Value="7,1"/>
            </Style>

            <Style x:Key="PaginationPageButtonStyle" TargetType="Button" BasedOn="{StaticResource PaginationBaseButtonStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                        <Setter Property="Background" Value="{StaticResource PaginationAccentBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource PaginationAccentBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource PaginationAccentForegroundBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsClickable}" Value="False">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource PaginationButtonDisabledBrush}"/>
                        <Setter Property="Cursor" Value="Arrow"/>
                        <Setter Property="Focusable" Value="False"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource ErrorListBackground}">
        <TabControl x:Name="MainTabControl"
                    TabStripPlacement="Bottom"
                    Style="{StaticResource BottomTabControlStyle}"
                    ItemContainerStyle="{StaticResource BottomTabItemStyle}"
                    Background="{DynamicResource ErrorListBackground}"
                    BorderThickness="0">

            <TabItem x:Name="ErrorsTab" Header="Ошибки">
                <Grid ClipToBounds="True" Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="0"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="8,8,8,6"
                                HorizontalAlignment="Left">

                        <ToggleButton x:Name="WarningButton"
                                      Tag="Warning"
                                      Style="{StaticResource VsFilterButtonStyle}"
                                      Content="0 из 0 предупреждений"
                                      PreviewMouseDown="WarningButton_PreviewMouseDown"
                                      Margin="0,0,6,0"/>

                        <ToggleButton x:Name="ErrorsButton"
                                      Tag="Error"
                                      Style="{StaticResource VsFilterButtonStyle}"
                                      Content="0 из 0 ошибок"
                                      PreviewMouseDown="ErrorsButton_PreviewMouseDown"/>
                    </StackPanel>

                    <DataGrid x:Name="IssuesGrid"
                              Grid.Row="1"
                              MinHeight="0"
                              Margin="0,0,0,34"
                              ItemsSource="{Binding Items, ElementName=root}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              FontFamily="{DynamicResource WinstonRegular}"
                              FontSize="13"
                              Background="{DynamicResource ErrorListBackground}"
                              Foreground="{DynamicResource ForegrounfBrushes}"
                              RowBackground="{DynamicResource ErrorListBackground}"
                              AlternatingRowBackground="{DynamicResource ErrorListBackground}"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              ColumnHeaderHeight="30"
                              RowHeight="25"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.IsDeferredScrollingEnabled="True"
                              MouseDoubleClick="DataGrid_MouseDoubleClick"
                              ScrollViewer.VerticalScrollBarVisibility="Visible">

                        <DataGrid.Resources>
                            <Style x:Key="CellTextTrim" TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="TextWrapping" Value="NoWrap"/>
                            </Style>

                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource ErrorListHeaderBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>

                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                                <Setter Property="Background" Value="{DynamicResource ErrorListBackground}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="5,0"/>
                            </Style>

                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="{DynamicResource ErrorListBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Setter Property="help:HelpProvider.HelpKey"
                                        Value="{Binding Code, Converter={StaticResource DiagnosticCodeToTagConverter}}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ErrorListSelection}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="40" MaxWidth="40" MinWidth="40">
                                <DataGridTemplateColumn.Header>
                                    <TextBlock Text="{Binding Items.Count, ElementName=root}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Padding="10"/>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ContentControl Content="{Binding}"
                                                        ContentTemplateSelector="{StaticResource IssueIconSelector}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Код"
                                                Width="80"
                                                Binding="{Binding Code, Converter={StaticResource DiagnosticCodeToTagConverter}}"
                                                FontFamily="{DynamicResource WinstonLight}"
                                                FontSize="14"/>

                            <DataGridTextColumn Header="Строка"
                                                x:Name="StringsNumber"
                                                Binding="{Binding ., Converter={StaticResource DiagnosticsCodeLinePairConverter}}"
                                                Width="60"
                                                FontFamily="{DynamicResource WinstonLight}"
                                                FontSize="14"/>

                            <DataGridTextColumn Header="Команда"
                                                Width="2*"
                                                Binding="{Binding Command}"
                                                ElementStyle="{StaticResource CellTextTrim}"
                                                FontFamily="{DynamicResource WinstonLight}"
                                                FontSize="14"/>

                            <DataGridTextColumn x:Name="MeasureResult"
                                                Header="Результат измерения"
                                                Binding="{Binding MeasureResult}"
                                                Width="150"
                                                FontFamily="{DynamicResource WinstonLight}"
                                                FontSize="14"
                                                Visibility="Collapsed"/>

                            <DataGridTextColumn Header="Описание"
                                                Width="3*"
                                                Binding="{Binding Description}"
                                                ElementStyle="{StaticResource CellTextTrim}"
                                                FontFamily="{DynamicResource WinstonLight}"
                                                FontSize="14"/>

                            <DataGridTextColumn Header="DEBUG"
                                                Width="*"
                                                x:Name="DebugColumn"
                                                Binding="{Binding DebugInfo}"
                                                ElementStyle="{StaticResource CellTextTrim}"
                                                FontFamily="{DynamicResource WinstonLight}"
                                                FontSize="14"
                                                Visibility="Collapsed"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="1"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Stretch"
                            Height="32"
                            Margin="8,0,8,8"
                            Panel.ZIndex="100"
                            Background="#D0101722"
                            BorderBrush="#4D5B4480"
                            BorderThickness="1"
                            CornerRadius="4">
                        <Grid>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button x:Name="PrevPageButton"
                                        Content="‹ Назад"
                                        Style="{StaticResource PaginationNavButtonStyle}"
                                        Click="PrevPageButton_Click"/>

                                <ItemsControl x:Name="PageButtonsControl"
                                              ItemsSource="{Binding PageButtons, ElementName=root}"
                                              Margin="4,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding DisplayText}"
                                                    Tag="{Binding PageIndex}"
                                                    IsEnabled="{Binding IsClickable}"
                                                    Style="{StaticResource PaginationPageButtonStyle}"
                                                    Click="PageNumberButton_Click"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button x:Name="NextPageButton"
                                        Content="Далее ›"
                                        Style="{StaticResource PaginationNavButtonStyle}"
                                        Click="NextPageButton_Click"/>
                            </StackPanel>

                            <TextBlock x:Name="PageInfoText"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Foreground="{DynamicResource ForegrounfBrushes}"
                                       FontFamily="{DynamicResource WinstonRegular}"
                                       FontSize="12"
                                       Opacity="0.68"
                                       Text="0 из 0"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="BreakpointsTab" Header="Точки остановки">
                <DataGrid x:Name="BreakpointsGrid"
                          ItemsSource="{Binding Breakpoints, ElementName=root}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          Background="{DynamicResource ErrorListBackground}"
                          Foreground="{DynamicResource ForegrounfBrushes}"
                          RowBackground="{DynamicResource ErrorListBackground}"
                          AlternatingRowBackground="{DynamicResource ErrorListBackground}"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          ColumnHeaderHeight="28"
                          RowHeight="25"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.IsDeferredScrollingEnabled="True"
                          MouseDoubleClick="BreakpointsGrid_MouseDoubleClick"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource ErrorListHeaderBackground}"/>
                            <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                            <Setter Property="Background" Value="{DynamicResource ErrorListBackground}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="5,0"/>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{DynamicResource ErrorListBackground}"/>
                            <Setter Property="Foreground" Value="{DynamicResource ForegrounfBrushes}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ErrorListSelection}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundSolidColorBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="80" MinWidth="80" MaxWidth="80" Header="Состояние">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource MarkingCheckBox}"
                                              VerticalAlignment="Center"
                                              Click="BreakpointEnabled_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Номер"
                                            Width="80"
                                            MinWidth="25"
                                            Binding="{Binding CommandNumber}"
                                            FontFamily="{DynamicResource WinstonLight}"
                                            FontSize="14"/>

                        <DataGridTextColumn Header="Мнемоника"
                                            Width="80"
                                            MinWidth="25"
                                            Binding="{Binding Mnemonic}"
                                            FontFamily="{DynamicResource WinstonLight}"
                                            FontSize="14"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>