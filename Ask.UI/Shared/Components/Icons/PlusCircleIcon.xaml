<UserControl x:Class="Ask.UI.Shared.Components.Icons.PlusCircleIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="{Binding Size, ElementName=Root}"
             Height="{Binding Size, ElementName=Root}"
             IsHitTestVisible="False">
  <UserControl.Resources>
    <Storyboard x:Key="MagnetInStoryboard">
      <DoubleAnimation Storyboard.TargetName="IconScale"
                       Storyboard.TargetProperty="ScaleX"
                       To="1.12"
                       Duration="0:0:0.12" />
      <DoubleAnimation Storyboard.TargetName="IconScale"
                       Storyboard.TargetProperty="ScaleY"
                       To="1.12"
                       Duration="0:0:0.12" />
      <DoubleAnimation Storyboard.TargetName="IconTranslate"
                       Storyboard.TargetProperty="X"
                       To="-0.65"
                       Duration="0:0:0.12" />
      <DoubleAnimation Storyboard.TargetName="IconTranslate"
                       Storyboard.TargetProperty="Y"
                       To="-0.65"
                       Duration="0:0:0.12" />
    </Storyboard>

    <Storyboard x:Key="MagnetOutStoryboard">
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IconScale"
                                     Storyboard.TargetProperty="ScaleX">
        <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="0.98"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.00"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IconScale"
                                     Storyboard.TargetProperty="ScaleY">
        <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="0.98"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.00"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimation Storyboard.TargetName="IconTranslate"
                       Storyboard.TargetProperty="X"
                       To="0"
                       Duration="0:0:0.18" />
      <DoubleAnimation Storyboard.TargetName="IconTranslate"
                       Storyboard.TargetProperty="Y"
                       To="0"
                       Duration="0:0:0.18" />
    </Storyboard>
  </UserControl.Resources>

  <Viewbox Stretch="Uniform">
    <Grid Width="24" Height="24"
          RenderTransformOrigin="0.5,0.5">
      <Grid.RenderTransform>
        <TransformGroup>
          <ScaleTransform x:Name="IconScale" ScaleX="1" ScaleY="1"/>
          <TranslateTransform x:Name="IconTranslate" X="0" Y="0"/>
        </TransformGroup>
      </Grid.RenderTransform>
      <Path Fill="{Binding Foreground, ElementName=Root}"
            Data="M12 23a11 11 0 1 0 0-22 11 11 0 0 0 0 22Zm7-11.12a1.5 1.5 0 0 1-1.47 1.52l-4 .07.07 4a1.5 1.5 0 0 1-3 .06l-.07-4-4 .07a1.5 1.5 0 0 1-.06-3l4-.07-.07-4a1.5 1.5 0 1 1 3-.06l.07 4 4-.07A1.5 1.5 0 0 1 19 11.88Z" />
    </Grid>
  </Viewbox>
</UserControl>
