<UserControl x:Class="Ask.UI.Shared.Components.Icons.PowerOffIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="{Binding Size, ElementName=Root}"
             Height="{Binding Size, ElementName=Root}"
             IsHitTestVisible="False">
  <Viewbox Stretch="Uniform">
    <Grid Width="24"
          Height="24">
      <Path Data="M12,4 L12,10.8"
            Stroke="{Binding Foreground, ElementName=Root}"
            StrokeThickness="2.8"
            StrokeStartLineCap="Round"
            StrokeEndLineCap="Round"
            Opacity="0.9" />

      <Path Data="M17.2,6.1 A7.8,7.8 0 1 1 6.8,6.1"
            Stroke="{Binding Foreground, ElementName=Root}"
            StrokeThickness="2.8"
            StrokeStartLineCap="Round"
            StrokeEndLineCap="Round"
            StrokeLineJoin="Round"
            Fill="Transparent"
            Opacity="0.9" />
    </Grid>
  </Viewbox>
</UserControl>
