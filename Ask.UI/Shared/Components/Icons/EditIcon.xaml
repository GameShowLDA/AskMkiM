<UserControl x:Class="Ask.UI.Shared.Components.Icons.EditIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="{Binding Size, ElementName=Root}"
             Height="{Binding Size, ElementName=Root}"
             IsHitTestVisible="False">
  <UserControl.Resources>
    <Storyboard x:Key="WriteStartStoryboard">
      <DoubleAnimation Storyboard.TargetName="PencilTranslate"
                       Storyboard.TargetProperty="X"
                       From="0"
                       To="1.0"
                       Duration="0:0:0.16"
                       AutoReverse="True"
                       RepeatBehavior="Forever" />
      <DoubleAnimation Storyboard.TargetName="PencilTranslate"
                       Storyboard.TargetProperty="Y"
                       From="0"
                       To="-0.5"
                       Duration="0:0:0.16"
                       AutoReverse="True"
                       RepeatBehavior="Forever" />
      <DoubleAnimation Storyboard.TargetName="QuestionScale"
                       Storyboard.TargetProperty="ScaleX"
                       From="0.92"
                       To="1.06"
                       Duration="0:0:0.24"
                       AutoReverse="True"
                       RepeatBehavior="Forever" />
      <DoubleAnimation Storyboard.TargetName="QuestionScale"
                       Storyboard.TargetProperty="ScaleY"
                       From="0.92"
                       To="1.06"
                       Duration="0:0:0.24"
                       AutoReverse="True"
                       RepeatBehavior="Forever" />
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="QuestionGlyph"
                                     Storyboard.TargetProperty="Opacity"
                                     RepeatBehavior="Forever">
        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.75" />
        <LinearDoubleKeyFrame KeyTime="0:0:0.12" Value="1" />
        <LinearDoubleKeyFrame KeyTime="0:0:0.24" Value="0.75" />
      </DoubleAnimationUsingKeyFrames>
    </Storyboard>

    <Storyboard x:Key="WriteStopStoryboard">
      <DoubleAnimation Storyboard.TargetName="PencilTranslate"
                       Storyboard.TargetProperty="X"
                       To="0"
                       Duration="0:0:0.08" />
      <DoubleAnimation Storyboard.TargetName="PencilTranslate"
                       Storyboard.TargetProperty="Y"
                       To="0"
                       Duration="0:0:0.08" />
      <DoubleAnimation Storyboard.TargetName="QuestionGlyph"
                       Storyboard.TargetProperty="Opacity"
                       To="0.0"
                       Duration="0:0:0.08" />
      <DoubleAnimation Storyboard.TargetName="QuestionScale"
                       Storyboard.TargetProperty="ScaleX"
                       To="1.0"
                       Duration="0:0:0.08" />
      <DoubleAnimation Storyboard.TargetName="QuestionScale"
                       Storyboard.TargetProperty="ScaleY"
                       To="1.0"
                       Duration="0:0:0.08" />
    </Storyboard>
  </UserControl.Resources>

  <Viewbox Stretch="Uniform">
    <Grid Width="24" Height="24">
      <TextBlock x:Name="QuestionGlyph"
                 Text="?"
                 FontSize="16"
                 FontWeight="Bold"
                 Foreground="{Binding Foreground, ElementName=Root}"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="0,0,0,0"
                 Opacity="0">
        <TextBlock.RenderTransform>
          <ScaleTransform x:Name="QuestionScale" CenterX="0.5" CenterY="0.5"/>
        </TextBlock.RenderTransform>
      </TextBlock>

      <Grid>
        <Grid.RenderTransform>
          <TranslateTransform x:Name="PencilTranslate" />
        </Grid.RenderTransform>
        <Path Fill="{Binding Foreground, ElementName=Root}"
              Data="M14.5 4.5l 5 5 2.09-2.09a2 2 0 0 0 0-2.82L19.4 2.4a2 2 0 0 0-2.82 0L14.5 4.5Z M2.25 21.13l 1.68-5.88a1 1 0 0 1 .25-.43L13 6l5 5-8.82 8.82a1 1 0 0 1-.43.25l-5.88 1.68a.5.5 0 0 1-.62-.62Z" />
      </Grid>
    </Grid>
  </Viewbox>
</UserControl>
