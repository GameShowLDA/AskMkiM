<UserControl x:Class="Ask.UI.Shared.Components.Icons.CutIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="{Binding Size, ElementName=Root}"
             Height="{Binding Size, ElementName=Root}"
             IsHitTestVisible="False">
  <UserControl.Resources>
    <StreamGeometry x:Key="SemiIconScissorsBase">
      M13.29 20.09 12 17.86l-1.3 2.25C10 21.5 8.42 23 6.5 23a4.5 4.5 0 1 1 2.62-8.16l.57-.98L6 6.46a4 4 0 0 1 .65-4.84c.4-.4 1.03-.2 1.3.29l6.93 12.93A4.5 4.5 0 1 1 17.5 23c-1.93 0-3.5-1.5-4.21-2.91ZM6.5 17a1.5 1.5 0 0 1 1.19 2.42A1.5 1.5 0 1 1 6.5 17Zm9.93 2.55A1.5 1.5 0 0 0 19 18.5a1.5 1.5 0 1 0-2.57 1.05ZM12 15a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z
    </StreamGeometry>

    <StreamGeometry x:Key="SemiIconScissorsUpperBlade">
      M15.37 12.03 18 6.46a4 4 0 0 0-.62-4.81c-.4-.41-1.06-.21-1.31.3l-3.01 6.08 2.3 4Z
    </StreamGeometry>

    <Storyboard x:Key="CutInStoryboard">
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LowerBladeRotate"
                                     Storyboard.TargetProperty="Angle">
        <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="-7" />
        <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="0" />
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="UpperBladeRotate"
                                     Storyboard.TargetProperty="Angle">
        <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="12" />
        <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="0" />
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IconTranslate"
                       Storyboard.TargetProperty="Y"
                       Duration="0:0:0.18">
        <EasingDoubleKeyFrame KeyTime="0:0:0.06" Value="-0.6" />
        <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="0" />
      </DoubleAnimationUsingKeyFrames>
    </Storyboard>

    <Storyboard x:Key="CutOutStoryboard">
      <DoubleAnimation Storyboard.TargetName="LowerBladeRotate"
                       Storyboard.TargetProperty="Angle"
                       To="0"
                       Duration="0:0:0.16" />
      <DoubleAnimation Storyboard.TargetName="UpperBladeRotate"
                       Storyboard.TargetProperty="Angle"
                       To="0"
                       Duration="0:0:0.16" />
      <DoubleAnimation Storyboard.TargetName="IconTranslate"
                       Storyboard.TargetProperty="Y"
                       To="0"
                       Duration="0:0:0.16" />
    </Storyboard>
  </UserControl.Resources>
  <Viewbox Stretch="Uniform">
    <Grid Width="24"
          Height="24"
          RenderTransformOrigin="0.5,0.5">
      <Grid.RenderTransform>
        <TransformGroup>
          <TranslateTransform x:Name="IconTranslate"
                              Y="0" />
        </TransformGroup>
      </Grid.RenderTransform>

      <Grid RenderTransformOrigin="0.5,0.58">
        <Grid.RenderTransform>
          <RotateTransform x:Name="LowerBladeRotate"
                           Angle="0" />
        </Grid.RenderTransform>
        <Path Fill="{Binding Foreground, ElementName=Root}"
              Data="{StaticResource SemiIconScissorsBase}" />
      </Grid>

      <Grid RenderTransformOrigin="0.49,0.56">
        <Grid.RenderTransform>
          <RotateTransform x:Name="UpperBladeRotate"
                           Angle="0" />
        </Grid.RenderTransform>
        <Path Fill="{Binding Foreground, ElementName=Root}"
              Data="{StaticResource SemiIconScissorsUpperBlade}" />
      </Grid>
    </Grid>
  </Viewbox>
</UserControl>
