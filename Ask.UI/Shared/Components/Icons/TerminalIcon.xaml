<UserControl x:Class="Ask.UI.Shared.Components.Icons.TerminalIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="{Binding Size, ElementName=Root}"
             Height="{Binding Size, ElementName=Root}"
             IsHitTestVisible="False">
  <UserControl.Resources>
    <StreamGeometry x:Key="SemiIconTerminal">
      M2 5a3 3 0 0 1 3-3h14a3 3 0 0 1 3 3v14a3 3 0 0 1-3 3H5a3 3 0 0 1-3-3V5Zm10 11a1 1 0 0 1 1-1h5a1 1 0 1 1 0 2h-5a1 1 0 0 1-1-1ZM7.7 6.3a1 1 0 0 0-1.4 1.4l3.36 3.37-3.44 4.3a1 1 0 0 0 1.56 1.25l4-5a1 1 0 0 0-.07-1.33l-4-4Z
    </StreamGeometry>

    <Storyboard x:Key="HoverInStoryboard">
      <DoubleAnimation Storyboard.TargetName="IconScale"
                       Storyboard.TargetProperty="ScaleX"
                       To="1.08"
                       Duration="0:0:0.12" />
      <DoubleAnimation Storyboard.TargetName="IconScale"
                       Storyboard.TargetProperty="ScaleY"
                       To="1.08"
                       Duration="0:0:0.12" />
      <DoubleAnimation Storyboard.TargetName="IconTranslate"
                       Storyboard.TargetProperty="Y"
                       To="-0.4"
                       Duration="0:0:0.12" />
    </Storyboard>

    <Storyboard x:Key="HoverOutStoryboard">
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IconScale"
                                     Storyboard.TargetProperty="ScaleX">
        <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="0.99" />
        <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1" />
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IconScale"
                                     Storyboard.TargetProperty="ScaleY">
        <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="0.99" />
        <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1" />
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimation Storyboard.TargetName="IconTranslate"
                       Storyboard.TargetProperty="Y"
                       To="0"
                       Duration="0:0:0.18" />
    </Storyboard>
  </UserControl.Resources>

  <Viewbox Stretch="Uniform">
    <Grid Width="24"
          Height="24"
          RenderTransformOrigin="0.5,0.5">
      <Grid.RenderTransform>
        <TransformGroup>
          <ScaleTransform x:Name="IconScale"
                          ScaleX="1"
                          ScaleY="1" />
          <TranslateTransform x:Name="IconTranslate"
                              Y="0" />
        </TransformGroup>
      </Grid.RenderTransform>
      <Path Fill="{Binding Foreground, ElementName=Root}"
            Data="{StaticResource SemiIconTerminal}" />
    </Grid>
  </Viewbox>
</UserControl>
