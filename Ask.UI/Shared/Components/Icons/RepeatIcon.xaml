<UserControl x:Class="Ask.UI.Shared.Components.Icons.RepeatIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root"
             Width="{Binding Size, ElementName=root}"
             Height="{Binding Size, ElementName=root}"
             Cursor="Hand"
             >
    <Viewbox Stretch="Uniform">
        <Canvas Width="100" Height="100">

            <!-- Дуга (сместили немного для баланса) -->
            <Path Stroke="#3d7dab"
                  StrokeThickness="20"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Fill="Transparent"
                  Data="M25,65 A35,35 0 1 1 70,30" Canvas.Left="12.5" Canvas.Top="17.75"/>

            <!-- Большая стрелка, более направленная вниз -->
            <Path Fill="#3d7dab"
                  Data="M70,30 L83,50 L96,30 Z" Canvas.Left="55.5" Canvas.Top="48.152" Height="30" Stretch="Fill" Width="50" HorizontalAlignment="Center" VerticalAlignment="Center"/>

        </Canvas>
    </Viewbox>
</UserControl>

