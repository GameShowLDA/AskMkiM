<UserControl x:Class="Ask.UI.Shared.Components.Icons.PauseIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Ask.UI.Shared.Components.Icons"
             mc:Ignorable="d" 
             Cursor="Hand"
             Width="{Binding Size, ElementName=root}"
             Height="{Binding Size, ElementName=root}">
    <Viewbox Stretch="Fill">
        <Canvas Width="100" Height="100">
            <Rectangle Width="20" Height="60" Fill="#D6D6D6" RadiusX="2" RadiusY="2" Canvas.Left="25" Canvas.Top="20"/>
            <Rectangle Width="20" Height="60" Fill="#D6D6D6" RadiusX="2" RadiusY="2" Canvas.Left="55" Canvas.Top="20"/>
        </Canvas>
    </Viewbox>
</UserControl>

