<UserControl x:Class="Ask.UI.Shared.Components.Icons.HelpCircleIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="{Binding Size, ElementName=Root}"
             Height="{Binding Size, ElementName=Root}"
             IsHitTestVisible="False">
  <UserControl.Resources>
    <StreamGeometry x:Key="SemiIconHelpCircle">
      M12 23a11 11 0 1 0 0-22 11 11 0 0 0 0 22Zm-.17-8.4c-.86 0-1.3-.53-1.3-1.23 0-1.05.53-1.72 1.74-2.64l.06-.05c.83-.62 1.4-1.06 1.4-1.85 0-.9-.83-1.4-1.76-1.4-.76 0-1.34.28-1.8.87-.33.34-.6.53-1.05.53C8.38 8.83 8 8.3 8 7.7c0-.6.34-1.22.88-1.68A5.15 5.15 0 0 1 12.28 5c2.71 0 4.62 1.34 4.62 3.64 0 1.68-1 2.5-2.2 3.31-.8.59-1.17.93-1.48 1.62-.33.6-.58 1.04-1.4 1.04Zm-.02 4.17c-.94 0-1.71-.6-1.71-1.54 0-.94.77-1.55 1.7-1.55.95 0 1.7.6 1.7 1.55 0 .93-.75 1.54-1.7 1.54Z
    </StreamGeometry>

    <Storyboard x:Key="HoverInStoryboard">
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="HelpScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     RepeatBehavior="Forever">
        <EasingDoubleKeyFrame KeyTime="0:0:0.00" Value="1.0" />
        <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="1.1" />
        <EasingDoubleKeyFrame KeyTime="0:0:0.45" Value="1.0" />
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="HelpScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     RepeatBehavior="Forever">
        <EasingDoubleKeyFrame KeyTime="0:0:0.00" Value="1.0" />
        <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="1.1" />
        <EasingDoubleKeyFrame KeyTime="0:0:0.45" Value="1.0" />
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="HelpTranslate"
                                     Storyboard.TargetProperty="Y"
                                     RepeatBehavior="Forever">
        <EasingDoubleKeyFrame KeyTime="0:0:0.00" Value="0.0" />
        <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="-0.35" />
        <EasingDoubleKeyFrame KeyTime="0:0:0.45" Value="0.0" />
      </DoubleAnimationUsingKeyFrames>
    </Storyboard>

    <Storyboard x:Key="HoverOutStoryboard">
      <DoubleAnimation Storyboard.TargetName="HelpScale"
                       Storyboard.TargetProperty="ScaleX"
                       To="1"
                       Duration="0:0:0.2" />
      <DoubleAnimation Storyboard.TargetName="HelpScale"
                       Storyboard.TargetProperty="ScaleY"
                       To="1"
                       Duration="0:0:0.2" />
      <DoubleAnimation Storyboard.TargetName="HelpTranslate"
                       Storyboard.TargetProperty="Y"
                       To="0"
                       Duration="0:0:0.2" />
    </Storyboard>
  </UserControl.Resources>

  <Viewbox Stretch="Uniform">
    <Grid Width="24"
          Height="24"
          RenderTransformOrigin="0.5,0.5">
      <Grid.RenderTransform>
        <TransformGroup>
          <ScaleTransform x:Name="HelpScale"
                          ScaleX="1"
                          ScaleY="1" />
          <TranslateTransform x:Name="HelpTranslate"
                              Y="0" />
        </TransformGroup>
      </Grid.RenderTransform>
      <Path Fill="{Binding Foreground, ElementName=Root}"
            Data="{StaticResource SemiIconHelpCircle}" />
    </Grid>
  </Viewbox>
</UserControl>
