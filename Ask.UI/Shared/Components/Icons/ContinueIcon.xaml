<UserControl x:Class="Ask.UI.Shared.Components.Icons.ContinueIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Ask.UI.Shared.Components.Icons"
             x:Name="root"
             mc:Ignorable="d" 
             Width="{Binding Size, ElementName=root}"
             Height="{Binding Size, ElementName=root}"
             Cursor="Hand">
    <Viewbox Stretch="Fill">
        <Canvas Width="100" Height="100">
            <Polygon Points="20,20 20,80 80,50"
                     Stroke="#78c65c"
                     StrokeThickness="8"
                     Fill="Transparent"/>
        </Canvas>
    </Viewbox>
</UserControl>

