<Window x:Class="Mode.Base.SearchDevices.SearchDevices"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Mode.Base.SearchDevices"
        mc:Ignorable="d"
        Height="100" 
        Background="Transparent"
        Width="500"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        >
    <Border CornerRadius="20" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Поиск устройств... Пожалуйста подождите!" Grid.Row="0" FontSize="20" VerticalAlignment="Center" Padding="10,5,0,0"/>
            <ProgressBar Grid.Row="1" Padding="10" Margin="10" IsIndeterminate="True"/>
            <TextBlock  Name="header" Grid.Row="2" FontSize="12" VerticalAlignment="Center" Padding="10,0,0,5"/>
        </Grid>
    </Border>
</Window>