             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mode.Metrology.PI"
             xmlns:Protocol="clr-namespace:UI.Controls.Protocol;assembly=UI"
             xmlns:Custom="clr-namespace:UI.Components;assembly=UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
