<UserControl x:Class="Mode.Device.DBC.DBCManager"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mode.Device.DBC"
             xmlns:Components="clr-namespace:UI.Components;assembly=UI"
             xmlns:Protocol="clr-namespace:UI.Components.ProtocolListBox;assembly=UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid  Background="{StaticResource SecondarySolidColorBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Name="ManagerChassisSelectionControl" Margin="5" Grid.Row="0" Background="{StaticResource ActiveBorderSolidColorBrush}" CornerRadius="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock TextWrapping="Wrap" TextTrimming="None" Text="УКШ" FontSize="20" Foreground="{StaticResource ForegroundSolidColorBrush}" Margin="0,5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Components:ChoiceDevice x:Name="ChassisData" Grid.Row="1" Height="40" SelectedDisplayText="Выберите УКШ"/>
                    </Grid>
                </Border>

                <Button Visibility="Collapsed" x:Name="Connect" Grid.Row="1" Height="50" Style="{StaticResource ConfigButtonStyle}" Margin="5" Content="Соединить" Background="{StaticResource GreenColorSolidColorBrush}" PreviewMouseDown="Connect_PreviewMouseDown"/>
                <Button Visibility="Collapsed" x:Name="Disconnect" Grid.Row="2" Height="50" Style="{StaticResource ConfigButtonStyle}" Margin="5" Content="Разорвать" Background="{StaticResource RedColorSolidColorBrush}" PreviewMouseDown="Disconnect_PreviewMouseDown"/>
                <Button Visibility="Collapsed" x:Name="Reset" Grid.Row="3" Height="50" Style="{StaticResource ConfigButtonStyle}" Margin="5" Content="Сброс" Background="{StaticResource RedColorSolidColorBrush}" PreviewMouseDown="Reset_PreviewMouseDown"/>

            </Grid>

            <Grid Grid.Column="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <WrapPanel Name="buttonPanel" HorizontalAlignment="Center" VerticalAlignment="Top" />
                    </ScrollViewer>

                    <Border Grid.Column="1"  Margin="10" Background="{StaticResource SecondarySolidColorBrush}" CornerRadius="15">
                        <Protocol:ProtocolListBoxUI Name="Protocol"/>
                    </Border>

                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
