<UserControl x:Class="Mode.ServicesTest.UKSH.UkshControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:InvokeConrols="clr-namespace:UI.Components.Invoke.InvokeRichTextBox;assembly=UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Border CornerRadius="0,0,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <StackPanel Margin="20" Grid.Column="0" VerticalAlignment="Top">

                <!-- Блок "Номер" + ComboBox -->
                <Border Style="{StaticResource ConfigAdditionalBlockStyle}" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Номер:"
                                   FontSize="20"
                                   VerticalAlignment="Center"
                                   Margin="10,0" 
                                   Padding="10,0,0,0"
                                   Foreground="{StaticResource ForegroundSolidColorBrush}" />

                        <ComboBox x:Name="CmbUkshInit"
                                  Grid.Column="1"
                                  Margin="10"
                                  Height="30"
                                  Width="120"
                                  Style="{StaticResource CustomComboBoxStyle}"
                                  SelectionChanged="CmbUkshInit_SelectionChanged" />
                    </Grid>
                </Border>

                <!-- Кнопка "Сброс устройства" -->
                <Button x:Name="BtnUkshReset"
                        Content="Сброс устройства"
                        Width="200"
                        Height="35"
                        Margin="0,0,0,15"
                        Style="{StaticResource MetrologyButtonStyle}"
                        PreviewMouseDown="BtnUkshReset_PreviewMouseDown"
                        IsEnabled="False" />

                <!-- Кнопка "ЗАПУСТИТЬ" -->
                <Button x:Name="BtnUkshStart"
                        Content="ЗАПУСТИТЬ"
                        Width="200"
                        Height="35"
                        Margin="0,0,0,15"
                        Style="{StaticResource MetrologyButtonStyle}"
                        IsEnabled="False"
                        PreviewMouseDown="BtnUkshStart_PreviewMouseDown" />

                 <!-- Поле поиска -->
 <TextBox x:Name="TbSearchRelays"
     Margin="0,0,0,10"
     Height="30"
     TextChanged="TbSearchRelays_TextChanged"
     IsEnabled="False" />

 <!-- Список реле (кнопок) -->
 <ScrollViewer VerticalScrollBarVisibility="Auto"
     HorizontalScrollBarVisibility="Disabled"
     MaxHeight="250">
     <ItemsControl x:Name="IcRelays"
         IsEnabled="False">
         <ItemsControl.ItemsPanel>
             <ItemsPanelTemplate>
                 <WrapPanel Orientation="Horizontal"/>
             </ItemsPanelTemplate>
         </ItemsControl.ItemsPanel>

         <ItemsControl.ItemTemplate>
             <DataTemplate>
                 <Grid Margin="2">
                     <!-- Кнопка для конкретного реле -->
                     <Button Width="80" Height="30"
     PreviewMouseDown="BtnRelay_PreviewMouseDown">

                         <!-- Стилизация кнопки: по умолчанию светло-серая, 
      при IsOn = true — красная. -->
                         <Button.Style>
                             <Style TargetType="Button">
                                 <Setter Property="Background" Value="LightGray"/>
                                 <Style.Triggers>
                                     <DataTrigger Binding="{Binding IsOn}" Value="True">
                                         <Setter Property="Background" Value="Red"/>
                                     </DataTrigger>
                                 </Style.Triggers>
                             </Style>
                         </Button.Style>

                         <!-- Текст на кнопке = номер реле -->
                         <Button.Content>
                             <TextBlock Text="{Binding RelayNum}" />
                         </Button.Content>
                     </Button>
                 </Grid>
             </DataTemplate>
         </ItemsControl.ItemTemplate>
     </ItemsControl>
 </ScrollViewer>
            </StackPanel>

            <!-- Правая панель (лог InvokeRichTextBoxUI) -->
            <Grid Grid.Column="1">
                <InvokeConrols:InvokeRichTextBoxUI 
                    x:Name="protocolTextBox"
                    Margin="10"
                    IsReadOnly="True" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
