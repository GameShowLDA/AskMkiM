<UserControl x:Class="Mode.ServicesTest.MKR.MkrControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Mode.ServicesTest.MKR"
             xmlns:InvokeConrols="clr-namespace:UI.Components.Invoke.InvokeRichTextBox;assembly=UI"
             xmlns:Protocol="clr-namespace:UI.Controls.ProtocolNew;assembly=UI"
             mc:Ignorable="d"
             d:DesignHeight="470" d:DesignWidth="800">

    <Grid>
        <!-- ProtocolUI строит свою панель и ожидает ContentView -->
        <Protocol:ProtocolUI x:Name="ProtocolSelfCheckControl"
                             Header="Сервисный режим БК">
            <Protocol:ProtocolUI.ContentView>
                <!-- Вот здесь единственный дочерний элемент: наш MkrContent -->
                <local:MkrContent/>
            </Protocol:ProtocolUI.ContentView>
        </Protocol:ProtocolUI>
    </Grid>
</UserControl>