<UserControl x:Class="Mode.ServicesTest.MKR.MkrContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Width="250"
             d:DesignHeight="470"
             d:DesignWidth="250">

    <Border CornerRadius="0,0,0,0" Padding="5">
        <Grid>
            <StackPanel Margin="10" VerticalAlignment="Top">

                <!-- Сокращённый заголовок -->
                <Border Style="{StaticResource ConfigAdditionalBlockStyle}" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Блок a.b:"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Margin="5,0"
                                   Foreground="{StaticResource ForegroundSolidColorBrush}" />

                        <ComboBox x:Name="SerialNumComboBox"
                                  Grid.Column="1"
                                  Margin="5"
                                  Height="30"
                                  Width="100"
                                  Style="{StaticResource CustomComboBoxStyle}"
                                  ItemsSource="{Binding ComboBoxItems}"
                                  SelectedItem="{Binding SelectedComboBoxItem, Mode=TwoWay}"
                                  SelectionChanged="SerialNumComboBox_SelectionChanged"/>
                    </Grid>
                </Border>

                <!-- Короткий текст кнопки -->
                <Button x:Name="BtnMkrReset"
                        Content="Сброс"
                        Width="120"
                        Height="30"
                        Margin="0,0,0,15"
                        Style="{StaticResource MetrologyButtonStyle}"
                        PreviewMouseDown="BtnMkrReset_PreviewMouseDown"
                        IsEnabled="False"/>

                <!-- Сокращённый заголовок группы шин -->
                <GroupBox Header="Группы шин AB"
                          Foreground="White"
                          Margin="0,0,0,10"
                          FontSize="14">
                    <WrapPanel Margin="5">
                        <RadioButton Content="1"
                                     Foreground="White"
                                     GroupName="TireRb"
                                     Name="RbAB1"
                                     Margin="3"
                                     IsEnabled="False"
                                     PreviewMouseDown="RadioButton_PreviewMouseDown"/>
                        <RadioButton Content="2"
                                     Foreground="White"
                                     GroupName="TireRb"
                                     Name="RbAB2"
                                     Margin="3"
                                     IsEnabled="False"
                                     PreviewMouseDown="RadioButton_PreviewMouseDown"/>
                        <RadioButton Content="3"
                                     Foreground="White"
                                     GroupName="TireRb"
                                     Name="RbAB3"
                                     Margin="3"
                                     IsEnabled="False"
                                     PreviewMouseDown="RadioButton_PreviewMouseDown"/>
                        <RadioButton Content="4"
                                     Foreground="White"
                                     GroupName="TireRb"
                                     Name="RbAB4"
                                     Margin="3"
                                     IsEnabled="False"
                                     PreviewMouseDown="RadioButton_PreviewMouseDown"/>
                        <RadioButton Content="Откл."
                                     Foreground="White"
                                     GroupName="TireRb"
                                     Name="RbOff"
                                     Margin="3"
                                     IsChecked="True"
                                     IsEnabled="False"
                                     PreviewMouseDown="RadioButton_PreviewMouseDown"/>
                    </WrapPanel>
                </GroupBox>

                <!-- Сокращённый текст для поиска -->
                <GroupBox Header="Поиск" Foreground="White" Margin="0,0,0,10" FontSize="14">
                    <TextBox x:Name="SearchBox"
                             Margin="5,0"
                             Height="20"
                             TextChanged="SearchBox_TextChanged"
                             IsEnabled="True"/>
                </GroupBox>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="180"
                              Margin="0,0,0,10">
                    <ItemsControl x:Name="PointsListBox">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2">
                                    <Button Width="60"
                                            Height="24"
                                            PreviewMouseDown="Point_PreviewMouseDown"
                                            Style="{StaticResource MkrPointStyle}">
                                        <Button.ContextMenu>
                                            <ContextMenu StaysOpen="True"
                                                         MouseLeave="ContextMenu_MouseLeave"
                                                         Background="#303843"
                                                         BorderBrush="#303843">
                                                <MenuItem Header="Шина A">
                                                    <MenuItem.Icon>
                                                        <CheckBox IsChecked="{Binding A}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Шина B">
                                                    <MenuItem.Icon>
                                                        <CheckBox IsChecked="{Binding B}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Легенда с минимальными отступами -->
                <GroupBox Header="Легенда" Foreground="White" Margin="0,0,0,0" FontSize="14">
                    <StackPanel Margin="5">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Rectangle Width="16" Height="16" Stroke="Black" StrokeThickness="1" Fill="Aqua"/>
                            <TextBlock Text=" – к шине A" Margin="4,0,0,0" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Rectangle Width="16" Height="16" Stroke="Black" StrokeThickness="1" Fill="Plum"/>
                            <TextBlock Text=" – к шине B" Margin="4,0,0,0" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <Rectangle Width="16" Height="16" Stroke="Black" StrokeThickness="1" Fill="DarkViolet"/>
                            <TextBlock Text=" – к A и B" Margin="4,0,0,0" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>