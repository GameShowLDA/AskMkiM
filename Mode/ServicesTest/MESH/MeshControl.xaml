<UserControl x:Class="Mode.ServicesTest.MESH.MeshControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:InvokeConrols="clr-namespace:UI.Components.Invoke.InvokeRichTextBox;assembly=UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Border CornerRadius="0,0,0,0">
        <Grid>
            <!-- Две колонки: левая (управление), правая (лог) -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Левая часть (StackPanel) -->
            <StackPanel Margin="20" Grid.Column="0" VerticalAlignment="Top">

                <!-- Блок "Номер:" + ComboBox (связанный с ViewModel.ComboBoxItems) -->
                <Border Style="{StaticResource ConfigAdditionalBlockStyle}" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Номер:"
                                   FontSize="20"
                                   VerticalAlignment="Center"
                                   Margin="10,0"
                                   Padding="10,0,0,0"
                                   Foreground="{StaticResource ForegroundSolidColorBrush}" />

                        <ComboBox x:Name="CmbMeshDevice"
                                  Grid.Column="1"
                                  Margin="10"
                                  Height="30"
                                  Width="180"
                                  Style="{StaticResource CustomComboBoxStyle}"
                                  ItemsSource="{Binding ComboBoxItems}"
                                  SelectedItem="{Binding SelectedComboBoxItem, Mode=TwoWay}"
                                  SelectionChanged="CmbMeshDevice_SelectionChanged"/>
                    </Grid>
                </Border>

                <!-- Кнопка "Включение питания" -->
                <Button x:Name="BtnMeshPower"
                        Content="ЗАПУСТИТЬ"
                        Width="310"
                        Height="35"
                        Margin="0,0,0,15"
                        Style="{StaticResource MetrologyButtonStyle}"
                        PreviewMouseDown="BtnMeshPower_PreviewMouseDown"
                        IsEnabled="False" />
            </StackPanel>

            <!-- Правая колонка (InvokeRichTextBoxUI для лога) -->
            <Grid Grid.Column="1">
                <InvokeConrols:InvokeRichTextBoxUI 
                    x:Name="protocolTextBox"
                    Margin="10"
                    IsReadOnly="True" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
