<UserControl x:Class="Mode.Settings.SettingsProgramm.SettingsProgrammControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mode.Settings.SettingsProgramm"
             xmlns:Components ="clr-namespace:UI.Components;assembly=UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="{StaticResource SecondarySolidColorBrush}" CornerRadius="20" Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock 
                Text="Параметры" 
                FontSize="22" 
                Padding="15,10"
                Foreground="{StaticResource ForegroundSolidColorBrush}"
                FontFamily="{StaticResource WinstonBold}"
                VerticalAlignment="Center"  
                Grid.Row="0"/>

            <!--Протокол-->
            <Border Grid.Row="2" Background="{StaticResource IsCheckedColorSolidColorBrush80}" Margin="15,10" CornerRadius="15" BorderThickness="1" BorderBrush="{StaticResource ForegroundSolidColorBrush60}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock 
                        Text="Протокол" 
                        FontSize="18" 
                        Padding="10,10"
                        Foreground="{StaticResource ForegroundSolidColorBrush}"
                        FontFamily="{StaticResource WinstonMedium}"
                        VerticalAlignment="Center"  
                        Grid.Row="0"/>

                    <WrapPanel Orientation="Horizontal" Grid.Row="1">

                        <Components:SettingsCard
                            Title="Отображение оборудования"
                            Description="Отображение информации выполняемых устройствами операций. В режиме отключения выводятся лишь измеренные значения. Ошибки показываются независимо от настройки."
                            IsChecked="{Binding IdleMode, Mode=TwoWay}" 
                            Margin="10,10"
                            VerticalAlignment="Top"
                            />

                        <Components:SettingsCard 
                            Title="Вывод времени операции" 
                            Description="Показывает, сколько времени прошло с момента запуска на каждом шаге выполнения."
                            IsChecked="{Binding IdleMode, Mode=TwoWay}" 
                            Margin="10,10"
                            VerticalAlignment="Top"
                            />

                        <Components:SettingsCard
                            Title="Сохранение протокола"
                            Description="Автоматически сохраняет протокол каждого запуска. Имя файла содержит дату, время и название выполняемых действий."
                            IsChecked="{Binding IdleMode, Mode=TwoWay}" 
                            Margin="10,10"
                            VerticalAlignment="Top"
                            />

                        <Components:SettingsCard
                            Title="Печать протокола"
                            Description="По завершении выполнения отображает диалог выбора принтера для печати итогового протокола."
                            IsChecked="{Binding IdleMode, Mode=TwoWay}" 
                            Margin="10,10"
                            VerticalAlignment="Top"
                            />
                    </WrapPanel>

                </Grid>
            </Border>

        </Grid>
    </Border>
</UserControl>
