<UserControl x:Class="Mode.Settings.MeasurementError.MeasurementErrorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mode.Settings.MeasurementError"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock 
             Text="Погрешности режимов" 
             FontSize="20" 
             Padding="15,5,0,15" 
             Style="{StaticResource ConfigTextBlockHeaderStyle}"
             VerticalAlignment="Center" 
             />
            <GroupBox Grid.Row="1" BorderThickness="0">

                <Grid >

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="10,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock 
                         Text="Погрешность режима КС:"
                         FontSize="18"
                         Foreground="{StaticResource ForegroundSolidColorBrush}" 
                         Grid.Column="0"/>

                        <Grid Grid.Column="1"  Margin="10,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15"  Grid.Column="0">
                                <TextBox 
                                 Name="percentErrorKC" 
                                 FontSize="18" 
                                 Width="40"  
                                 Background="Transparent" 
                                 Foreground="{StaticResource ForegroundSolidColorBrush}" 
                                 BorderThickness="0"  
                                 PreviewTextInput="TextBox_PreviewTextInput"
                                 Text="1" 
                                 TextChanged="TextChanged"/>
                            </Border>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15" Grid.Column="1">
                                <TextBlock 
                                 Text="%" 
                                 FontSize="18" 
                                 Foreground="{StaticResource ForegroundSolidColorBrush}" 
                                 HorizontalAlignment="Right" 
                                 VerticalAlignment="Center" 
                                 Padding="5,0,0,0"/>
                            </Border>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15"  Grid.Column="2">
                                <TextBox 
                                 Name="absoluteErrorKC" 
                                 FontSize="18" 
                                 Width="40" 
                                 Background="Transparent" 
                                 Foreground="{StaticResource ForegroundSolidColorBrush}"   
                                 BorderThickness="0" 
                                 PreviewTextInput="TextBox_PreviewTextInput" 
                                 Text="5" 
                                 TextChanged="TextChanged"
                             />
                            </Border>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15"  Grid.Column="3">
                                <TextBlock 
                                 Text="Ом" 
                                 FontSize="18" 
                                 Foreground="{StaticResource ForegroundSolidColorBrush}"  
                                 Padding="5,0,0,0"
                                 />
                            </Border>

                        </Grid>
                    </Grid>

                    <Grid Grid.Row="1" Margin="10,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock 
                         Text="Погрешность режима ИЕ:"
                         FontSize="18"
                         Foreground="{StaticResource ForegroundSolidColorBrush}" 
                         Grid.Column="0"/>

                        <Grid Grid.Column="1"  Margin="10,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15"  Grid.Column="0">
                                <TextBox 
                             Name="percentErrorIE" 
                             FontSize="18" 
                             Width="40"  
                             Background="Transparent" 
                             Foreground="{StaticResource ForegroundSolidColorBrush}" 
                             BorderThickness="0"  
                             PreviewTextInput="TextBox_PreviewTextInput" 
                             Text="1" 
                             TextChanged="TextChanged"/>
                            </Border>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15" Grid.Column="1">
                                <TextBlock 
                              Text="%" 
                              FontSize="18" 
                              Foreground="{StaticResource ForegroundSolidColorBrush}" 
                              HorizontalAlignment="Right" 
                              VerticalAlignment="Center" 
                              Padding="5,0,0,0"/>
                            </Border>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15"  Grid.Column="2">
                                <TextBox 
                             Name="absoluteErrorIE" 
                             FontSize="18" 
                             Width="40" 
                             Background="Transparent" 
                             Foreground="{StaticResource ForegroundSolidColorBrush}"   
                             BorderThickness="0" 
                             PreviewTextInput="TextBox_PreviewTextInput" 
                             Text="0.5" 
                             TextChanged="TextChanged"
                             />
                            </Border>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15"  Grid.Column="3">
                                <TextBlock 
                              Text="пкФ" 
                              FontSize="18" 
                              Foreground="{StaticResource ForegroundSolidColorBrush}"  
                              Padding="5,0,0,0"
                              />
                            </Border>

                        </Grid>
                    </Grid>

                    <Grid Grid.Row="2" Margin="10,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock 
                         Text="Погрешность режима ПР:"
                         FontSize="18"
                         Foreground="{StaticResource ForegroundSolidColorBrush}" 
                         Grid.Column="0"/>

                        <Grid Grid.Column="1"  Margin="10,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15"  Grid.Column="0">
                                <TextBox 
                                 Name="percentErrorPR" 
                                 FontSize="18" 
                                 Width="40"  
                                 Background="Transparent" 
                                 Foreground="{StaticResource ForegroundSolidColorBrush}" 
                                 BorderThickness="0"  
                                 PreviewTextInput="TextBox_PreviewTextInput" 
                                 Text="1" 
                                 TextChanged="TextChanged"/>
                            </Border>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15" Grid.Column="1">
                                <TextBlock 
                                 Text="%" 
                                 FontSize="18" 
                                 Foreground="{StaticResource ForegroundSolidColorBrush}" 
                                 HorizontalAlignment="Right" 
                                 VerticalAlignment="Center" 
                                 Padding="5,0,0,0"/>
                            </Border>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15"  Grid.Column="2">
                                <TextBox 
                                 Name="absoluteErrorPR" 
                                 FontSize="18" 
                                 Width="40" 
                                 Background="Transparent" 
                                 Foreground="{StaticResource ForegroundSolidColorBrush}"   
                                 BorderThickness="0" 
                                 PreviewTextInput="TextBox_PreviewTextInput" 
                                 Text="5" 
                                 TextChanged="TextChanged"
                                 />
                            </Border>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15"  Grid.Column="3">
                                <TextBlock 
                                 Text="Ом" 
                                 FontSize="18" 
                                 Foreground="{StaticResource ForegroundSolidColorBrush}"  
                                 Padding="5,0,0,0"
                                 />
                            </Border>

                        </Grid>
                    </Grid>

                    <Grid Grid.Row="3" Margin="10,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock 
                         Text="Погрешность режима СИ:"
                         FontSize="18"
                         Foreground="{StaticResource ForegroundSolidColorBrush}" 
                         Grid.Column="0"/>

                        <Grid Grid.Column="1"  Margin="10,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15"  Grid.Column="0">
                                <TextBox 
                                 Name="percentErrorCI" 
                                 FontSize="18" 
                                 Width="40"  
                                 Background="Transparent" 
                                 Foreground="{StaticResource ForegroundSolidColorBrush}" 
                                 BorderThickness="0"  
                                 PreviewTextInput="TextBox_PreviewTextInput" 
                                 Text="1" 
                                 TextChanged="TextChanged"/>
                            </Border>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15" Grid.Column="1">
                                <TextBlock 
                                 Text="%" 
                                 FontSize="18" 
                                 Foreground="{StaticResource ForegroundSolidColorBrush}" 
                                 HorizontalAlignment="Right" 
                                 VerticalAlignment="Center" 
                                 Padding="5,0,0,0"/>
                            </Border>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15"  Grid.Column="2">
                                <TextBox 
                                 Name="absoluteErrorCI" 
                                 FontSize="18" 
                                 Width="40" 
                                 Background="Transparent" 
                                 Foreground="{StaticResource ForegroundSolidColorBrush}"   
                                 BorderThickness="0" 
                                 PreviewTextInput="TextBox_PreviewTextInput" 
                                 Text="5" 
                                 TextChanged="TextChanged"
                                 />
                            </Border>

                            <Border BorderThickness="0,0,0,2" BorderBrush="White" Margin="0,0,0,15"  Grid.Column="3">
                                <TextBlock 
                                 Text="Ом" 
                                 FontSize="18" 
                                 Foreground="{StaticResource ForegroundSolidColorBrush}"  
                                 Padding="5,0,0,0"
                                 />
                            </Border>

                        </Grid>
                    </Grid>

                </Grid>
            </GroupBox>
        </Grid>

    </Grid>
</UserControl>
