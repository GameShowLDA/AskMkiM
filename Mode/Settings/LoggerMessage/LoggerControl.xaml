<UserControl x:Class="Mode.Settings.LoggerMessage.LoggerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mode.Settings.LoggerMessage"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Name="BackgroundRichBox" Grid.Row="0" Margin="10" Style="{StaticResource RichBoxBorder}">
        <RichTextBox Name="LogTextBox"
           BorderThickness="0"
           Style="{StaticResource RichBoxText}"
           FontSize="20"
           IsReadOnly="True"
           AllowDrop="True"
           PreviewDragOver="LogTextBox_PreviewDragOver"
           Drop="LogTextBox_Drop"
           PreviewDragEnter="LogTextBox_PreviewDragEnter"
           PreviewDragLeave="LogTextBox_PreviewDragLeave">
            <FlowDocument>
                <Paragraph LineHeight="1">
                    <Run Text=""/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>
    </Border>
</UserControl>
