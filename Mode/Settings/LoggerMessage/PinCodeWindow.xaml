<Window x:Class="Mode.Settings.LoggerMessage.PinCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Mode.Settings.LoggerMessage"
        mc:Ignorable="d"
         Title="Введите PIN-код" Height="150" Width="300" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="10">
        <TextBlock Text="Введите PIN-код:" Margin="0,0,0,5"/>
        <PasswordBox x:Name="PinCodeBox" Margin="0,0,0,10"/>
        <Button Content="Подтвердить" Click="ConfirmButton_Click"/>
    </StackPanel>
</Window>
