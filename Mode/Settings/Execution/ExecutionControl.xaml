<UserControl x:Class="Mode.Settings.Execution.ExecutionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mode.Settings.Execution"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border CornerRadius="0,0,0,0" Padding="0" >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <TextBlock 
            Text="Холостой режим" 
            FontSize="20" 
            Padding="15,5,0,15"
            Style="{StaticResource ConfigTextBlockHeaderStyle}"
            VerticalAlignment="Center"  
            />
                <GroupBox Grid.Row="1" BorderThickness="0">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Name="idleMode"  Style="{StaticResource AnimatedSwitch}" Width="20" Checked="IdleMode_Checked" Unchecked="IdleMode_Checked"/>
                            <TextBlock 
                        Text="Холостой режим выполнения" 
                        Grid.Column="1" 
                        Foreground="{StaticResource ForegroundSolidColorBrush}" 
                        FontSize="18"
                        />
                        </Grid>

                        <Grid Grid.Row="1" Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Name="executionDelay" Style="{StaticResource AnimatedSwitch}" Checked="ExecutionDelay_Checked" Unchecked="ExecutionDelay_Checked"/>
                            <TextBlock 
                        Text="Задержки в холостом режиме" 
                        Grid.Column="1" 
                        Foreground="{StaticResource ForegroundSolidColorBrush}" 
                        FontSize="18" 
                        />
                        </Grid>

                        <Grid Grid.Row="2" Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Name="isErrorSimulation" VerticalAlignment="Center" Style="{DynamicResource AnimatedSwitch}" HorizontalAlignment="Left" Width="20" Checked="ExecutionDelay_Checked" Unchecked="ExecutionDelay_Checked"/>
                            <TextBlock 
                        Text="Выполнение с ошибками" 
                        Grid.Column="1" 
                        Foreground="{StaticResource ForegroundSolidColorBrush}" 
                        FontSize="18" />
                        </Grid>

                    </Grid>
                </GroupBox>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <TextBlock 
            Text="Выполнение режимов" 
            FontSize="20" 
            Padding="15,5,0,15" 
            Style="{StaticResource ConfigTextBlockHeaderStyle}"
            VerticalAlignment="Center" 
            />
                <GroupBox Grid.Row="1" BorderThickness="0">

                    <Grid >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="2" Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Name="stepByStep" Style="{StaticResource AnimatedSwitch}" Checked="StepByStep_Checked"  Unchecked="StepByStep_Checked"/>
                            <TextBlock 
                        Text="Пошаговый режим" 
                        Grid.Column="1" 
                        Foreground="{StaticResource ForegroundSolidColorBrush}"  
                        FontSize="18" />
                        </Grid>

                        <Grid Grid.Row="3" Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox  Name="stopOnError" Style="{StaticResource AnimatedSwitch}" Checked="StepByStep_Checked"  Unchecked="StepByStep_Checked"/>
                            <TextBlock Text="Остановка по ошибке" Grid.Column="1" Foreground="{StaticResource ForegroundSolidColorBrush}"  FontSize="18" />
                        </Grid>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>
    </Border>
</UserControl>
