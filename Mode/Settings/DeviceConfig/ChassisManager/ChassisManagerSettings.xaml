<UserControl x:Class="Mode.Settings.DeviceConfig.ChassisManager.ChassisManagerSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mode.Settings.DeviceConfig.ChassisManager"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="NonSelectableListViewItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
            <Setter Property="Focusable" Value="false" />
            <Setter Property="IsHitTestVisible" Value="false" />
        </Style>

        <Style TargetType="TextBox" x:Key="NonChangingBorderTextBox">
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Name="border"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock 
            Name="mainHeader" 
            Visibility="Visible" 
            Text="Настройки уcтройства:" 
            Padding="20,10,0,10" 
            Style="{StaticResource ConfigTextBlockHeaderStyle}"
            FontSize="18" 
            Grid.Row="0" 
            FontWeight="Bold"/>

        <Grid Grid.Row="1" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border  
                Grid.Row="1" 
                Style="{StaticResource ConfigAdditionalBlockStyle}"
                >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <TextBlock 
                        Name="textDevice"
                        Grid.Column="0" 
                        Text="Устройство:" 
                        FontSize="20" 
                        Foreground="{StaticResource ForegroundSolidColorBrush}" 
                        Margin="0,15"  
                        Padding="20,0,0,0" 
                        FontWeight="Bold"/>

                    <ComboBox 
                        Name="deviceModelComboBox"  
                        Grid.Column="1" 
                        Height="30" 
                        MinWidth="100"
                        Width="auto" 
                        Margin="15" 
                        Style="{StaticResource CustomComboBoxStyle}"
                        HorizontalAlignment="Left"
                        SelectionChanged="DeviceModelComboBox_SelectionChanged"
                        />
                </Grid>

            </Border>

        </Grid>

        <Border  
            Grid.Row="2" 
            Style="{StaticResource ConfigAdditionalBlockStyle}">
            <Grid Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Name="DefaultSettingDevice">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock 
                             Name="textNumber"
                             Grid.Column="0" 
                             Text="Номер:" 
                             FontSize="20" 
                             Foreground="{StaticResource ForegroundSolidColorBrush}" 
                             Margin="0,15"  
                             Padding="20,0,0,0" 
                             FontWeight="Bold"
                             />
                        <TextBox Grid.Column="1" Margin="5" 
                            Name="deviceNumber"
                            MinWidth="100"
                            Style="{StaticResource NonChangingBorderTextBox}" 
                            PreviewTextInput="TextBox_PreviewTextInput"
                            TextChanged="TextBox_TextChanged"
                            DataObject.Pasting="TextBox_Pasting"/>
                     </Grid>
                     <Grid  Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock 
                        Name="textConnectionType"
                        Text="Тип подключения:" 
                        FontSize="20" 
                        Foreground="{StaticResource ForegroundSolidColorBrush}" 
                        Margin="0,15"  
                        Padding="20,0,0,0" 
                        FontWeight="Bold"/>

                        <ComboBox 
                        Name="connectionTypeComboBox"
                        Grid.Column="1"
                        Height="30"
                        Width="auto"
                        Margin="15"
                        Style="{StaticResource CustomComboBoxStyle}"
                        SelectionChanged="ConnectionTypeComboBox_SelectionChanged">
                            <ComboBoxItem Content="IP" Name="IpItem"/>
                            <ComboBoxItem Content="COM" Name="ComItem"/>
                        </ComboBox>
                    </Grid>
                </Grid>

            </Grid>

        </Border>

        <Border 
            Grid.Row="3" 
            Style="{StaticResource ConfigAdditionalBlockStyle}"
            >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!--НАСТРОЙКИ IP-->
                <Grid  Background="Transparent" Name="IpSettings">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock  
                        Text="IPAddress:" 
                        FontSize="20" 
                        Foreground="{StaticResource ForegroundSolidColorBrush}" 
                        Margin="0,15,10,15"  
                        Padding="20,0,0,0" 
                        HorizontalAlignment="Right"
                        FontWeight="Bold"/>

                    <TextBox Name="ipPart1TextBox" Grid.Column="1" Style="{StaticResource NonChangingBorderTextBox}" MinWidth="40"
                  PreviewTextInput="IpPart_PreviewTextInput" TextChanged="IpPart_TextChanged" IsReadOnly="True" Text="192"/>

                    <TextBlock Grid.Column="2" FontWeight="Bold" FontSize="20" Margin="5"
                    Text="." VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Foreground="{StaticResource ForegroundSolidColorBrush}"/>

                    <TextBox Name="ipPart2TextBox" Grid.Column="3" Style="{StaticResource NonChangingBorderTextBox}" MinWidth="40"
                  PreviewTextInput="IpPart_PreviewTextInput" TextChanged="IpPart_TextChanged" IsReadOnly="True" Text="168"/>

                    <TextBlock Grid.Column="4" FontWeight="Bold" FontSize="20" Margin="5"
                    Text="." VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Foreground="{StaticResource ForegroundSolidColorBrush}"/>

                    <TextBox Name="ipPart3TextBox" Grid.Column="5" Style="{StaticResource NonChangingBorderTextBox}" MinWidth="40"
                  PreviewTextInput="IpPart_PreviewTextInput" TextChanged="IpPart_TextChanged" BorderBrush="{StaticResource ActiveBorderSolidColorBrush}"/>

                    <TextBlock Grid.Column="6" FontWeight="Bold" FontSize="20" Margin="5"
                    Text="." VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Foreground="{StaticResource ForegroundSolidColorBrush}"/>

                    <TextBox Name="ipPart4TextBox" Grid.Column="7" Style="{StaticResource NonChangingBorderTextBox}" MinWidth="40"
                  PreviewTextInput="IpPart_PreviewTextInput" TextChanged="IpPart_TextChanged" IsReadOnly="True" Text="0"/>

                </Grid>

                <!--НАСТРОЙКИ COM-->
                <Grid Grid.Row="1" Background="Transparent" Name="ComSettings">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <!--Выбр COM порта-->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock 
                            Text="COM-порт:" 
                            FontSize="20" 
                            Foreground="{StaticResource ForegroundSolidColorBrush}" 
                            Margin="0,15,10,15"  
                            Padding="20,0,0,0" 
                            HorizontalAlignment="Right"
                            FontWeight="Bold"/>

                        <ComboBox Grid.Column="1"
                             x:Name="comPortComboBox"
                             MinWidth="100"
                             Style="{StaticResource CustomComboBoxStyle}"
                             VerticalAlignment="Center"
                             SelectionChanged="ComPortComboBox_SelectionChanged"/>
                    </Grid>

                    <!--VID-->
                    <Grid Grid.Column="1" Name="VidSettings">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Text="VID:" 
                                FontSize="20" 
                                Foreground="{StaticResource ForegroundSolidColorBrush}" 
                                Margin="0,15,10,15"  
                                Padding="20,0,0,0" 
                                HorizontalAlignment="Right"
                                FontWeight="Bold"
                                />
                            <TextBox Grid.Column="1"
                                Style="{StaticResource NonChangingBorderTextBox}"
                                     Margin="0,10"
                                Name="VidData"
                                     MinWidth="100"
                                />

                        </Grid>

                        <!--PID-->
                        <Grid Grid.Column="1" Name="PidSettings">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Text="PID:" 
                               
                                FontSize="20" 
                                Foreground="{StaticResource ForegroundSolidColorBrush}" 
                                Margin="0,15,10,15"  
                                Padding="20,0,0,0" 
                                HorizontalAlignment="Right"
                                FontWeight="Bold"
                                />

                            <TextBox Grid.Column="1"
                                     MinWidth="100"
                                Style="{StaticResource NonChangingBorderTextBox}"
                                     Margin="0,10"
                                      Name="PidData"
                                />
                        </Grid>
                    </Grid>

                    <!--Бит в секунду-->
                    <Grid Grid.Row="1" Name="BaudRateSettings">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Бит в секунду:" 
                            FontSize="20" 
                            Foreground="{StaticResource ForegroundSolidColorBrush}" 
                            Margin="0,15,10,15"  
                            Padding="20,0,0,0" 
                            HorizontalAlignment="Right"
                            FontWeight="Bold"
                        />

                        <ComboBox Grid.Column="1"
                            SelectedIndex="3"
                            MinWidth="100"
                            Style="{StaticResource CustomComboBoxStyle}"
                            VerticalAlignment="Center">
                            <ComboBoxItem>1200</ComboBoxItem>
                            <ComboBoxItem>2400</ComboBoxItem>
                            <ComboBoxItem>4800</ComboBoxItem>
                            <ComboBoxItem>9600</ComboBoxItem>
                            <ComboBoxItem>14400</ComboBoxItem>
                            <ComboBoxItem>19200</ComboBoxItem>
                            <ComboBoxItem>38400</ComboBoxItem>
                            <ComboBoxItem>57600</ComboBoxItem>
                            <ComboBoxItem>115200</ComboBoxItem>
                        </ComboBox>
                    </Grid>

                    <!--Биты данных-->
                    <Grid Grid.Row="2" Name="DataBitsSettings">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Биты данных:" 
                            FontSize="20" 
                            Foreground="{StaticResource ForegroundSolidColorBrush}" 
                            Margin="0,15,10,15"  
                            Padding="20,0,0,0" 
                            HorizontalAlignment="Right"
                            FontWeight="Bold"
                            />

                        <ComboBox Grid.Column="1"
                            SelectedIndex="4"
                            MinWidth="100"
                            Style="{StaticResource CustomComboBoxStyle}"
                            VerticalAlignment="Center">
                            <ComboBoxItem>4</ComboBoxItem>
                            <ComboBoxItem>5</ComboBoxItem>
                            <ComboBoxItem>6</ComboBoxItem>
                            <ComboBoxItem>7</ComboBoxItem>
                            <ComboBoxItem>8</ComboBoxItem>
                        </ComboBox>
                    </Grid>

                    <!--Стоповые биты-->
                    <Grid Grid.Column="1" Grid.Row="1" Name="StopBitsSettings">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Стоповые биты:" 
                            FontSize="20" 
                            Foreground="{StaticResource ForegroundSolidColorBrush}" 
                            Margin="0,15,10,15"  
                            Padding="20,0,0,0" 
                            HorizontalAlignment="Right"
                            FontWeight="Bold"
                            />

                        <ComboBox Grid.Column="1"
                            SelectedIndex="0"
                            Style="{StaticResource CustomComboBoxStyle}"
                            VerticalAlignment="Center">
                            <ComboBoxItem>1</ComboBoxItem>
                            <ComboBoxItem>1.5</ComboBoxItem>
                            <ComboBoxItem>2</ComboBoxItem>
                        </ComboBox>
                    </Grid>

                    <!--Чётность-->
                    <Grid Grid.Column="1" Grid.Row="2" Name="ParitySettings">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Чётность:" 
                            FontSize="20" 
                            Foreground="{StaticResource ForegroundSolidColorBrush}" 
                            Margin="0,15,10,15"  
                            Padding="20,0,0,0" 
                            HorizontalAlignment="Right"
                            FontWeight="Bold"
                            />

                        <ComboBox Grid.Column="1"
                            SelectedIndex="2"
                            Style="{StaticResource CustomComboBoxStyle}"
                            VerticalAlignment="Center">
                            <ComboBoxItem>Чет</ComboBoxItem>
                            <ComboBoxItem>Нечет</ComboBoxItem>
                            <ComboBoxItem>Нет</ComboBoxItem>
                            <ComboBoxItem>Маркер</ComboBoxItem>
                            <ComboBoxItem>Пробел</ComboBoxItem>
                        </ComboBox>
                    </Grid>

                    <!--Управление потоком-->
                    <Grid Grid.Row="3" Name="FlowControlSettings">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Управление потоком:" 
                            FontSize="20" 
                            Foreground="{StaticResource ForegroundSolidColorBrush}" 
                            Margin="0,15,10,15"  
                            Padding="20,0,0,0" 
                            HorizontalAlignment="Right"
                            FontWeight="Bold"
                            />

                        <ComboBox Grid.Column="1"
                            SelectedIndex="2"
                            MinWidth="100"
                            Style="{StaticResource CustomComboBoxStyle}"
                            VerticalAlignment="Center">
                            <ComboBoxItem>Xon/Xoff</ComboBoxItem>
                            <ComboBoxItem>Аппаратное</ComboBoxItem>
                            <ComboBoxItem>Нет</ComboBoxItem>
                        </ComboBox>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Name="exit" Grid.Column="0" Content="Отменить" Style="{StaticResource CustomButtonStyle}" Background="{StaticResource SecondarySolidColorBrush}" Margin="20,10" Width="200" HorizontalAlignment="Left" PreviewMouseDown="exit_PreviewMouseDown"/>
            <Button Name="save" Grid.Column="1" Content="Сохранить" Style="{StaticResource CustomButtonStyle}" Background="{StaticResource SecondarySolidColorBrush}" Width="200" HorizontalAlignment="Left" PreviewMouseDown="save_PreviewMouseDown"/>
        </Grid>

    </Grid>
</UserControl>
