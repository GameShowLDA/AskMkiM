<UserControl x:Class="Mode.Settings.DeviceConfig.DeviceConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mode.Settings.DeviceConfig"
             xmlns:Chassis="clr-namespace:Mode.Settings.DeviceConfig.ChassisManager"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" MinWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Chassis:ChassisManagerControl x:Name="chassisManager" Background="White"/>
        <Border Grid.Column="1" Background="Blue" Name="deviceBorder"/>
        <Border Grid.Column="2" Background="Red" Name="setingsBorder"/>

    </Grid>
</UserControl>
