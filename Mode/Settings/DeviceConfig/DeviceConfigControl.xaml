<UserControl x:Class="Mode.Settings.DeviceConfig.DeviceConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mode.Settings.DeviceConfig"
             xmlns:Chassis="clr-namespace:Mode.Settings.DeviceConfig.ChassisManager"
             mc:Ignorable="d"
             MinWidth="800" MinHeight="600">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="0" x:Name="Column3"/>
        </Grid.ColumnDefinitions>

        <Chassis:ChassisManagerControl x:Name="chassisManager" Grid.Column="0"/>
        <Border Grid.Column="1" Background="{StaticResource PrimarySolidColorBrush}" Name="deviceBorder"/>
        <Border Grid.Column="2" Background="{StaticResource PrimarySolidColorBrush}" Name="settingsBorder" Visibility="Collapsed"/>
        
    </Grid>
</UserControl>
