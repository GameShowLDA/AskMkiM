<UserControl x:Class="Mode.Settings.DeviceConfig.DeviceManager.DeviceManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mode.Settings.DeviceConfig.DeviceManager"
             xmlns:CustomControls="clr-namespace:UI.Components;assembly=UI"
             xmlns:DeviceList="clr-namespace:Mode.Settings.DeviceConfig.Controls"
             mc:Ignorable="d" 
             Width="Auto"
             Height="Auto">
    <UserControl.Resources>
        <!-- Стилизация ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand" 
                                                  Background="Transparent" 
                                                  BorderThickness="0" 
                                                  Height="10"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Name="Thumb" 
                                           Background="{StaticResource SecondarySolidColorBrush}" 
                                           BorderThickness="0"
                                           Cursor="ScrollNS">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" 
                                                        BorderBrush="Transparent" 
                                                        BorderThickness="0"
                                                        CornerRadius="10"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand" 
                                                  Background="Transparent" 
                                                  BorderThickness="0" 
                                                  Height="10"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border CornerRadius="0,0,0,0" Width="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

                
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="ButtonsPanel" Background="Transparent">
                        <StackPanel Background="Transparent" Margin="2">
                            <DeviceList:DeviceListControl x:Name="SwitchingDeviceControl" DeviceTitle="Устройство коммутации шин" Margin="5,5,5,0"/>
                            <DeviceList:DeviceListControl x:Name="RelaySwitchModuleControl" DeviceTitle="Модуль коммутации реле" Margin="5,5,5,0"/>
                            <DeviceList:DeviceListControl x:Name="PowerSourceModuleControl" DeviceTitle="Модуль ист. напряжения и тока" Margin="5,5,5,0"/>
                            <DeviceList:DeviceListControl x:Name="PrecisionMeterControl" DeviceTitle="Измеритель (точный)" Margin="5,5,5,0"/>
                            <DeviceList:DeviceListControl x:Name="FastMeterControl" DeviceTitle="Измеритель (быстрый)" Margin="5,5,5,0"/>
                            <DeviceList:DeviceListControl x:Name="BreakdownTesterControl" DeviceTitle="Пробойная установка" Margin="5,5,5,0"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
                

            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                <Button Name="AutoConfig" Margin="5" Style="{StaticResource CustomButtonStyle}" 
                        Background="{StaticResource SecondarySolidColorBrush}" >
                    <TextBlock Text="Автоматическая конфигурация" 
                               TextWrapping="Wrap"  
                               Margin="5" 
                               TextAlignment="Center"/>
                </Button>

                <Button Name="Save" Margin="5" Style="{StaticResource CustomButtonStyle}" 
                        Background="{StaticResource SecondarySolidColorBrush}" >
                    <TextBlock Text="Сохранить" 
                               TextWrapping="Wrap" 
                               Margin="5" 
                               TextAlignment="Center"/>
                </Button>

                <Button Name="Exit" Margin="5" Style="{StaticResource CustomButtonStyle}" 
                    Background="{StaticResource SecondarySolidColorBrush}" PreviewMouseDown="Exit_PreviewMouseDown">
                    <TextBlock Text="Отмена" 
                            TextWrapping="Wrap" 
                            Margin="5" 
                            TextAlignment="Center"/>
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>
