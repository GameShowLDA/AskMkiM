<UserControl x:Class="Mode.Settings.ConfigSettings.ConfigSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mode.Settings.ConfigSettings"
             xmlns:CustomControls="clr-namespace:UI.Components;assembly=UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Стиль для отключения выделения элементов в ListView, наследующий базовый стиль -->
        <Style 
            x:Key="NonSelectableListViewItemStyle" 
            TargetType="ListViewItem" 
            BasedOn="{StaticResource {x:Type ListViewItem}}">
            <Setter Property="Focusable" Value="false" />
            <Setter Property="IsHitTestVisible" Value="false" />
        </Style>

        <Style TargetType="TextBox" x:Key="NonChangingBorderTextBox">
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Name="border"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border CornerRadius="0,0,0,0" >
        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="60*"/>
            </Grid.ColumnDefinitions>

            <Grid x:Name="ButtonsPanel" Background="Transparent" Grid.Column="0" Width="300" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Background="Transparent"  Margin="2" Grid.Row="1">

                    <Grid Margin="5,5,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="managerShassyButton" 
                                Style="{StaticResource ConfigHeaderButtonStyle}" 
                                PreviewMouseLeftButtonDown="ManagerShassyButton_PreviewMouseDown"
                                Grid.Column="0">
                            <TextBlock Text="Менеджер Шасси" 
                                TextWrapping="Wrap" 
                                TextAlignment="Center"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                        </Button>
                        <CustomControls:PlusButtonControl x:Name="addManagerShassyButton" 
                                                          Grid.Column="1" 
                                                          FontSize="4" 
                                                          Width="{Binding ActualHeight, ElementName=managerShassyButton}" 
                                                          Height="{Binding ActualHeight, ElementName=managerShassyButton}" 
                                                          Style="{StaticResource PlusButtonStyle}"
                                                          Padding="5" Margin="5,0,0,0" 
                                                          BorderThickness="3,3,3,3" 
                                                          MouseEnter="PlusButton_MouseEnter" 
                                                          MouseLeave="PlusButton_MouseLeave"
                                                          PreviewMouseLeftButtonDown="AddManagerShassyButton_PreviewMouseLeftButtonDown"
                                                          />
                    </Grid>
                    <StackPanel x:Name="managerShassyContent" Margin="8,0,8,5" Height="Auto" Background="#303843"/>


                    <Grid Margin="5,5,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="deviceBusCommutationButton" 
                                Style="{StaticResource ConfigHeaderButtonStyle}" 
                                PreviewMouseLeftButtonDown="DeviceBusCommutationButton_PreviewMouseDown" 
                                >
                            <TextBlock Text="Устройство коммутации шин" 
                                TextWrapping="Wrap" 
                                TextAlignment="Center"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                        </Button>
                        <CustomControls:PlusButtonControl x:Name="addDeviceBusCommutationButton" 
                                                          Grid.Column="1" 
                                                          FontSize="4" 
                                                          Width="{Binding ActualHeight, ElementName=managerShassyButton}" 
                                                          Height="{Binding ActualHeight, ElementName=managerShassyButton}" 
                                                          Padding="5" 
                                                          Margin="5,0,0,0" 
                                                          BorderThickness="3,3,3,3" 
                                                          Style="{StaticResource PlusButtonStyle}"
                                                          MouseEnter="PlusButton_MouseEnter" 
                                                          MouseLeave="PlusButton_MouseLeave"
                                                          PreviewMouseLeftButtonDown="AddDeviceBusCommutationButton_PreviewMouseLeftButtonDown"
                                                          />
                    </Grid>
                    <StackPanel x:Name="deviceBusCommutationContent" Margin="8,0,8,5" Height="Auto" Background="#303843"/>

                    <Grid Margin="5,5,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="moduleRelayButton" 
                                Style="{StaticResource ConfigHeaderButtonStyle}" 
                                PreviewMouseLeftButtonDown="ModuleRelayButton_PreviewMouseDown" 
                                >
                            <TextBlock Text="Модуль коммутации реле" 
                                TextWrapping="Wrap" 
                                TextAlignment="Center"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                        </Button>
                        <CustomControls:PlusButtonControl x:Name="addModuleRelayButton" 
                                                          Grid.Column="1" 
                                                          FontSize="4" 
                                                          Width="{Binding ActualHeight, ElementName=managerShassyButton}" 
                                                          Height="{Binding ActualHeight, ElementName=managerShassyButton}" 
                                                          Padding="5" 
                                                          Margin="5,0,0,0" 
                                                          BorderThickness="3,3,3,3" 
                                                          Style="{StaticResource PlusButtonStyle}"
                                                          MouseEnter="PlusButton_MouseEnter" 
                                                          MouseLeave="PlusButton_MouseLeave"
                                                          PreviewMouseLeftButtonDown="AddModuleRelayButton_PreviewMouseLeftButtonDown"
                                                          />
                    </Grid>
                    <StackPanel x:Name="moduleRelayContent" Margin="8,0,8,5" Height="Auto" Background="#303843"/>

                    <Grid Margin="5,5,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="moduleVoltageCurrentSourceButton" 
                                Style="{StaticResource ConfigHeaderButtonStyle}" 
                                PreviewMouseLeftButtonDown="ModuleVoltageCurrentSourceButton_PreviewMouseDown" 
                                >
                            <TextBlock Text="Модуль ист. напряжения и тока" 
                                           TextWrapping="Wrap" 
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                        </Button>
                        <CustomControls:PlusButtonControl x:Name="addModuleVoltageCurrentSourceButton" 
                                                          Grid.Column="1" 
                                                          FontSize="4" 
                                                          Width="{Binding ActualHeight, ElementName=managerShassyButton}" 
                                                          Height="{Binding ActualHeight, ElementName=managerShassyButton}" 
                                                          Padding="5" 
                                                          Margin="5,0,0,0" 
                                                          BorderThickness="3,3,3,3" 
                                                          Style="{StaticResource PlusButtonStyle}"
                                                          MouseEnter="PlusButton_MouseEnter" 
                                                          MouseLeave="PlusButton_MouseLeave"
                                                          PreviewMouseLeftButtonDown="AddModuleVoltageCurrentSourceButton_PreviewMouseLeftButtonDown"
                                                          />
                    </Grid>
                    <StackPanel  x:Name="moduleVoltageCurrentSourceContent" Margin="8,0,8,5" Height="Auto" Background="#303843"/>

                    <Grid Margin="5,5,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="accurateMeterButton" 
                                Content="Измеритель (точный)" 
                                Style="{StaticResource ConfigHeaderButtonStyle}" 
                                PreviewMouseLeftButtonDown="AccurateMeterButton_PreviewMouseDown" 
                                />
                        <CustomControls:PlusButtonControl x:Name="addAccurateMeterButton" 
                                                          Grid.Column="1" 
                                                          FontSize="4" 
                                                          Width="{Binding ActualHeight, ElementName=managerShassyButton}" 
                                                          Height="{Binding ActualHeight, ElementName=managerShassyButton}" 
                                                          Padding="5" 
                                                          Margin="5,0,0,0" 
                                                          BorderThickness="3,3,3,3" 
                                                          Style="{StaticResource PlusButtonStyle}"
                                                          MouseEnter="PlusButton_MouseEnter" 
                                                          MouseLeave="PlusButton_MouseLeave"
                                                          PreviewMouseLeftButtonDown="AddAccurateMeterButton_PreviewMouseLeftButtonDown"
                                                          />
                    </Grid>
                    <StackPanel  x:Name="accurateMeterContent" Margin="8,0,8,5" Height="Auto" Background="#303843"/>


                    <Grid Margin="5,5,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="fastMeterButton" 
                                Content="Измеритель (быстрый)" 
                                Style="{StaticResource ConfigHeaderButtonStyle}" 
                                PreviewMouseLeftButtonDown="FastMeterButton_PreviewMouseDown" 
                                />
                        <CustomControls:PlusButtonControl x:Name="addFastMeterButton" 
                                                          Grid.Column="1" 
                                                          FontSize="4" 
                                                          Width="{Binding ActualHeight, ElementName=managerShassyButton}" 
                                                          Height="{Binding ActualHeight, ElementName=managerShassyButton}" 
                                                          Padding="5" 
                                                          Margin="5,0,0,0" 
                                                          BorderThickness="3,3,3,3" 
                                                          Style="{StaticResource PlusButtonStyle}"
                                                          MouseEnter="PlusButton_MouseEnter" 
                                                          MouseLeave="PlusButton_MouseLeave"
                                                          PreviewMouseLeftButtonDown="AddFastMeterButton_PreviewMouseLeftButtonDown"
                                                          />
                    </Grid>
                    <StackPanel  x:Name="fastMeterContent" Margin="8,0,8,5" Height="Auto" Background="#303843"/>

                    <Grid Margin="5,5,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="breakdownButton" 
            Content="Пробойная установка" 
            Style="{StaticResource ConfigHeaderButtonStyle}" 
            PreviewMouseLeftButtonDown="FastMeterButton_PreviewMouseDown" 
            />
                        <CustomControls:PlusButtonControl x:Name="addBrakedownButton" 
                                      Grid.Column="1" 
                                      FontSize="4" 
                                      Width="{Binding ActualHeight, ElementName=managerShassyButton}" 
                                      Height="{Binding ActualHeight, ElementName=managerShassyButton}" 
                                      Padding="5" 
                                      Margin="5,0,0,0" 
                                      BorderThickness="3,3,3,3" 
                                      Style="{StaticResource PlusButtonStyle}"
                                      MouseEnter="PlusButton_MouseEnter" 
                                      MouseLeave="PlusButton_MouseLeave"
                                      PreviewMouseLeftButtonDown="AddBreakdownButton_PreviewMouseLeftButtonDown"
                                      />
                    </Grid>
                    <StackPanel  x:Name="breakdownContent" Margin="8,0,8,5" Height="Auto" Background="#303843"/>
                </StackPanel>

                <StackPanel Margin="0,40,0,0" Grid.Row="2">

                    <Button 
                        Style="{StaticResource CustomButtonStyle}" 
                        Background="{StaticResource SecondarySolidColorBrush}" 
                        Name="AutoConfig" 
                        Height="Auto" 
                        Margin="5" 
                        Grid.Row="2" 
                        PreviewMouseLeftButtonDown="AutoConfig_MouseDown" >
                        <TextBlock 
                            Text="Автоматическая конфигурация" 
                            TextWrapping="Wrap"  
                            Margin="10,5" 
                            TextAlignment="Center" />
                    </Button>

                    <Button 
                        Style="{StaticResource ConfigAdditionalButtonStyle}"
                        Name="Save"  
                        Margin="5"  
                        Grid.Row="3" 
                        PreviewMouseLeftButtonDown="SaveConfiguration_PreviewMouseDown" >
                        <TextBlock 
                            Text="Сохранить" 
                            TextWrapping="Wrap" 
                            Margin="5" 
                            TextAlignment="Center"/>
                    </Button>
                </StackPanel>

            </Grid>

            <Border 
                Name="contentPanel" 
                Background="Transparent" 
                CornerRadius="0" 
                Margin="0" 
                BorderThickness="2,0,0,0" 
                BorderBrush="#95abc2" 
                Grid.Column="2"
                />

        </Grid>
    </Border>
</UserControl>
