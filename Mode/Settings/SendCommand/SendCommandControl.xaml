<UserControl x:Class="Mode.Settings.SendCommand.SendCommandControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mode.Settings.SendCommand"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="10" Style="{StaticResource RichBoxBorder}">
            <RichTextBox Name="ProtocolTextBox"
                  BorderThickness="0"
                  Style="{StaticResource RichBoxText}"
                  FontSize="20"
                  IsReadOnly="True">
                <FlowDocument>
                    <Paragraph LineHeight="1">
                        <Run Text=""/>
                    </Paragraph>
                </FlowDocument>
            </RichTextBox>
        </Border>

        <Border Grid.Row="1" CornerRadius="10" Style="{StaticResource RichBoxBorder}" Margin="10" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Name="InputLabel" Content="IP:" Foreground="{StaticResource RichBoxForegroundColor}" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" Name="InputTextBox" 
              Background="Transparent"
              BorderThickness="0"
              Foreground="{StaticResource RichBoxForegroundColor}"
              FontSize="20"
              KeyDown="InputTextBox_KeyDown"
              VerticalAlignment="Center"
              />
            </Grid>
        </Border>
    </Grid>
</UserControl>
