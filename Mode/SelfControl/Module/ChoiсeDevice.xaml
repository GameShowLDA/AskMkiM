<UserControl x:Class="Mode.SelfControl.Module.ChoiсeDevice"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mode.SelfControl.Module"
             mc:Ignorable="d" 
             d:DesignHeight="100 " d:DesignWidth="300"  MinHeight="50">
    <Grid>
        <ToggleButton x:Name="toggleButton"
              Content="Выберите устройство:"
              Style="{StaticResource ToggleButtonStyle}"
              Cursor="Hand"
              Background="{StaticResource SecondarySolidColorBrush}" 
              Margin="0"
             />

        <Popup x:Name="popup"
       IsOpen="{Binding IsChecked, ElementName=toggleButton}"
       StaysOpen="False"
       PlacementTarget="{Binding ElementName=toggleButton}">
            <Border Background="{StaticResource PrimarySolidColorBrush}" CornerRadius="8">
                <ListView x:Name="deviceList"
                  SelectionMode="Single"
                  Background="{StaticResource SecondarySolidColorBrush}"
                  BorderThickness="0"
                  Height="Auto"
                  ItemContainerStyle="{StaticResource {x:Type ListViewItem}}"/>
            </Border>
        </Popup>
    </Grid>
</UserControl>
