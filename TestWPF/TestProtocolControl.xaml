<UserControl x:Class="TestWPF.TestProtocolControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TestWPF"
             xmlns:Protocol="clr-namespace:UI.Controls.ProtocolNew;assembly=UI"
             xmlns:Custom="clr-namespace:UI.Components;assembly=UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Protocol:ProtocolUI x:Name="ProtocolUI" Header="Тестовый протокол">
            <Protocol:ProtocolUI.ContentView>
                <Custom:InputField Height="Auto" IsTimeVisible="True" IsVoltageVisible="True" />
            </Protocol:ProtocolUI.ContentView>
        </Protocol:ProtocolUI>
    </Grid>
    
</UserControl>
