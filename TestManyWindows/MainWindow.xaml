<Window x:Class="TestManyWindows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TestManyWindows"
        Title="Dock Example" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Файл">
                <MenuItem Header="Создать новый" Click="NewFile_Click"/>
            </MenuItem>
        </Menu>

        <local:DockingPanel x:Name="DockPanel" Grid.Row="1"/>
    </Grid>
</Window>
