<Window x:Class="TestDocking.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dz="http://schemas.devzest.com/presentation/docking"
        xmlns:avalonEdit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
        xmlns:local="clr-namespace:UI.Controls.TextEditor;assembly=UI"
        Title="DevZest Docking" Height="450" Width="800" Background="LightGray">
    <DockPanel Background="Transparent">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Background="Transparent">
            <Button Content="Открыть файл" Click="OpenFile_Click" Margin="5" />
        </StackPanel>

        <dz:DockControl x:Name="DockManager">
            <!-- Вкладки будут добавляться динамически -->
        </dz:DockControl>
    </DockPanel>
</Window>
