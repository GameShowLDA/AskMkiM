<Window x:Class="ConsoleUI.ConsoleUI.ConsoleOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ConsoleOverlay"
        Height="400" Width="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Opacity="0.95">

    <Border Background="#CC1E1E1E" CornerRadius="10" Padding="10"
        BorderThickness="1" BorderBrush="#33FFFFFF"
        MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Прокручиваемый вывод -->
            <ScrollViewer x:Name="ConsoleScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Grid.Row="0">
                <StackPanel x:Name="ConsolePanel"/>
            </ScrollViewer>

            <!-- Ввод команд -->
            <TextBox x:Name="CommandInput"
                 Grid.Row="1"
                 FontFamily="Consolas"
                 FontSize="14"
                 Margin="0,10,0,0"
                 Padding="6"
                 Background="#FF1E1E1E"
                 Foreground="White"
                 BorderThickness="1"
                 BorderBrush="#555"
                     TextChanged="CommandInput_TextChanged"
                 KeyDown="CommandInput_KeyDown"/>

            <ListBox x:Name="AutocompleteBox"
         Grid.Row="2"
         FontFamily="Consolas"
         FontSize="13"
         Background="#222"
         Foreground="White"
         Visibility="Collapsed"
         BorderThickness="1"
         BorderBrush="#555"
         MaxHeight="100"
         MouseDoubleClick="AutocompleteBox_MouseDoubleClick"/>
        </Grid>
    </Border>
</Window>
