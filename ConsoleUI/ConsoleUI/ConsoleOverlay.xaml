<Window x:Class="ConsoleUI.ConsoleUI.ConsoleOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ConsoleOverlay"
        Height="400" Width="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Opacity="0.95">

    <Window.Resources>
        <DataTemplate x:Key="LogEntryTemplate">
            <TextBlock Text="{Binding Text}"
                       Foreground="{Binding Color}"
                       FontFamily="Consolas"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Margin="0,2,0,2"/>
        </DataTemplate>

        <Style x:Key="ConsoleListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <EventSetter Event="MouseDoubleClick" Handler="LogItem_MouseDoubleClick"/>
        </Style>

        <Style x:Key="ConsoleListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="ItemTemplate" Value="{StaticResource LogEntryTemplate}"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ConsoleListBoxItemStyle}"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="True"/>
            <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="VirtualizingStackPanel.CacheLengthUnit" Value="Item"/>
            <Setter Property="VirtualizingStackPanel.CacheLength" Value="2,2"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
    </Window.Resources>

    <Border Background="#CC1E1E1E" CornerRadius="10" Padding="10"
        BorderThickness="1" BorderBrush="#33FFFFFF"
        MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Вывод логов -->
            <ContentControl x:Name="ConsoleHost"
                            Grid.Row="0"/>

            <!-- Ввод команд -->
            <TextBox x:Name="CommandInput"
                 Grid.Row="1"
                 FontFamily="Consolas"
                 FontSize="14"
                 Margin="0,10,0,0"
                 Padding="6"
                 Background="#FF1E1E1E"
                 Foreground="White"
                 BorderThickness="1"
                 BorderBrush="#555"
                     TextChanged="CommandInput_TextChanged"
                     PreviewTextInput="CommandInput_PreviewTextInput"
                 KeyDown="CommandInput_KeyDown"/>

            <ListBox x:Name="AutocompleteBox"
         Grid.Row="2"
         FontFamily="Consolas"
         FontSize="13"
         Background="#222"
         Foreground="White"
         Visibility="Collapsed"
         BorderThickness="1"
         BorderBrush="#555"
         MaxHeight="100"
         MouseDoubleClick="AutocompleteBox_MouseDoubleClick"/>
        </Grid>
    </Border>
</Window>
