<Window x:Class="ConsoleUI.ConsoleUI.ConsoleOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ConsoleOverlay"
        Height="430" Width="880"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Opacity="0.97">

    <Window.Resources>
        <SolidColorBrush x:Key="GlassBackground" Color="#D916181D"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#CC1D1F25"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#26FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryText" Color="#EAEAEA"/>
        <SolidColorBrush x:Key="MutedText" Color="#A6FFFFFF"/>

        <FontFamily x:Key="UiFont">SF Pro Text, Segoe UI Variable Text, Segoe UI</FontFamily>
        <FontFamily x:Key="MonoFont">SF Mono, Cascadia Mono, Consolas</FontFamily>

        <DataTemplate x:Key="LogEntryTemplate">
            <Grid Margin="0,3,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Ellipse Width="8"
                         Height="8"
                         Fill="{Binding Color}"
                         VerticalAlignment="Top"
                         Margin="0,5,6,0"
                         Opacity="0.9"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Text}"
                           Foreground="{Binding Color}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="13.5"
                           TextWrapping="Wrap"
                           LineHeight="18"/>
            </Grid>
        </DataTemplate>

        <Style x:Key="ConsoleListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <EventSetter Event="MouseDoubleClick" Handler="LogItem_MouseDoubleClick"/>
        </Style>

        <DataTemplate x:Key="ToastTemplate">
            <Border Background="#E0121419"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,8"
                    Margin="0,0,0,6"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TranslateTransform X="16"/>
                </Border.RenderTransform>
                <TextBlock Text="{Binding Text}"
                           Foreground="{StaticResource PrimaryText}"
                           FontFamily="{StaticResource UiFont}"
                           FontSize="12.5"/>
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="0" Opacity="0.35"/>
                </Border.Effect>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1"
                                                 Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                 From="16" To="0"
                                                 Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 BeginTime="0:0:1.6"
                                                 Duration="0:0:0.3"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                 To="8"
                                                 BeginTime="0:0:1.6"
                                                 Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
            </Border>
        </DataTemplate>

        <Style x:Key="ConsoleListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="ItemTemplate" Value="{StaticResource LogEntryTemplate}"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ConsoleListBoxItemStyle}"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="True"/>
            <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="VirtualizingStackPanel.CacheLengthUnit" Value="Item"/>
            <Setter Property="VirtualizingStackPanel.CacheLength" Value="2,2"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="14" Padding="14"
        BorderThickness="1" BorderBrush="{StaticResource PanelBorder}"
        MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E015161B" Offset="0"/>
                <GradientStop Color="#E021232A" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.45"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Верхняя панель -->
            <Grid Grid.Row="0" Margin="2,0,2,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#FF5F56" Margin="0,0,6,0"/>
                    <Ellipse Width="10" Height="10" Fill="#FFBD2E" Margin="0,0,6,0"/>
                    <Ellipse Width="10" Height="10" Fill="#27C93F"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="Console"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource UiFont}"
                           FontSize="13"
                           Foreground="{StaticResource MutedText}"/>

                <TextBlock Grid.Column="2"
                           Text="LIVE"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource UiFont}"
                           FontSize="11"
                           Foreground="#88FFFFFF"
                           Margin="0,0,6,0"/>
            </Grid>

            <!-- Вывод логов -->
            <Grid Grid.Row="1">
                <ContentControl x:Name="ConsoleHost"/>
                <ItemsControl x:Name="ToastHost"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              Margin="0,4,4,0"
                              IsHitTestVisible="False"
                              Panel.ZIndex="5"
                              ItemTemplate="{StaticResource ToastTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>

            <!-- Ввод команд -->
            <TextBox x:Name="CommandInput"
                 Grid.Row="2"
                 FontFamily="{StaticResource MonoFont}"
                 FontSize="13.5"
                 Margin="0,12,0,0"
                 Padding="10,6"
                 Background="{StaticResource PanelBackground}"
                 Foreground="{StaticResource PrimaryText}"
                 BorderThickness="1"
                 BorderBrush="#2FFFFFFF"
                 CaretBrush="White"
                     TextChanged="CommandInput_TextChanged"
                     PreviewTextInput="CommandInput_PreviewTextInput"
                 KeyDown="CommandInput_KeyDown"/>

            <ListBox x:Name="AutocompleteBox"
         Grid.Row="3"
         FontFamily="{StaticResource MonoFont}"
         FontSize="12.5"
         Background="#1C1E24"
         Foreground="{StaticResource PrimaryText}"
         Visibility="Collapsed"
         BorderThickness="1"
         BorderBrush="#2FFFFFFF"
         MaxHeight="110"
         MouseDoubleClick="AutocompleteBox_MouseDoubleClick"/>
        </Grid>
    </Border>
</Window>
